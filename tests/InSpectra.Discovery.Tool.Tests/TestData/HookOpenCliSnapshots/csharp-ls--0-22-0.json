{
  "info": {
    "title": "csharp-ls",
    "version": "0.22.0",
    "description": "C# LSP language server"
  },
  "options": [
    {
      "name": "--version",
      "description": "display versioning information",
      "aliases": [
        "-v"
      ]
    },
    {
      "name": "--loglevel",
      "description": "set log level, <trace|debug|info|warning|error>;\ndefault is `info`",
      "aliases": [
        "-l"
      ]
    },
    {
      "name": "--solution",
      "description": "specify .sln file to load (relative to CWD)",
      "aliases": [
        "-s"
      ]
    },
    {
      "name": "--debug",
      "description": "enable debug mode"
    },
    {
      "name": "--diagnose",
      "description": "run diagnostics"
    },
    {
      "name": "--features",
      "description": "enable optional features, comma-separated:\n[metadata-uris, razor-support]",
      "aliases": [
        "-f"
      ]
    },
    {
      "name": "--help",
      "description": "display this list of options."
    }
  ],
  "commands": [
    {
      "name": "root"
    }
  ]
}
