<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LIST-->
  <Command Name="list" IsBranch="false" ClrType="CcPlugins.Commands.ListCommand"
Settings="CcPlugins.Commands.ListCommand+Settings">
    <Description>List all plugins in a directory</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to search for plugins</Description>
      </Argument>
      <Option Short="d" Long="detailed" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show detailed information</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list" />
      <Example commandLine="./plugins" />
      <Example commandLine="list" />
      <Example commandLine="--detailed" />
      <Example commandLine="list" />
      <Example commandLine="--json" />
    </Examples>
  </Command>
  <!--PACK-->
  <Command Name="pack" IsBranch="false" ClrType="CcPlugins.Commands.PackCommand"
Settings="CcPlugins.Commands.PackCommand+Settings">
    <Description>Package a plugin into a .plugin file</Description>
    <Parameters>
      <Argument Name="PLUGIN_PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the plugin directory</Description>
      </Argument>
      <Option Short="b" Long="bump" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Bump version before packing (major, minor, 
patch)</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for the .plugin file</Description>
      </Option>
      <Option Short="" Long="skip-validation" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip validation</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="pack" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="pack" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="-o" />
      <Example commandLine="./dist" />
      <Example commandLine="pack" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="--bump" />
      <Example commandLine="patch" />
    </Examples>
  </Command>
  <!--PACK-ALL-->
  <Command Name="pack-all" IsBranch="false" 
ClrType="CcPlugins.Commands.PackAllCommand" 
Settings="CcPlugins.Commands.PackAllCommand+Settings">
    <Description>Package all plugins in a directory</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to search for plugins</Description>
      </Argument>
      <Option Short="" Long="continue-on-error" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Continue on error</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for .plugin files</Description>
      </Option>
      <Option Short="" Long="skip-validation" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip validation</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="pack-all" />
      <Example commandLine="./plugins" />
      <Example commandLine="pack-all" />
      <Example commandLine="./plugins" />
      <Example commandLine="-o" />
      <Example commandLine="./dist" />
      <Example commandLine="pack-all" />
      <Example commandLine="--continue-on-error" />
    </Examples>
  </Command>
  <!--VALIDATE-->
  <Command Name="validate" IsBranch="false" 
ClrType="CcPlugins.Commands.ValidateCommand" 
Settings="CcPlugins.Commands.ValidateCommand+Settings">
    <Description>Validate a plugin structure</Description>
    <Parameters>
      <Argument Name="PLUGIN_PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the plugin directory</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="validate" />
      <Example commandLine="./plugins/my-plugin" />
    </Examples>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="CcPlugins.Commands.VersionCommand" 
Settings="CcPlugins.Commands.VersionCommand+Settings">
    <Description>View or update plugin version</Description>
    <Parameters>
      <Argument Name="PLUGIN_PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the plugin directory</Description>
      </Argument>
      <Option Short="b" Long="bump" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Bump version (major, minor, patch)</Description>
      </Option>
      <Option Short="s" Long="set" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Set version to a specific value</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="version" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="version" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="--bump" />
      <Example commandLine="minor" />
      <Example commandLine="version" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="--set" />
      <Example commandLine="2.0.0" />
    </Examples>
  </Command>
  <!--PUBLISH-->
  <Command Name="publish" IsBranch="false" 
ClrType="CcPlugins.Commands.PublishCommand" 
Settings="CcPlugins.Commands.PublishCommand+Settings">
    <Description>Publish a plugin to a marketplace</Description>
    <Parameters>
      <Argument Name="PLUGIN_PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the plugin directory or .plugin file</Description>
      </Argument>
      <Option Short="k" Long="api-key" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>API key for authentication</Description>
      </Option>
      <Option Short="b" Long="bump" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Bump version before publishing (major, minor, 
patch)</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Dry run - pack but don't upload</Description>
      </Option>
      <Option Short="u" Long="url" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Marketplace URL</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip confirmation prompt</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="publish" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="publish" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="--bump" />
      <Example commandLine="patch" />
      <Example commandLine="publish" />
      <Example commandLine="./dist/my-plugin-1.0.0.plugin" />
      <Example commandLine="-u" />
      <Example commandLine="https://marketplace.example.com" />
      <Example commandLine="publish" />
      <Example commandLine="./plugins/my-plugin" />
      <Example commandLine="--dry-run" />
    </Examples>
  </Command>
</Model>