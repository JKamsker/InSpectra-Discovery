<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--RUN-->
  <Command Name="run" IsBranch="false" 
ClrType="ChatRoom.Client.ChatRoomClientCommand" 
Settings="ChatRoom.SDK.ChatRoomAgentClientCommandSettings">
    <Parameters>
      <Option Short="c" Long="config" Value="CONFIG" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Configuration file.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CREATE-->
  <Command Name="create" IsBranch="false" 
ClrType="ChatRoom.Client.CreateConfigurationCommand" 
Settings="ChatRoom.SDK.TemplateCommandSettings">
    <Parameters>
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>the name of the configuration file to be created. Default 
is config.json</Description>
      </Option>
      <Option Short="t" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
  <!--LIST-TEMPLATES-->
  <Command Name="list-templates" IsBranch="false" 
ClrType="ChatRoom.Client.ListTemplatesCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
</Model>