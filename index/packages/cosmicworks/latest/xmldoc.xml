    <!--EMPLOYEES-->
    <Command Name="employees" IsBranch="false" 
ClrType="Microsoft.Samples.Cosmos.NoSQL.CosmicWorks.Tool.Commands.GenerateEmploy
eesCommand" 
Settings="Microsoft.Samples.Cosmos.NoSQL.CosmicWorks.Tool.Settings.GenerateEmplo
yeesSettings">
      <Description>Generate fictitious employee data for Azure Cosmos DB for 
NoSQL.</Description>
      <Parameters>
        <Option Short="" Long="connection-string" Value="CONNECTION_STRING" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Optional [NOT RECOMMENDED]. The connection string to the 
Azure Cosmos DB for NoSQL account using a resource owner password credential 
(ROPC). The --endpoint option is preferred.</Description>
        </Option>
        <Option Short="c" Long="container-name" Value="CONTAINER_NAME" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Optional. The name of the container to use. Defaults to 
'employees'.</Description>
        </Option>
        <Option Short="d" Long="database-name" Value="DATABASE_NAME" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Optional. The name of the database to use. Defaults to 
'cosmicworks'.</Description>
        </Option>
        <Option Short="" Long="disable-formatting" Value="DISABLE_FORMATTING" 
Required="false" Kind="flag" ClrType="System.Nullable`1[[System.Boolean, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Optional. Disables ANSI and color formatting for console 
output. This setting is useful for redirecting output to a file, log, or other 
output stream that doesn't support ANSI or color formatting. Defaults to 
false.</Description>
        </Option>
        <Option Short="" Long="disable-hierarchical-partition-keys" Value="NULL"
Required="false" Kind="flag" ClrType="System.Nullable`1[[System.Boolean, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Optional. Disables hierarchical partition keys and uses 
only the first partition key value. Defaults to false.</Description>
        </Option>
        <Option Short="e" Long="emulator" Value="EMULATOR" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Optional. Use the Azure Cosmos DB Emulator.</Description>
        </Option>
        <Option Short="n" Long="endpoint" Value="ENDPOINT" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The endpoint to the Azure Cosmos DB for NoSQL 
account.</Description>
        </Option>
        <Option Short="" Long="hide-credentials" Value="HIDE_CREDENTIALS" 
Required="false" Kind="flag" ClrType="System.Nullable`1[[System.Boolean, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Optional. Hides the credentials. It is recommended to use
this option when using the --connection-string option. Defaults to 
false.</Description>
        </Option>
        <Option Short="q" Long="quantity" Value="QUANTITY" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Optional. The number of items to generate. Defaults to 
the maximum number of items for the entity type.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="generate" />
        <Example commandLine="employees" />
        <Example commandLine="--endpoint" />
        <Example commandLine="&lt;azure-cosmos-db-nosql-account-endpoint&gt;" />
        <Example commandLine="generate" />
        <Example commandLine="employees" />
        <Example commandLine="--endpoint" />
        <Example commandLine="&lt;azure-cosmos-db-nosql-account-endpoint&gt;" />
        <Example commandLine="--quantity" />
        <Example commandLine="100" />
        <Example commandLine="generate" />
        <Example commandLine="products" />
        <Example commandLine="--endpoint" />
        <Example commandLine="&lt;azure-cosmos-db-nosql-account-endpoint&gt;" />
        <Example commandLine="--database-name" />
        <Example commandLine="human-resources" />
        <Example commandLine="--container-name" />
        <Example commandLine="people" />
        <Example commandLine="generate" />
        <Example commandLine="employees" />
        <Example commandLine="--connection-string" />
        <Example commandLine="&lt;azure-cosmos-db-nosql-connection-string&gt;" 
/>
        <Example commandLine="--disable-hierarchical-partition-keys" />
        <Example commandLine="generate" />
        <Example commandLine="employees" />
        <Example commandLine="--emulator" />
      </Examples>
    </Command>
