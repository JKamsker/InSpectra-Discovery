<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VERSION-BUMPS-->
  <Command Name="version-bumps" IsBranch="false" 
ClrType="GitHubMilestoneCleaner.Commands.CleanVersionBumpsCommand" 
Settings="GitHubMilestoneCleaner.Commands.CleanVersionBumpsCommand+Settings">
    <Parameters>
      <Option Short="c" Long="closed" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Include closed milestones. Default is to search only in 
open milestones.</Description>
      </Option>
      <Option Short="m" Long="milestone" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Milestone to clean.</Description>
      </Option>
      <Option Short="q" Long="non-interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Interactively select which issues to remove from the 
milestone.</Description>
      </Option>
      <Option Short="o" Long="owner" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Owner of the repository.</Description>
      </Option>
      <Option Short="r" Long="repository" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Repository name.</Description>
      </Option>
      <Option Short="s" Long="subIssueComment" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The comment to add to issues that are removed from the 
milestone, if the issue is not on the first level of the 
issue-tree.</Description>
      </Option>
      <Option Short="t" Long="token" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Token (PAT) used to access the repository.</Description>
      </Option>
      <Option Short="i" Long="topIssueComment" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The comment to add to issues that are removed from the 
milestone, if the issue is on the first level of the issue-tree.</Description>
      </Option>
      <Option Short="w" Long="whatIf" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Do not actually remove any items, only show what would be 
removed.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>