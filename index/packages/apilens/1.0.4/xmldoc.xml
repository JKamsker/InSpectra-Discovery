Kind="scalar" ClrType="System.String">
        <Description>Path to .csproj, .fsproj, or .sln file</Description>
      </Argument>
      <Option Short="" Long="clean" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Clean the index before analyzing</Description>
      </Option>
      <Option Short="" Long="format" Value="FORMAT" Required="false" 
Kind="scalar" ClrType="ApiLens.Cli.Commands.AnalyzeCommand+OutputFormat">
        <Description>Output format: table, json, markdown</Description>
      </Option>
      <Option Short="" Long="include-transitive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include transitive dependencies</Description>
      </Option>
      <Option Short="i" Long="index" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
