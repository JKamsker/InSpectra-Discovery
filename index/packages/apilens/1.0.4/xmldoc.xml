  <!--NUGET-->
  <Command Name="nuget" IsBranch="false" 
ClrType="ApiLens.Cli.Commands.NuGetCommand" 
Settings="ApiLens.Cli.Commands.NuGetCommand+Settings">
    <Description>Scan and index NuGet package cache.
Automatically discovers your NuGet cache location and indexes all packages
with XML documentation. Supports filtering, latest-version selection, and
listing packages without indexing.</Description>
    <Parameters>
      <Option Short="c" Long="clean" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Clean the index before adding new documents</Description>
      </Option>
      <Option Short="i" Long="index" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path to the Lucene index directory</Description>
      </Option>
      <Option Short="" Long="latest-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Only include the latest version of each package per target 
framework</Description>
      </Option>
      <Option Short="l" Long="list" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>List packages without indexing</Description>
      </Option>
      <Option Short="p" Long="package,filter" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter packages by name (supports wildcards)</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show verbose output</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter packages by version (regex)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="nuget" />
      <Example commandLine="nuget" />
      <Example commandLine="--clean" />
      <Example commandLine="--latest" />
      <Example commandLine="nuget" />
      <Example commandLine="--filter" />
      <Example commandLine="microsoft.*" />
      <Example commandLine="--latest" />
      <Example commandLine="nuget" />
      <Example commandLine="--list" />
      <Example commandLine="nuget" />
      <Example commandLine="--list" />
      <Example commandLine="--filter" />
      <Example commandLine="system.*" />
    </Examples>
  </Command>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="ApiLens.Cli.Commands.AnalyzeCommand" 
Settings="ApiLens.Cli.Commands.AnalyzeCommand+Settings">
