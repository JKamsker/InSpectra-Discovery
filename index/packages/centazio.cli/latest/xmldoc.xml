<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Centazio.Cli.Commands.InteractiveCliMenuCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--GEN-->
  <Command Name="gen" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--SLN-->
    <Command Name="sln" IsBranch="false" 
ClrType="Centazio.Cli.Commands.Gen.Centazio.GenerateSlnCommand" 
Settings="Centazio.Cli.Commands.Gen.Centazio.GenerateSlnCommand+Settings">
      <Parameters>
        <Argument Name="SOLUTION_NAME" Position="0" Required="true" 
Kind="scalar" ClrType="System.String" />
        <Option Short="e" Long="env" Value="ENVIRONMENT" Required="false" 
Kind="vector" ClrType="System.String[]" />
        <Option Short="p" Long="provider" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
      </Parameters>
    </Command>
    <!--FUNC-->
    <Command Name="func" IsBranch="false" 
ClrType="Centazio.Cli.Commands.Gen.Centazio.GenerateFunctionCommand" 
Settings="Centazio.Cli.Commands.Gen.Centazio.GenerateFunctionCommand+Settings">
      <Parameters>
        <Argument Name="SYSTEM_NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Option Short="a" Long="assembly" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="e" Long="env" Value="ENVIRONMENT" Required="false" 
Kind="vector" ClrType="System.String[]" />
        <Option Short="o" Long="other" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
        <Option Short="p" Long="promote" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
        <Option Short="r" Long="read" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
        <Option Short="w" Long="write" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
      </Parameters>
    </Command>
  </Command>
</Model>