  <Command Name="release" IsBranch="false" 
ClrType="Chrono.Commands.Git.CreateReleaseBranchCommand" 
Settings="Chrono.Commands.Git.CreateReleaseBranchCommand+Settings">
    <Description>Creates a new release branch</Description>
    <Parameters>
      <Argument Name="BranchKey" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Argument Name="Commit Message {oldVersion} {newVersion}" Position="1" 
Required="false" Kind="scalar" ClrType="System.String" />
      <Option Short="c" Long="commit" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="i" Long="ignore-dirty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      <Option Short="t" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
