<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Chrono.Commands.Miscellaneous.InitCommand" 
Settings="Chrono.Commands.Miscellaneous.InitCommand+Settings">
    <Description>Initializes the current directory with the required files for 
Chrono to work</Description>
    <Parameters>
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="i" Long="ignore-dirty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      <Option Short="t" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="init" />
    </Examples>
  </Command>
  <!--GET-->
  <Command Name="get" IsBranch="false" 
ClrType="Chrono.Commands.Core.GetVersionCommand" 
Settings="Chrono.Commands.Core.GetVersionCommand+Settings">
    <Description>Gets the current version of the project</Description>
    <Parameters>
      <Argument Name="Target" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="p" Long="gitRoot" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="i" Long="ignore-dirty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      <Option Short="n" Long="numeric" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
      <Option Short="t" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="e" Long="useEnvVars" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="get" />
    </Examples>
  </Command>
  <!--SET-->
  <Command Name="set" IsBranch="false" 
ClrType="Chrono.Commands.Core.SetVersionCommand" 
Settings="Chrono.Commands.Core.SetVersionCommand+Settings">
    <Description>Sets the current version of the project</Description>
    <Parameters>
      <Argument Name="VERSION" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="i" Long="ignore-dirty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      <Option Short="t" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="set" />
    </Examples>
  </Command>
  <!--BUMP-->
  <Command Name="bump" IsBranch="false" 
ClrType="Chrono.Commands.Core.BumpVersionCommand" 
Settings="Chrono.Commands.Core.BumpVersionCommand+Settings">
    <Description>Increments the current version of the project</Description>
    <Parameters>
      <Argument Name="Version Component" Position="0" Required="true" 
Kind="scalar" ClrType="Chrono.Core.VersionComponent" />
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="i" Long="ignore-dirty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      <Option Short="t" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="bump" />
    </Examples>
  </Command>
