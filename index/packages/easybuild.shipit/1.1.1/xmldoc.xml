<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="EasyBuild.ShipIt.Commands.Default+DefaultCommand" 
Settings="EasyBuild.ShipIt.Types.Settings+DefaultCommandSettings">
    <Description>Automate changelog generation based on conventional commit 
messages and create pull requests for releases.
The tool will do its best to automatically detect the Git provider based on the 
git remote URL.
You can force it to use a specific provider using sub-commands, e.g. 'shipit 
github' to force using GitHub.
Learn more at https://github.com/easybuild-org/EasyBuild.ShipIt</Description>
    <Parameters>
      <Option Short="" Long="allow-branch" Value="VALUES" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>List of branches that are allowed to be used to generate 
the changelog</Description>
      </Option>
      <Option Short="" Long="mode" Value="MODE" Required="false" Kind="scalar" 
ClrType="Microsoft.FSharp.Core.FSharpOption`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Mode of operation. Possible values are 'local', 
'pull-request' and 'push'</Description>
      </Option>
      <Option Short="" Long="pre-release" Value="PREFIX" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Indicate that the generated version is a pre-release 
version. Optionally, you can provide a prefix for the beta version. Default is 
'beta'</Description>
      </Option>
      <Option Short="" Long="remote-hostname" Value="HOSTNAME" Required="false" 
Kind="scalar" ClrType="Microsoft.FSharp.Core.FSharpOption`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Git remote hostname, e.g. github.com, 
gitlab.com</Description>
      </Option>
      <Option Short="" Long="remote-owner" Value="OWNER" Required="false" 
Kind="scalar" ClrType="Microsoft.FSharp.Core.FSharpOption`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Git remote owner or organization name</Description>
      </Option>
      <Option Short="" Long="remote-repo" Value="REPO" Required="false" 
Kind="scalar" ClrType="Microsoft.FSharp.Core.FSharpOption`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Git remote repository name</Description>
      </Option>
      <Option Short="" Long="skip-invalid-commit" Value="NULL" Required="false" 
Kind="scalar" ClrType="Spectre.Console.Cli.FlagValue`1[[System.Boolean, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Skip invalid commits instead of failing (default: 
false)</Description>
      </Option>
      <Option Short="" Long="skip-merge-commit" Value="NULL" Required="false" 
Kind="scalar" ClrType="Spectre.Console.Cli.FlagValue`1[[System.Boolean, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Skip merge commits when generating the changelog (commit 
messages starting with 'Merge ') (default: false)</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show version information</Description>
      </Option>
    </Parameters>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="EasyBuild.ShipIt.Commands.Version+VersionCommand" 
Settings="EasyBuild.ShipIt.Types.Settings+VersionSettings" />
  <!--CONVENTIONS-->
  <Command Name="conventions" IsBranch="false" 
ClrType="EasyBuild.ShipIt.Commands.Conventions+ConventionsCommand" 
Settings="EasyBuild.ShipIt.Types.Settings+ConventionsSettings">
    <Description>List supported Conventional Commit types</Description>
  </Command>
