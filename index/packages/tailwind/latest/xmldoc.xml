<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Tailwind.App.DefaultTailwindCommand" 
Settings="Tailwind.App.DefaultTailwindCommand+DefaultSettings" />
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Tailwind.App.InitTailwindCommand" 
Settings="Tailwind.App.TailwindSettings">
    <Parameters>
      <Option Short="d" Long="dir" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The root directory for your code</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path to the output css file relative to the project 
file</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The version of Tailwind to install</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" 
ClrType="Tailwind.App.RemoveTailwindCommand" 
Settings="Tailwind.App.RemoveTailwindSettings">
    <Parameters>
      <Option Short="d" Long="dir" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The root directory for your code</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Present the 'what-if' analysis</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path to the output css file relative to the project 
file</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The version of Tailwind to install</Description>
      </Option>
    </Parameters>
  </Command>
</Model>