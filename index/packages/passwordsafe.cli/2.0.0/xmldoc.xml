<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage the configuration</Description>
    <!--INIT-->
    <Command Name="init" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.InitConfigCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Initialize the configuration file</Description>
    </Command>
    <!--PATH-->
    <Command Name="path" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.ConfigPathCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Print the configuration file path</Description>
    </Command>
    <!--SHOW-->
    <Command Name="show" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.ShowConfigCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Show current configuration</Description>
    </Command>
    <!--SET-->
    <Command Name="set" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.SetConfigCommand" 
Settings="PwSafeClient.Cli.Commands.SetConfigCommand+Settings">
      <Description>Update configuration values</Description>
      <Parameters>
        <Option Short="" Long="default-db" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Set the default database alias</Description>
        </Option>
        <Option Short="" Long="idle-time" Value="MINUTES" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Set idle time in minutes</Description>
        </Option>
        <Option Short="" Long="max-backup-count" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Set maximum number of backup files to keep</Description>
        </Option>
      </Parameters>
    </Command>
    <!--EDIT-->
    <Command Name="edit" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.EditConfigCommand" 
Settings="PwSafeClient.Cli.Commands.EditConfigCommand+Settings">
      <Description>Open the configuration file in an editor</Description>
      <Parameters>
        <Option Short="" Long="init" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Create the config file first if it does not 
exist</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESET-->
    <Command Name="reset" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.ResetConfigCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Reset the configuration file (overwrite)</Description>
    </Command>
  </Command>
  <!--DB-->
  <Command Name="db" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage the pwsafe databases</Description>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.AddDatabaseCommand" 
Settings="PwSafeClient.Cli.Commands.AddDatabaseCommand+Settings">
      <Description>Add a new database to configuration</Description>
      <Parameters>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias for the database</Description>
        </Option>
        <Option Short="" Long="allow-missing" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Allow adding a database path that does not exist 
yet</Description>
        </Option>
        <Option Short="d" Long="default" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Set the database as default</Description>
        </Option>
        <Option Short="f" Long="file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the database file</Description>
        </Option>
        <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Force to update the alias if it already 
exists</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.ListDatabaseCommand" 
Settings="PwSafeClient.Cli.Commands.ListDatabaseCommand+Settings">
      <Description>List all configured databases</Description>
      <Parameters>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output results as JSON</Description>
        </Option>
        <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Suppress non-essential output</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REMOVE-->
    <Command Name="remove" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.RemoveDatabaseCommand" 
Settings="PwSafeClient.Cli.Commands.RemoveDatabaseCommand+Settings">
      <Description>Remove a database from configuration</Description>
      <Parameters>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias for the database</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SET-->
    <Command Name="set" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.SetDatabaseCommand" 
Settings="PwSafeClient.Cli.Commands.SetDatabaseCommand+Settings">
      <Description>Set the default database</Description>
      <Parameters>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias for the database</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.CreateDatabaseCommand" 
Settings="PwSafeClient.Cli.Commands.CreateDatabaseCommand+Settings">
      <Description>Create an empty database</Description>
      <Parameters>
        <Argument Name="FILE_PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the database file</Description>
        </Argument>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias for the database</Description>
        </Option>
        <Option Short="d" Long="default" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Set the database as default</Description>
        </Option>
        <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Force to create the database file if it already 
exists</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SHOW-->
    <Command Name="show" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.ShowDatabaseCommand" 
Settings="PwSafeClient.Cli.Commands.ShowDatabaseCommand+Settings">
      <Description>Show the database information</Description>
      <Parameters>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias of the database</Description>
        </Option>
        <Option Short="f" Long="file" Value="FILE_PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the database file</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output results as JSON</Description>
        </Option>
        <Option Short="" Long="password-env" Value="VAR" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Read database password from environment 
variable</Description>
        </Option>
        <Option Short="" Long="password-stdin" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Read database password from stdin</Description>
        </Option>
        <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Suppress non-essential output</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--ENTRY-->
  <Command Name="entry" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage password safe entries</Description>
    <!--GET-->
    <Command Name="get" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.GetPasswordCommand" 
Settings="PwSafeClient.Cli.Commands.GetPasswordCommand+Settings">
      <Description>Get the password of an entry</Description>
      <Parameters>
        <Argument Name="ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.Guid">
          <Description>The ID of the entry</Description>
        </Argument>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias for the database</Description>
        </Option>
        <Option Short="" Long="clear-after" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Clear the clipboard after N seconds (requires clipboard 
copy)</Description>
        </Option>
        <Option Short="f,p" Long="file,path" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the database file</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output results as JSON</Description>
        </Option>
        <Option Short="" Long="no-clipboard" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Do not copy the password to the clipboard</Description>
        </Option>
        <Option Short="" Long="password-env" Value="VAR" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Read database password from environment 
variable</Description>
        </Option>
        <Option Short="" Long="password-stdin" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Read database password from stdin</Description>
        </Option>
        <Option Short="" Long="print" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Print the password to stdout</Description>
        </Option>
        <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Suppress non-essential output</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SHOW-->
    <Command Name="show" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.ShowEntryCommand" 
Settings="PwSafeClient.Cli.Commands.ShowEntryCommand+Settings">
      <Description>Show the details of an entry</Description>
      <Parameters>
        <Argument Name="ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.Guid">
          <Description>The ID of the entry</Description>
        </Argument>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias for the database</Description>
        </Option>
        <Option Short="f,p" Long="file,path" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the database file</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output results as JSON</Description>
        </Option>
        <Option Short="" Long="password-env" Value="VAR" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Read database password from environment 
variable</Description>
        </Option>
        <Option Short="" Long="password-stdin" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Read database password from stdin</Description>
        </Option>
        <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Suppress non-essential output</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.ListEntriesCommand" 
Settings="PwSafeClient.Cli.Commands.ListEntriesCommand+Settings">
      <Description>List all entries in the database</Description>
      <Parameters>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias for the database</Description>
        </Option>
        <Option Short="" Long="created-since" Value="DATE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter entries created on/after this date/time (parseable
by .NET)</Description>
        </Option>
        <Option Short="f,p" Long="file,path" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the database file</Description>
        </Option>
        <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter by group path</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output results as JSON</Description>
        </Option>
        <Option Short="" Long="modified-since" Value="DATE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter entries modified on/after this date/time 
(parseable by .NET)</Description>
        </Option>
        <Option Short="" Long="password-env" Value="VAR" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Read database password from environment 
variable</Description>
        </Option>
        <Option Short="" Long="password-stdin" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Read database password from stdin</Description>
        </Option>
        <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Suppress non-essential output</Description>
        </Option>
        <Option Short="" Long="title" Value="TITLE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter by title containing the given text</Description>
        </Option>
        <Option Short="" Long="tree-view" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Display results in a tree view grouped by group 
path</Description>
        </Option>
        <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Filter by URL containing the given text</Description>
        </Option>
        <Option Short="" Long="username" Value="USERNAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter by username containing the given 
text</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SEARCH-->
    <Command Name="search" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.SearchEntriesCommand" 
Settings="PwSafeClient.Cli.Commands.SearchEntriesCommand+Settings">
      <Description>Search entries by title/username/url/notes</Description>
      <Parameters>
        <Argument Name="QUERY" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Search query (plain text or regex pattern)</Description>
        </Argument>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Alias for the database</Description>
        </Option>
        <Option Short="" Long="case-sensitive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Use case-sensitive matching</Description>
        </Option>
        <Option Short="f,p" Long="file,path" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the database file</Description>
        </Option>
        <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter results to the given group path</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output results as JSON</Description>
        </Option>
        <Option Short="" Long="limit" Value="LIMIT" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Maximum number of results to show (0 = no 
limit)</Description>
        </Option>
        <Option Short="" Long="password-env" Value="VAR" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Read database password from environment 
variable</Description>
        </Option>
        <Option Short="" Long="password-stdin" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Read database password from stdin</Description>
        </Option>
        <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Suppress non-essential output</Description>
        </Option>
        <Option Short="" Long="regex" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Treat QUERY as a regular expression</Description>
        </Option>
      </Parameters>
    </Command>
    <!--NEW-->
    <Command Name="new" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.NewEntryCommand" 
Settings="PwSafeClient.Cli.Commands.NewEntryCommand+Settings">
      <Description>Create a new entry in the database</Description>
