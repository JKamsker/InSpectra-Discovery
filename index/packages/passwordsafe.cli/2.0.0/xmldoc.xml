Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage password policies</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="PwSafeClient.Cli.Commands.ListPoliciesCommand" 
Settings="PwSafeClient.Cli.Commands.ListPoliciesCommand+Settings">
      <Description>List all password policies</Description>
      <Parameters>
        <Option Short="a" Long="alias" Value="ALIAS" Required="false" 
Kind="scalar" ClrType="System.String">
