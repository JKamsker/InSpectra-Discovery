<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DotNetNuke.BulkInstall.DeployClient.DeployCommand" 
Settings="DotNetNuke.BulkInstall.DeployClient.DeployInput">
    <Parameters>
      <Option Short="a" Long="api-key" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The key used to authenticate with the web 
server.</Description>
      </Option>
      <Option Short="e" Long="encryption-key" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The key used to encrypt the packages before 
uploading.</Description>
      </Option>
      <Option Short="t" Long="installation-status-timeout" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.Int32">
        <Description>The number of seconds to ignore 404 errors when checking 
installation status.</Description>
      </Option>
      <Option Short="" Long="legacy-api" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Whether to use the PolyDeploy API instead of the 
BulkInstall API.</Description>
      </Option>
      <Option Short="l" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="DotNetNuke.BulkInstall.DeployClient.LogLevel">
        <Description>Defines the amount of logging.</Description>
      </Option>
      <Option Short="d" Long="packages-directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Defines the directory that contains the install 
packages.</Description>
      </Option>
      <Option Short="r" Long="recurse" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Whether to search the packages directory 
recursively.</Description>
      </Option>
      <Option Short="u" Long="target-uri" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The URL of the site to which the packages will be 
deployed.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>