<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--RAND-->
  <Command Name="rand" IsBranch="false" 
ClrType="MicroFun.Utils.Commands.RandCommand" 
Settings="MicroFun.Utils.Commands.RandCommand+Settings">
    <Parameters>
      <Argument Name="bytes" Position="0" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of bytes to generate. Default is 16.</Description>
      </Argument>
      <Option Short="" Long="colors" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable colors in output.</Description>
      </Option>
      <Option Short="" Long="hex,hexadecimal" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Output as hexadecimal in lower case.</Description>
      </Option>
      <Option Short="" Long="HEX,HEXADECIMAL" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Output as hexadecimal in upper case.</Description>
      </Option>
      <Option Short="l" Long="max-length" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum length of the output. Default is 
unlimited.</Description>
      </Option>
      <Option Short="" Long="no-headers" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Omit csv headers</Description>
      </Option>
      <Option Short="" Long="no-indent" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>No indent json output.</Description>
      </Option>
      <Option Short="f" Long="output-format" Value="NULL" Required="false" 
Kind="scalar" ClrType="MicroFun.Utils.Commands.OutputFormat">
        <Description>Output format. Default is text.</Description>
      </Option>
      <Option Short="" Long="quoted" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Quote csv fields</Description>
      </Option>
      <Option Short="" Long="unpadded" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Output as base64 without padding.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--FILE-->
  <Command Name="file" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--STATS-->
    <Command Name="stats" IsBranch="false" 
ClrType="MicroFun.Utils.Commands.FileSystem.FileStatsCommand" 
Settings="MicroFun.Utils.Commands.FileSystem.FileStatsCommand+Settings">
      <Parameters>
        <Argument Name="folder" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Folder to scan. Default is current folder.</Description>
        </Argument>
        <Argument Name="pattern" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>File pattern to match. Default is *.*</Description>
        </Argument>
        <Option Short="a" Long="asc,ascending" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Sort results in ascending order. By default is 
descending.</Description>
        </Option>
        <Option Short="" Long="colors" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Enable colors in output.</Description>
        </Option>
        <Option Short="d" Long="depth" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Maximum depth to recurse into subfolders. Default is 
infinite.</Description>
        </Option>
        <Option Short="" Long="no-headers" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Omit csv headers</Description>
        </Option>
        <Option Short="" Long="no-hidden" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Do not count hidden files</Description>
        </Option>
        <Option Short="" Long="no-indent" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>No indent json output.</Description>
        </Option>
        <Option Short="" Long="no-recurse" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Do not recurse into subfolders.</Description>
        </Option>
        <Option Short="" Long="no-system" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Do not count system files</Description>
        </Option>
        <Option Short="f" Long="output-format" Value="NULL" Required="false" 
Kind="scalar" ClrType="MicroFun.Utils.Commands.OutputFormat">
          <Description>Output format. Default is text.</Description>
        </Option>
        <Option Short="" Long="quoted" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Quote csv fields</Description>
        </Option>
        <Option Short="s" Long="sort" Value="NULL" Required="false" 
Kind="scalar" ClrType="MicroFun.Utils.BucketStatsBinField">
          <Description>Field to sort results. By default is by Sum</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>