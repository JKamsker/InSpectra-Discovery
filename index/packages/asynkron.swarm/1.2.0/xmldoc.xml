<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Asynkron.Swarm.Commands.SwarmCommand" 
Settings="Asynkron.Swarm.Commands.SwarmSettings">
    <Parameters>
      <Option Short="" Long="arena" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Arena mode: timed rounds, supervisor evaluates and picks 
winning changes</Description>
      </Option>
      <Option Short="" Long="autopilot" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Autopilot mode: runs continuously without timed rounds 
(default)</Description>
      </Option>
      <Option Short="" Long="claude" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of Claude worker agents (default: 4 if no agents 
specified)</Description>
      </Option>
      <Option Short="" Long="codex" Value="COUNT" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of Codex worker agents</Description>
      </Option>
      <Option Short="" Long="copilot" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of Copilot worker agents</Description>
      </Option>
      <Option Short="" Long="detect" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Detect installed CLI agents and exit</Description>
      </Option>
      <Option Short="" Long="gemini" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of Gemini worker agents</Description>
      </Option>
      <Option Short="" Long="max-rounds" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum number of rounds before stopping</Description>
      </Option>
      <Option Short="m" Long="minutes" Value="MINUTES" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Minutes to run each round before killing 
workers</Description>
      </Option>
      <Option Short="r" Long="repo" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the git repository (default: current directory if 
in a repo)</Description>
      </Option>
      <Option Short="" Long="resume" Value="SESSION_ID" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Resume a previous session by its ID</Description>
      </Option>
      <Option Short="" Long="skip-detect" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip agent detection at startup</Description>
      </Option>
      <Option Short="" Long="supervisor" Value="TYPE" Required="false" 
Kind="scalar" ClrType="Asynkron.Swarm.Models.AgentType">
        <Description>Supervisor agent type: Claude, Codex, Copilot, or 
Gemini</Description>
      </Option>
      <Option Short="t" Long="todo" Value="FILE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the todo file (relative to repo root)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>