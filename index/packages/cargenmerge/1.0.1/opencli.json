    "cliParsedDescription": "(C) 2020 thehambone"
  },
  "options": [
    {
      "name": "--priority-list",
      "recursive": false,
      "hidden": false,
      "description": "A CSV file specifying the order in which to replace car generators. The\ncolumns are (priority,index) where 'priority' represents the replacement\norder and 'index' specifies the index of a car generator in the target\nsave's car generator list. A priority of 0 is the highest priority and thus\nthe first to be replaced. A negative priority will exclude a row. If\nmultiple rows share the same priority, one of the rows will be chosen at\nrandom until all rows have been chosen exactly once. Lines beginning with\n'#' are treated as comments and ignored. If no priority list is specified,\ncar generators will be replaced at random.",
      "aliases": [
        "-p"
      ],
      "arguments": [
        {
          "name": "PRIORITYFILE",
          "required": false,
          "arity": {
            "minimum": 0,
            "maximum": 1
          },
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ]
    },
    {
      "name": "--radius",
      "recursive": false,
      "hidden": false,
      "description": "(Default: 5) Set the collision radius. If two car generators are found\nwithin the collision radius, the merge process will be aborted.",
      "aliases": [
        "-r"
      ],
      "arguments": [
        {
          "name": "RADIUS",
          "required": false,
          "arity": {
            "minimum": 0,
            "maximum": 1
          },
