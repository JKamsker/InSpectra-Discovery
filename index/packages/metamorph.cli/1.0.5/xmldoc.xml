ClrType="MetaMorph.Cli.Commands.CopyMetadata.CopyMetadataCommand" 
Settings="MetaMorph.Cli.Commands.CopyMetadata.CopyMetadataSettings">
    <Parameters>
      <Argument Name="sourceFilePath" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the source file.</Description>
      </Argument>
      <Argument Name="targetFilePath" Position="1" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the target file.</Description>
      </Argument>
      <Option Short="d" Long="only-dates" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Copy only dates.</Description>
      </Option>
      <Option Short="g" Long="only-gps" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Copy only GPS.</Description>
      </Option>
    </Parameters>
  </Command>
