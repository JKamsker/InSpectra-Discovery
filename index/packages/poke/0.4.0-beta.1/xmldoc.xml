<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SELECT-->
  <Command Name="select" IsBranch="false" ClrType="Poke.Commands.SelectCommand" 
Settings="Poke.Commands.RunSettings">
    <Description>Display a list of configured servers to execute 
against.</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Configuration file to use</Description>
      </Option>
      <Option Short="b" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show detailed exception information</Description>
      </Option>
      <Option Short="d" Long="dry-run" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Dry run the command without attempting any 
connections</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ALL-->
  <Command Name="all" IsBranch="false" ClrType="Poke.Commands.AllCommand" 
Settings="Poke.Commands.RunSettings">
    <Description>Run all configured servers without selection.</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Configuration file to use</Description>
      </Option>
      <Option Short="b" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show detailed exception information</Description>
      </Option>
      <Option Short="d" Long="dry-run" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Dry run the command without attempting any 
connections</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="false" ClrType="Poke.Commands.ConfigCommand" 
Settings="Poke.Commands.BaseSettings">
    <Description>Display configuration.</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Configuration file to use</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" ClrType="Poke.Commands.AddCommand" 
Settings="Poke.Commands.AddSettings">
    <Description>[[Deprecated]] Add a new SQL Server to the configuration file. 
Use 'new sqlserver' instead.</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Configuration file to use</Description>
      </Option>
      <Option Short="g" Long="group" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Group name for the SQL Server</Description>
      </Option>
      <Option Short="h" Long="host" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Host name or IP address of the SQL Server</Description>
      </Option>
      <Option Short="i" Long="instance" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Instance name of the SQL Server</Description>
      </Option>
    </Parameters>
  </Command>
  <!--NEW-->
  <Command Name="new" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Add a new server to the configuration file.</Description>
    <!--SQLSERVER-->
    <Command Name="sqlserver" IsBranch="false" 
ClrType="Poke.Commands.AddSqlServerCommand" 
Settings="Poke.Commands.AddSqlServerSettings">
      <Description>Add a new SQL Server to the configuration file.</Description>
      <Parameters>
        <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Configuration file to use</Description>
        </Option>
        <Option Short="s" Long="connection-string" Value="NULL" Required="false"
Kind="scalar" ClrType="System.String">
          <Description>Connection string for the SQL Server (takes precedence 
over --data-source)</Description>
        </Option>
        <Option Short="d" Long="data-source" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Data source (host name or IP address) of the SQL 
Server</Description>
        </Option>
        <Option Short="g" Long="group" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Group name for the SQL Server</Description>
        </Option>
        <Option Short="i" Long="instance" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Instance name of the SQL Server</Description>
        </Option>
      </Parameters>
    </Command>
    <!--HTTP-->
    <Command Name="http" IsBranch="false" ClrType="Poke.Commands.AddHttpCommand"
Settings="Poke.Commands.AddHttpSettings">
      <Description>Add a new HTTP Server to the configuration 
file.</Description>
      <Parameters>
        <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Configuration file to use</Description>
        </Option>
        <Option Short="g" Long="group" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Group name for the HTTP Server</Description>
        </Option>
        <Option Short="x" Long="insecure" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip SSL certificate validation</Description>
        </Option>
        <Option Short="i" Long="instance" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Instance name of the HTTP Server</Description>
        </Option>
        <Option Short="u" Long="uri" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>URI for the HTTP request</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>