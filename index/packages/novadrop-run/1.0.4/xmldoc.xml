<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CLIENT-->
  <Command Name="client" IsBranch="false" 
ClrType="Vezel.Novadrop.Commands.ClientCommand" 
Settings="Vezel.Novadrop.Commands.ClientCommand+ClientCommandSettings">
    <Parameters>
      <Argument Name="executable" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>TERA.exe path</Description>
      </Argument>
      <Argument Name="language" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Data center language</Description>
      </Argument>
      <Argument Name="account-name" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Account name</Description>
      </Argument>
      <Argument Name="session-ticket" Position="3" Required="true" Kind="scalar"
ClrType="System.String">
        <Description>Session ticket</Description>
      </Argument>
      <Argument Name="server-host" Position="4" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Server host</Description>
      </Argument>
      <Argument Name="server-port" Position="5" Required="true" Kind="scalar" 
ClrType="System.UInt16">
        <Description>Server port</Description>
      </Argument>
      <Option Short="" Long="patch" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable Themida and telemetry removal</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LAUNCHER-->
  <Command Name="launcher" IsBranch="false" 
ClrType="Vezel.Novadrop.Commands.LauncherCommand" 
Settings="Vezel.Novadrop.Commands.LauncherCommand+LauncherCommandSettings">
    <Parameters>
      <Argument Name="executable" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Tl.exe path</Description>
      </Argument>
      <Argument Name="account-name" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Account name</Description>
      </Argument>
      <Argument Name="session-ticket" Position="2" Required="true" Kind="scalar"
ClrType="System.String">
        <Description>Session ticket</Description>
      </Argument>
      <Argument Name="url" Position="3" Required="true" Kind="scalar" 
ClrType="System.Uri">
        <Description>Server list URL</Description>
      </Argument>
      <Option Short="" Long="server-id" Value="ID" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Set preferred server ID</Description>
      </Option>
    </Parameters>
  </Command>
</Model>