<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--AUTH-->
  <Command Name="auth" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage credentials</Description>
    <!--LOGIN-->
    <Command Name="login" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Auth.AuthLoginCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Set up encrypted credentials</Description>
      <Examples>
        <Example commandLine="auth" />
        <Example commandLine="login" />
      </Examples>
    </Command>
    <!--LOGOUT-->
    <Command Name="logout" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Auth.AuthLogoutCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Remove saved credentials</Description>
      <Examples>
        <Example commandLine="auth" />
        <Example commandLine="logout" />
      </Examples>
    </Command>
  </Command>
  <!--DNS-->
  <Command Name="dns" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage DNS records</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Dns.DnsListCommand" 
Settings="ZoneEe.Cli.Commands.Dns.DnsListSettings">
      <Description>List DNS records (all types if type omitted)</Description>
      <Parameters>
        <Argument Name="domain" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Domain name (e.g. example.com)</Description>
        </Argument>
        <Argument Name="type" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Record type (a, aaaa, cname, mx, txt, srv, ns, caa, 
sshfp, url, tlsa). Omit to show all</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be sent without making the 
request</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON instead of a table</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="dns" />
        <Example commandLine="list" />
        <Example commandLine="example.com" />
        <Example commandLine="dns" />
        <Example commandLine="list" />
        <Example commandLine="example.com" />
        <Example commandLine="a" />
      </Examples>
    </Command>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Dns.DnsAddCommand" 
Settings="ZoneEe.Cli.Commands.Dns.DnsAddSettings">
      <Description>Create a DNS record</Description>
      <Parameters>
        <Argument Name="domain" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Domain name (e.g. example.com)</Description>
        </Argument>
        <Argument Name="type" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Record type (a, aaaa, cname, mx, txt, srv, 
ns)</Description>
        </Argument>
        <Argument Name="name" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Record name (e.g. www.example.com or @ for 
root)</Description>
        </Argument>
        <Argument Name="destination" Position="3" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Destination value (IP address, hostname, 
etc.)</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be sent without making the 
request</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON instead of a table</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="dns" />
        <Example commandLine="add" />
        <Example commandLine="example.com" />
        <Example commandLine="a" />
        <Example commandLine="www.example.com" />
        <Example commandLine="1.2.3.4" />
      </Examples>
    </Command>
    <!--UPDATE-->
    <Command Name="update" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Dns.DnsUpdateCommand" 
Settings="ZoneEe.Cli.Commands.Dns.DnsUpdateSettings">
      <Description>Update a DNS record</Description>
      <Parameters>
        <Argument Name="domain" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Domain name</Description>
        </Argument>
        <Argument Name="type" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Record type</Description>
        </Argument>
        <Argument Name="id" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Record ID</Description>
        </Argument>
        <Argument Name="destination" Position="3" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>New destination value</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be sent without making the 
request</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON instead of a table</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="dns" />
        <Example commandLine="update" />
        <Example commandLine="example.com" />
        <Example commandLine="a" />
        <Example commandLine="12345" />
        <Example commandLine="2.3.4.5" />
      </Examples>
    </Command>
    <!--DELETE-->
    <Command Name="delete" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Dns.DnsDeleteCommand" 
Settings="ZoneEe.Cli.Commands.Dns.DnsDeleteSettings">
      <Description>Delete a DNS record</Description>
      <Parameters>
        <Argument Name="domain" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Domain name</Description>
        </Argument>
        <Argument Name="type" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Record type</Description>
        </Argument>
        <Argument Name="id" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Record ID</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be sent without making the 
request</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON instead of a table</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="dns" />
        <Example commandLine="delete" />
        <Example commandLine="example.com" />
        <Example commandLine="a" />
        <Example commandLine="12345" />
      </Examples>
    </Command>
  </Command>
  <!--DOMAIN-->
  <Command Name="domain" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage domains</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Domain.DomainListCommand" 
Settings="ZoneEe.Cli.Commands.Domain.DomainListSettings">
      <Description>List all domains</Description>
      <Parameters>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be sent without making the 
request</Description>
        </Option>
        <Option Short="" Long="expiring" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show only domains expiring within 30 days</Description>
        </Option>
        <Option Short="f" Long="filter" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter domains by name</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON instead of a table</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="domain" />
        <Example commandLine="list" />
      </Examples>
    </Command>
    <!--INFO-->
    <Command Name="info" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Domain.DomainInfoCommand" 
Settings="ZoneEe.Cli.Commands.Domain.DomainInfoSettings">
      <Description>Show domain details</Description>
      <Parameters>
        <Argument Name="domain" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Domain name (e.g. example.com)</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be sent without making the 
request</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON instead of a table</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="domain" />
        <Example commandLine="info" />
        <Example commandLine="example.com" />
      </Examples>
    </Command>
    <!--RENEW-->
    <Command Name="renew" IsBranch="false" 
ClrType="ZoneEe.Cli.Commands.Domain.DomainRenewCommand" 
Settings="ZoneEe.Cli.Commands.Domain.DomainRenewSettings">
      <Description>Renew or reactivate a domain</Description>
      <Parameters>
        <Argument Name="domain" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Domain name to renew (e.g. example.com)</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be sent without making the 
request</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON instead of a table</Description>
        </Option>
        <Option Short="p" Long="period" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Renewal period in years (default: 1)</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="domain" />
        <Example commandLine="renew" />
        <Example commandLine="example.com" />
      </Examples>
    </Command>
  </Command>
</Model>