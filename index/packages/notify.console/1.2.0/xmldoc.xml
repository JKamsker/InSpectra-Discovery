<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SYSTEM-->
  <Command Name="system" IsBranch="false" 
ClrType="Notify.Console.Commands.SystemCommand" 
Settings="Notify.Console.Commands.SystemCommand+Settings">
    <Description>Show a native OS notification</Description>
    <Parameters>
      <Option Short="" Long="description" Value="DESCRIPTION" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="title" Value="TITLE" Required="false" Kind="scalar"
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--SLACK-->
  <Command Name="slack" IsBranch="false" 
ClrType="Notify.Console.Commands.SlackCommand" 
Settings="Notify.Console.Commands.SlackCommand+Settings">
    <Description>Send a Slack message using a config profile</Description>
    <Parameters>
      <Argument Name="PROFILE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="json" Value="JSON" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="json-file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="message" Value="MESSAGE" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
  <!--MESSAGEBOX-->
  <Command Name="messagebox" IsBranch="false" 
ClrType="Notify.Console.Commands.MessageBoxCommand" 
Settings="Notify.Console.Commands.MessageBoxCommand+Settings">
    <Description>Show a native OS message box dialog</Description>
    <Parameters>
      <Option Short="" Long="message" Value="MESSAGE" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="title" Value="TITLE" Required="false" Kind="scalar"
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--EMAIL-->
  <Command Name="email" IsBranch="false" 
ClrType="Notify.Console.Commands.EmailCommand" 
Settings="Notify.Console.Commands.EmailCommand+Settings">
    <Description>Send an email using a config profile</Description>
    <Parameters>
      <Argument Name="PROFILE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="attach" Value="FILE" Required="false" Kind="vector"
ClrType="System.String[]" />
      <Option Short="" Long="bcc" Value="EMAIL" Required="false" Kind="vector" 
ClrType="System.String[]" />
      <Option Short="" Long="body" Value="BODY" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="cc" Value="EMAIL" Required="false" Kind="vector" 
ClrType="System.String[]" />
      <Option Short="" Long="draft" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="" Long="file" Value="FILE" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="subject" Value="SUBJECT" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="to" Value="EMAIL" Required="false" Kind="vector" 
ClrType="System.String[]" />
    </Parameters>
  </Command>
</Model>