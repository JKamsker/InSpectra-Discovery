<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CTORS-->
  <Command Name="ctors" IsBranch="false" 
ClrType="ScatMan.Cli.Commands.CtorsCommand" 
Settings="ScatMan.Cli.Commands.CtorsCommand+Settings">
    <Description>List constructors of a type in a NuGet package.</Description>
    <Parameters>
      <Argument Name="package" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>NuGet package ID</Description>
      </Argument>
      <Argument Name="version" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Package version</Description>
      </Argument>
      <Argument Name="typeName" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Full or simple type name</Description>
      </Argument>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="ctors" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="NAudio.CoreAudioApi.WasapiCapture" />
    </Examples>
  </Command>
  <!--MEMBERS-->
  <Command Name="members" IsBranch="false" 
ClrType="ScatMan.Cli.Commands.MembersCommand" 
Settings="ScatMan.Cli.Commands.MembersCommand+Settings">
    <Description>List public members of a type in a NuGet package.</Description>
    <Parameters>
      <Argument Name="package" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>NuGet package ID</Description>
      </Argument>
      <Argument Name="version" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Package version</Description>
      </Argument>
      <Argument Name="typeName" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Full or simple type name</Description>
      </Argument>
      <Option Short="" Long="include-attributes" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include member and parameter attributes in 
signatures</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
      <Option Short="" Long="no-default-values" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Do not include optional parameter default values in method 
signatures</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="members" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="NAudio.CoreAudioApi.WasapiCapture" />
    </Examples>
  </Command>
  <!--TYPES-->
  <Command Name="types" IsBranch="false" 
ClrType="ScatMan.Cli.Commands.TypesCommand" 
Settings="ScatMan.Cli.Commands.TypesCommand+Settings">
    <Description>List public types in a NuGet package.</Description>
    <Parameters>
      <Argument Name="package" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>NuGet package ID</Description>
      </Argument>
      <Argument Name="version" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Package version</Description>
      </Argument>
      <Option Short="f" Long="filter" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Case-insensitive substring filter on type 
name</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by namespace</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="types" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="types" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="--namespace" />
      <Example commandLine="NAudio.CoreAudioApi" />
      <Example commandLine="types" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="--filter" />
      <Example commandLine="Capture" />
    </Examples>
  </Command>
  <!--SEARCH-->
  <Command Name="search" IsBranch="false" 
ClrType="ScatMan.Cli.Commands.SearchCommand" 
Settings="ScatMan.Cli.Commands.SearchCommand+Settings">
    <Description>Search for types and members by name across an entire NuGet 
package.</Description>
    <Parameters>
      <Argument Name="package" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>NuGet package ID</Description>
      </Argument>
      <Argument Name="version" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Package version</Description>
      </Argument>
      <Argument Name="query" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Case-insensitive substring to search for in type and member
names</Description>
      </Argument>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Restrict search to this namespace</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="search" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="Capture" />
      <Example commandLine="search" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="GetDefaultDevice" />
    </Examples>
  </Command>
  <!--VERSIONS-->
  <Command Name="versions" IsBranch="false" 
ClrType="ScatMan.Cli.Commands.VersionsCommand" 
Settings="ScatMan.Cli.Commands.VersionsCommand+Settings">
    <Description>List available versions of a NuGet package.</Description>
    <Parameters>
      <Argument Name="package" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>NuGet package ID</Description>
      </Argument>
      <Option Short="" Long="head" Value="N" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Show only the N most recent versions</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
      <Option Short="" Long="pre" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Include prerelease versions</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="versions" />
      <Example commandLine="NAudio.Lame" />
      <Example commandLine="versions" />
      <Example commandLine="LiveChartsCore.SkiaSharpView.Maui" />
      <Example commandLine="--pre" />
    </Examples>
  </Command>
  <!--META-->
  <Command Name="meta" IsBranch="false" 
ClrType="ScatMan.Cli.Commands.MetaCommand" 
Settings="ScatMan.Cli.Commands.MetaCommand+Settings">
    <Description>Show metadata about the ScatGirl CLI tool, including version 
and build information.</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
</Model>