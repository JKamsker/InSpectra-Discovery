    <Parameters>
      <Argument Name="package" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>NuGet package ID</Description>
      </Argument>
      <Argument Name="version" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Package version</Description>
      </Argument>
      <Argument Name="typeName" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Full or simple type name</Description>
      </Argument>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="members" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="NAudio.CoreAudioApi.WasapiCapture" />
    </Examples>
  </Command>
  <!--TYPES-->
  <Command Name="types" IsBranch="false" 
ClrType="ScatMan.Cli.Commands.TypesCommand" 
Settings="ScatMan.Cli.Commands.TypesCommand+Settings">
    <Description>List public types in a NuGet package.</Description>
    <Parameters>
      <Argument Name="package" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>NuGet package ID</Description>
      </Argument>
      <Argument Name="version" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Package version</Description>
      </Argument>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by namespace</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="types" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="types" />
      <Example commandLine="NAudio.Wasapi" />
      <Example commandLine="2.2.1" />
      <Example commandLine="--namespace" />
      <Example commandLine="NAudio.CoreAudioApi" />
    </Examples>
  </Command>
</Model>