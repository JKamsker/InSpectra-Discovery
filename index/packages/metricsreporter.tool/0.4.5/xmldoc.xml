<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="MetricsReporter.Cli.Commands.GenerateCommand" 
Settings="MetricsReporter.Cli.Settings.GenerateSettings">
    <Description>Aggregates metrics from OpenCover/Roslyn/SARIF inputs and 
produces metrics-report.json/metrics-report.html.</Description>
    <Parameters>
      <Option Short="" Long="aggregate-after-scripts" Value="TRUE|FALSE" 
Required="false" Kind="flag" ClrType="System.Nullable`1[[System.Boolean, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Controls aggregation after scripts. Defaults to true for 
read/test/readsarif; ignored for generate.</Description>
      </Option>
      <Option Short="" Long="analyze-suppressed-symbols" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Enable suppressed-symbol analysis before 
aggregation.</Description>
      </Option>
      <Option Short="" Long="baseline" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to baseline metrics JSON.</Description>
      </Option>
      <Option Short="" Long="baseline-ref" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Baseline reference label (git commit, build ID, 
etc.).</Description>
      </Option>
      <Option Short="" Long="baseline-storage-path" Value="PATH" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Directory where old baseline files are 
archived.</Description>
      </Option>
      <Option Short="" Long="config" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Optional path to .metricsreporter.json. If omitted, the 
file is discovered by walking up from the working directory.</Description>
      </Option>
      <Option Short="" Long="coverage-html-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Directory containing HTML coverage reports for 
hyperlinking.</Description>
      </Option>
      <Option Short="" Long="exclude-events" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Exclude events from metrics output.</Description>
      </Option>
      <Option Short="" Long="exclude-fields" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Exclude fields from metrics output.</Description>
      </Option>
      <Option Short="" Long="exclude-methods" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Exclude methods from metrics output.</Description>
      </Option>
      <Option Short="" Long="exclude-properties" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Exclude properties from metrics output.</Description>
      </Option>
      <Option Short="" Long="excluded-assemblies" Value="LIST" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma/semicolon-separated assembly name patterns to 
exclude.</Description>
      </Option>
      <Option Short="" Long="excluded-members" Value="LIST" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma/semicolon-separated member name patterns to 
exclude.</Description>
      </Option>
      <Option Short="" Long="excluded-types" Value="LIST" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma/semicolon-separated type name patterns to 
exclude.</Description>
      </Option>
      <Option Short="" Long="input-json" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Existing metrics-report.json used to generate HTML 
only.</Description>
      </Option>
      <Option Short="" Long="log-truncation-limit" Value="INT" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of stdout/stderr characters logged on script
failures. Defaults to 4000.</Description>
      </Option>
      <Option Short="" Long="metric-aliases" Value="JSON" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>JSON object mapping metric identifiers to alias arrays. CLI
overrides env/config.</Description>
      </Option>
      <Option Short="" Long="metrics-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Root directory for metrics artifacts 
(OpenCover/Roslyn/SARIF/baseline).</Description>
      </Option>
      <Option Short="" Long="opencover" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Path to OpenCover coverage XML. Repeat for multiple 
files.</Description>
      </Option>
      <Option Short="" Long="output-html" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the resulting metrics-report.html.</Description>
      </Option>
      <Option Short="" Long="output-json" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the resulting metrics-report.json.</Description>
      </Option>
      <Option Short="" Long="replace-baseline" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Replace baseline when new report differs.</Description>
      </Option>
      <Option Short="" Long="roslyn" Value="PATH" Required="false" Kind="scalar"
ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Path to Roslyn metrics XML. Repeat for multiple 
files.</Description>
      </Option>
      <Option Short="" Long="run-scripts" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Controls execution of configured scripts. Defaults to 
true.</Description>
      </Option>
      <Option Short="" Long="sarif" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Path to SARIF file. Repeat for multiple 
files.</Description>
      </Option>
      <Option Short="" Long="script" Value="PATH" Required="false" Kind="scalar"
ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>PowerShell script executed before aggregation. Repeat for 
multiple scripts.</Description>
      </Option>
      <Option Short="" Long="solution-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution directory used for suppressed-symbol 
analysis.</Description>
      </Option>
      <Option Short="" Long="solution-name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution name displayed in reports.</Description>
      </Option>
      <Option Short="" Long="source-code-folders" Value="LIST" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma/semicolon-separated list of source code folder roots 
for suppressed-symbol analysis.</Description>
      </Option>
      <Option Short="" Long="suppressed-symbols" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to JSON file where suppressed symbol metadata is 
stored.</Description>
      </Option>
      <Option Short="" Long="thresholds" Value="JSON" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Inline JSON string with metric thresholds.</Description>
      </Option>
      <Option Short="" Long="thresholds-file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to JSON file with symbol-level 
thresholds.</Description>
      </Option>
      <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Timeout in seconds for external scripts. Defaults to 
configuration or 900 seconds.</Description>
      </Option>
      <Option Short="" Long="verbosity" Value="QUIET|MINIMAL|NORMAL|DETAILED" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Controls informational logging. Errors are always 
logged.</Description>
      </Option>
      <Option Short="" Long="working-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Working directory used for resolving relative 
paths.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="--metrics-dir" />
      <Example commandLine="build/Metrics" />
      <Example commandLine="--opencover" />
      <Example commandLine="coverage.xml" />
      <Example commandLine="--roslyn" />
      <Example commandLine="metrics.xml" />
      <Example commandLine="--sarif" />
      <Example commandLine="analyzers.sarif" />
      <Example commandLine="--output-json" />
      <Example commandLine="build/Metrics/Report/MetricsReport.g.json" />
      <Example commandLine="generate" />
      <Example commandLine="--input-json" />
      <Example commandLine="build/Metrics/Report/MetricsReport.g.json" />
      <Example commandLine="--output-html" />
      <Example commandLine="build/Metrics/Report/MetricsReport.html" />
    </Examples>
  </Command>
  <!--READ-->
  <Command Name="read" IsBranch="false" 
ClrType="MetricsReporter.Cli.Commands.ReadCommand" 
Settings="MetricsReporter.Cli.Settings.ReadSettings">
    <Description>Reads metric violations for a namespace. Returns the most 
severe violation by default; use --all for full listing.</Description>
    <Parameters>
      <Option Short="" Long="aggregate-after-scripts" Value="TRUE|FALSE" 
Required="false" Kind="flag" ClrType="System.Nullable`1[[System.Boolean, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Controls aggregation after scripts. Defaults to true for 
read/test/readsarif; ignored for generate.</Description>
      </Option>
      <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Emit all matching entries instead of only the most severe 
one.</Description>
      </Option>
      <Option Short="" Long="config" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Optional path to .metricsreporter.json. If omitted, the 
file is discovered by walking up from the working directory.</Description>
      </Option>
      <Option Short="" Long="group-by" Value="METRIC|METHOD|TYPE|NAMESPACE" 
Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[MetricsReporter.MetricsReader.Settings.MetricsReader
GroupByOption, MetricsReporter, Version=0.4.5.0, Culture=neutral, 
PublicKeyToken=null]]">
        <Description>Controls grouping of violations (metric, namespace, type, 
method).</Description>
      </Option>
      <Option Short="" Long="include-suppressed" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include metrics that have been suppressed via 
SuppressMessage attributes.</Description>
      </Option>
      <Option Short="" Long="log-truncation-limit" Value="INT" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of stdout/stderr characters logged on script
failures. Defaults to 4000.</Description>
      </Option>
      <Option Short="" Long="metric" Value="NAME" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Metric identifier or alias (Complexity, Coupling, 
Maintainability, etc.).</Description>
      </Option>
      <Option Short="" Long="metric-aliases" Value="JSON" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>JSON object mapping metric identifiers to alias arrays. CLI
overrides env/config.</Description>
      </Option>
      <Option Short="" Long="metric-script" Value="METRIC=PATH" Required="false"
Kind="scalar" ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>PowerShell script executed when the specified metric is 
requested. Repeatable.</Description>
      </Option>
      <Option Short="" Long="namespace" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Namespace prefix to filter symbols (e.g. 
Sample.Loader.Infrastructure).</Description>
      </Option>
      <Option Short="" Long="report" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path to MetricsReport.g.json (can be provided via 
config).</Description>
      </Option>
      <Option Short="" Long="ruleid" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Optional SARIF rule identifier filter (e.g. CA1506, 
IDE0051).</Description>
      </Option>
      <Option Short="" Long="run-scripts" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Controls execution of configured scripts. Defaults to 
true.</Description>
      </Option>
      <Option Short="" Long="script" Value="PATH" Required="false" Kind="scalar"
ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>PowerShell script executed before reading. Repeat for 
multiple scripts.</Description>
      </Option>
      <Option Short="" Long="symbol-kind" Value="ANY|TYPE|MEMBER" 
Required="false" Kind="scalar" 
ClrType="MetricsReporter.MetricsReader.Settings.MetricsReaderSymbolKind">
        <Description>Symbol level to inspect. Defaults to Any.</Description>
      </Option>
      <Option Short="" Long="thresholds-file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional thresholds file (MetricsReporterThresholds.json) 
used to override report metadata.</Description>
      </Option>
      <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Timeout in seconds for external scripts. Defaults to 
configuration or 900 seconds.</Description>
      </Option>
      <Option Short="" Long="verbosity" Value="QUIET|MINIMAL|NORMAL|DETAILED" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Controls informational logging. Errors are always 
logged.</Description>
      </Option>
      <Option Short="" Long="working-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Working directory used for resolving relative 
paths.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="read" />
      <Example commandLine="--report" />
      <Example commandLine="build/Metrics/Report/MetricsReport.g.json" />
      <Example commandLine="--namespace" />
      <Example commandLine="Sample.Loader" />
      <Example commandLine="--metric" />
      <Example commandLine="Complexity" />
    </Examples>
  </Command>
  <!--READSARIF-->
  <Command Name="readsarif" IsBranch="false" 
ClrType="MetricsReporter.Cli.Commands.ReadSarifCommand" 
Settings="MetricsReporter.Cli.Settings.ReadSarifSettings">
    <Description>Aggregates SARIF-based metrics (SarifCaRuleViolations, 
SarifIdeRuleViolations) by rule ID for the specified namespace.</Description>
    <Parameters>
      <Option Short="" Long="aggregate-after-scripts" Value="TRUE|FALSE" 
Required="false" Kind="flag" ClrType="System.Nullable`1[[System.Boolean, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Controls aggregation after scripts. Defaults to true for 
read/test/readsarif; ignored for generate.</Description>
      </Option>
      <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Emit all matching groups instead of only the most severe 
one.</Description>
      </Option>
      <Option Short="" Long="config" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Optional path to .metricsreporter.json. If omitted, the 
file is discovered by walking up from the working directory.</Description>
      </Option>
      <Option Short="" Long="group-by" 
Value="METRIC|METHOD|TYPE|NAMESPACE|RULEID" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[MetricsReporter.MetricsReader.Settings.MetricsReader
GroupByOption, MetricsReporter, Version=0.4.5.0, Culture=neutral, 
PublicKeyToken=null]]">
        <Description>Controls grouping of SARIF violations (metric, namespace, 
type, method, ruleId). Defaults to ruleId.</Description>
      </Option>
      <Option Short="" Long="include-suppressed" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include metrics that have been suppressed via 
SuppressMessage attributes.</Description>
      </Option>
      <Option Short="" Long="log-truncation-limit" Value="INT" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of stdout/stderr characters logged on script
failures. Defaults to 4000.</Description>
      </Option>
      <Option Short="" Long="metric" Value="NAME" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>SARIF metric identifier (SarifCaRuleViolations, 
SarifIdeRuleViolations) or 'Any'. Defaults to Any.</Description>
      </Option>
      <Option Short="" Long="metric-aliases" Value="JSON" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>JSON object mapping metric identifiers to alias arrays. CLI
overrides env/config.</Description>
      </Option>
      <Option Short="" Long="metric-script" Value="METRIC=PATH" Required="false"
Kind="scalar" ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>PowerShell script executed when the specified metric is 
requested. Repeatable.</Description>
      </Option>
      <Option Short="" Long="namespace" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Namespace prefix to filter symbols (e.g. 
Sample.Loader.Infrastructure).</Description>
      </Option>
      <Option Short="" Long="report" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path to MetricsReport.g.json (can be provided via 
config).</Description>
      </Option>
      <Option Short="" Long="ruleid" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Optional SARIF rule identifier filter (e.g. CA1506, 
IDE0051).</Description>
      </Option>
      <Option Short="" Long="run-scripts" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Controls execution of configured scripts. Defaults to 
true.</Description>
      </Option>
      <Option Short="" Long="script" Value="PATH" Required="false" Kind="scalar"
ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>PowerShell script executed before reading. Repeat for 
multiple scripts.</Description>
      </Option>
      <Option Short="" Long="symbol-kind" Value="ANY|TYPE|MEMBER" 
Required="false" Kind="scalar" 
ClrType="MetricsReporter.MetricsReader.Settings.MetricsReaderSymbolKind">
        <Description>Symbol level to inspect. Defaults to Any.</Description>
      </Option>
      <Option Short="" Long="thresholds-file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional thresholds file (MetricsReporterThresholds.json) 
used to override report metadata.</Description>
      </Option>
      <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Timeout in seconds for external scripts. Defaults to 
configuration or 900 seconds.</Description>
      </Option>
      <Option Short="" Long="verbosity" Value="QUIET|MINIMAL|NORMAL|DETAILED" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Controls informational logging. Errors are always 
logged.</Description>
      </Option>
      <Option Short="" Long="working-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Working directory used for resolving relative 
paths.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="readsarif" />
      <Example commandLine="--report" />
      <Example commandLine="build/Metrics/Report/MetricsReport.g.json" />
      <Example commandLine="--namespace" />
      <Example commandLine="Sample.Loader" />
      <Example commandLine="readsarif" />
      <Example commandLine="--report" />
      <Example commandLine="build/Metrics/Report/MetricsReport.g.json" />
      <Example commandLine="--namespace" />
      <Example commandLine="Sample.Loader" />
      <Example commandLine="--metric" />
      <Example commandLine="SarifIdeRuleViolations" />
      <Example commandLine="--all" />
    </Examples>
  </Command>
  <!--TEST-->
  <Command Name="test" IsBranch="false" 
ClrType="MetricsReporter.Cli.Commands.TestCommand" 
Settings="MetricsReporter.Cli.Settings.TestSettings">
    <Description>Checks whether a symbol satisfies the specified metric after 
refactoring.</Description>
    <Parameters>
      <Option Short="" Long="aggregate-after-scripts" Value="TRUE|FALSE" 
Required="false" Kind="flag" ClrType="System.Nullable`1[[System.Boolean, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Controls aggregation after scripts. Defaults to true for 
read/test/readsarif; ignored for generate.</Description>
      </Option>
      <Option Short="" Long="config" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Optional path to .metricsreporter.json. If omitted, the 
file is discovered by walking up from the working directory.</Description>
      </Option>
      <Option Short="" Long="include-suppressed" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include metrics that have been suppressed via 
SuppressMessage attributes.</Description>
      </Option>
      <Option Short="" Long="log-truncation-limit" Value="INT" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
