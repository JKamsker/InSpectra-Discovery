        <Description>Metric identifier or alias to verify (e.g. Complexity, 
Coupling).</Description>
      </Option>
      <Option Short="" Long="metric-aliases" Value="JSON" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>JSON object mapping metric identifiers to alias arrays. CLI
overrides env/config.</Description>
      </Option>
      <Option Short="" Long="metric-script" Value="METRIC=PATH" Required="false"
Kind="scalar" ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>PowerShell script executed when the specified metric is 
requested. Repeatable.</Description>
      </Option>
      <Option Short="" Long="report" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path to MetricsReport.g.json (can be provided via 
config).</Description>
      </Option>
      <Option Short="" Long="run-scripts" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Controls execution of configured scripts. Defaults to 
true.</Description>
      </Option>
      <Option Short="" Long="script" Value="PATH" Required="false" Kind="scalar"
ClrType="System.Collections.Generic.List`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>PowerShell script executed before reading. Repeat for 
multiple scripts.</Description>
      </Option>
      <Option Short="" Long="symbol" Value="FQN" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Fully qualified symbol name (type or member).</Description>
      </Option>
      <Option Short="" Long="thresholds-file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional thresholds file (MetricsReporterThresholds.json) 
used to override report metadata.</Description>
      </Option>
      <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Timeout in seconds for external scripts. Defaults to 
configuration or 900 seconds.</Description>
      </Option>
      <Option Short="" Long="verbosity" Value="QUIET|MINIMAL|NORMAL|DETAILED" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Controls informational logging. Errors are always 
