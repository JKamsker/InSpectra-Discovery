<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--EXPORT-->
  <Command Name="export" IsBranch="false" 
ClrType="ResXporter.Commands.ExportCommand" 
Settings="ResXporter.Commands.ExportCommand+Settings">
    <Parameters>
      <Option Short="" Long="copy-translations" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If enabled, copy missing translations from other keys with 
the same default culture value.</Description>
      </Option>
      <Option Short="" Long="exporter" Value="FORMAT" Required="false" 
Kind="vector" ClrType="ResXporter.Exporter[]">
        <Description>The exporters to be used to process the resx 
files.</Description>
      </Option>
      <Option Short="" Long="file" Value="FILE" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>List of .resx files to export.</Description>
      </Option>
      <Option Short="" Long="only-missing" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Export only keys that have at least one missing 
translation.</Description>
      </Option>
      <Option Short="" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.IO.DirectoryInfo">
        <Description>Path to the directory where the .resx files will be 
exported.</Description>
      </Option>
      <Option Short="" Long="path" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.IO.DirectoryInfo">
        <Description>Path to the directory containing the .resx 
files.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>