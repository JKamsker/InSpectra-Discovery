<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--EXPORT-->
  <Command Name="export" IsBranch="false" 
ClrType="ResXporter.Commands.ExportCommand" 
Settings="ResXporter.Commands.ExportCommand+Settings">
    <Parameters>
      <Option Short="" Long="copy-translations" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If enabled, copy missing translations from other keys with 
the same default culture value.</Description>
      </Option>
      <Option Short="e" Long="exporter" Value="FORMAT" Required="false" 
Kind="vector" ClrType="ResXporter.Providers.Provider[]">
        <Description>The exporters to be used to process the resx 
files.</Description>
      </Option>
      <Option Short="a" Long="exporter-arg" Value="KEY=VALUE" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Additional arguments for the selected exporter 
(FORMAT:key=value).</Description>
      </Option>
      <Option Short="f" Long="file" Value="FILE" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>List of .resx files to export.</Description>
      </Option>
      <Option Short="" Long="only-missing" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Export only keys that have at least one missing 
translation.</Description>
      </Option>
      <Option Short="p" Long="path" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.IO.DirectoryInfo">
        <Description>Path to the directory containing the .resx 
files.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--IMPORT-->
  <Command Name="import" IsBranch="false" 
ClrType="ResXporter.Commands.ImportCommand" 
Settings="ResXporter.Commands.ImportCommand+Settings">
    <Parameters>
      <Option Short="l" Long="loader" Value="LOADER" Required="false" 
Kind="scalar" ClrType="ResXporter.Providers.Provider">
        <Description>The type of the loader to use.</Description>
      </Option>
      <Option Short="a" Long="loader-arg" Value="KEY=VALUE" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Additional arguments for the selected loader 
(key=value).</Description>
      </Option>
      <Option Short="p" Long="path" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.IO.DirectoryInfo">
        <Description>Path to the directory containing the resource 
files.</Description>
      </Option>
      <Option Short="" Long="update-existing" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Update existing translations.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>