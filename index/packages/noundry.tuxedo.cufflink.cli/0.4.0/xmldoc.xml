<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--WIZARD-->
  <Command Name="wizard" IsBranch="false" 
ClrType="Noundry.Tuxedo.Cufflink.CLI.Commands.WizardCommand" 
Settings="Noundry.Tuxedo.Cufflink.CLI.Commands.WizardCommand+Settings">
    <Description>Interactive wizard for generating fake data (recommended for 
beginners)</Description>
    <Parameters>
      <Option Short="d" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Directory to scan for models (defaults to current 
directory)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="wizard" />
      <Example commandLine="wizard" />
      <Example commandLine="--directory" />
      <Example commandLine="./bin/Debug/net8.0" />
    </Examples>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Noundry.Tuxedo.Cufflink.CLI.Commands.GenerateCommand" 
Settings="Noundry.Tuxedo.Cufflink.CLI.Commands.GenerateCommand+Settings">
    <Description>Generate fake data for Tuxedo models (command 
mode)</Description>
    <Parameters>
      <Option Short="b" Long="batch-size" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Batch size for bulk inserts</Description>
      </Option>
      <Option Short="c" Long="connection-string" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Database connection string (or found from 
appsettings.json)</Description>
      </Option>
      <Option Short="d" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Directory to scan for models (defaults to current 
directory)</Description>
      </Option>
      <Option Short="" Long="json-schema-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Directory containing JSON schema files for JSON/JSONB 
columns</Description>
      </Option>
      <Option Short="p" Long="provider" Value="NULL" Required="false" 
Kind="scalar" ClrType="Noundry.Tuxedo.Cufflink.Core.DatabaseProvider">
        <Description>Database provider (SqlServer, PostgreSQL, MySQL, 
SQLite)</Description>
      </Option>
      <Option Short="r" Long="records" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of records to generate per table</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="--records" />
      <Example commandLine="1000" />
      <Example commandLine="generate" />
      <Example commandLine="--records" />
      <Example commandLine="500" />
      <Example commandLine="--provider" />
      <Example commandLine="SqlServer" />
      <Example commandLine="generate" />
      <Example commandLine="--records" />
      <Example commandLine="100" />
      <Example commandLine="--connection-string" />
      <Example commandLine="Data Source=app.db" />
      <Example commandLine="generate" />
      <Example commandLine="--records" />
      <Example commandLine="1000" />
      <Example commandLine="--json-schema-dir" />
      <Example commandLine="./schemas" />
    </Examples>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" 
ClrType="Noundry.Tuxedo.Cufflink.CLI.Commands.InfoCommand" 
Settings="Noundry.Tuxedo.Cufflink.CLI.Commands.InfoCommand+Settings">
    <Description>Display information about discovered models</Description>
    <Parameters>
      <Option Short="d" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Directory to scan for models (defaults to current 
directory)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="info" />
      <Example commandLine="info" />
      <Example commandLine="--directory" />
      <Example commandLine="./bin/Debug/net8.0" />
    </Examples>
  </Command>
</Model>