<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="LibYear.Command" Settings="LibYear.Settings">
    <Parameters>
      <Argument Name="target" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>the project file(s) or directory paths to 
analyze</Description>
      </Argument>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.Double, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>fails if total libyears behind is greater than this 
value</Description>
      </Option>
      <Option Short="a" Long="limit-any" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Double, System.Private.CoreLib,
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>fails if any dependency is more libyears behind than this 
value</Description>
      </Option>
      <Option Short="p" Long="limit-project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Double, System.Private.CoreLib,
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>fails if any project's total libyears behind is greater 
than this value</Description>
      </Option>
      <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>only output outdated packages</Description>
      </Option>
      <Option Short="u" Long="update" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>update any outdated packages</Description>
      </Option>
    </Parameters>
  </Command>
</Model>