<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DcmOrganize.OrganizeCommand" 
Settings="DcmOrganize.OrganizeCommand+Settings">
    <Parameters>
      <Option Short="a" Long="action" Value="NULL" Required="false" 
Kind="scalar" ClrType="DcmOrganize.Action">
        <Description>Action to execute for each file</Description>
      </Option>
      <Option Short="d" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>--directory</Description>
      </Option>
      <Option Short="" Long="errorMode" Value="NULL" Required="false" 
Kind="scalar" ClrType="DcmOrganize.ErrorMode">
        <Description>Specifies what to do when an error occurs</Description>
      </Option>
      <Option Short="f" Long="files" Value="NULL" Required="false" Kind="vector"
ClrType="System.String[]">
        <Description>Organize these DICOM files. When missing, this option will 
be read from the piped input.</Description>
      </Option>
      <Option Short="" Long="parallelism" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Parse files in parallel</Description>
      </Option>
      <Option Short="p" Long="pattern" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Write DICOM files using this pattern. DICOM tags are 
supported. Fallback for missing DICOM tags are supported. Nested directories 
will be created on demand.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>