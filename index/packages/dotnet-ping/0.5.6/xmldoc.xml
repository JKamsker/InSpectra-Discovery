<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DotnetPing.AppCommand" Settings="DotnetPing.AppSettings">
    <Parameters>
      <Argument Name="urls" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>The URLs to ping. If not specified, the URLs are read from 
the JSON config file.</Description>
      </Argument>
      <Option Short="b" Long="base-url" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sets the base-URL to use for requests.</Description>
      </Option>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path to the JSON config file.</Description>
      </Option>
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use debug console messaging.</Description>
      </Option>
      <Option Short="e" Long="expect" Value="NULL" Required="false" 
Kind="vector" ClrType="System.UInt32[]">
        <Description>Sets the expected status code of requests. Default: 
200.</Description>
      </Option>
      <Option Short="m" Long="minimal" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Use minimal console messaging.</Description>
      </Option>
      <Option Short="X" Long="request" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sets the request method. Default: GET.</Description>
      </Option>
      <Option Short="s" Long="sleep" Value="NULL" Required="false" Kind="vector"
ClrType="System.UInt32[]">
        <Description>Sets the sleep wait time between requests in milliseconds. 
Default: 500ms.</Description>
      </Option>
      <Option Short="t" Long="timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.UInt32">
        <Description>Sets the timeout for requests in milliseconds. Default: 
5000ms. If two values are provided, a random number between the two numbers will
be generated for each request.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="https://example.com" />
      <Example commandLine="https://example.com" />
      <Example commandLine="other.com" />
      <Example commandLine="-s" />
      <Example commandLine="1000" />
      <Example commandLine="https://example.com" />
      <Example commandLine="other.com" />
      <Example commandLine="-s" />
      <Example commandLine="1000" />
      <Example commandLine="-s" />
      <Example commandLine="2000" />
      <Example commandLine="-t" />
      <Example commandLine="5000" />
      <Example commandLine="/about" />
      <Example commandLine="/contact" />
      <Example commandLine="-b" />
      <Example commandLine="https://example.com" />
      <Example commandLine="-c" />
      <Example commandLine="ping.json" />
    </Examples>
  </Command>
</Model>