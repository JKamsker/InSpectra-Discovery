<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--REGISTER-->
  <Command Name="register" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.RegisterCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.RegisterCommand+Settings">
    <Description>Discover projects and register them as shared 
resources</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Root path to search for projects</Description>
      </Argument>
      <Option Short="" Long="defaults" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Skip interactive prompts and auto-generate resource 
configuration</Description>
      </Option>
      <Option Short="" Long="depth" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Maximum directory depth to search</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.InitCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.InitCommand+Settings">
    <Description>Configure an AppHost to consume shared resources</Description>
    <Parameters>
      <Argument Name="apphost-path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the AppHost .csproj file</Description>
      </Argument>
      <Option Short="" Long="search" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Run project discovery before showing registered 
resources</Description>
      </Option>
    </Parameters>
  </Command>
  <!--IMPORT-->
  <Command Name="import" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.ImportCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.ImportCommand+Settings">
    <Description>Import shared resources from an AppHost .csproj into global 
config</Description>
    <Parameters>
      <Argument Name="csprojPath" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the AppHost .csproj file to import 
SharedResourceReference elements from</Description>
      </Argument>
      <Option Short="" Long="merge" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Merge imported values into existing resources instead of 
skipping them</Description>
      </Option>
      <Option Short="" Long="no-auto-clone" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Disable automatic cloning of GitHub 
repositories</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.ListCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.ListCommand+Settings">
    <Description>List all registered resources</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.InfoCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.InfoCommand+Settings">
    <Description>Show detailed information about a registered 
resource</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Resource ID</Description>
      </Argument>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.RemoveCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.RemoveCommand+Settings">
    <Description>Remove a registered resource</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The resource ID to remove</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.UpdateCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.UpdateCommand+Settings">
    <Description>Update a registered resource</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The resource ID to update</Description>
      </Argument>
      <Option Short="" Long="build-image" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Automatically build image before AppHost 
start</Description>
      </Option>
      <Option Short="" Long="build-image-command" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Command to build the container image</Description>
      </Option>
      <Option Short="" Long="build-image-workdir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Working directory for the build image command</Description>
      </Option>
      <Option Short="" Long="container-image" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Container image name</Description>
      </Option>
      <Option Short="" Long="container-tag" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Container image tag</Description>
      </Option>
      <Option Short="" Long="mode" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Resource mode (Project or Container)</Description>
      </Option>
      <Option Short="" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Display name for the resource</Description>
      </Option>
      <Option Short="" Long="project-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the project file</Description>
      </Option>
    </Parameters>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.BuildCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.BuildCommand+Settings">
    <Description>Build the container image for a registered 
resource</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The resource ID to build</Description>
      </Argument>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force rebuild even if the image already 
exists</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GET-MODE-->
  <Command Name="get-mode" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.GetModeCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.GetModeCommand+Settings">
    <Description>Get the mode of a registered resource 
(machine-readable)</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--GET-PROJECT-PATH-->
  <Command Name="get-project-path" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.GetProjectPathCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.GetProjectPathCommand+Settings">
    <Description>Get the project path of a registered resource 
(machine-readable)</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--GET-CONFIG-->
  <Command Name="get-config" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.GetConfigCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.GetConfigCommand+Settings">
    <Description>Get a configuration property of a registered resource 
(machine-readable)</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Argument Name="key" Position="1" Required="true" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--MODES-->
  <Command Name="modes" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.ModesCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>View and toggle the mode (Project/Container) of registered 
resources</Description>
  </Command>
  <!--CLEAR-->
  <Command Name="clear" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.ClearCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.ClearCommand+Settings">
    <Description>Delete all resources from the global 
configuration</Description>
  </Command>
  <!--OVERRIDE-->
  <Command Name="override" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage global overrides</Description>
    <!--SET-->
    <Command Name="set" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideSetCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideSetCommand+Settings">
      <Description>Set an override (Mode or BuildImage)</Description>
      <Parameters>
        <Argument Name="key" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Override key (Mode, BuildImage, or 
AutoClone)</Description>
        </Argument>
        <Argument Name="value" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Override value</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--SET-REGISTRY-->
    <Command Name="set-registry" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideSetRegistryCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideSetRegistryCommand+Setting
s">
      <Description>Add a registry rewrite rule</Description>
      <Parameters>
        <Argument Name="from" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Source registry to rewrite</Description>
        </Argument>
        <Argument Name="to" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Target registry</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--REMOVE-->
    <Command Name="remove" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideRemoveCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideRemoveCommand+Settings">
      <Description>Remove an override</Description>
      <Parameters>
        <Argument Name="key" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Override key to remove (Mode or BuildImage)</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--REMOVE-REGISTRY-->
    <Command Name="remove-registry" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideRemoveRegistryCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideRemoveRegistryCommand+Sett
ings">
      <Description>Remove a registry rewrite rule</Description>
      <Parameters>
        <Argument Name="from" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Source registry to remove</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--SET-IMAGE-->
    <Command Name="set-image" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideSetImageCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideSetImageCommand+Settings">
      <Description>Add an image rewrite rule</Description>
      <Parameters>
        <Argument Name="from" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Source image (e.g. rabbitmq:4-management)</Description>
        </Argument>
        <Argument Name="to" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Target image (e.g. rabbitmq:4)</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--REMOVE-IMAGE-->
    <Command Name="remove-image" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideRemoveImageCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideRemoveImageCommand+Setting
s">
      <Description>Remove an image rewrite rule</Description>
      <Parameters>
        <Argument Name="from" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Source image to remove</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideListCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideListCommand+Settings">
      <Description>List current overrides</Description>
    </Command>
    <!--CLEAR-->
    <Command Name="clear" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideClearCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.OverrideClearCommand+Settings">
      <Description>Remove all overrides</Description>
    </Command>
  </Command>
</Model>