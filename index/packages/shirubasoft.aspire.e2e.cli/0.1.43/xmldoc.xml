<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SEARCH-->
  <Command Name="search" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.SearchCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.SearchCommand+Settings">
    <Description>Search for projects referencing Shirubasoft.Aspire.E2E and 
register them</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Root path to search for projects</Description>
      </Argument>
      <Option Short="" Long="depth" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Maximum directory depth to search</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.ListCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>List all registered resources</Description>
  </Command>
  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.RemoveCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.RemoveCommand+Settings">
    <Description>Remove a registered resource</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The resource ID to remove</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.UpdateCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.UpdateCommand+Settings">
    <Description>Update a registered resource</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The resource ID to update</Description>
      </Argument>
      <Option Short="" Long="build-image" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Whether to build the container image</Description>
      </Option>
      <Option Short="" Long="build-image-command" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Command to build the container image</Description>
      </Option>
      <Option Short="" Long="container-image" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Container image name</Description>
      </Option>
      <Option Short="" Long="container-tag" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Container image tag</Description>
      </Option>
      <Option Short="" Long="mode" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Resource mode (Project or Container)</Description>
      </Option>
      <Option Short="" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Display name for the resource</Description>
      </Option>
      <Option Short="" Long="project-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the project file</Description>
      </Option>
    </Parameters>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.BuildCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.BuildCommand+Settings">
    <Description>Build the container image for a registered 
resource</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The resource ID to build</Description>
      </Argument>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force rebuild even if the image already 
exists</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GET-MODE-->
  <Command Name="get-mode" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.GetModeCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.GetModeCommand+Settings">
    <Description>Get the mode of a registered resource 
(machine-readable)</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--GET-PROJECT-PATH-->
  <Command Name="get-project-path" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.GetProjectPathCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.GetProjectPathCommand+Settings">
    <Description>Get the project path of a registered resource 
(machine-readable)</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--GET-CONFIG-->
  <Command Name="get-config" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.GetConfigCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.GetConfigCommand+Settings">
    <Description>Get a configuration property of a registered resource 
(machine-readable)</Description>
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Argument Name="key" Position="1" Required="true" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--IMPORT-->
  <Command Name="import" IsBranch="false" 
ClrType="Shirubasoft.Aspire.E2E.Cli.Commands.ImportCommand" 
Settings="Shirubasoft.Aspire.E2E.Cli.Commands.ImportCommand+Settings">
    <Description>Import resources from an e2e-resources.json file into the 
global configuration</Description>
    <Parameters>
      <Argument Name="filePath" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the e2e-resources.json file to import</Description>
      </Argument>
    </Parameters>
  </Command>
</Model>