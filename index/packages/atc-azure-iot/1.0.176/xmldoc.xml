      <Command Name="individual" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
        <Description>Operations related to individual enrollments on Device 
Provisioning Service.</Description>
        <!--ALL-->
        <Command Name="all" IsBranch="false" 
ClrType="Atc.Azure.IoT.CLI.Commands.DPS.DpsEnrollmentIndividualGetAllCommand" 
Settings="Atc.Azure.IoT.CLI.Commands.Settings.ConnectionBaseCommandSettings">
          <Description>Retrieves all individual enrollments.</Description>
