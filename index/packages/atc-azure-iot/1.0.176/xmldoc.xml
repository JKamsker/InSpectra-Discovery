            <Description>IotHub Device Id</Description>
          </Option>
          <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Use verbose for more debug/trace 
information</Description>
          </Option>
        </Parameters>
        <Examples>
          <Example commandLine="iothub device get -c &lt;connection-string&gt; 
-d &lt;device-id&gt;" />
        </Examples>
      </Command>
