Required="false" Kind="scalar" ClrType="System.String">
              <Description>ConnectionString</Description>
            </Option>
            <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
              <Description>Use verbose for more debug/trace 
information</Description>
            </Option>
          </Parameters>
          <Examples>
            <Example commandLine="dps enrollment individual all -c 
&lt;connection-string&gt;" />
          </Examples>
        </Command>
        <!--CREATE-->
        <Command Name="create" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
          <Description>Operations related to creating individual 
enrollments.</Description>
          <!--TPM-->
          <Command Name="tpm" IsBranch="false" 
ClrType="Atc.Azure.IoT.CLI.Commands.DPS.DpsEnrollmentIndividualCreateTpmCommand"
Settings="Atc.Azure.IoT.CLI.Commands.Settings.DpsEnrollmentIndividualCreateTpmCo
mmandSettings">
            <Description>Reads a single node variable.</Description>
            <Parameters>
              <Option Short="c" Long="connection-string" 
Value="CONNECTION-STRING" Required="false" Kind="scalar" 
ClrType="System.String">
                <Description>ConnectionString</Description>
              </Option>
              <Option Short="" Long="desired-properties" 
Value="DESIRED-PROPERTIES" Required="false" Kind="flagvalue" 
ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, System.Private.CoreLib,
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
                <Description>Desired Properties</Description>
              </Option>
              <Option Short="d" Long="device-id" Value="DEVICE-ID" 
Required="false" Kind="scalar" ClrType="System.String">
                <Description>Device Id</Description>
              </Option>
              <Option Short="" Long="endorsement-key" Value="ENDORSEMENT-KEY" 
Required="false" Kind="scalar" ClrType="System.String">
                <Description>Endorsement Key</Description>
              </Option>
              <Option Short="r" Long="registration-id" Value="REGISTRATION-ID" 
Required="false" Kind="scalar" ClrType="System.String">
                <Description>Registration Id</Description>
              </Option>
              <Option Short="" Long="tags" Value="TAGS" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=9.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
                <Description>Tags</Description>
              </Option>
              <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
                <Description>Use verbose for more debug/trace 
information</Description>
              </Option>
            </Parameters>
            <Examples>
              <Example commandLine="dps enrollment individual create tpm -c 
&lt;connection-string&gt; -r &lt;registration-id&gt; --endorsement-key 
&lt;endorsement-key&gt; --device-id &lt;device-id&gt; --tags 
tag1=value1,tag2=value2" />
