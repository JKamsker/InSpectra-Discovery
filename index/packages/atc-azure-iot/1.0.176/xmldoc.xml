ClrType="Atc.Azure.IoT.CLI.Commands.IotHub.IotHubDeviceCreateCommand" 
Settings="Atc.Azure.IoT.CLI.Commands.Settings.IotHubDeviceCreateCommandSettings"
>
        <Description>Create a device in the device registry in the IoT 
Hub.</Description>
        <Parameters>
          <Option Short="c" Long="connection-string" Value="CONNECTION-STRING" 
Required="false" Kind="scalar" ClrType="System.String">
            <Description>ConnectionString</Description>
          </Option>
          <Option Short="d" Long="device-id" Value="DEVICE-ID" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>IotHub Device Id</Description>
          </Option>
          <Option Short="" Long="edge-enabled" Value="EDGE-ENABLED" 
Required="false" Kind="flag" ClrType="System.Boolean">
            <Description>Indicates if the device should be edge 
