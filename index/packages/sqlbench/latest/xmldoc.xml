<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--BENCH-->
  <Command Name="bench" IsBranch="false" 
ClrType="SqlBench.Commands.BenchCommand" 
Settings="SqlBench.Commands.BenchCommand+Settings">
    <Parameters>
      <Argument Name="benchmarksTomlPath" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>Path to TOML file containing benchmarks to 
run.</Description>
      </Argument>
      <Option Short="n" Long="iterations" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of iterations to run each benchmark.</Description>
      </Option>
      <Option Short="" Long="re-run-all" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Re-run all benchmarks. Skips reusing old 
results.</Description>
      </Option>
      <Option Short="" Long="sort-results" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Sort results by time</Description>
      </Option>
      <Option Short="t" Long="sql-timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>SQL timeout for each benchmark run</Description>
      </Option>
      <Option Short="" Long="verify-result-equality" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Verify that the cases return identical output before 
testing. This will cause an additional execution.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="SqlBench.Commands.InitCommand" 
Settings="SqlBench.Commands.InitCommand+Settings" />
</Model>