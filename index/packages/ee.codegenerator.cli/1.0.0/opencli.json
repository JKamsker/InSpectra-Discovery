{
  "opencli": "0.1-draft",
  "info": {
    "title": "EE Code Generator CLI",
    "version": "1.0.0",
    "description": "A powerful code generation command line tool"
  },
  "x-inspectra": {
    "artifactSource": "startup-hook",
    "generator": "InSpectra.Discovery",
    "hookCapture": {
      "cliFramework": "System.CommandLine",
      "frameworkVersion": "2.0.0.0",
      "systemCommandLineVersion": "2.0.0.0",
      "patchTarget": "Parse-postfix ()"
    },
    "cliFramework": "System.CommandLine",
    "cliParsedTitle": "ee-code-generator-cli"
  },
  "options": [
    {
      "name": "--help",
      "recursive": true,
      "hidden": false,
      "description": "Show help and usage information",
      "aliases": [
        "-h",
        "/h",
        "-?",
        "/?"
      ]
    },
    {
      "name": "--version",
      "recursive": false,
      "hidden": false,
      "description": "Show version information"
    }
  ],
  "commands": [
    {
      "name": "generate",
      "description": "生成代码",
      "commands": [
        {
          "name": "cli",
          "description": "为静态的公共方法生成 C# 基于 System.CommandLine 的命令行代码，你只需要写静态类和方法以及注释就可以自动生成命令行工具",
          "options": [
            {
              "name": "--dll_type",
              "recursive": false,
              "hidden": false,
              "description": "dll 的路径以及静态类名，例如 mycli.dll:classname。若不指定静态类名，例如 mycli.dll 则为所有公开的静态类生成命令行",
              "arguments": [
                {
                  "name": "DLL_TYPE",
                  "required": true,
                  "arity": {
                    "minimum": 1,
                    "maximum": 1
                  },
                  "type": "String"
                }
              ]
            },
            {
              "name": "--output",
              "recursive": false,
              "hidden": false,
              "description": "输出的文件名，不带后缀会自动加上后缀",
              "arguments": [
                {
                  "name": "OUTPUT",
                  "required": true,
                  "arity": {
                    "minimum": 1,
                    "maximum": 1
                  },
                  "type": "String"
                }
              ]
            },
            {
              "name": "--sub",
              "recursive": false,
              "hidden": false,
              "description": "命令行模式：0(默认). 只有 1 个类型的命令则直接对方法生成命令，多个类型的命令用小写类型名包裹一层命令，方法生成子命令 / 1. 去掉类型方法直接就是命令(注意多个类型的方法不能重名) / 2. 类型名都生成命令，方法作为子命令",
              "arguments": [
                {
                  "name": "SUB",
                  "required": true,
                  "arity": {
                    "minimum": 1,
                    "maximum": 1
                  },
                  "type": "Int32"
                }
              ]
            }
          ]
        },
        {
          "name": "schema",
          "description": "为一个类生成 Json Schema，可以在 Json 配置文件中",
          "options": [
            {
              "name": "--dll_type",
              "recursive": false,
              "hidden": false,
              "description": "dll 的路径以及类名，例如 mycli:dll_classname",
              "arguments": [
                {
                  "name": "DLL_TYPE",
                  "required": true,
                  "arity": {
                    "minimum": 1,
                    "maximum": 1
                  },
                  "type": "String"
                }
              ]
            },
            {
              "name": "--output",
              "recursive": false,
              "hidden": false,
              "description": "输出的文件名，不带后缀会自动加上后缀",
              "arguments": [
                {
                  "name": "OUTPUT",
                  "required": true,
                  "arity": {
                    "minimum": 1,
                    "maximum": 1
                  },
                  "type": "String"
                }
              ]
            },
            {
              "name": "--root",
              "recursive": false,
              "hidden": false,
              "description": "将类型作为一个字段名进行配置，不填则将类型作为根类型直接配置类型的字段",
              "arguments": [
                {
                  "name": "ROOT",
                  "required": true,
                  "arity": {
                    "minimum": 1,
                    "maximum": 1
                  },
                  "type": "String"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "template",
      "description": "创建项目模板",
      "commands": [
        {
          "name": "init",
          "description": "创建一个模板项目",
          "options": [
            {
              "name": "--template",
              "recursive": false,
              "hidden": false,
              "description": "cmd: 命令行工具 / asp: 服务端",
              "arguments": [
                {
                  "name": "TEMPLATE",
                  "required": true,
                  "arity": {
                    "minimum": 1,
                    "maximum": 1
                  },
                  "type": "String"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
