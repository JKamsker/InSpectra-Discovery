<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="JiraGit.RunCommand" Settings="JiraGit.RunCommand+Settings">
    <Parameters>
      <Option Short="l" Long="list" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>List all issues</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="false" ClrType="JiraGit.ConfigCommand" 
Settings="JiraGit.ConfigCommand+Settings">
    <Parameters>
      <Option Short="l" Long="list" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>List all configurations</Description>
      </Option>
      <Option Short="p" Long="page-size" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Jira Issues Display Page Size</Description>
      </Option>
      <Option Short="s" Long="sql" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Jira Issues Query SQL</Description>
      </Option>
      <Option Short="u" Long="url" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Jira URL</Description>
      </Option>
    </Parameters>
  </Command>
</Model>