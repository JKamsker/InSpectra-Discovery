<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="JJConsulting.Deploy.Console.Commands.InteractiveCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--INSTALL-->
  <Command Name="install" IsBranch="false" 
ClrType="JJConsulting.Deploy.Console.Commands.ProductInstallCommand" 
Settings="JJConsulting.Deploy.Console.Models.ProductInstallSettings">
    <Description>Executa o deploy de um produto.</Description>
    <Parameters>
      <Argument Name="product" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Alias ou chave do produto.</Description>
      </Argument>
      <Argument Name="target-directory" Position="1" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Diretório de destino para deploy de artefato ou serviço 
Windows.</Description>
      </Argument>
      <Option Short="b" Long="branch" Value="BRANCH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Branch do Git usada para localizar os 
artefatos.</Description>
      </Option>
      <Option Short="s" Long="service" Value="SERVICE_NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Nome do serviço Windows.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--RESTART-->
  <Command Name="restart" IsBranch="false" 
ClrType="JJConsulting.Deploy.Console.Commands.ProductRestartCommand" 
Settings="JJConsulting.Deploy.Console.Commands.ProductServiceCommandSettings">
    <Description>Reinicia o serviço Windows de um produto.</Description>
    <Parameters>
      <Argument Name="product" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Alias ou chave do produto.</Description>
      </Argument>
      <Option Short="s" Long="service-name" Value="SERVICE_NAME" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Nome do serviço Windows.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UNINSTALL-->
  <Command Name="uninstall" IsBranch="false" 
ClrType="JJConsulting.Deploy.Console.Commands.ProductUninstallCommand" 
Settings="JJConsulting.Deploy.Console.Commands.ProductServiceCommandSettings">
    <Description>Desinstala o serviço Windows de um produto.</Description>
    <Parameters>
      <Argument Name="product" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Alias ou chave do produto.</Description>
      </Argument>
      <Option Short="s" Long="service-name" Value="SERVICE_NAME" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Nome do serviço Windows.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="JJConsulting.Deploy.Console.Commands.ProductListCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Lista todos os produtos cadastrados.</Description>
  </Command>
  <!--TOKEN-->
  <Command Name="token" IsBranch="false" 
ClrType="JJConsulting.Deploy.Console.Commands.TokenCommand" 
Settings="JJConsulting.Deploy.Console.Commands.TokenCommand+Settings">
    <Description>Registra o token da API do GitLab usado pelo 
JJDeploy.</Description>
    <Parameters>
      <Argument Name="token" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Token da API do GitLab.</Description>
      </Argument>
    </Parameters>
  </Command>
</Model>