<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Forge.Cli.Commands.DefaultCommand" 
Settings="Forge.Cli.Commands.DefaultCommand+Settings" />
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="Forge.Cli.Commands.AnalyzeCommand" 
Settings="Forge.Cli.Commands.AnalyzeSettings">
    <Description>Analyze project and generate Stack Profile + conventions 
file</Description>
    <Parameters>
      <Option Short="" Long="all-engines" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Generate conventions files for all supported 
engines</Description>
      </Option>
      <Option Short="" Long="conventions-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Generate only conventions file(s), skip 
profile</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show what would be generated without writing 
files</Description>
      </Option>
      <Option Short="e" Long="engine" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target AI engine for conventions file (claude, codex, 
gemini, cursor)</Description>
      </Option>
      <Option Short="o" Long="output-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for generated files (default: 
.forge)</Description>
      </Option>
      <Option Short="" Long="profile-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Generate only the Stack Profile, skip conventions 
file</Description>
      </Option>
      <Option Short="" Long="update" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Re-analyze incrementally, only updating sections that 
changed while preserving manual edits</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show detailed detection reasoning</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="Forge.Cli.Commands.InitCommand"
Settings="Forge.Cli.Commands.InitSettings">
    <Description>Initialize Forge in the current project</Description>
    <Parameters>
      <Option Short="p" Long="profile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Use a built-in profile name or path to a custom profile 
file</Description>
      </Option>
      <Option Short="" Long="skip-analyze" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip auto-analysis and use built-in profile selection 
instead</Description>
      </Option>
    </Parameters>
  </Command>
  <!--RUN-->
  <Command Name="run" IsBranch="false" ClrType="Forge.Cli.Commands.RunCommand" 
Settings="Forge.Cli.Commands.RunSettings">
    <Description>Run a sprint pipeline</Description>
    <Parameters>
      <Option Short="" Long="budget" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.Decimal, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum USD budget for AI calls (e.g., --budget 
5.00)</Description>
      </Option>
      <Option Short="" Long="continue" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Resume from saved state</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Plan phase only, don't implement</Description>
      </Option>
      <Option Short="" Long="fresh-memory" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Start with empty memory (profile/state still 
loaded)</Description>
      </Option>
      <Option Short="" Long="max-iterations" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Cap iterations (default: 20)</Description>
      </Option>
      <Option Short="" Long="no-commit" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip git commits (changes are staged but not 
committed)</Description>
      </Option>
      <Option Short="" Long="no-parallel" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Disable parallel execution (force sequential)</Description>
      </Option>
      <Option Short="" Long="parallel" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable parallel execution of independent 
deliverables</Description>
      </Option>
      <Option Short="" Long="parallel-max" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum parallel tracks (default: from profile, typically 
3)</Description>
      </Option>
      <Option Short="" Long="review-after" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Pause every N iterations for review (default: 0 = 
never)</Description>
      </Option>
      <Option Short="s" Long="spec" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Sprint spec markdown file (required on first 
run)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" 
ClrType="Forge.Cli.Commands.StatusCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Show current sprint status</Description>
  </Command>
  <!--REPORT-->
  <Command Name="report" IsBranch="false" 
ClrType="Forge.Cli.Commands.ReportCommand" 
Settings="Forge.Cli.Commands.ReportSettings">
    <Description>Generate a sprint report</Description>
    <Parameters>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format: md or json (default: md)</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path (default: 
./reports/sprint-N.md)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--TEST-->
  <Command Name="test" IsBranch="false" ClrType="Forge.Cli.Commands.TestCommand"
Settings="Forge.Cli.Commands.TestSettings">
    <Description>Run changeset testing pipeline (selective tests, edge cases, 
live testing)</Description>
    <Parameters>
      <Option Short="" Long="changeset" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Run changeset testing against current uncommitted 
changes</Description>
      </Option>
      <Option Short="" Long="concurrency" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Specifically run concurrency-focused tests</Description>
      </Option>
      <Option Short="" Long="diff" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Diff range to test (e.g., main..HEAD, 
main..feature/branch)</Description>
      </Option>
      <Option Short="" Long="edge-cases-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Only generate and run edge cases, skip selective 
tests</Description>
      </Option>
      <Option Short="" Long="full" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Run full test suite after affected tests pass</Description>
      </Option>
      <Option Short="" Long="max-cases" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Override max edge cases per change (default: 
15)</Description>
      </Option>
      <Option Short="" Long="no-api" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip live API testing</Description>
      </Option>
      <Option Short="" Long="no-ui" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip live UI testing</Description>
      </Option>
      <Option Short="" Long="report-format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Report output format: md or json (default: 
md)</Description>
      </Option>
      <Option Short="" Long="save" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Save recommended generated tests to project</Description>
      </Option>
      <Option Short="" Long="selective-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Only run affected existing tests, skip edge case 
generation</Description>
      </Option>
    </Parameters>
  </Command>
  <!--MCP-->
  <Command Name="mcp" IsBranch="true" 
Settings="Forge.Cli.Commands.McpBranchSettings">
    <Description>MCP server mode for AI agent integration</Description>
    <!--START-->
    <Command Name="start" IsBranch="false" 
ClrType="Forge.Cli.Commands.McpStartCommand" 
Settings="Forge.Cli.Commands.McpStartSettings">
      <Description>Start MCP server on stdio</Description>
      <Parameters>
        <Option Short="" Long="read-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Expose only inspection and memory tools, not execution 
tools</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--PROFILE-->
  <Command Name="profile" IsBranch="true" 
Settings="Forge.Cli.Commands.ProfileBranchSettings">
    <Description>Manage stack profiles</Description>
    <!--IMPORT-->
    <Command Name="import" IsBranch="false" 
ClrType="Forge.Cli.Commands.ProfileImportCommand" 
Settings="Forge.Cli.Commands.ProfileImportSettings">
      <Description>Import a profile from a local path or GitHub 
repository</Description>
      <Parameters>
        <Argument Name="source" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Local path, GitHub user/repo, or full GitHub 
URL</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Forge.Cli.Commands.ProfileListCommand" 
Settings="Forge.Cli.Commands.ProfileBranchSettings">
      <Description>List available built-in profiles</Description>
    </Command>
    <!--INFO-->
    <Command Name="info" IsBranch="false" 
ClrType="Forge.Cli.Commands.ProfileInfoCommand" 
Settings="Forge.Cli.Commands.ProfileInfoSettings">
      <Description>Show detailed information about a profile</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Profile name (built-in) or path to a profile YAML 
file</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--VALIDATE-->
    <Command Name="validate" IsBranch="false" 
ClrType="Forge.Cli.Commands.ProfileValidateCommand" 
Settings="Forge.Cli.Commands.ProfileValidateSettings">
      <Description>Validate a profile YAML file</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the profile YAML file to validate</Description>
        </Argument>
      </Parameters>
    </Command>
  </Command>
  <!--MEMORY-->
  <Command Name="memory" IsBranch="true" 
Settings="Forge.Cli.Commands.MemoryBranchSettings">
    <Description>Manage sprint memory</Description>
    <!--__DEFAULT_COMMAND-->
    <Command Name="__default_command" IsBranch="false" 
ClrType="Forge.Cli.Commands.MemoryShowCommand" 
Settings="Forge.Cli.Commands.MemoryBranchSettings" />
    <!--SHOW-->
    <Command Name="show" IsBranch="false" 
ClrType="Forge.Cli.Commands.MemoryShowCommand" 
Settings="Forge.Cli.Commands.MemoryBranchSettings">
      <Description>Display current memory contents</Description>
    </Command>
    <!--CLEAR-->
    <Command Name="clear" IsBranch="false" 
ClrType="Forge.Cli.Commands.MemoryClearCommand" 
Settings="Forge.Cli.Commands.MemoryClearSettings">
      <Description>Clear memory (all or by section)</Description>
      <Parameters>
        <Option Short="s" Long="section" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Clear only a specific section: patterns, failures, 
hotspots, or notes</Description>
        </Option>
      </Parameters>
    </Command>
    <!--EXPORT-->
    <Command Name="export" IsBranch="false" 
ClrType="Forge.Cli.Commands.MemoryExportCommand" 
Settings="Forge.Cli.Commands.MemoryExportSettings">
      <Description>Export memory to a JSON file</Description>
      <Parameters>
        <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output file path (default: 
memory-backup.json)</Description>
        </Option>
      </Parameters>
    </Command>
    <!--IMPORT-->
    <Command Name="import" IsBranch="false" 
ClrType="Forge.Cli.Commands.MemoryImportCommand" 
Settings="Forge.Cli.Commands.MemoryImportSettings">
      <Description>Import memory from another project</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the memory JSON file to import</Description>
        </Argument>
      </Parameters>
    </Command>
  </Command>
</Model>