{
  "opencli": "0.1-draft",
  "info": {
    "title": "swagger-diff",
    "version": "1.0"
  },
  "commands": [
    {
      "name": "list",
      "options": [
        {
          "name": "--dir",
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Directory to scan for snapshot files.",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "List available OpenAPI snapshots in a directory.",
      "hidden": false,
      "examples": [
        "list",
        "list --dir Docs/Versions"
      ]
    },
    {
      "name": "snapshot",
      "options": [
        {
          "name": "--assembly",
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Direct path to a built assembly DLL. Overrides\n--project (skips build).",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--configuration",
          "aliases": [
            "-c"
          ],
          "arguments": [
            {
              "name": "CONFIG",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Build configuration.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--doc-name",
          "arguments": [
            {
              "name": "NAME",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Swagger document name.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--no-build",
          "description": "Skip the build step (assumes the project was already\nbuilt).",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--output",
          "arguments": [
            {
              "name": "DIR",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Output directory for snapshots.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--project",
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Path to the .csproj file. Defaults to the single\n.csproj in the current directory.",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "Generate a new OpenAPI snapshot from a built assembly.",
      "hidden": false,
      "examples": [
        "snapshot",
        "snapshot --project ./src/MyApi/MyApi.csproj",
        "snapshot -c Release --output Docs/Versions",
        "snapshot --assembly ./bin/Release/net8.0/MyApi.dll"
      ]
    },
    {
      "name": "_snapshot",
      "options": [
        {
          "name": "--assembly",
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Path to the built API assembly DLL.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--doc-name",
          "arguments": [
            {
              "name": "NAME",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Swagger document name.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--output",
          "arguments": [
            {
              "name": "DIR",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Output directory for snapshots.",
          "recursive": false,
          "hidden": false
        }
      ],
      "hidden": true
    }
  ],
  "x-inspectra": {
    "artifactSource": "tool-output"
  }
}
