<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SNAPSHOT-->
  <Command Name="snapshot" IsBranch="false" 
ClrType="SwaggerDiff.Tool.Commands.SnapshotCommand" 
Settings="SwaggerDiff.Tool.Commands.SnapshotCommand+Settings">
    <Description>Generate OpenAPI snapshots from built assemblies. 
Auto-discovers ASP.NET Core web projects when run from a solution 
directory.</Description>
    <Parameters>
      <Option Short="" Long="assembly" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Direct path to a built assembly DLL. Overrides --project 
(skips build). Single project only.</Description>
      </Option>
      <Option Short="c" Long="configuration" Value="CONFIG" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Build configuration.</Description>
      </Option>
      <Option Short="" Long="doc-name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Swagger document name.</Description>
      </Option>
      <Option Short="" Long="exclude" Value="NAME" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Project names to exclude from auto-discovery (without 
.csproj extension). Repeat for multiple.</Description>
      </Option>
      <Option Short="" Long="exclude-dir" Value="DIR" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Directory names to exclude from auto-discovery. Repeat for 
multiple.</Description>
      </Option>
      <Option Short="" Long="no-build" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Skip the build step (assumes the project was already 
built).</Description>
      </Option>
      <Option Short="" Long="output" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Output directory for snapshots (relative to each project 
directory).</Description>
      </Option>
      <Option Short="" Long="project" Value="PATH" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Path to one or more .csproj files. Repeat for multiple 
projects.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="snapshot" />
      <Example commandLine="snapshot" />
      <Example commandLine="--project" />
      <Example commandLine="./src/MyApi/MyApi.csproj" />
      <Example commandLine="snapshot" />
      <Example commandLine="--project" />
      <Example commandLine="./src/Api1/Api1.csproj" />
      <Example commandLine="--project" />
      <Example commandLine="./src/Api2/Api2.csproj" />
      <Example commandLine="snapshot" />
      <Example commandLine="--exclude" />
      <Example commandLine="MyApi.Tests" />
      <Example commandLine="--exclude-dir" />
      <Example commandLine="tests" />
      <Example commandLine="snapshot" />
      <Example commandLine="-c" />
      <Example commandLine="Release" />
      <Example commandLine="--output" />
      <Example commandLine="Docs/Versions" />
      <Example commandLine="snapshot" />
      <Example commandLine="--assembly" />
      <Example commandLine="./bin/Release/net8.0/MyApi.dll" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="SwaggerDiff.Tool.Commands.ListCommand" 
Settings="SwaggerDiff.Tool.Commands.ListCommand+Settings">
    <Description>List available OpenAPI snapshots in a directory.</Description>
    <Parameters>
      <Option Short="" Long="dir" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Directory to scan for snapshot files.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list" />
      <Example commandLine="list" />
      <Example commandLine="--dir" />
      <Example commandLine="Docs/Versions" />
    </Examples>
  </Command>
</Model>