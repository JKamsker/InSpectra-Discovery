{
  "opencli": "0.1-draft",
  "info": {
    "title": "swaggerdiff",
    "version": "1.0"
  },
  "commands": [
    {
      "name": "list",
      "options": [
        {
          "name": "--dir",
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Directory to scan for snapshot files.",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "List available OpenAPI snapshots in a directory.",
      "hidden": false,
      "examples": [
        "list",
        "list --dir Docs/Versions"
      ]
    },
    {
      "name": "snapshot",
      "options": [
        {
          "name": "--assembly",
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String[]"
                }
              ]
            }
          ],
          "description": "Direct path to built assembly DLL(s). Skips build and \nproject discovery. Repeat for multiple.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--configuration",
          "aliases": [
            "-c"
          ],
          "arguments": [
            {
              "name": "CONFIG",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Build configuration.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--doc-name",
          "arguments": [
            {
              "name": "NAME",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Swagger document name.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--exclude",
          "arguments": [
            {
              "name": "NAME",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String[]"
                }
              ]
            }
          ],
          "description": "Project names to exclude from auto-discovery (without \n.csproj extension). Repeat for multiple.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--exclude-dir",
          "arguments": [
            {
              "name": "DIR",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String[]"
                }
              ]
            }
          ],
          "description": "Directory names to exclude from auto-discovery. Repeat\nfor multiple.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--no-build",
          "description": "Skip the build step (assumes the project was already \nbuilt).",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--output",
          "arguments": [
            {
              "name": "DIR",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Output directory for snapshots (relative to each \nproject directory).",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--parallelism",
          "arguments": [
            {
              "name": "N",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.Int32"
                }
              ]
            }
          ],
          "description": "Maximum concurrent snapshot subprocesses. Defaults to \nnumber of projects.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--project",
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String[]"
                }
              ]
            }
          ],
          "description": "Path to one or more .csproj files. Repeat for multiple\nprojects.",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "Generate OpenAPI snapshots from built assemblies. \nAuto-discovers ASP.NET Core web projects when run from a solution directory.",
      "hidden": false,
      "examples": [
        "snapshot",
        "snapshot --project ./src/MyApi/MyApi.csproj",
        "snapshot --project ./src/Api1/Api1.csproj --project \n./src/Api2/Api2.csproj",
        "snapshot --exclude MyApi.Tests --exclude-dir tests",
        "snapshot -c Release --output Docs/Versions",
        "snapshot --assembly ./bin/Release/net8.0/MyApi.dll"
      ]
    },
    {
      "name": "_snapshot",
      "options": [
        {
          "name": "--assembly",
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Path to the built API assembly DLL.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--doc-name",
          "arguments": [
            {
              "name": "NAME",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Swagger document name.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--output",
          "arguments": [
            {
              "name": "DIR",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Output directory for snapshots.",
          "recursive": false,
          "hidden": false
        }
      ],
      "hidden": true
    }
  ],
  "x-inspectra": {
    "artifactSource": "tool-output"
  }
}
