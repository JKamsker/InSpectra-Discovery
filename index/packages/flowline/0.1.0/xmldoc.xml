<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CLONE-->
  <Command Name="clone" IsBranch="false" 
ClrType="FlowLineCli.Commands.CloneCommand" 
Settings="FlowLineCli.Commands.CloneCommandSettings">
    <Description>Clone a Power Platform environment (similar to Clone/pull and 
Branch)</Description>
    <Parameters>
      <Argument Name="environment" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The Power Platform environment to work with</Description>
      </Argument>
      <Option Short="r" Long="repo" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Git repository URL</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="clone" />
      <Example commandLine="https://automatevalue.crm4.dynamics.com/" />
    </Examples>
  </Command>
  <!--SYNC-->
  <Command Name="sync" IsBranch="false" 
ClrType="FlowLineCli.Commands.SyncCommand" 
Settings="FlowLineCli.Commands.SyncCommandSettings">
    <Description>Sync a Power Platform solution (similar to 
Commit)</Description>
    <Parameters>
      <Argument Name="environment" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The Power Platform environment to work with</Description>
      </Argument>
      <Option Short="m" Long="message" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Commit message</Description>
      </Option>
      <Option Short="r" Long="repo" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Git repository URL</Description>
      </Option>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The solution name to sync</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="sync" />
      <Example commandLine="https://automatevalue-dev.crm4.dynamics.com/" />
    </Examples>
  </Command>
  <!--PUSH-TO-TEST-->
  <Command Name="push-to-test" IsBranch="false" 
ClrType="FlowLineCli.Commands.PushToTestCommand" 
Settings="FlowLineCli.FlowlineCommandSettings">
    <Description>Push changes to test environment (similar to 
PullRequest)</Description>
    <Parameters>
      <Argument Name="environment" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The Power Platform environment to work with</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--MERGE-->
  <Command Name="merge" IsBranch="false" 
ClrType="FlowLineCli.Commands.MergeCommand" 
Settings="FlowLineCli.FlowlineCommandSettings">
    <Description>Merge pull request into master</Description>
    <Parameters>
      <Argument Name="environment" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The Power Platform environment to work with</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--DELETE-ENV-->
  <Command Name="delete-env" IsBranch="false" 
ClrType="FlowLineCli.Commands.DeleteEnvCommand" 
Settings="FlowLineCli.FlowlineCommandSettings">
    <Description>Delete a Power Platform environment</Description>
    <Parameters>
      <Argument Name="environment" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The Power Platform environment to work with</Description>
      </Argument>
    </Parameters>
  </Command>
</Model>