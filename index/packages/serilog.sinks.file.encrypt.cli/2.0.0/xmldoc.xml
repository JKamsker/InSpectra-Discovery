<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Serilog.Sinks.File.Encrypt.Cli.Commands.GenerateCommand" 
Settings="Serilog.Sinks.File.Encrypt.Cli.Commands.GenerateCommand+Settings">
    <Description>Generate a new RSA key pair for log encryption</Description>
    <Parameters>
      <Option Short="k" Long="key-size" Value="KEY_SIZE" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The size of the RSA key in bits (default: 
2048)</Description>
      </Option>
      <Option Short="o" Long="output" Value="OUTPUT" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>The output path to write the public/private key pair in XML
format</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="--output" />
      <Example commandLine="./keys" />
    </Examples>
  </Command>
  <!--DECRYPT-->
  <Command Name="decrypt" IsBranch="false" 
ClrType="Serilog.Sinks.File.Encrypt.Cli.Commands.DecryptCommand" 
Settings="Serilog.Sinks.File.Encrypt.Cli.Commands.DecryptCommand+Settings">
    <Description>Decrypt encrypted log files using an RSA private 
key</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to encrypted log file, directory (uses *.log pattern),
or glob pattern (e.g., *.log)</Description>
      </Argument>
      <Option Short="" Long="error-log" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Write detailed error information to a separate log 
file</Description>
      </Option>
      <Option Short="k" Long="key" Value="KEY" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The file containing the RSA private key in XML 
format</Description>
      </Option>
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory or file path (default: adds .decrypted to 
original filename)</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Process directories recursively</Description>
      </Option>
      <Option Short="s" Long="strict" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Fail immediately on first decryption error (default: false,
continues processing)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="decrypt" />
      <Example commandLine="app.log" />
      <Example commandLine="-k" />
      <Example commandLine="private_key.xml" />
      <Example commandLine="decrypt" />
      <Example commandLine="./logs" />
      <Example commandLine="-k" />
      <Example commandLine="private_key.xml" />
      <Example commandLine="decrypt" />
      <Example commandLine="*.log" />
      <Example commandLine="-k" />
      <Example commandLine="private_key.xml" />
      <Example commandLine="decrypt" />
      <Example commandLine="logs/*.txt" />
      <Example commandLine="-k" />
      <Example commandLine="private_key.xml" />
      <Example commandLine="decrypt" />
      <Example commandLine="./logs" />
      <Example commandLine="-k" />
      <Example commandLine="private_key.xml" />
      <Example commandLine="-r" />
      <Example commandLine="decrypt" />
      <Example commandLine="app.log" />
      <Example commandLine="-k" />
      <Example commandLine="private_key.xml" />
      <Example commandLine="-o" />
      <Example commandLine="decrypted.log" />
      <Example commandLine="decrypt" />
      <Example commandLine="app.log" />
      <Example commandLine="-k" />
      <Example commandLine="private_key.xml" />
      <Example commandLine="--strict" />
      <Example commandLine="decrypt" />
      <Example commandLine="./logs" />
      <Example commandLine="-k" />
      <Example commandLine="private_key.xml" />
      <Example commandLine="--error-log" />
      <Example commandLine="errors.log" />
    </Examples>
  </Command>
</Model>