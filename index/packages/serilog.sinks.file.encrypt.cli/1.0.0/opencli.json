{
  "opencli": "0.1-draft",
  "info": {
    "title": "serilog-encrypt",
    "version": "1.0"
  },
  "commands": [
    {
      "name": "decrypt",
      "options": [
        {
          "name": "--continue-on-error",
          "required": false,
          "description": "Continue decryption even when errors are encountered \n(default: true)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--error-log",
          "required": false,
          "arguments": [
            {
              "name": "PATH",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Path for error log file (only used with \nWriteToErrorLog mode)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--error-mode",
          "required": false,
          "aliases": [
            "-e"
          ],
          "arguments": [
            {
              "name": "MODE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "Serilog.Sinks.File.Encrypt.Models.ErrorHandlingMode"
                }
              ]
            }
          ],
          "description": "Error handling mode: Skip (default, clean output), \nWriteInline (errors inline), WriteToErrorLog (separate file), ThrowException \n(fail fast)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--key",
          "required": false,
          "aliases": [
            "-k"
          ],
          "arguments": [
            {
              "name": "KEY",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "The file containing the RSA private key in XML \nformat",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--output",
          "required": false,
          "aliases": [
            "-o"
          ],
          "arguments": [
            {
              "name": "OUTPUT",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Output directory or file path (default: adds \n.decrypted to original filename)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--pattern",
          "required": false,
          "aliases": [
            "-p"
          ],
          "arguments": [
            {
              "name": "PATTERN",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "File pattern to match when processing directories \n(default: *.log)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--recursive",
          "required": false,
          "aliases": [
            "-r"
          ],
          "description": "Process directories recursively",
          "recursive": false,
          "hidden": false
        }
      ],
      "arguments": [
        {
          "name": "PATH",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Path to encrypted log file, directory, or glob pattern\n(e.g., *.log)",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "Decrypt encrypted log files using an RSA private key",
      "hidden": false,
      "examples": [
        "decrypt app.log -k private_key.xml",
        "decrypt ./logs -k private_key.xml",
        "decrypt *.log -k private_key.xml",
        "decrypt ./logs -k private_key.xml -r",
        "decrypt app.log -k private_key.xml -o decrypted.log"
      ]
    },
    {
      "name": "generate",
      "options": [
        {
          "name": "--key-size",
          "required": false,
          "aliases": [
            "-k"
          ],
          "arguments": [
            {
              "name": "KEY_SIZE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.Int32"
                }
              ]
            }
          ],
          "description": "The size of the RSA key in bits (default: 2048)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--output",
          "required": true,
          "aliases": [
            "-o"
          ],
          "arguments": [
            {
              "name": "OUTPUT",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "The output path to write the public/private key pair \nin XML format",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "Generate a new RSA key pair for log encryption",
      "hidden": false,
      "examples": [
        "generate --output ./keys"
      ]
    }
  ]
}
