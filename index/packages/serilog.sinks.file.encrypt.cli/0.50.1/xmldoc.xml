<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Serilog.Sinks.File.Encrypt.Cli.Commands.GenerateCommand" 
Settings="Serilog.Sinks.File.Encrypt.Cli.Commands.GenerateCommand+Settings">
    <Description>Generate a new RSA key pair for log encryption</Description>
    <Parameters>
      <Option Short="k" Long="key-size" Value="KEY_SIZE" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The size of the RSA key in bits (default: 
2048)</Description>
      </Option>
      <Option Short="o" Long="output" Value="OUTPUT" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>The output path to write the public/private key pair in XML
format</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DECRYPT-->
  <Command Name="decrypt" IsBranch="false" 
ClrType="Serilog.Sinks.File.Encrypt.Cli.Commands.DecryptCommand" 
Settings="Serilog.Sinks.File.Encrypt.Cli.Commands.DecryptCommand+Settings">
    <Description>Decrypt encrypted log files using an RSA private 
key</Description>
    <Parameters>
      <Option Short="" Long="continue-on-error" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Continue decryption even when errors are encountered 
(default: true)</Description>
      </Option>
      <Option Short="" Long="error-log" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path for error log file (only used with WriteToErrorLog 
mode)</Description>
      </Option>
      <Option Short="e" Long="error-mode" Value="MODE" Required="false" 
Kind="scalar" ClrType="Serilog.Sinks.File.Encrypt.Models.ErrorHandlingMode">
        <Description>Error handling mode: Skip (default, clean output), 
WriteInline (errors inline), WriteToErrorLog (separate file), ThrowException 
(fail fast)</Description>
      </Option>
      <Option Short="f" Long="file" Value="FILE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The encrypted log file to decrypt</Description>
      </Option>
      <Option Short="k" Long="key" Value="KEY" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The file containing the RSA private key in XML 
format</Description>
      </Option>
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output file for the decrypted log content</Description>
      </Option>
    </Parameters>
  </Command>
</Model>