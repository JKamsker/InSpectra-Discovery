<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--PARSE-->
  <Command Name="parse" IsBranch="false" 
ClrType="SharkyParser.Cli.Commands.ParseCommand" 
Settings="SharkyParser.Cli.Commands.ParseCommand+Settings">
    <Description>Parse log file and display entries in table 
format</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the log file (e.g., mylog.log or 
/path/to/logs/server.log)</Description>
      </Argument>
      <Option Short="" Long="embedded" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Output in pipe-delimited format for integration with other 
tools</Description>
      </Option>
      <Option Short="f" Long="filter" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by log level: error, warn, info, debug (shows only 
matching entries)</Description>
      </Option>
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Log type: installation, update, rabbitmq, iis</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="parse" />
      <Example commandLine="path/to/log.log" />
      <Example commandLine="-t" />
      <Example commandLine="installation" />
      <Example commandLine="parse" />
      <Example commandLine="path/to/log.log" />
      <Example commandLine="-t" />
      <Example commandLine="update" />
      <Example commandLine="-f" />
      <Example commandLine="error" />
    </Examples>
  </Command>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="SharkyParser.Cli.Commands.AnalyzeCommand" 
Settings="SharkyParser.Cli.Commands.AnalyzeCommand+Settings">
    <Description>Analyze log file and show statistics (errors, warnings, 
etc.)</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the log file (e.g., mylog.log or 
/path/to/logs/server.log)</Description>
      </Argument>
      <Option Short="" Long="embedded" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Output in structured format for integration with other 
tools</Description>
      </Option>
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Log type: installation, update, rabbitmq, iis</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="analyze" />
      <Example commandLine="path/to/log.log" />
      <Example commandLine="-t" />
      <Example commandLine="installation" />
      <Example commandLine="analyze" />
      <Example commandLine="path/to/log.log" />
      <Example commandLine="-t" />
      <Example commandLine="iis" />
    </Examples>
  </Command>
</Model>