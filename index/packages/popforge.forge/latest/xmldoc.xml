<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SETUP-->
  <Command Name="setup" IsBranch="false" 
ClrType="Popforge.Forge.Commands.SetupCommand" 
Settings="Popforge.Forge.Commands.SetupCommand+Settings">
    <Description>Vérifie et configure l'environnement de développement (Docker, 
.NET SDK, Node.js).</Description>
    <Parameters>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Revalide et reconfigure l'environnement même si déjà 
validé.</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Produit une sortie JSON structurée sur stdout (pour agents 
IA et CI).</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="setup" />
      <Example commandLine="setup" />
      <Example commandLine="--force" />
      <Example commandLine="setup" />
      <Example commandLine="--json" />
    </Examples>
  </Command>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Popforge.Forge.Commands.InitCommand" 
Settings="Popforge.Forge.Commands.InitCommand+Settings">
    <Description>Initialise la structure d'un nouveau cluster (metadata + 
backend + frontend).</Description>
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Nom du cluster (PascalCase, ex: MyApp)</Description>
      </Argument>
      <Option Short="" Long="company" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Nom de la société (complétion metadata)</Description>
      </Option>
      <Option Short="" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Namespace racine C# (défaut: &lt;name&gt;)</Description>
      </Option>
      <Option Short="" Long="output" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Répertoire de destination (défaut: 
./&lt;name&gt;)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="init" />
      <Example commandLine="MyApp" />
      <Example commandLine="init" />
      <Example commandLine="MyApp" />
      <Example commandLine="--namespace" />
      <Example commandLine="MyCompany.MyApp" />
      <Example commandLine="--company" />
      <Example commandLine="ACME" />
    </Examples>
  </Command>
  <!--NEW-ENTITY-->
  <Command Name="new-entity" IsBranch="false" 
ClrType="Popforge.Forge.Commands.NewEntityCommand" 
Settings="Popforge.Forge.Commands.NewEntityCommand+Settings">
    <Description>Crée un stub YAML dans metadata/entities/ pour une nouvelle 
entité.</Description>
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Nom de l'entité (PascalCase, ex: Appointment)</Description>
      </Argument>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Dossier de sortie des métadonnées (défaut: 
./metadata/entities)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="new-entity" />
      <Example commandLine="Appointment" />
    </Examples>
  </Command>
  <!--CHECK-METADATA-->
  <Command Name="check-metadata" IsBranch="false" 
ClrType="Popforge.Forge.Commands.CheckMetadataCommand" 
Settings="Popforge.Forge.Commands.CheckMetadataCommand+Settings">
    <Description>Valide les fichiers YAML de métadonnées sans générer de 
code.</Description>
    <Parameters>
      <Option Short="" Long="metadata" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Dossier des métadonnées YAML (défaut: 
./metadata)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="check-metadata" />
    </Examples>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Popforge.Forge.Commands.GenerateCommand" 
Settings="Popforge.Forge.Commands.GenerateCommand+Settings">
    <Description>Génère le code backend et frontend à partir des métadonnées 
YAML.</Description>
    <Parameters>
      <Option Short="" Long="backend-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Génère uniquement le code backend</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Simule la génération sans écrire de fichiers</Description>
      </Option>
      <Option Short="" Long="frontend-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Génère uniquement le code frontend</Description>
      </Option>
      <Option Short="" Long="metadata" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Dossier des métadonnées YAML (défaut: 
./metadata)</Description>
      </Option>
      <Option Short="" Long="output" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Racine du projet à générer (défaut: répertoire 
courant)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="generate" />
      <Example commandLine="--dry-run" />
      <Example commandLine="generate" />
      <Example commandLine="--backend-only" />
    </Examples>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="Popforge.Forge.Commands.UpdateCommand" 
Settings="Popforge.Forge.Commands.UpdateCommand+Settings">
    <Description>Met à jour l'outil forge vers la dernière version (ou une 
version précise).</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Produit une sortie JSON structurée sur stdout (pour agents 
IA et CI).</Description>
      </Option>
      <Option Short="" Long="pre" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Inclut les versions pré-release depuis 
NuGet.org.</Description>
      </Option>
      <Option Short="" Long="source" Value="URL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>URL du feed NuGet source. Prioritaire sur 
--pre.</Description>
      </Option>
      <Option Short="" Long="version" Value="VERSION" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Version spécifique à installer (ex. 1.2.3). Par défaut : 
dernière version disponible.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="update" />
      <Example commandLine="update" />
      <Example commandLine="--pre" />
      <Example commandLine="update" />
      <Example commandLine="--version" />
      <Example commandLine="1.2.3" />
      <Example commandLine="update" />
      <Example commandLine="--source" />
      <Example commandLine="https://nuget.pkg.github.com/popforge/index.json" />
      <Example commandLine="update" />
      <Example commandLine="--json" />
    </Examples>
  </Command>
  <!--PUBLISH-->
  <Command Name="publish" IsBranch="false" 
ClrType="Popforge.Forge.Commands.PublishCommand" 
Settings="Popforge.Forge.Commands.PublishCommand+Settings">
    <Description>Crée et pousse un tag git v{VERSION} vers origin ; GitHub 
Actions publie ensuite sur NuGet.org.</Description>
    <Parameters>
      <Argument Name="VERSION" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Version SemVer à publier (ex. 1.0.1 ou 1.0.1-rc.1). Crée et
pousse le tag git v{VERSION} ; GitHub Actions publie ensuite sur 
NuGet.org.</Description>
      </Argument>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Affiche ce qui serait exécuté sans rien 
modifier.</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Produit une sortie JSON structurée sur 
stdout.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="publish" />
      <Example commandLine="1.0.1" />
      <Example commandLine="publish" />
      <Example commandLine="1.0.1-rc.1" />
      <Example commandLine="publish" />
      <Example commandLine="1.0.1" />
      <Example commandLine="--dry-run" />
      <Example commandLine="publish" />
      <Example commandLine="1.0.1" />
      <Example commandLine="--json" />
    </Examples>
  </Command>
</Model>