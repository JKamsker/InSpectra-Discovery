<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DRILL-->
  <Command Name="drill" IsBranch="false" 
ClrType="LoadTestToolbox.Tools.Drill.DrillCommand" 
Settings="LoadTestToolbox.Tools.Drill.DrillSettings">
    <Parameters>
      <Option Short="b" Long="body" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The body of the HTTP request</Description>
      </Option>
      <Option Short="d" Long="duration" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Byte">
        <Description>&lt;required&gt; The duration (in seconds) to send requests
for</Description>
      </Option>
      <Option Short="f" Long="filename" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>&lt;required&gt; The file to write the chart 
to</Description>
      </Option>
      <Option Short="H" Long="header" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>The HTTP header(s) to add to the request</Description>
      </Option>
      <Option Short="m" Long="method" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The HTTP method to use</Description>
      </Option>
      <Option Short="r" Long="rps" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.UInt16">
        <Description>&lt;required&gt; The number of requests per second to 
send</Description>
      </Option>
      <Option Short="u" Long="url" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Uri">
        <Description>&lt;required&gt; The URL to send requests to</Description>
      </Option>
    </Parameters>
  </Command>
