<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GEN-->
  <Command Name="gen" IsBranch="false" 
ClrType="GitIgnore.Cli.Commands.GenCommand" 
Settings="GitIgnore.Cli.Commands.GenCommandSettings">
    <Description>生成.gitignore文件</Description>
    <Parameters>
      <Argument Name="templates" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]" />
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="GitIgnore.Cli.Commands.ListCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>列出可用模板</Description>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="GitIgnore.Cli.Commands.AddCommand" 
Settings="GitIgnore.Cli.Commands.AddCommandSettings">
    <Description>向现有 .gitignore 增量添加规则</Description>
    <Parameters>
      <Argument Name="templates" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]" />
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
</Model>