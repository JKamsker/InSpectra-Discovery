  <Command Name="listen" IsBranch="false" 
ClrType="DeviceRunners.Cli.Commands.PortListenerCommand" 
Settings="DeviceRunners.Cli.Commands.PortListenerCommand+Settings">
    <Description>Start a TCP port listener</Description>
    <Parameters>
      <Option Short="" Long="connection-timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Connection timeout in seconds (non-interactive mode 
only)</Description>
      </Option>
      <Option Short="" Long="data-timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Data timeout in seconds (non-interactive mode 
only)</Description>
      </Option>
      <Option Short="" Long="non-interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Run in non-interactive mode</Description>
      </Option>
      <Option Short="" Long="output" Value="NULL" Required="false" Kind="scalar"
ClrType="DeviceRunners.Cli.Models.OutputFormat">
        <Description>Output format (json, xml, text)</Description>
      </Option>
      <Option Short="" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>TCP port to listen on</Description>
      </Option>
      <Option Short="" Long="results-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to save received data</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="listen" />
      <Example commandLine="--port" />
      <Example commandLine="16384" />
      <Example commandLine="listen" />
      <Example commandLine="--port" />
      <Example commandLine="16384" />
      <Example commandLine="--non-interactive" />
