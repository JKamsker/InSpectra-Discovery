<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="NugetCpmCleaner.Commands.CleanCommand" 
Settings="NugetCpmCleaner.Commands.CleanCommandSettings">
    <Parameters>
      <Option Short="" Long="auto-remove" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Automatically remove all unused packages without 
prompting.</Description>
      </Option>
      <Option Short="" Long="root" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the repository root. Defaults to the current 
directory.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="--root" />
      <Example commandLine="C:/repos/my-solution" />
      <Example commandLine="--root" />
      <Example commandLine="." />
      <Example commandLine="--auto-remove" />
    </Examples>
  </Command>
</Model>