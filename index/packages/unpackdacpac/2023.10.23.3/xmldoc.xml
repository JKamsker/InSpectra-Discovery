<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--UNPACK-->
  <Command Name="unpack" IsBranch="false" 
ClrType="UnpackDacPac.Commands.UnpackCommand" 
Settings="UnpackDacPac.Commands.Settings.UnpackSettings">
    <Parameters>
      <Argument Name="dacPacPath" Position="0" Required="true" Kind="scalar" 
ClrType="Cake.Core.IO.FilePath">
        <Description>DAC Package Path</Description>
        <Validators>
          <Validator 
ClrType="UnpackDacPac.Commands.Validation.ValidatePathAttribute" Message="NULL" 
/>
        </Validators>
      </Argument>
      <Argument Name="outputPath" Position="1" Required="true" Kind="scalar" 
ClrType="Cake.Core.IO.DirectoryPath">
        <Description>Output path</Description>
        <Validators>
          <Validator 
ClrType="UnpackDacPac.Commands.Validation.ValidatePathAttribute" Message="NULL" 
/>
        </Validators>
      </Argument>
      <Option Short="" Long="clean-output-path" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Flag for if output path should be cleaned before 
extraction.</Description>
      </Option>
      <Option Short="" Long="deploy-create-new-database" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Flag that specifies whether the existing database will be 
dropped and a new database created before proceeding with the actual deployment 
actions. Acquires single-user mode before dropping the existing database 
(default false).</Description>
      </Option>
      <Option Short="" Long="deploy-script-database-options" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Deployment script flag that specifies whether the database 
options in the target database should be updated to match the source model 
(default false).</Description>
      </Option>
      <Option Short="" Long="deploy-script-exclude-object-type" 
Value="EXCLUDEDOBJECTTYPE" Required="false" Kind="vector" 
ClrType="Microsoft.SqlServer.Dac.ObjectType[]">
        <Description>Deployment script setting to exclude object 
types</Description>
      </Option>
      <Option Short="" Long="deploy-script-ignore-permissions" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Deployment script flag that specifies whether to exclude 
all permission statements from consideration when comparing the source and 
target model (default false).</Description>
      </Option>
      <Option Short="" Long="target-database" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target database name used for deploy script, if not 
specified DAC Package name without extension is used.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>