<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CSHARP-->
  <Command Name="csharp" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Generate C# API clients using various generators</Description>
    <!--AUTOREST-->
    <Command Name="autorest" IsBranch="false" 
ClrType="Rapicgen.CLI.Commands.CSharp.AutoRestCommand" 
Settings="Rapicgen.CLI.Commands.CSharp.AutoRestCommand+AutoRestSettings">
      <Description>AutoRest (v3.0.0-beta.20210504.2)</Description>
      <Parameters>
        <Argument Name="swaggerFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the Swagger / Open API specification 
file</Description>
        </Argument>
        <Argument Name="namespace" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Default namespace to in the generated code</Description>
        </Argument>
        <Argument Name="outputFile" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Output filename to write the generated code to. Default 
is the swaggerFile .cs</Description>
        </Argument>
        <Option Short="" Long="no-logging" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disables Analytics and Error Reporting</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="autorest" />
        <Example commandLine="petstore.json" />
        <Example commandLine="GeneratedCode" />
        <Example commandLine="Output.cs" />
      </Examples>
    </Command>
    <!--KIOTA-->
    <Command Name="kiota" IsBranch="false" 
ClrType="Rapicgen.CLI.Commands.CSharp.KiotaCommand" 
Settings="Rapicgen.CLI.Commands.CSharp.KiotaCommandSettings">
      <Description>Microsoft Kiota (v1.28.0)</Description>
      <Parameters>
        <Argument Name="swaggerFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the Swagger / Open API specification 
file</Description>
        </Argument>
        <Argument Name="namespace" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Default namespace to in the generated code</Description>
        </Argument>
        <Argument Name="outputFile" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Output filename to write the generated code to. Default 
is the swaggerFile .cs</Description>
        </Argument>
        <Option Short="b" Long="backing-store" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Generate EF backing store code in models (default: 
FALSE)</Description>
        </Option>
        <Option Short="m" Long="generate-multiple-files" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Set this to TRUE to generate multiple files (default: 
FALSE)</Description>
        </Option>
        <Option Short="" Long="no-logging" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disables Analytics and Error Reporting</Description>
        </Option>
        <Option Short="" Long="type-access-modifier" Value="NULL" 
Required="false" Kind="scalar" 
ClrType="Rapicgen.Core.Generators.Kiota.TypeAccessModifier">
          <Description>Set the access modifier for the generated types (default:
public)</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="kiota" />
        <Example commandLine="petstore.json" />
        <Example commandLine="GeneratedCode" />
        <Example commandLine="Output.cs" />
      </Examples>
    </Command>
    <!--NSWAG-->
    <Command Name="nswag" IsBranch="false" 
ClrType="Rapicgen.CLI.Commands.CSharp.NSwagCommand" 
Settings="Rapicgen.CLI.Commands.CSharp.NSwagCommandSettings">
      <Description>NSwag (v14.4.0)</Description>
      <Parameters>
        <Argument Name="swaggerFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the Swagger / Open API specification 
file</Description>
        </Argument>
        <Argument Name="namespace" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Default namespace to in the generated code</Description>
        </Argument>
        <Argument Name="outputFile" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Output filename to write the generated code to. Default 
is the swaggerFile .cs</Description>
        </Argument>
        <Option Short="" Long="class-style" Value="NULL" Required="false" 
Kind="scalar" ClrType="NJsonSchema.CodeGeneration.CSharp.CSharpClassStyle">
          <Description>C# Class Style. 
POCO (Plain Old C# Objects), 
Inpc (Implements INotifyPropertyChanged), 
Prism (Prism base class), 
Records (readonly POCO)</Description>
        </Option>
        <Option Short="" Long="document-title-as-class-name" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Set this to TRUE to use the OpenAPI Document Info Title 
as the generated class name. 
Set this to FALSE to use the filename (default: TRUE)</Description>
        </Option>
        <Option Short="" Long="generate-dto-types" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
          <Description>Set this to TRUE to generate DTO types (default: 
TRUE)</Description>
        </Option>
        <Option Short="" Long="generate-interfaces" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Set this to TRUE to generate client interfaces (default: 
TRUE)</Description>
        </Option>
        <Option Short="" Long="inject-http-client" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
          <Description>Set this to TRUE to generate the constructor that accepts
HttpClient (default: TRUE)</Description>
        </Option>
        <Option Short="" Long="no-logging" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disables Analytics and Error Reporting</Description>
        </Option>
        <Option Short="" Long="parameter-date-time-format" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Specifies the format for DateTime type method 
parameters</Description>
        </Option>
        <Option Short="" Long="use-base-url" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Set this to TRUE to include a base URL for every HTTP 
request (default: FALSE)</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="nswag" />
        <Example commandLine="petstore.json" />
        <Example commandLine="GeneratedCode" />
        <Example commandLine="Output.cs" />
      </Examples>
    </Command>
    <!--REFITTER-->
    <Command Name="refitter" IsBranch="false" 
ClrType="Rapicgen.CLI.Commands.CSharp.RefitterCommand" 
Settings="Rapicgen.CLI.Commands.CSharp.RefitterCommandSettings">
      <Description>Refitter (v1.6.3)</Description>
      <Parameters>
        <Argument Name="swaggerFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the Swagger / Open API specification 
file</Description>
        </Argument>
        <Argument Name="namespace" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Default namespace to in the generated code</Description>
        </Argument>
        <Argument Name="outputFile" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Output filename to write the generated code to. Default 
is the swaggerFile .cs</Description>
        </Argument>
        <Option Short="" Long="cancellation-tokens" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Set this to generate the API interface with Cancellation 
Tokens</Description>
        </Option>
        <Option Short="" Long="generate-internal-types" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Set this to generate the API interface and contract types
using the internal accessibility modifier (default modifier: 
public)</Description>
        </Option>
        <Option Short="" Long="multiple-files" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Generate multiple files</Description>
        </Option>
        <Option Short="" Long="no-logging" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disables Analytics and Error Reporting</Description>
        </Option>
        <Option Short="" Long="no-operation-headers" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Don't generate operation headers</Description>
        </Option>
        <Option Short="" Long="return-api-response" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Set this to wrap the returned the contract types in 
IApiResponse&lt;T&gt; (default: Disabled)</Description>
        </Option>
        <Option Short="" Long="settings-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to a .refitter settings file to use for code 
generation</Description>
        </Option>
        <Option Short="" Long="skip-generate-contracts" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Set this to skip generating the contract types (default: 
Enabled)</Description>
        </Option>
        <Option Short="" Long="skip-generate-xml-doc-code-comments" Value="NULL"
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Set this to skip generating XML doc style code comments 
(default: Enabled)</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="refitter" />
        <Example commandLine="petstore.json" />
        <Example commandLine="GeneratedCode" />
        <Example commandLine="Output.cs" />
      </Examples>
    </Command>
