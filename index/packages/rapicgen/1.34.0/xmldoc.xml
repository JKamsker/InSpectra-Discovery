    <!--OPENAPI-->
    <Command Name="openapi" IsBranch="false" 
ClrType="Rapicgen.CLI.Commands.CSharp.OpenApiCSharpGeneratorCommand" 
Settings="Rapicgen.CLI.Commands.CSharp.OpenApiCSharpGeneratorCommandSettings">
      <Description>OpenAPI Generator (v7.16.0)</Description>
      <Parameters>
        <Argument Name="swaggerFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the Swagger / Open API specification 
file</Description>
        </Argument>
        <Argument Name="namespace" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Default namespace to in the generated code</Description>
        </Argument>
        <Argument Name="outputFile" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Output filename to write the generated code to. Default 
is the swaggerFile .cs</Description>
        </Argument>
        <Option Short="" Long="custom-additional-properties-props" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Setting this will override all the other additional 
properties</Description>
        </Option>
        <Option Short="" Long="emit-default-value" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
          <Description>Set to true if the default value for a member should be 
generated in the serialization stream. Setting the EmitDefaultValue property to 
false is not a recommended practice. It should only be done if there is a 
specific need to do so (such as for interoperability or to reduce data 
size).</Description>
        </Option>
        <Option Short="" Long="generate-multiple-files" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Generate multiple files for each operation. This only 
works for SDK style projects</Description>
        </Option>
        <Option Short="" Long="generate-property-changed" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Generate PropertyChanged notifications</Description>
        </Option>
        <Option Short="" Long="http-user-agent" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Sets the User-Agent header value to be sent in the HTTP 
request</Description>
        </Option>
        <Option Short="" Long="method-argument" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>C# Optional method argument, e.g. void square(int x=10) 
(.net 4.0+ only).</Description>
        </Option>
        <Option Short="" Long="no-logging" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disables Analytics and Error Reporting</Description>
        </Option>
        <Option Short="" Long="skip-form-model" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>To skip models defined as the form parameters in 
'requestBody'</Description>
        </Option>
        <Option Short="" Long="target-framework" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="Rapicgen.Core.Options.OpenApiGenerator.OpenApiSupportedTargetFramework"
>
          <Description>The target .NET Standard / Core / Framework 
version</Description>
        </Option>
        <Option Short="" Long="templates-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to directory containing additional mustache template
files</Description>
        </Option>
        <Option Short="" Long="use-collection" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Use collection instead of list</Description>
        </Option>
        <Option Short="" Long="use-configuration-file" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Use the configuration file if present</Description>
        </Option>
        <Option Short="" Long="use-datetimeoffset" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
          <Description>Use DateTimeOffset to model date-time 
properties</Description>
        </Option>
        <Option Short="" Long="version" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="Rapicgen.Core.Options.OpenApiGenerator.OpenApiSupportedVersion">
          <Description>The version of the generator to use</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="openapi" />
        <Example commandLine="petstore.json" />
        <Example commandLine="GeneratedCode" />
        <Example commandLine="Output.cs" />
      </Examples>
    </Command>
  </Command>
