  <!--EXPORT-->
  <Command Name="export" IsBranch="false" 
ClrType="JTest.Cli.Commands.ExportCommand" 
Settings="JTest.Cli.Settings.ExportCommandSettings">
    <Description>Export tests to other frameworks</Description>
    <Parameters>
      <Argument Name="format" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Format of the export. Supported formats are: 'postman, 
karate'</Description>
      </Argument>
      <Argument Name="test-file" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to test file that will be exported</Description>
      </Argument>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output folder path where reports are saved (default: 
working directory)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="my_api_tests.json" />
      <Example commandLine="postman" />
      <Example commandLine="-o" />
      <Example commandLine="C://output" />
    </Examples>
  </Command>
  <!--CREATE-->
  <Command Name="create" IsBranch="false" 
