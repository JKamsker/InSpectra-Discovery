      </Argument>
      <Option Short="c" Long="categories" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of test file categories to run 
(default: all)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="my_api_tests" />
    </Examples>
  </Command>
</Model>