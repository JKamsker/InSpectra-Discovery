<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--RUN-->
  <Command Name="run" IsBranch="false" ClrType="JTest.Cli.Commands.RunCommand" 
Settings="JTest.Cli.Settings.RunCommandSettings">
    <Description>Run test file(s) - supports wildcards</Description>
    <Parameters>
      <Argument Name="test-file-patterns" Position="0" Required="true" 
Kind="vector" ClrType="System.String[]">
        <Description>List of test file patterns that are executed in order. 
Example: "tests/**/*" "!tests/obsolete-tests/*"</Description>
      </Argument>
      <Option Short="c" Long="categories" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of test file categories to run 
(default: all)</Description>
      </Option>
      <Option Short="e" Long="env" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.IEnumerable`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Environment variable formatted as key=value. You can 
specify the option multiple times to define multiple enviornment 
variables</Description>
      </Option>
      <Option Short="" Long="env-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>File path to environment variables</Description>
      </Option>
      <Option Short="" Long="globals-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>File path to global variables</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output folder path where reports are saved (default: 
working directory)</Description>
      </Option>
      <Option Short="f" Long="output-format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>One of the following output formats: 'markdown' (default: 
markdown)</Description>
      </Option>
      <Option Short="p" Long="parallel" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Run test files in parallel (default: 1)</Description>
      </Option>
      <Option Short="" Long="skip-output" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>When specified, then does not output a report file 
(default: false)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="my_api_tests.json" />
      <Example commandLine="-e" />
      <Example commandLine="apiKey=SecretValue" />
      <Example commandLine="-o" />
      <Example commandLine="C://output" />
      <Example commandLine="tests/api-*.json" />
      <Example commandLine="tests/**/*" />
      <Example commandLine="!tests/obsolete-tests/*" />
    </Examples>
  </Command>
