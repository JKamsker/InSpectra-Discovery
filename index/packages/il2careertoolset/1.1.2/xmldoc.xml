<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SETTINGS-->
  <Command Name="settings" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Commands to find the path to the game or set the log level for 
the application</Description>
    <!--AUTO-->
    <Command Name="auto" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.AutomaticallyDetectDatabaseCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Automaticly detect the game folder</Description>
      <Examples>
        <Example commandLine="settings" />
        <Example commandLine="auto" />
      </Examples>
    </Command>
    <!--MANUEL-->
    <Command Name="manuel" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.ManuelDatabaseCommand" 
Settings="IL2CareerToolset.Commands.Cli.Settings.ManuelDatabaseCommandSettings">
      <Description>Command to set the game path by yourself</Description>
      <Parameters>
        <Argument Name="GameRootFolder" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the root folder of the game</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="settings" />
        <Example commandLine="manuel" />
        <Example commandLine="settings" />
        <Example commandLine="manuel" />
        <Example commandLine="path\to\game\root\directory" />
      </Examples>
    </Command>
    <!--LOGLEVEL-->
    <Command Name="loglevel" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.SetLogLevelCommand" 
Settings="IL2CareerToolset.Commands.Cli.Settings.SetLogLevelCommandSettings">
      <Description>Set the log level for the application. If you set it on 
Information every log for information and above will be shown</Description>
      <Parameters>
        <Argument Name="LOG_LEVEL" Position="0" Required="true" Kind="scalar" 
ClrType="IL2CareerToolset.Enums.LogSeverity">
          <Description>The log level to use for the program. Possible values are
Trace, Debug, Information, Warning, Error, Critical</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="settings" />
        <Example commandLine="loglevel" />
        <Example commandLine="Information" />
      </Examples>
    </Command>
  </Command>
  <!--SAVE-->
  <Command Name="save" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Commands to manage backups or interact with the game 
database</Description>
    <!--BACKUP-->
    <Command Name="backup" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Commands to create, delete, list and restore backups of the 
game database</Description>
      <!--CREATE-->
      <Command Name="create" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Save.CreateBackupCommand" 
Settings="IL2CareerToolset.Commands.Cli.Settings.CreateBackupCommandSettings">
        <Description>Create a backup from your savegames</Description>
        <Parameters>
          <Argument Name="BACKUP_NAME" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>The name of the backup to create</Description>
          </Argument>
        </Parameters>
        <Examples>
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="create" />
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="create" />
          <Example commandLine="&quot;Backup name&quot;" />
        </Examples>
      </Command>
      <!--DELETE-->
      <Command Name="delete" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Save.DeleteBackupsCommand" 
Settings="IL2CareerToolset.Commands.Cli.Settings.DeleteBackupsCommandSettings">
        <Description>Delete a single or multiple backups</Description>
        <Parameters>
          <Argument Name="BACKUP_GUID" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>The backup guid to delete</Description>
          </Argument>
          <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Delete all backups</Description>
          </Option>
        </Parameters>
        <Examples>
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="delete" />
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="delete" />
          <Example commandLine="1cdb087d-3d64-47bd-adb1-648f21cf6f69" />
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="delete" />
          <Example commandLine="--all" />
        </Examples>
      </Command>
      <!--LIST-->
      <Command Name="list" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Save.ListBackupsCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
        <Description>List all the available backups</Description>
        <Examples>
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="list" />
        </Examples>
      </Command>
      <!--RENAME-->
      <Command Name="rename" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Save.ChangeBackupNameCommand" 
Settings="IL2CareerToolset.Commands.Cli.Settings.ChangeBackupNameSettings">
        <Description>Change the name for a backup</Description>
        <Parameters>
          <Argument Name="BACKUP_GUID" Position="0" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Guid, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
            <Description>The guid of the backup to rename</Description>
          </Argument>
          <Argument Name="NEW_NAME" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
            <Description>The new name to use for the backup</Description>
          </Argument>
        </Parameters>
        <Examples>
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="rename" />
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="rename" />
          <Example commandLine="1cdb087d-3d64-47bd-adb1-648f21cf6f69" />
          <Example commandLine="&quot;New name&quot;" />
        </Examples>
      </Command>
      <!--RESTORE-->
      <Command Name="restore" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Save.RestoreBackupCommand" 
Settings="IL2CareerToolset.Commands.Cli.Settings.RestoreBackupCommandSettings">
        <Description>Restore a previously created backup</Description>
        <Parameters>
          <Argument Name="GUID" Position="0" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Guid, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
            <Description>The guid of the backup to restore</Description>
          </Argument>
        </Parameters>
        <Examples>
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="restore" />
          <Example commandLine="save" />
          <Example commandLine="backup" />
          <Example commandLine="restore" />
          <Example commandLine="1cdb087d-3d64-47bd-adb1-648f21cf6f69" />
        </Examples>
      </Command>
    </Command>
    <!--GAME-->
    <Command Name="game" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Commands to list pilots or revive them</Description>
      <!--PILOT-->
      <Command Name="pilot" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Entity.GetPilotsCommand" 
Settings="IL2CareerToolset.Commands.Cli.Settings.GetPilotSettings">
        <Description>Get all pilots listed in a table</Description>
        <Parameters>
          <Argument Name="Pilot Name" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>The name of the pilot to search</Description>
          </Argument>
          <Option Short="p" Long="player" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Show player only pilots</Description>
          </Option>
        </Parameters>
        <Examples>
          <Example commandLine="save" />
          <Example commandLine="game" />
          <Example commandLine="pilot" />
          <Example commandLine="save" />
          <Example commandLine="game" />
          <Example commandLine="pilot" />
          <Example commandLine="--player" />
          <Example commandLine="save" />
          <Example commandLine="game" />
          <Example commandLine="pilot" />
          <Example commandLine="Pilot name" />
          <Example commandLine="save" />
          <Example commandLine="game" />
          <Example commandLine="pilot" />
          <Example commandLine="Pilot name" />
          <Example commandLine="--player" />
        </Examples>
      </Command>
      <!--REVIVE-->
      <Command Name="revive" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Entity.RevivePilotCommand" 
Settings="IL2CareerToolset.Commands.Cli.Settings.RevivePilotCommandSettings">
        <Description>Revive a pilot from a career</Description>
        <Parameters>
          <Option Short="i" Long="ironman" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Include iron man characters</Description>
          </Option>
        </Parameters>
        <Examples>
          <Example commandLine="save" />
          <Example commandLine="game" />
          <Example commandLine="revive" />
          <Example commandLine="save" />
          <Example commandLine="game" />
          <Example commandLine="revive" />
          <Example commandLine="--ironman" />
        </Examples>
      </Command>
    </Command>
  </Command>
  <!--APP-->
  <Command Name="app" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Commands for interacting with the application like open the 
repository, an issues or get some help</Description>
    <!--OPEN-->
    <Command Name="open" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Web.OpenRepositoryCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Open the link to the public repository of the 
project</Description>
      <Examples>
        <Example commandLine="app" />
        <Example commandLine="open" />
      </Examples>
    </Command>
    <!--ISSUE-->
    <Command Name="issue" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Web.OpenIssueCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Open the link to create issues in the web 
browser</Description>
      <Examples>
        <Example commandLine="app" />
        <Example commandLine="issue" />
      </Examples>
    </Command>
    <!--HELP-->
    <Command Name="help" IsBranch="false" 
ClrType="IL2CareerToolset.Commands.Cli.Web.OpenHelpCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Open the online link for this application</Description>
      <Examples>
        <Example commandLine="app" />
        <Example commandLine="help" />
      </Examples>
    </Command>
  </Command>
</Model>