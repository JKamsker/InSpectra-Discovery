<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="Umunna.Cli.Commands.BuildCommand" 
Settings="Umunna.Cli.Commands.BuildCommand+Settings">
    <Description>Generate code from schema</Description>
    <Parameters>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show what would be generated without writing 
files</Description>
      </Option>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Overwrite existing files</Description>
      </Option>
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for generated files</Description>
      </Option>
      <Option Short="s" Long="schema" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to schema file or assembly</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Verbose output</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="build" />
      <Example commandLine="build" />
      <Example commandLine="--output" />
      <Example commandLine="./src/MyApp" />
      <Example commandLine="build" />
      <Example commandLine="--dry-run" />
    </Examples>
  </Command>
  <!--WATCH-->
  <Command Name="watch" IsBranch="false" 
ClrType="Umunna.Cli.Commands.WatchCommand" 
Settings="Umunna.Cli.Commands.WatchCommand+Settings">
    <Description>Watch schema and regenerate on changes</Description>
    <Parameters>
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory</Description>
      </Option>
      <Option Short="s" Long="schema" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to schema project</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="watch" />
    </Examples>
  </Command>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="Umunna.Cli.Commands.CheckCommand" 
Settings="Umunna.Cli.Commands.CheckCommand+Settings">
    <Description>Validate schema without generating</Description>
    <Parameters>
      <Option Short="s" Long="schema" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to schema assembly</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="check" />
    </Examples>
  </Command>
  <!--NEW-->
  <Command Name="new" IsBranch="false" ClrType="Umunna.Cli.Commands.NewCommand" 
Settings="Umunna.Cli.Commands.NewCommand+Settings">
    <Description>Create a new project from template</Description>
    <Parameters>
      <Argument Name="TEMPLATE" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project template (api, api-auth, saas, marketplace, 
cms)</Description>
      </Argument>
      <Argument Name="NAME" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project name</Description>
      </Argument>
      <Option Short="l" Long="list" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>List available templates</Description>
      </Option>
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="new" />
      <Example commandLine="api" />
      <Example commandLine="MyApp" />
      <Example commandLine="new" />
      <Example commandLine="saas" />
      <Example commandLine="MySaasApp" />
      <Example commandLine="new" />
      <Example commandLine="--list" />
    </Examples>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" ClrType="Umunna.Cli.Commands.AddCommand" 
Settings="Umunna.Cli.Commands.AddCommand+Settings">
    <Description>Add plugins to an existing project</Description>
    <Parameters>
      <Argument Name="PLUGINS" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
        <Description>Plugin name(s) to add (e.g., Auth SaaS 
Billing)</Description>
      </Argument>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show what would be added without making 
changes</Description>
      </Option>
      <Option Short="" Long="no-deps" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Don't automatically add dependencies</Description>
      </Option>
      <Option Short="p" Long="project" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to .csproj file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="add" />
      <Example commandLine="Auth" />
      <Example commandLine="add" />
      <Example commandLine="SaaS" />
      <Example commandLine="Billing" />
      <Example commandLine="add" />
      <Example commandLine="Auth" />
      <Example commandLine="--dry-run" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="Umunna.Cli.Commands.ListCommand" 
Settings="Umunna.Cli.Commands.ListCommand+Settings">
    <Description>List available plugins</Description>
    <Parameters>
      <Option Short="i" Long="installed" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show only installed plugins</Description>
      </Option>
      <Option Short="t" Long="tag" Value="TAG" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by tag (e.g., auth, billing, social)</Description>
      </Option>
      <Option Short="" Long="tags" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>List all available tags</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list" />
      <Example commandLine="list" />
      <Example commandLine="--tag" />
      <Example commandLine="auth" />
      <Example commandLine="list" />
      <Example commandLine="--installed" />
    </Examples>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" 
ClrType="Umunna.Cli.Commands.InfoCommand" 
Settings="Umunna.Cli.Commands.InfoCommand+Settings">
    <Description>Show detailed plugin information</Description>
    <Parameters>
      <Argument Name="PLUGIN" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Plugin name (e.g., Auth, SaaS, Billing)</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="info" />
      <Example commandLine="Auth" />
      <Example commandLine="info" />
      <Example commandLine="SaaS" />
    </Examples>
  </Command>
  <!--DOCS-->
  <Command Name="docs" IsBranch="false" 
ClrType="Umunna.Cli.Commands.DocsCommand" 
Settings="Umunna.Cli.Commands.DocsCommand+Settings">
    <Description>Generate API documentation from schema</Description>
    <Parameters>
      <Option Short="" Long="format" Value="FORMAT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format (markdown, html)</Description>
      </Option>
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for documentation</Description>
      </Option>
      <Option Short="s" Long="schema" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to schema assembly</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Verbose output</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="docs" />
      <Example commandLine="docs" />
      <Example commandLine="-o" />
      <Example commandLine="./api-docs" />
    </Examples>
  </Command>
  <!--TEST-INTEGRATION-->
  <Command Name="test-integration" IsBranch="false" 
ClrType="Umunna.Cli.Commands.TestIntegrationCommand" 
Settings="Umunna.Cli.Commands.TestIntegrationCommand+Settings">
    <Description>Test package integration against test app</Description>
    <Parameters>
      <Argument Name="PACKAGE" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Package name to test (e.g., 
Umunna.Plugin.SaaS)</Description>
      </Argument>
      <Option Short="a" Long="auto-fix" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Attempt to automatically fix issues</Description>
      </Option>
      <Option Short="" Long="local-packages" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to local NuGet packages</Description>
      </Option>
      <Option Short="m" Long="max-iterations" Value="N" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum auto-fix iterations</Description>
      </Option>
      <Option Short="r" Long="report" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output report file path (JSON)</Description>
      </Option>
      <Option Short="" Long="skip-tests" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip running tests after successful build</Description>
      </Option>
      <Option Short="t" Long="test-app" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to test application</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Verbose output</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="test-integration" />
      <Example commandLine="Umunna.Plugin.SaaS" />
      <Example commandLine="test-integration" />
      <Example commandLine="--auto-fix" />
      <Example commandLine="test-integration" />
      <Example commandLine="-t" />
      <Example commandLine="../MyTestApp" />
      <Example commandLine="--verbose" />
    </Examples>
  </Command>
</Model>