ClrType="CodeTorch.Ado.Cli.Commands.QueryCommand" 
Settings="CodeTorch.Ado.Cli.Commands.QuerySettings">
    <Description>Run a WIQL query and return matching work items</Description>
    <Parameters>
      <Argument Name="wiql" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>WIQL query string</Description>
      </Argument>
      <Option Short="" Long="agent-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Guid, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Agent machine ID (for env-id mode)</Description>
      </Option>
      <Option Short="" Long="api-url" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>CodeTorch API URL (for env-id mode)</Description>
      </Option>
      <Option Short="" Long="env-id" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.Guid, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>CodeTorch environment ID (fetches ADO settings from 
environment)</Description>
      </Option>
      <Option Short="" Long="fields" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Comma-separated list of fields to return</Description>
      </Option>
      <Option Short="" Long="human" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Human-readable table/tree output</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>JSON output (default)</Description>
      </Option>
      <Option Short="" Long="org" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Organization URL (e.g., 
https://dev.azure.com/myorg)</Description>
      </Option>
      <Option Short="" Long="pat" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Azure DevOps Personal Access Token</Description>
      </Option>
      <Option Short="" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Project name</Description>
      </Option>
      <Option Short="" Long="task-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Guid, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>CodeTorch task ID (resolves target environment settings 
automatically)</Description>
      </Option>
      <Option Short="" Long="timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>HTTP timeout in seconds</Description>
      </Option>
      <Option Short="" Long="top" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Maximum number of results (default: 200)</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show request/response details for debugging</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="query" />
      <Example commandLine="&quot;SELECT [System.Id] FROM WorkItems WHERE 
[System.State] = 'Testing'&quot;" />
    </Examples>
  </Command>
