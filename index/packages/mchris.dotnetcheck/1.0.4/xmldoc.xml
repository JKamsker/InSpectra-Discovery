<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="DotnetCheck.Commands.CheckCommand" 
Settings="DotnetCheck.Commands.CheckCommand+Settings">
    <Description>Check a file for diagnostics</Description>
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable verbose debug output</Description>
      </Option>
      <Option Short="f" Long="file" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the file to check</Description>
      </Option>
      <Option Short="s" Long="solution" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution filename to use when multiple exist in current 
directory</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="check" />
      <Example commandLine="--file" />
      <Example commandLine="src/MyClass.cs" />
    </Examples>
  </Command>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="DotnetCheck.Commands.AnalyzeCommand" 
Settings="DotnetCheck.Commands.AnalyzeCommand+Settings">
    <Description>Analyze entire solution</Description>
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable verbose debug output</Description>
      </Option>
      <Option Short="" Long="min-severity" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum severity level (error, warning, info, 
hidden)</Description>
      </Option>
      <Option Short="s" Long="solution" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution filename to use when multiple exist in current 
directory</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="analyze" />
      <Example commandLine="analyze" />
      <Example commandLine="--min-severity" />
      <Example commandLine="warning" />
    </Examples>
  </Command>
