<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="DotnetCheck.Commands.CheckCommand" 
Settings="DotnetCheck.Commands.CheckCommand+Settings">
    <Description>Check a file for diagnostics</Description>
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable verbose debug output</Description>
      </Option>
      <Option Short="f" Long="file" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the file to check</Description>
      </Option>
      <Option Short="s" Long="solution" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution filename to use when multiple exist in current 
directory</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="check" />
      <Example commandLine="--file" />
      <Example commandLine="src/MyClass.cs" />
    </Examples>
  </Command>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="DotnetCheck.Commands.AnalyzeCommand" 
Settings="DotnetCheck.Commands.AnalyzeCommand+Settings">
    <Description>Analyze entire solution</Description>
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable verbose debug output</Description>
      </Option>
      <Option Short="" Long="min-severity" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum severity level (error, warning, info, 
hidden)</Description>
      </Option>
      <Option Short="s" Long="solution" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution filename to use when multiple exist in current 
directory</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="analyze" />
      <Example commandLine="analyze" />
      <Example commandLine="--min-severity" />
      <Example commandLine="warning" />
    </Examples>
  </Command>
  <!--SERVER-->
  <Command Name="server" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Server management commands</Description>
    <!--STATUS-->
    <Command Name="status" IsBranch="false" 
ClrType="DotnetCheck.Commands.StatusCommand" 
Settings="DotnetCheck.Commands.StatusCommand+Settings">
      <Description>Show server status</Description>
      <Parameters>
        <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Enable verbose debug output</Description>
        </Option>
        <Option Short="s" Long="solution" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Solution filename to use when multiple exist in current 
directory</Description>
        </Option>
      </Parameters>
    </Command>
    <!--STOP-->
    <Command Name="stop" IsBranch="false" 
ClrType="DotnetCheck.Commands.StopCommand" 
Settings="DotnetCheck.Commands.StopCommand+Settings">
      <Description>Stop the diagnostic server</Description>
      <Parameters>
        <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Enable verbose debug output</Description>
        </Option>
        <Option Short="s" Long="solution" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Solution filename to use when multiple exist in current 
directory</Description>
        </Option>
      </Parameters>
    </Command>
    <!--START-->
    <Command Name="start" IsBranch="false" 
ClrType="DotnetCheck.Commands.StartCommand" 
Settings="DotnetCheck.Commands.StartCommand+Settings">
      <Description>Start server without running diagnostics 
(pre-warming)</Description>
      <Parameters>
        <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Enable verbose debug output</Description>
        </Option>
        <Option Short="s" Long="solution" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Solution filename to use when multiple exist in current 
directory</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESTART-->
    <Command Name="restart" IsBranch="false" 
ClrType="DotnetCheck.Commands.RestartCommand" 
Settings="DotnetCheck.Commands.RestartCommand+Settings">
      <Description>Restart server with fresh workspace</Description>
      <Parameters>
        <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Enable verbose debug output</Description>
        </Option>
        <Option Short="s" Long="solution" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Solution filename to use when multiple exist in current 
directory</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Configuration commands</Description>
    <!--INIT-->
    <Command Name="init" IsBranch="false" 
ClrType="DotnetCheck.Commands.InitConfigCommand" 
Settings="DotnetCheck.Commands.InitConfigCommand+Settings">
      <Description>Create a new configuration template</Description>
      <Parameters>
        <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Enable verbose debug output</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>