<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="KoshCLI.Commands.InitCommand" 
Settings="KoshCLI.Commands.InitCommand+InitSettings">
    <Description>Creates koshconfig.yaml file in the current 
directory</Description>
  </Command>
  <!--START-->
  <Command Name="start" IsBranch="false" ClrType="KoshCLI.Commands.StartCommand"
Settings="KoshCLI.Commands.StartCommand+StartSettings">
    <Description>Starts all services defined in koshconfig.yaml</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional path to a custom koshconfig.yaml</Description>
      </Option>
    </Parameters>
  </Command>
  <!--EXAMPLE-->
  <Command Name="example" IsBranch="false" 
ClrType="KoshCLI.Commands.ExampleCommand" 
Settings="KoshCLI.Commands.ExampleCommand+ExampleSettings">
    <Description>Shows the example of the koshconfig.yaml</Description>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="KoshCLI.Commands.VersionCommand" 
Settings="KoshCLI.Commands.VersionCommand+VersionSettings">
    <Description>Shows current kosh version</Description>
  </Command>
</Model>