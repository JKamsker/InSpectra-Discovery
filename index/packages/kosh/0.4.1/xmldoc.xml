<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Kosh.Cli.Commands.Init.InitCommand" 
Settings="Kosh.Cli.Commands.Init.InitCommand+InitSettings">
    <Description>Creates koshconfig.yaml file in the current 
directory</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional path to a custom koshconfig.yaml</Description>
      </Option>
    </Parameters>
  </Command>
  <!--START-->
  <Command Name="start" IsBranch="false" 
ClrType="Kosh.Cli.Commands.Start.StartCommand" 
Settings="Kosh.Cli.Commands.Start.StartCommand+Settings">
    <Description>Starts all services defined in koshconfig.yaml</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional path to a custom koshconfig.yaml</Description>
      </Option>
    </Parameters>
  </Command>
  <!--EXAMPLE-->
  <Command Name="example" IsBranch="false" 
ClrType="Kosh.Cli.Commands.Example.ExampleCommand" 
Settings="Kosh.Cli.Commands.Example.ExampleCommand+ExampleSettings">
    <Description>Shows the example of the koshconfig.yaml</Description>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="Kosh.Cli.Commands.Version.VersionCommand" 
Settings="Kosh.Cli.Commands.Version.VersionCommand+VersionSettings">
    <Description>Shows current kosh version</Description>
  </Command>
</Model>