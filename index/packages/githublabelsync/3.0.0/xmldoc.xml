<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="GitHubLabelSync.Command" Settings="GitHubLabelSync.Settings">
    <Parameters>
      <Argument Name="org/username" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The name of the GitHub organization or username to 
sync</Description>
      </Argument>
      <Option Short="k" Long="api-key" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>GitHub API Key (Personal Access Token)</Description>
      </Option>
      <Option Short="r" Long="dry-run" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Do not perform any actions (equivalent to `-a -e 
-d`)</Description>
      </Option>
      <Option Short="f" Long="filter" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Only sync repositories that match the given regular 
expression</Description>
      </Option>
      <Option Short="a" Long="no-add" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Do not add new labels</Description>
      </Option>
      <Option Short="d" Long="no-delete" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Do not delete existing labels</Description>
      </Option>
      <Option Short="e" Long="no-edit" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Do not edit existing labels</Description>
      </Option>
    </Parameters>
  </Command>
</Model>