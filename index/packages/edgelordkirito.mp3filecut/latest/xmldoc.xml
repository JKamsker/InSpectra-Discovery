<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CUT-->
  <Command Name="cut" IsBranch="false" ClrType="FFmpegCliMp3Cutter.CliCommand" 
Settings="FFmpegCliMp3Cutter.CliCommand+Settings">
    <Description>This C# app processes a file by cutting it between specified 
start and end points.
If only an end point is given, it cuts from the beginning to that point.
If only a start point is provided, it cuts from that point to the end.
At least one parameter must be specified.
</Description>
    <Parameters>
      <Argument Name="filePath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to target file.</Description>
      </Argument>
      <Option Short="b" Long="back" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="f" Long="front" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String" />
    </Parameters>
    <Examples>
      <Example commandLine="cut" />
      <Example commandLine="C:\user\selected.mp3" />
      <Example commandLine="-f" />
      <Example commandLine="01:30" />
      <Example commandLine="-b" />
      <Example commandLine="02:00" />
      <Example commandLine="cut" />
      <Example commandLine="C:\user\selected.mp3" />
      <Example commandLine="-f" />
      <Example commandLine="01:30" />
      <Example commandLine="cut" />
      <Example commandLine="C:\user\selected.mp3" />
      <Example commandLine="-b" />
      <Example commandLine="02:00" />
    </Examples>
  </Command>
</Model>