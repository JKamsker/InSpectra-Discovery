<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="Cli.Commands.InitCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Initialize a new DataLib project in the current 
directory</Description>
  </Command>
  <!--SECRET-->
  <Command Name="secret" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--GENERATE-->
    <Command Name="generate" IsBranch="false" 
ClrType="Cli.Commands.SecretGenerateCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Generate a new API secret</Description>
    </Command>
    <!--SHOW-->
    <Command Name="show" IsBranch="false" 
ClrType="Cli.Commands.SecretShowCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Show the current API secret</Description>
    </Command>
  </Command>
  <!--PORT-->
  <Command Name="port" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--SET-->
    <Command Name="set" IsBranch="false" ClrType="Cli.Commands.PortSetCommand" 
Settings="Cli.Commands.PortSetCommand+Settings">
      <Description>Set the host port</Description>
      <Parameters>
        <Argument Name="port" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32" />
      </Parameters>
    </Command>
  </Command>
  <!--START-->
  <Command Name="start" IsBranch="false" ClrType="Cli.Commands.StartCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Start the DataLib container</Description>
  </Command>
  <!--STOP-->
  <Command Name="stop" IsBranch="false" ClrType="Cli.Commands.StopCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Stop the DataLib container</Description>
  </Command>
  <!--RESTART-->
  <Command Name="restart" IsBranch="false" ClrType="Cli.Commands.RestartCommand"
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Restart the DataLib container</Description>
  </Command>
  <!--LOGS-->
  <Command Name="logs" IsBranch="false" ClrType="Cli.Commands.LogsCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Follow DataLib container logs</Description>
  </Command>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" ClrType="Cli.Commands.StatusCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Show container status</Description>
  </Command>
</Model>