<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--METADATA-->
  <Command Name="metadata" IsBranch="false" ClrType="DocDB.MetadataCommand" 
Settings="DocDB.MetadataCommandOptions">
    <Parameters>
      <Argument Name="connstr" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>A literal connection string or a the name of an environment
variable or file that contains the connection string</Description>
      </Argument>
      <Option Short="" Long="display-database-name" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>An alternative database (display) name</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output base directory (default: 
'.\metadata')</Description>
      </Option>
      <Option Short="" Long="schema-version-query" Value="NULL" Required="false"
Kind="scalar" ClrType="System.String">
        <Description>A SQL (SELECT) statement to get the schema version of the 
database</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Set log level to verbose</Description>
      </Option>
      <Option Short="" Long="warnings-as-errors" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Treats warnings as errors</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="metadata" />
      <Example commandLine="connection-string.txt" />
      <Example commandLine="metadata" />
      <Example commandLine="&quot;%MY_CONN_STR%&quot;" />
      <Example commandLine="metadata" />
      <Example commandLine="&quot;Data Source=.;Initial 
Catalog=MyDatabase;Integrated Security=True;Encrypt=False&quot;" />
    </Examples>
  </Command>
</Model>