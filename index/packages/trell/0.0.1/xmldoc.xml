<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SERVE-->
  <Command Name="serve" IsBranch="false" 
ClrType="Trell.CliCommands.ServerCommand" 
Settings="Trell.CliCommands.ServerCommand+Settings">
    <Description>Start trell as a server, accepting commands via 
gRPC</Description>
    <Parameters>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String" />
      <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[Serilog.Events.LogEventLevel, Serilog,
Version=4.1.0.0, Culture=neutral, PublicKeyToken=24c2f752a8e58a10]]" />
    </Parameters>
    <Examples>
      <Example commandLine="serve" />
      <Example commandLine="--config" />
      <Example commandLine="Trell.toml" />
    </Examples>
  </Command>
  <!--RUN-->
  <Command Name="run" IsBranch="true" 
Settings="Trell.CliCommands.RunCommandSettings">
    <Description>Run scripts, directories, or workers (by id).</Description>
    <Parameters>
      <Option Short="n" Long="" Value="COUNT" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of times to execute the code on the 
server</Description>
      </Option>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String" />
      <Option Short="" Long="handler" Value="NULL" Required="false" 
Kind="scalar" ClrType="Trell.Rpc.Function+ValueOneofCase">
        <Description>Specifies which worker handler function to call: scheduled,
fetch, or upload</Description>
      </Option>
      <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[Serilog.Events.LogEventLevel, Serilog,
Version=4.1.0.0, Culture=neutral, PublicKeyToken=24c2f752a8e58a10]]" />
      <Option Short="u" Long="user-id" Value="USER-ID" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>User id to send in work order; also used for worker id 
resolution</Description>
      </Option>
    </Parameters>
    <!--WORKER-->
    <Command Name="worker" IsBranch="false" 
ClrType="Trell.CliCommands.RunWorkerIdCommand" 
Settings="Trell.CliCommands.RunWorkerIdCommandSettings">
      <Description>Runs the named worker code stored in the server's 
data</Description>
      <Parameters>
        <Argument Name="worker-id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Worker id to tell the server to execute</Description>
        </Argument>
      </Parameters>
    </Command>
    <Examples>
      <Example commandLine="run file worker.js --handler cron" />
      <Example commandLine="run dir my-worker-dir --handler webhook" />
      <Example commandLine="run worker-id worker-123 --handler upload" />
    </Examples>
  </Command>
</Model>