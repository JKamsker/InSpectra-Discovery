<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="Trell.CliCommands.InitCommand" 
Settings="Trell.CliCommands.InitCommandSettings">
    <Description>Initialize directory with a new worker to get started with 
trell faster</Description>
    <Examples>
      <Example commandLine="init" />
    </Examples>
  </Command>
  <!--SERVE-->
  <Command Name="serve" IsBranch="false" 
ClrType="Trell.CliCommands.ServerCommand" 
Settings="Trell.CliCommands.ServerCommand+Settings">
    <Description>Start trell as a server, accepting commands via 
gRPC</Description>
    <Parameters>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String" />
      <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[Serilog.Events.LogEventLevel, Serilog,
Version=4.1.0.0, Culture=neutral, PublicKeyToken=24c2f752a8e58a10]]" />
    </Parameters>
    <Examples>
      <Example commandLine="serve" />
    </Examples>
  </Command>
  <!--RUN-->
  <Command Name="run" IsBranch="false" ClrType="Trell.CliCommands.RunCommand" 
Settings="Trell.CliCommands.RunCommandSettings">
    <Description>Run a handler on the worker</Description>
    <Parameters>
      <Argument Name="handler-fn" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Worker handler to call: cron, request, or 
upload</Description>
      </Argument>
      <Argument Name="data-file" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>File path for data to upload</Description>
      </Argument>
      <Option Short="H" Long="header" Value="HEADER-VALUE" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Adds a header to the request</Description>
      </Option>
      <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Sets the request's URL</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="run" />
      <Example commandLine="cron" />
      <Example commandLine="run" />
      <Example commandLine="upload" />
      <Example commandLine="example.csv" />
    </Examples>
  </Command>
  <!--RUN-FILE-->
  <Command Name="run-file" IsBranch="false" 
ClrType="Trell.CliCommands.RunFileCommand" 
Settings="Trell.CliCommands.RunFileCommandSettings">
    <Description>Run a user-defined handler from a specified file</Description>
    <Parameters>
      <Argument Name="file-name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the file to run</Description>
      </Argument>
      <Argument Name="function-name" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the function to run</Description>
      </Argument>
      <Argument Name="optional-args" Position="2" Required="false" Kind="vector"
ClrType="System.String[]">
        <Description>Optional arguments to pass to the function.
Arguments will be wrapped into a single object: { argv: [[ "arg1", "arg2", ... 
]] }</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="run-file" />
      <Example commandLine="myFile.js" />
      <Example commandLine="myFunction" />
      <Example commandLine="run-file" />
      <Example commandLine="myFile.js" />
      <Example commandLine="myFunction" />
      <Example commandLine="optionalArg1" />
      <Example commandLine="optionalArg2" />
      <Example commandLine="..." />
    </Examples>
  </Command>
</Model>