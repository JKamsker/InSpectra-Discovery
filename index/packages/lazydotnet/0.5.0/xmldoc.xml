<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="lazydotnet.Commands.DefaultCommand" 
Settings="lazydotnet.Commands.DefaultSettings">
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The path to the solution, project or directory to 
open.</Description>
      </Argument>
      <Option Short="p" Long="project" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The project file (.csproj) to open.</Description>
      </Option>
      <Option Short="s" Long="solution" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The solution file (.sln, .slnx, .slnf) to 
open.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>