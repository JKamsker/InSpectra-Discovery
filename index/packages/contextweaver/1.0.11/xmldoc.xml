<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="ContextWeaver.Cli.Commands.WizardCommand" 
Settings="ContextWeaver.Cli.Commands.WizardSettings">
    <Parameters>
      <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Inicia con todos los archivos seleccionados (omite la 
pregunta de selección).</Description>
      </Option>
      <Option Short="d" Long="directory" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>El directorio raíz del proyecto a analizar. Por defecto, es
el directorio actual.</Description>
      </Option>
      <Option Short="" Long="exclude-sections" Value="EXCLUDE_SECTIONS" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Secciones a excluir separadas por coma (omite el 
selector).</Description>
      </Option>
      <Option Short="f" Long="format" Value="FORMAT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Formato de salida: markdown, json, xml (omite el selector 
de formato).</Description>
      </Option>
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Nombre del archivo de salida (omite el prompt del 
nombre).</Description>
      </Option>
      <Option Short="" Long="sections" Value="SECTIONS" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Secciones a incluir separadas por coma (omite el selector).
Ejemplo: '🔥 Hotspots,📁 Contenido de Archivos'.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="ContextWeaver.Cli.Commands.AnalyzeCommand" 
Settings="ContextWeaver.Cli.Commands.AnalyzeSettings">
    <Description>Ejecuta el análisis automático sin interacción (ideal para 
CI/CD).</Description>
    <Parameters>
      <Option Short="d" Long="directory" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>El directorio raíz del proyecto a analizar. Por defecto, es
el directorio actual.</Description>
      </Option>
      <Option Short="f" Long="format" Value="FORMAT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>El formato del reporte de salida.</Description>
      </Option>
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>El archivo de salida para el reporte 
consolidado.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>