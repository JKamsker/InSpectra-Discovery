<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Markdowner.PreviewCommand" Settings="Markdowner.PreviewSettings">
    <Parameters>
      <Argument Name="markdown-file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the markdown file to preview</Description>
      </Argument>
      <Option Short="b" Long="breakpoint" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Max-width breakpoint (sm, md, lg, xl, 2xl)</Description>
      </Option>
      <Option Short="c" Long="color" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Color scheme (slate, gray, zinc, neutral, 
stone)</Description>
      </Option>
      <Option Short="f" Long="font-size" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Font size using Tailwind prose sizes (prose-sm, prose-base,
prose-lg, prose-xl, prose-2xl)</Description>
      </Option>
      <Option Short="l" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.Extensions.Logging.LogLevel">
        <Description>Logging level (Debug, Information, Warning, Error, 
Critical, None)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>