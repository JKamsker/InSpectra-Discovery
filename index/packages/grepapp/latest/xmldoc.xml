<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="GrepApp.SearchCommand" Settings="GrepApp.SearchCommand+Settings">
    <Parameters>
      <Argument Name="query" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Search query to find in code</Description>
      </Argument>
      <Option Short="l" Long="language" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by programming language (e.g., python, javascript, 
csharp)</Description>
      </Option>
      <Option Short="n" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of results to show (default: 
10)</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by file path pattern</Description>
      </Option>
      <Option Short="r" Long="repository" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by repository (e.g., microsoft/vscode)</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show detailed output with code snippets</Description>
      </Option>
    </Parameters>
  </Command>
</Model>