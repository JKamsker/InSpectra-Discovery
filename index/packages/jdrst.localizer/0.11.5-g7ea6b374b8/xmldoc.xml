<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="Localizer.Application.Commands.VersionCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Prints version information.</Description>
    <Examples>
      <Example commandLine="version" />
    </Examples>
  </Command>
  <!--TRANSLATE-->
  <Command Name="translate" IsBranch="false" 
ClrType="Localizer.Application.Commands.TranslateCommand" 
Settings="Localizer.Application.Commands.TranslateCommand+Settings">
    <Description>Update and translate locale files according to the base file 
and their respective culture postfix.</Description>
    <Parameters>
      <Argument Name="base file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base file that is used by 'kli.Localize'. Relative to the 
current directory.</Description>
      </Argument>
      <Option Short="p" Long="prefix" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Prefix for the resulting files. If not specified files will
be changed in place.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="translate locale.json" />
    </Examples>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Localizer.Application.Commands.Config.ListCommand" 
Settings="Localizer.Application.Commands.Config.ListCommand+Settings">
      <Description>Lists all set config values.</Description>
      <Examples>
        <Example commandLine="config list" />
      </Examples>
    </Command>
    <!--GET-->
    <Command Name="get" IsBranch="false" 
ClrType="Localizer.Application.Commands.Config.GetCommand" 
Settings="Localizer.Application.Commands.Config.GetCommand+Settings">
      <Description>Gets the configuration value for the given key.</Description>
      <Parameters>
        <Argument Name="config key" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Config key to get the value for. For nested values use 
':' as separator.</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="config get DeepL:Context" />
      </Examples>
    </Command>
    <!--SET-->
    <Command Name="set" IsBranch="false" 
ClrType="Localizer.Application.Commands.Config.SetCommand" 
Settings="Localizer.Application.Commands.Config.SetCommand+Settings">
      <Description>Sets the given config key to the given value.</Description>
      <Parameters>
        <Argument Name="config key" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Config key to be set. For nested values use ':' as 
separator.</Description>
        </Argument>
        <Argument Name="config value" Position="1" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Config value the key should be set to. Leave empty to 
unset.</Description>
        </Argument>
        <Option Short="g" Long="global" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Set global or local config</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="config set DeepL:Context 'This is additional 
context'" />
      </Examples>
    </Command>
  </Command>
</Model>