<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="EasyDotnet.IDE.Commands.RunCommand" 
Settings="EasyDotnet.IDE.Commands.RunCommand+Settings">
    <Parameters>
      <Option Short="" Long="logLevel" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.Diagnostics.SourceLevels">
        <Description>Logging verbosity (Off, Critical, Error, Warning, 
Information, Verbose, All). Default: Off</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GENERATE-RPC-DOCS-->
  <Command Name="generate-rpc-docs" IsBranch="false" 
ClrType="EasyDotnet.IDE.Commands.GenerateRpcDocsCommand" 
Settings="EasyDotnet.IDE.Commands.GenerateRpcDocsCommand+Settings">
    <Description>Generate RPC documentation in JSON or Markdown 
format.</Description>
    <Parameters>
      <Option Short="" Long="format" Value="FORMAT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format: 'json' (default) or 
'markdown'.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--COMPAT-->
  <Command Name="compat" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Run compatibility commands (run, build, test).</Description>
    <!--RUN-->
    <Command Name="run" IsBranch="false" 
ClrType="EasyDotnet.IDE.Commands.CompatRunCommand" 
Settings="EasyDotnet.IDE.Commands.CompatRunCommand+Settings">
      <Description>Build and run a .NET project.</Description>
      <Parameters>
        <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the project file (.csproj).</Description>
        </Argument>
        <Option Short="" Long="msbuild" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to MSBuild.exe.</Description>
        </Option>
        <Option Short="" Long="target" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to compiled target executable.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RUN-IIS-->
    <Command Name="run-iis" IsBranch="false" 
ClrType="EasyDotnet.IDE.Commands.CompatRunIisCommand" 
Settings="EasyDotnet.IDE.Commands.CompatRunIisCommand+Settings">
      <Description>Build and run a .NET project using IIS Express.</Description>
      <Parameters>
        <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the project file (.csproj).</Description>
        </Argument>
        <Option Short="" Long="config" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to IIS configuration file.</Description>
        </Option>
        <Option Short="" Long="iis-exe" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to IIS Express executable.</Description>
        </Option>
        <Option Short="" Long="msbuild" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to MSBuild.exe.</Description>
        </Option>
        <Option Short="" Long="site" Value="NAME" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Site name for IIS Express.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--BUILD-->
    <Command Name="build" IsBranch="false" 
ClrType="EasyDotnet.IDE.Commands.CompatBuildCommand" 
Settings="EasyDotnet.IDE.Commands.CompatBuildCommand+Settings">
      <Description>Build a project using MSBuild.</Description>
      <Parameters>
        <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the project file (.csproj).</Description>
        </Argument>
        <Option Short="" Long="msbuild" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to MSBuild.exe.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--TEST-->
    <Command Name="test" IsBranch="false" 
ClrType="EasyDotnet.IDE.Commands.CompatTestCommand" 
Settings="EasyDotnet.IDE.Commands.CompatTestCommand+Settings">
      <Description>Build and run tests using VSTest.</Description>
      <Parameters>
        <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path to the project file (.csproj).</Description>
        </Argument>
        <Option Short="" Long="msbuild" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to MSBuild.exe.</Description>
        </Option>
        <Option Short="" Long="target" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the test assembly (e.g., 
MyTests.dll).</Description>
        </Option>
        <Option Short="" Long="vstest" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to vstest.console.exe.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--PROJECT-LANGUAGE-SERVER-->
  <Command Name="project-language-server" IsBranch="false" 
ClrType="EasyDotnet.IDE.Commands.ProjectLanguageServerCommand" 
Settings="EasyDotnet.IDE.Commands.ProjectLanguageServerCommand+Settings" />
  <!--ROSLYN-->
  <Command Name="roslyn" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Roslyn language server commands.</Description>
    <!--START-->
    <Command Name="start" IsBranch="false" 
ClrType="EasyDotnet.IDE.Commands.RoslynStartCommand" 
Settings="EasyDotnet.IDE.Commands.RoslynStartCommand+Settings">
      <Description>Start the Roslyn Language Server over stdio.</Description>
      <Parameters>
        <Option Short="" Long="analyzer" Value="PATH" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Additional analyzer assemblies to load.</Description>
        </Option>
        <Option Short="" Long="csharpDesignTimePath" Value="PATH" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Full path to the C# design time target path 
(optional).</Description>
        </Option>
        <Option Short="" Long="devKitDependencyPath" Value="PATH" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Full path to the Roslyn dependency used with DevKit 
(optional).</Description>
        </Option>
        <Option Short="" Long="razorDesignTimePath" Value="PATH" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Full path to the Razor design time target path 
(optional).</Description>
        </Option>
        <Option Short="" Long="razorSourceGenerator" Value="PATH" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Full path to the Razor source generator 
(optional).</Description>
        </Option>
        <Option Short="" Long="roslynator" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable Roslynator analyzers (optional).</Description>
        </Option>
        <Option Short="" Long="version" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show the Roslyn version and exit.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>