<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--COUNT-->
  <Command Name="count" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Count files, words, code.</Description>
    <!--FILES-->
    <Command Name="files" IsBranch="false" 
ClrType="FileInformation.Cli.Commands.Count.CountAllFiles" 
Settings="FileInformation.Cli.Commands.Count.CountAllFiles+Settings">
      <Description>Count files in a directory and group them by 
extension.</Description>
      <Parameters>
        <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Path to search. Defaults to current 
directory.</Description>
        </Argument>
        <Option Short="d" Long="depth" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32" />
        <Option Short="" Long="head" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32" />
        <Option Short="" Long="hidden" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
        <Option Short="p" Long="pattern" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="r" Long="recurse" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      </Parameters>
    </Command>
    <!--WORDS-->
    <Command Name="words" IsBranch="false" 
ClrType="FileInformation.Cli.Commands.Count.CountWords" 
Settings="FileInformation.Cli.Commands.Count.CountWords+Settings">
      <Description>Count words in files in a directory.</Description>
      <Parameters>
        <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Path to search. Defaults to current 
directory.</Description>
        </Argument>
        <Argument Name="filter" Position="1" Required="false" Kind="vector" 
ClrType="System.String[]">
          <Description>A list of words to find. Can be comma or space separated.
Each word/phrase can be surrounded by quotes.</Description>
        </Argument>
        <Option Short="d" Long="depth" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32" />
        <Option Short="" Long="group" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Group by file</Description>
        </Option>
        <Option Short="" Long="head" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32" />
        <Option Short="" Long="hidden" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
        <Option Short="p" Long="pattern" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="r" Long="recurse" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      </Parameters>
      <Examples>
        <Example commandLine="words" />
        <Example commandLine="." />
        <Example commandLine="'foo'" />
        <Example commandLine="'bar'" />
        <Example commandLine="-r" />
        <Example commandLine="words" />
        <Example commandLine="-r" />
        <Example commandLine="--hidden" />
      </Examples>
    </Command>
  </Command>
  <!--SIZE-->
  <Command Name="size" IsBranch="false" 
ClrType="FileInformation.Cli.Commands.GetSizeOfAllFiles" 
Settings="FileInformation.Cli.Commands.GetSizeOfAllFiles+Settings">
    <Description>Calculate the size of all files in a directory.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to search. Defaults to current 
directory.</Description>
      </Argument>
      <Option Short="" Long="head" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32" />
      <Option Short="" Long="hidden" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="p" Long="pattern" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="r" Long="recurse" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
      <Option Short="" Long="tail" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32" />
    </Parameters>
  </Command>
  <!--TREE-->
  <Command Name="tree" IsBranch="false" 
ClrType="FileInformation.Cli.Commands.DisplayDirectoriesAsTree" 
Settings="FileInformation.Cli.Commands.DisplayDirectoriesAsTree+Settings">
    <Description>Display files and directories as a tree.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to search. Defaults to current 
directory.</Description>
      </Argument>
      <Option Short="d" Long="depth" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32" />
      <Option Short="" Long="hidden" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
</Model>