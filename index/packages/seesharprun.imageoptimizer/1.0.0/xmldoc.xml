<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="OptimizeCommand" Settings="OptimizeSettings">
    <Parameters>
      <Option Short="f" Long="file" Value="FILE" Required="false" Kind="scalar" 
ClrType="System.IO.FileInfo">
        <Description>The file to optimize.</Description>
      </Option>
      <Option Short="o" Long="opacity-transparent" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
        <Description>Whether to keep the transparency of the image. Defaults to 
false.</Description>
      </Option>
      <Option Short="p" Long="path" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.IO.DirectoryInfo">
        <Description>The path to optimize images in.</Description>
      </Option>
      <Option Short="t" Long="types" Value="TYPES" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>The file types to optimize. Defaults to .png and 
.jpg.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>