<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Example.DefaultCommand" Settings="Example.DefaultCommand+Settings">
    <Parameters>
      <Argument Name="EXAMPLE" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The example to run.
If none is specified, all examples will be listed</Description>
      </Argument>
      <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Runs all available examples</Description>
      </Option>
      <Option Short="l" Long="list" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Lists all available examples</Description>
      </Option>
      <Option Short="" Long="select" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Select an example from a list</Description>
      </Option>
      <Option Short="" Long="skip" Value="NULL" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Skips example when combined with 
[grey]--all[/]</Description>
      </Option>
      <Option Short="s" Long="source" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show example source code</Description>
      </Option>
    </Parameters>
  </Command>
</Model>