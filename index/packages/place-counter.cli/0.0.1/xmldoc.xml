<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GOOGLE-->
  <Command Name="google" IsBranch="false" 
ClrType="PlaceCounter.Cli.GoogleLocation" 
Settings="PlaceCounter.Cli.GoogleLocationSettings">
    <Parameters>
      <Argument Name="filePath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the Google Location 'Records.json' 
file</Description>
      </Argument>
      <Option Short="a" Long="latitude" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Double">
        <Description>Latitude of the place to search</Description>
      </Option>
      <Option Short="o" Long="longitude" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Double">
        <Description>Longitude of the place to search</Description>
      </Option>
      <Option Short="r" Long="radius" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Double">
        <Description>Radius from the POI in meters. Default: 100m</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Print more information about the points found</Description>
      </Option>
    </Parameters>
  </Command>
</Model>