<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--REWRITER-->
  <Command Name="rewriter" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Swallow.Refactor.Commands.Common.ListRewriters" 
Settings="Swallow.Refactor.Execution.BaseCommand+EmptySettings" />
    <!--DESCRIBE-->
    <Command Name="describe" IsBranch="false" 
ClrType="Swallow.Refactor.Commands.Common.DescribeRewriter" 
Settings="Swallow.Refactor.Commands.Common.DescribeRewriterSettings">
      <Parameters>
        <Argument Name="REWRITER" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The rewriter to describe</Description>
        </Argument>
      </Parameters>
    </Command>
  </Command>
  <!--SYMBOL-FILTER-->
  <Command Name="symbol-filter" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Swallow.Refactor.Commands.Common.ListSymbolFilters" 
Settings="Swallow.Refactor.Execution.BaseCommand+EmptySettings" />
  </Command>
  <!--UNUSED-->
  <Command Name="unused" IsBranch="false" 
ClrType="Swallow.Refactor.Commands.Unused.FindUnusedCommand" 
Settings="Swallow.Refactor.Commands.Unused.FindUnusedSettings">
    <Parameters>
      <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the project to analyze</Description>
      </Argument>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Where to write the generated usage-log to</Description>
      </Option>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the solution to work with</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REFERENCES-->
  <Command Name="references" IsBranch="false" 
ClrType="Swallow.Refactor.Commands.References.ListReferencesCommand" 
Settings="Swallow.Refactor.Commands.References.ListReferencesSettings">
    <Parameters>
      <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the project to analyze</Description>
      </Argument>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the solution to work with</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REFACTOR-->
  <Command Name="refactor" IsBranch="true" 
Settings="Swallow.Refactor.Commands.Refactor.RefactorCommandSettings">
    <Parameters>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the solution to work with</Description>
      </Option>
    </Parameters>
    <!--CODE-->
    <Command Name="code" IsBranch="false" 
ClrType="Swallow.Refactor.Commands.Refactor.Code.RefactorCodeCommand" 
Settings="Swallow.Refactor.Commands.Refactor.Code.RefactorCodeSettings">
      <Parameters>
        <Argument Name="REWRITERS" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
          <Description>Which rewriters to run; can be specified multiple 
times</Description>
        </Argument>
        <Option Short="" Long="filter-content" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Text that files need to contain to be 
processed</Description>
        </Option>
        <Option Short="" Long="filter-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Regex for the filepaths to process</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SYMBOL-->
    <Command Name="symbol" IsBranch="false" 
ClrType="Swallow.Refactor.Commands.Refactor.Symbol.RefactorSymbolCommand" 
Settings="Swallow.Refactor.Commands.Refactor.Symbol.RefactorSymbolSettings">
      <Parameters>
        <Argument Name="REWRITERS" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
          <Description>Which rewriters to run; can be specified multiple 
times</Description>
        </Argument>
        <Option Short="" Long="cursor" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Cursor which is on the symbol to refactor, in the form 
'filename;line:column', e.g. 'Program.cs;15:4</Description>
        </Option>
        <Option Short="" Long="member" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Name of the member to refactor</Description>
        </Option>
        <Option Short="" Long="type" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Name of the type to refactor</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--ASYNCIFY-->
  <Command Name="asyncify" IsBranch="false" 
ClrType="Swallow.Refactor.Commands.Asyncify.AsyncifyMethodCommand" 
Settings="Swallow.Refactor.Commands.Asyncify.AsyncifyMethodSettings">
    <Parameters>
      <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the project containing the method to 
asyncify</Description>
      </Argument>
      <Argument Name="METHOD" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Signature of the Method to asyncify</Description>
      </Argument>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the solution to work with</Description>
      </Option>
    </Parameters>
  </Command>
</Model>