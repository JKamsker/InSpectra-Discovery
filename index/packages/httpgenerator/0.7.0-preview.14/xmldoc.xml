<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="HttpGenerator.GenerateCommand" Settings="HttpGenerator.Settings">
    <Parameters>
      <Argument Name="URL or input file" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>URL or file path to OpenAPI Specification 
file</Description>
      </Argument>
      <Option Short="" Long="authorization-header" Value="HEADER" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Authorization header to use for all requests</Description>
      </Option>
      <Option Short="" Long="authorization-header-variable-name" 
Value="VARIABLE-NAME" Required="false" Kind="scalar" ClrType="System.String">
        <Description>Name of the environment variable to load the authorization 
header from</Description>
      </Option>
      <Option Short="" Long="azure-scope" Value="SCOPE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Azure Entra ID Scope to use for retrieving Access Token for
Authorization header</Description>
      </Option>
      <Option Short="" Long="azure-tenant-id" Value="TENANT-ID" Required="false"
Kind="scalar" ClrType="System.String">
        <Description>Azure Entra ID Tenant ID to use for retrieving Access Token
for Authorization header</Description>
      </Option>
      <Option Short="" Long="base-url" Value="BASE-URL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Default Base URL to use for all requests. Use this if the 
OpenAPI spec doesn't explicitly specify a server URL.</Description>
      </Option>
      <Option Short="" Long="content-type" Value="CONTENT-TYPE" Required="false"
Kind="scalar" ClrType="System.String">
        <Description>Default Content-Type header to use for all 
requests</Description>
      </Option>
      <Option Short="" Long="generate-intellij-tests" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Generate IntelliJ tests that assert whether the response 
status code is 200</Description>
      </Option>
      <Option Short="" Long="load-authorization-header-from-environment" 
Value="NULL" Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Load the authorization header from an environment variable 
or define it in the .http file. You can use --authorization-header-variable-name
to specify the environment variable name.</Description>
      </Option>
      <Option Short="" Long="no-logging" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't log errors or collect telemetry</Description>
      </Option>
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory</Description>
      </Option>
      <Option Short="" Long="output-type" Value="OUTPUT-TYPE" Required="false" 
Kind="scalar" ClrType="HttpGenerator.Core.OutputType">
        <Description>OneRequestPerFile generates one .http file per request. 
OneFile generates a single .http file for all requests. OneFilePerTag generates 
one .http file per first tag associated with each request.</Description>
      </Option>
      <Option Short="" Long="skip-validation" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip validation of OpenAPI Specification file</Description>
      </Option>
      <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Timeout (in seconds) for writing files to 
disk</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="./openapi.json" />
      <Example commandLine="./openapi.json" />
      <Example commandLine="--output" />
      <Example commandLine="./" />
      <Example commandLine="./openapi.json" />
      <Example commandLine="--output-type" />
      <Example commandLine="onefile" />
      <Example commandLine="https://petstore.swagger.io/v2/swagger.json" />
      <Example commandLine="https://petstore3.swagger.io/api/v3/openapi.json" />
      <Example commandLine="--base-url" />
      <Example commandLine="https://petstore3.swagger.io" />
      <Example commandLine="./openapi.json" />
      <Example commandLine="--authorization-header" />
      <Example commandLine="Bearer 
eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4
gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c" />
      <Example commandLine="./openapi.json" />
      <Example commandLine="--azure-scope" />
      <Example commandLine="[Some Application ID URI]/.default" />
    </Examples>
  </Command>
</Model>