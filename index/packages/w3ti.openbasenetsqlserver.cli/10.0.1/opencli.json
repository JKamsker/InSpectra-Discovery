    "version": "1.0"
  },
  "commands": [
    {
      "name": "help",
      "description": "Exibe a ajuda para os comandos do OpenBaseNET",
      "hidden": false,
      "examples": []
    },
    {
      "name": "install",
      "description": "Instala o ecossistema de templates OpenBaseNET.",
      "hidden": false,
      "examples": [
        "install"
      ]
    },
    {
      "name": "new",
      "options": [
        {
          "name": "--name",
          "required": false,
          "aliases": [
            "-n"
          ],
          "arguments": [
            {
              "name": "NOME",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "O nome do projeto a ser criado",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--template",
          "required": false,
          "aliases": [
            "-s"
          ],
          "arguments": [
            {
              "name": "TEMPLATE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "O nome do template (ex: sqlserver)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--type",
          "required": false,
          "aliases": [
            "-t"
          ],
          "arguments": [
            {
              "name": "TIPO",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "O tipo do template (ex: api)",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "Cria um novo projeto baseado em um template.",
      "hidden": false,
      "examples": [
        "new --type api --template sqlserver --name MeuProjeto"
      ]
    },
    {
      "name": "update",
      "description": "Sincroniza e atualiza todos os templates OpenBaseNET.",
      "hidden": false,
      "examples": []
    },
    {
      "name": "version",
      "description": "Exibe as versões da CLI e do template do \nOpenBaseNET",
      "hidden": false,
      "examples": []
    }
