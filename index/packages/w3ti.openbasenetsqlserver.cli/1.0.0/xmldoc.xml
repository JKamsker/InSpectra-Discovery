<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INSTALL-->
  <Command Name="install" IsBranch="false" 
ClrType="OpenBaseNetSqlServerCLI.Commands.InstallCommand" 
Settings="OpenBaseNetSqlServerCLI.Commands.EmptySettings">
    <Description>Instala o template do OpenBaseNET</Description>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="OpenBaseNetSqlServerCLI.Commands.UpdateCommand" 
Settings="OpenBaseNetSqlServerCLI.Commands.EmptySettings">
    <Description>Atualiza o template e a CLI do OpenBaseNET</Description>
  </Command>
  <!--NEW-->
  <Command Name="new" IsBranch="false" 
ClrType="OpenBaseNetSqlServerCLI.Commands.NewCommand" 
Settings="OpenBaseNetSqlServerCLI.Commands.NewSettings">
    <Description>Cria um novo projeto baseado no OpenBaseNET</Description>
    <Parameters>
      <Argument Name="PROJECT_NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>O nome do projeto que será criado</Description>
      </Argument>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Diretório de saída (opcional)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>