<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ADDTESTS-->
  <Command Name="addTests" IsBranch="false" 
ClrType="awork.BackendCli.AddTestCommand" 
Settings="awork.BackendCli.AddTestCommand+Settings">
    <Parameters>
      <Argument Name="FilePathToFileToTest" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>Path for the file to create a test for.</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--ADDEVENTRECEIVER-->
  <Command Name="addEventReceiver" IsBranch="false" 
ClrType="awork_backend_cli.Utils.AddEventreceiverCommand" 
Settings="awork_backend_cli.Utils.AddEventreceiverCommand+Setting">
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the event receiver to create.</Description>
      </Argument>
      <Argument Name="feature" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The area of the feature, only needed for core 
service.</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--ADDENDPOINT-->
  <Command Name="addEndpoint" IsBranch="false" 
ClrType="awork_backend_cli.Utils.AddEndpointCommand" 
Settings="awork_backend_cli.Utils.AddEndpointCommand+Setting">
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the endpoint to create.</Description>
      </Argument>
      <Argument Name="featureArea" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The area of the feature, only needed for core 
service.</Description>
      </Argument>
      <Argument Name="feature" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The feature.</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--DEPLOYIMAGE-->
  <Command Name="deployImage" IsBranch="false" 
ClrType="aworkBackendCli.DeployImageCommand" 
Settings="aworkBackendCli.DeployImageCommand+Setting">
    <Parameters>
      <Argument Name="service-name" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the service you are deploying to.</Description>
      </Argument>
      <Argument Name="image-name" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The name of the image to be deployed.</Description>
      </Argument>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Apply the changes without asking for 
confirmation.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>