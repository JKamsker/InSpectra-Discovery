<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--MANIFEST-->
  <Command Name="manifest" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--GENERATE-->
    <Command Name="generate" IsBranch="false" 
ClrType="Nodsoft.MoltenObsidian.Tool.Commands.Manifest.GenerateManifestCommand" 
Settings="Nodsoft.MoltenObsidian.Tool.Commands.Manifest.GenerateManifestSettings
">
      <Parameters>
        <Argument Name="VAULT_PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The path to the Molten Obsidian vault to generate a 
manifest for.</Description>
        </Argument>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Forces the manifest to be generated even if vault 
validation fails.</Description>
        </Option>
        <Option Short="" Long="ignore-file" Value="IGNORED_FILE" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>Sets a file to be ignored when generating the manifest. 
Can be called multiple times.</Description>
        </Option>
        <Option Short="" Long="ignore-folder" Value="IGNORED_FOLDER" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>Sets a folder to be ignored when generating the manifest.
Can be called multiple times.</Description>
        </Option>
        <Option Short="o" Long="output" Value="OUTPUT_PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The path to the output folder to write the manifest 
to.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--SSG-->
  <Command Name="ssg" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--GENERATE-->
    <Command Name="generate" IsBranch="false" 
ClrType="Nodsoft.MoltenObsidian.Tool.Commands.SSG.GenerateStaticSite" 
Settings="Nodsoft.MoltenObsidian.Tool.Commands.SSG.GenerateStaticSiteCommandSett
ings">
      <Parameters>
        <Option Short="" Long="from-folder" Value="PATH_TO_VAULT" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Path to the local moltenobsidian vault</Description>
        </Option>
        <Option Short="" Long="from-url" Value="PATH_TO_MANIFEST" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Full url to the manifest file for remote 
vault</Description>
        </Option>
        <Option Short="" Long="ignored-files" Value="IGNONRED_FOLDER" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>Ignore these files when creating the static 
site.</Description>
        </Option>
        <Option Short="" Long="ignored-folders" Value="IGNORED_FILES" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>Ignore an entire directoroy when creating the static 
site.</Description>
        </Option>
        <Option Short="o" Long="output-path" Value="OUTPUT_PATH" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Directory to write the output files to</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>