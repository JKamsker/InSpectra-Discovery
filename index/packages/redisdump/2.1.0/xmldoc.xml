<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DUMP-->
  <Command Name="dump" IsBranch="false" ClrType="RedisDump.Commands.DumpCommand"
Settings="RedisDump.Commands.DumpCommandSettings">
    <Description>Dumps Redis data to a file</Description>
    <Parameters>
      <Option Short="b" Long="batch-size" Value="SIZE" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of keys to process in a single Lua 
batch</Description>
      </Option>
      <Option Short="c" Long="connection" Value="CONNECTION_STRING" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Redis connection string (e.g. 
localhost:6379,password=secret,ssl=true)</Description>
      </Option>
      <Option Short="d" Long="database" Value="DATABASE_NUMBER" Required="false"
Kind="vector" ClrType="System.Int32[]">
        <Description>Redis database numbers to process (can be specified 
multiple times). If not specified, all databases will be 
processed.</Description>
      </Option>
      <Option Short="o" Long="output" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show verbose output</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="dump" />
      <Example commandLine="--connection" />
      <Example commandLine="localhost:6379,password=secret,ssl=true" />
      <Example commandLine="--output" />
      <Example commandLine="redis-backup.json" />
      <Example commandLine="dump" />
      <Example commandLine="--connection" />
      <Example commandLine="localhost:6379" />
      <Example commandLine="--database" />
      <Example commandLine="2" />
      <Example commandLine="--output" />
      <Example commandLine="redis-backup.json" />
      <Example commandLine="dump" />
      <Example commandLine="--connection" />
      <Example commandLine="localhost:6379" />
      <Example commandLine="-d" />
      <Example commandLine="0" />
      <Example commandLine="-d" />
      <Example commandLine="1" />
      <Example commandLine="-d" />
      <Example commandLine="2" />
      <Example commandLine="--output" />
      <Example commandLine="redis-backup.json" />
    </Examples>
  </Command>
  <!--RESTORE-->
  <Command Name="restore" IsBranch="false" 
ClrType="RedisDump.Commands.RestoreCommand" 
Settings="RedisDump.Commands.RestoreCommandSettings">
    <Description>Restores Redis data from a file</Description>
    <Parameters>
      <Option Short="c" Long="connection" Value="CONNECTION_STRING" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Redis connection string (e.g. 
localhost:6379,password=secret,ssl=true)</Description>
      </Option>
      <Option Short="d" Long="database" Value="DATABASE_NUMBER" Required="false"
Kind="vector" ClrType="System.Int32[]">
        <Description>Redis database numbers to process (can be specified 
multiple times). If not specified, all databases will be 
processed.</Description>
      </Option>
      <Option Short="" Long="flush" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Flush the database before restoring</Description>
      </Option>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force restore even if keys already exist</Description>
      </Option>
      <Option Short="i" Long="input" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Input file path</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show verbose output</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="restore" />
      <Example commandLine="--connection" />
      <Example commandLine="localhost:6379,password=secret,allowAdmin=true" />
      <Example commandLine="-d" />
      <Example commandLine="0" />
      <Example commandLine="--input" />
      <Example commandLine="redis-backup.json" />
      <Example commandLine="restore" />
      <Example commandLine="--connection" />
      <Example commandLine="localhost:6379" />
      <Example commandLine="--input" />
      <Example commandLine="redis-backup.json" />
      <Example commandLine="--force" />
      <Example commandLine="restore" />
      <Example commandLine="--connection" />
      <Example commandLine="localhost:6379" />
      <Example commandLine="--input" />
      <Example commandLine="redis-backup.json" />
      <Example commandLine="--flush" />
      <Example commandLine="--force" />
    </Examples>
  </Command>
</Model>