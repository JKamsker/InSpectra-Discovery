<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="ChromeProtocol.Tools.Commands.GenerateCommand" 
Settings="ChromeProtocol.Tools.Commands.GenerateCommand+Settings">
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
        <Description>Path to the .json file with the CDP schema to generate 
protocol definitions from.</Description>
      </Argument>
      <Option Short="" Long="clean" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Should output folder be cleaned before performing 
generation or not.</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Namespace for the generated files.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Folder where generated files should be 
placed.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>