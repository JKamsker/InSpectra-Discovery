<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Corvus.Json.SchemaGenerator.GenerateCommand" 
Settings="Corvus.Json.SchemaGenerator.GenerateCommand+Settings">
    <Parameters>
      <Argument Name="schemaFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The path to the schema file to process.</Description>
      </Argument>
      <Option Short="" Long="assertFormat" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If --assertFormat is specified, assert format 
specifications.</Description>
      </Option>
      <Option Short="" Long="outputMapFile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name to use for a map file which includes details of 
the files that were written.</Description>
      </Option>
      <Option Short="" Long="outputPath" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The dotnet type name for the root type.</Description>
      </Option>
      <Option Short="" Long="outputRootTypeName" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The dotnet type name for the root type.</Description>
      </Option>
      <Option Short="" Long="rebaseToRootPath" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If a --rootPath is specified, rebase the document as if it 
was rooted on the specified element.</Description>
      </Option>
      <Option Short="" Long="rootNamespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The default root namespace for generated 
types.</Description>
      </Option>
      <Option Short="" Long="rootPath" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path in the document for the root type.</Description>
      </Option>
      <Option Short="" Long="useSchema" Value="NULL" Required="false" 
Kind="scalar" ClrType="Corvus.Json.SchemaGenerator.SchemaVariant">
        <Description>Override the schema variant to use. If NotSpecified, and it
cannot be picked up from the schema itself, it will use 
Draft2020-12.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>