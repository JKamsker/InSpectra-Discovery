<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Corvus.Json.CodeGenerator.GenerateCommand" 
Settings="Corvus.Json.CodeGenerator.GenerateCommand+Settings">
    <Parameters>
      <Argument Name="schemaFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The path to the schema file to process.</Description>
      </Argument>
      <Option Short="" Long="addExplicitUsings" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If true, the generate will include using statements for the
standard implicit usings.</Description>
      </Option>
      <Option Short="" Long="assertFormat" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If --assertFormat is specified, assert format 
specifications.</Description>
      </Option>
      <Option Short="" Long="disableNamingHeuristic" Value="NULL" 
Required="false" Kind="vector" ClrType="System.String[]">
        <Description>Disables the specific naming heuristic.</Description>
      </Option>
      <Option Short="" Long="disableOptionalNamingHeuristics" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Disables all optional naming heuristics.</Description>
      </Option>
      <Option Short="" Long="optionalAsNullable" Value="NULL" Required="false" 
Kind="scalar" ClrType="Corvus.Json.CodeGenerator.OptionalAsNullable">
        <Description>If NullOrUndefined, optional properties are emitted as .NET
nullable values.</Description>
      </Option>
      <Option Short="" Long="outputMapFile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name to use for a map file which includes details of 
the files that were written.</Description>
      </Option>
      <Option Short="" Long="outputPath" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path to which to write the generated 
code.</Description>
      </Option>
      <Option Short="" Long="outputRootTypeName" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The .NET type name for the root type.</Description>
      </Option>
      <Option Short="" Long="rebaseToRootPath" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If a --rootPath is specified, rebase the document as if it 
was rooted on the specified element.</Description>
      </Option>
      <Option Short="" Long="rootNamespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The default root namespace for generated 
types.</Description>
      </Option>
      <Option Short="" Long="rootPath" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path in the document for the root type.</Description>
      </Option>
      <Option Short="" Long="useImplicitOperatorString" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>If true, conversion operators to string are implicit, 
rather than explicit.</Description>
      </Option>
      <Option Short="" Long="useSchema" Value="NULL" Required="false" 
Kind="scalar" ClrType="Corvus.Json.CodeGenerator.SchemaVariant">
        <Description>Override the fallback schema variant to use. If 
NotSpecified, and it cannot be inferred from the schema itself, it will use 
Draft2020-12.</Description>
      </Option>
      <Option Short="" Long="useUnixLineEndings" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If true, line endings emitted using the Unix style ('\n'). 
Otherwise, it uses the Windows style ('\r\n').</Description>
      </Option>
      <Option Short="" Long="yaml" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>If true, YAML support is enabled. You may use YAML, JSON or
a mixture of such documents.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="false" 
ClrType="Corvus.Json.CodeGenerator.GenerateWithDriverCommand" 
Settings="Corvus.Json.CodeGenerator.GenerateWithDriverCommand+Settings">
    <Parameters>
      <Argument Name="generationSpecificationFile" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>The path to the code generation specification 
file.</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--LISTNAMEHEURISTICS-->
  <Command Name="listNameHeuristics" IsBranch="false" 
ClrType="Corvus.Json.CodeGenerator.ListNamingHeuristicsCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--VALIDATEDOCUMENT-->
  <Command Name="validateDocument" IsBranch="false" 
ClrType="Corvus.Json.CodeGenerator.ValidateDocumentCommand" 
Settings="Corvus.Json.CodeGenerator.ValidateDocumentCommand+Settings">
    <Parameters>
      <Argument Name="schemaFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The path to the schema file to use.</Description>
      </Argument>
      <Argument Name="documentFile" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The path to the document file to process.</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="Corvus.Json.CodeGenerator.VersionCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
</Model>