<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="OpenApi.Client.Cli.Commands.GenerateCommand" 
Settings="OpenApi.Client.Cli.Settings.GenerateCommandSettings">
    <Description>Generates the Open API Client from the provided 
json.</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The Open API file to parse.</Description>
      </Argument>
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output directory.</Description>
      </Option>
      <Option Short="s" Long="serializer" Value="TYPE" Required="false" 
Kind="scalar" ClrType="OpenApi.Client.Cli.Settings.JsonSerializerType">
        <Description>The JSON serializer.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="my-open-api.json" />
      <Example commandLine="--output" />
      <Example commandLine="MyOpenApiClient.cs" />
    </Examples>
  </Command>
</Model>