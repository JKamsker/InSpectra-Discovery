<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--RUN-->
  <Command Name="run" IsBranch="false" ClrType="aunit.RunCommand" 
Settings="aunit.RunCommand+Settings">
    <Parameters>
      <Argument Name="PATH*" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Specific directories, solution files, or assemblies to 
search tests in. </Description>
      </Argument>
      <Option Short="c" Long="config" Value="CONFIG" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Only tests assemblies with this build configuration, e.g. 
Debug or Release. </Description>
      </Option>
      <Option Short="o" Long="output" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Saves test results to FILE. </Description>
      </Option>
      <Option Short="t" Long="type" Value="TESTCLASS" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Only run tests contained in this class. Multiple allowed. 
</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" ClrType="aunit.ListCommand" 
Settings="aunit.ListCommand+Settings">
    <Parameters>
      <Argument Name="PATH*" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Specific directories, solution files, or assemblies to 
search tests in. </Description>
      </Argument>
    </Parameters>
  </Command>
</Model>