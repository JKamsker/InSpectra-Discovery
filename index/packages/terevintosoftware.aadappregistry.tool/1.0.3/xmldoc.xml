<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CONFIGURE-->
  <Command Name="configure" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--MODE-->
    <Command Name="mode" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.ConfigureGeneralSettings
Command" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.GeneralConfigurationCom
mandSettings">
      <Parameters>
        <Option Short="t" Long="tenant-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The name of the tenant to use for B2C mode. Examples: 
contoso.onmicrosoft.com | login.contoso.com</Description>
        </Option>
        <Option Short="" Long="use-b2c" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Whether to use the AAD (false) or B2C (true) 
mode</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CREDENTIALS-->
    <Command Name="credentials" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.ConfigureCredentialsComm
and" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.ClientCredentialsSettin
gs">
      <Parameters>
        <Option Short="c" Long="client-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The ID of the client</Description>
        </Option>
        <Option Short="s" Long="client-secret" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The secret to authenticate the client</Description>
        </Option>
        <Option Short="t" Long="tenant-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The ID of the Tenant where the app is 
registered</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--VALIDATE-->
  <Command Name="validate" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.ValidateCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--PUBLISH-->
  <Command Name="publish" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--API-->
    <Command Name="api" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.PublishApiAppCommand" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.PublishApiCommandSettin
gs">
      <Parameters>
        <Argument Name="APP_NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The name of the application</Description>
        </Argument>
        <Option Short="" Long="access-as-user" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Adds the access_as_user scope. Requires the application 
uri to be set.</Description>
        </Option>
        <Option Short="" Long="app-uri" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Sets the specified URI. [darkorange]Mutually exclusive 
with --set-default-uri[/]</Description>
        </Option>
        <Option Short="" Long="disable-duplicate-check" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>If enabled, disables a check for an existing application 
with the same name</Description>
        </Option>
        <Option Short="" Long="set-default-uri" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Sets the default URI for the application. AAD mode will 
use [bold royalblue1]api://{id}[/] while B2C mode will use [bold 
royalblue1]https://{tenant}.onmicrosoft.com/{id}[/].</Description>
        </Option>
        <Option Short="" Long="sign-in-audience" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Settings.SignInAudienceType">
          <Description>The valid audience for this client. Options: AzureADMyOrg
[[default]], AzureADMultipleOrgs, AzureADandPersonalMicrosoftAccount, and 
PersonalMicrosoftAccount</Description>
        </Option>
      </Parameters>
    </Command>
    <!--WEB-->
    <Command Name="web" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.PublishWebAppCommand" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.PublishWebCommandSettin
gs">
      <Parameters>
        <Argument Name="APP_NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The name of the application</Description>
        </Argument>
        <Option Short="" Long="disable-duplicate-check" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>If enabled, disables a check for an existing application 
with the same name</Description>
        </Option>
        <Option Short="" Long="redirect-uris" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>The redirect URIs that are valid for this 
client</Description>
        </Option>
        <Option Short="" Long="sign-in-audience" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Settings.SignInAudienceType">
          <Description>The valid audience for this client. Options: AzureADMyOrg
[[default]], AzureADMultipleOrgs, AzureADandPersonalMicrosoftAccount, and 
PersonalMicrosoftAccount</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SPA-->
    <Command Name="spa" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.PublishSpaAppCommand" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.PublishSpaCommandSettin
gs">
      <Parameters>
        <Argument Name="APP_NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The name of the application</Description>
        </Argument>
        <Option Short="" Long="disable-duplicate-check" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>If enabled, disables a check for an existing application 
with the same name</Description>
        </Option>
        <Option Short="" Long="redirect-uris" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>The redirect URIs that are valid for this 
client</Description>
        </Option>
        <Option Short="" Long="sign-in-audience" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Settings.SignInAudienceType">
          <Description>The valid audience for this client. Options: AzureADMyOrg
[[default]], AzureADMultipleOrgs, AzureADandPersonalMicrosoftAccount, and 
PersonalMicrosoftAccount</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CONFIDENTIAL-->
    <Command Name="confidential" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.PublishConfidentialAppCo
mmand" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.PublishConfidentialComm
andSettings">
      <Parameters>
        <Argument Name="APP_NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The name of the application</Description>
        </Argument>
        <Option Short="" Long="disable-duplicate-check" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>If enabled, disables a check for an existing application 
with the same name</Description>
        </Option>
        <Option Short="" Long="dots-as-dashes" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>[[Optional:]] replaces dots in the application name with 
dashes. This is useful when using the application name as the secret name in the
key vault.</Description>
        </Option>
        <Option Short="k" Long="key-vault" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>[[Optional:]] the URI of the key vault to store the 
client secret in. The Service Principal is used for authenticating to the Key 
Vault.</Description>
        </Option>
        <Option Short="e" Long="secret-expiration-days" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.Int32">
          <Description>The number in days after which the client secret expires.
Defaults to 180 days.</Description>
        </Option>
        <Option Short="n" Long="secret-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>[[Optional:]] the name of the secret in the key vault. 
Defaults to the name of the application.</Description>
        </Option>
        <Option Short="" Long="sign-in-audience" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Settings.SignInAudienceType">
          <Description>The valid audience for this client. Options: AzureADMyOrg
[[default]], AzureADMultipleOrgs, AzureADandPersonalMicrosoftAccount, and 
PersonalMicrosoftAccount</Description>
        </Option>
        <Option Short="s" Long="with-client-secret" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Creates a client secret</Description>
        </Option>
      </Parameters>
    </Command>
    <!--NATIVE-->
    <Command Name="native" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.PublishNativeAppCommand"
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.PublishSpaCommandSettin
gs">
      <Parameters>
        <Argument Name="APP_NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The name of the application</Description>
        </Argument>
        <Option Short="" Long="disable-duplicate-check" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>If enabled, disables a check for an existing application 
with the same name</Description>
        </Option>
        <Option Short="" Long="redirect-uris" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>The redirect URIs that are valid for this 
client</Description>
        </Option>
        <Option Short="" Long="sign-in-audience" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Settings.SignInAudienceType">
          <Description>The valid audience for this client. Options: AzureADMyOrg
[[default]], AzureADMultipleOrgs, AzureADandPersonalMicrosoftAccount, and 
PersonalMicrosoftAccount</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--APP-->
  <Command Name="app" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--VIEW-->
    <Command Name="view" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.ViewAppDetailsCommand" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.ViewAppDetailsSettings"
>
      <Parameters>
        <Argument Name="APP" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The Display Name or Client Id of the 
application</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--ADD-SCOPE-->
    <Command Name="add-scope" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.AppAddScopeCommand" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.ConfigureAppAddScopeSet
tings">
      <Parameters>
        <Argument Name="APP" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The Display Name or Client Id of the 
application</Description>
        </Argument>
        <Option Short="" Long="api-app-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The Client Id or Display Name of the API to be 
consumed</Description>
        </Option>
        <Option Short="" Long="scope-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The name of the scope to be added.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DELETE-->
    <Command Name="delete" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.AppDeleteCommand" 
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.DeleteAppSettings">
      <Parameters>
        <Argument Name="APP" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The Display Name or Client Id of the 
application</Description>
        </Argument>
        <Option Short="y" Long="" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Skip confirmation before deletion.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="TerevintoSoftware.AadAppRegistry.Tool.Commands.ListApplicationsCommand"
Settings="TerevintoSoftware.AadAppRegistry.Tool.Settings.ListAppsSettings">
    <Parameters>
      <Option Short="" Long="order-by" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The property to use to order apps by. Defaults to 
displayName.</Description>
      </Option>
      <Option Short="" Long="take" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>The number of apps to take. Defaults to 50.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>