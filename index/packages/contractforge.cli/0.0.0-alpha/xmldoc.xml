<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="ContractForge.Cli.CodeGenCommand" 
Settings="ContractForge.Cli.CodeGenCommand+Settings">
    <Parameters>
      <Option Short="e" Long="entry" Value="NULL" Required="false" Kind="vector"
ClrType="System.String[]">
        <Description>The .thrift file(s) you would like to use as the entry 
point(s) to your service definition. Can be specified multiple 
times.</Description>
      </Option>
      <Option Short="g" Long="generator" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output code generator you would like to 
use</Description>
      </Option>
      <Option Short="i" Long="include" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Add a directory to the list of directories searched for 
include directives</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output file to save the generated code to (optional, 
defaults to console)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="ContractForge.Cli.CodeGenCommand" 
Settings="ContractForge.Cli.CodeGenCommand+Settings">
    <Description>Generate code from thrift definitions</Description>
    <Parameters>
      <Option Short="e" Long="entry" Value="NULL" Required="false" Kind="vector"
ClrType="System.String[]">
        <Description>The .thrift file(s) you would like to use as the entry 
point(s) to your service definition. Can be specified multiple 
times.</Description>
      </Option>
      <Option Short="g" Long="generator" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output code generator you would like to 
use</Description>
      </Option>
      <Option Short="i" Long="include" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Add a directory to the list of directories searched for 
include directives</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output file to save the generated code to (optional, 
defaults to console)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LINT-->
  <Command Name="lint" IsBranch="false" ClrType="ContractForge.Cli.LintCommand" 
Settings="ContractForge.Cli.LintCommand+Settings">
    <Description>Lint thrift definitions</Description>
    <Parameters>
      <Option Short="e" Long="entry" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>The .thirft file you would like to lint</Description>
      </Option>
      <Option Short="i" Long="include" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Add a directory to the list of directories searched for 
include directives</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LSP-->
  <Command Name="lsp" IsBranch="false" ClrType="ContractForge.Cli.LspCommand" 
Settings="ContractForge.Cli.LspCommand+Settings">
    <Description>Start the lsp server over stdio</Description>
  </Command>
</Model>