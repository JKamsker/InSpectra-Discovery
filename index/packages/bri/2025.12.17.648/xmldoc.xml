<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INVENTORY-->
  <Command Name="inventory" IsBranch="false" 
ClrType="BRI.Commands.InventoryCommand" 
Settings="BRI.Commands.Settings.InventorySettings">
    <Description>Example inventory command.</Description>
    <Parameters>
      <Argument Name="acrloginserver" Position="0" Required="true" Kind="scalar"
ClrType="System.String">
        <Description> Azure Container Registry Login Server</Description>
        <Validators>
          <Validator ClrType="BRI.Commands.Validation.ValidateStringAttribute" 
Message="NULL" />
        </Validators>
      </Argument>
      <Argument Name="outputpath" Position="1" Required="true" Kind="scalar" 
ClrType="Cake.Core.IO.DirectoryPath">
        <Description> Output path</Description>
        <Validators>
          <Validator ClrType="BRI.Commands.Validation.ValidatePathAttribute" 
Message="NULL" />
        </Validators>
      </Argument>
      <Option Short="t" Long="tag-limit-number" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Max number of tags to fetch (default 5).</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="inventory" />
      <Example commandLine="test.azurecr.io" />
      <Example commandLine="outputpath" />
    </Examples>
  </Command>
</Model>