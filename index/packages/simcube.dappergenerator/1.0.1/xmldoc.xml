<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="SimCube.DapperGenerator.Commands.Generate.GenerateCommand" 
Settings="SimCube.DapperGenerator.Commands.Generate.GenerateSettings">
    <Parameters>
      <Option Short="c" Long="connection" Value="CONNECTION" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Set MSSQL connection string.</Description>
      </Option>
      <Option Short="" Long="include-json" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include json property names when generating 
pocos.</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NAMESPACE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Set class namespace.</Description>
      </Option>
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Generated file path.</Description>
      </Option>
      <Option Short="" Long="prefix" Value="PREFIX" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Class name prefix.</Description>
      </Option>
      <Option Short="" Long="suffix" Value="SUFFIX" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Class name suffix.</Description>
      </Option>
      <Option Short="" Long="validators" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Generate validator class (FluentValidation).</Description>
      </Option>
    </Parameters>
  </Command>
</Model>