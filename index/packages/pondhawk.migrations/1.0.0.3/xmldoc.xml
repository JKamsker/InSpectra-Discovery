<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Pondhawk.Migrations.DefaultCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--UP-->
  <Command Name="Up" IsBranch="false" 
ClrType="Pondhawk.Migrations.Commands.UpCommand" 
Settings="Pondhawk.Migrations.Commands.UpCommand+UpSettings">
    <Description>Run a DB schema migration</Description>
    <Parameters>
      <Option Short="C" Long="connection" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Db connection string</Description>
      </Option>
      <Option Short="P" Long="provider" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name of the Provider (MySql, Postgres, Sqlist, 
SqlServer, etc.)</Description>
      </Option>
      <Option Short="Q" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>No terminal output</Description>
      </Option>
      <Option Short="S" Long="scripts-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The scripts path</Description>
      </Option>
      <Option Short="T" Long="test" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Just show discovered Options and pre run 
status</Description>
      </Option>
    </Parameters>
  </Command>
</Model>