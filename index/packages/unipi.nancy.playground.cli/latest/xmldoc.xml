  <Command Name="run" IsBranch="false" ClrType="Unipi.Nancy.Playground.Cli.RunCommand" Settings="Unipi.Nancy.Playground.Cli.RunCommand+Settings">
    <Description>Runs a .mppg script</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" ClrType="System.String">
        <Description>Path to the .mppg file to run</Description>
      </Argument>
      <Option Short="" Long="deterministic" Value="NULL" Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>If enabled, makes the output deterministic, removing preamble and time measurements. Useful to implement tests.</Description>
      </Option>
