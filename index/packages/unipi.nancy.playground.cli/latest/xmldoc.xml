      <Option Short="e" Long="on-error" Value="NULL" Required="false" Kind="scalar" ClrType="System.Nullable`1[[Unipi.Nancy.Playground.Cli.OnErrorMode, Unipi.Nancy.Playground.Cli, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null]]">
