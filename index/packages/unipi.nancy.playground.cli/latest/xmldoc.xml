      <Example commandLine="run" />
      <Example commandLine="./Examples/hal-04513292v1.mppg" />
      <Example commandLine="--output-mode" />
      <Example commandLine="MppgClassic" />
      <Example commandLine="--run-mode" />
      <Example commandLine="PerStatement" />
      <Example commandLine="run" />
      <Example commandLine="./Examples/hal-04513292v1.mppg" />
      <Example commandLine="--output-mode" />
      <Example commandLine="NancyNew" />
      <Example commandLine="--run-mode" />
      <Example commandLine="ExpressionsBased" />
    </Examples>
