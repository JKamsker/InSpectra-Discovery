<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="MemoryLeakDetector.Cli.Commands.AnalyzeCommand" 
Settings="MemoryLeakDetector.Cli.Commands.AnalyzeSettings">
    <Parameters>
      <Argument Name="PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to solution (.sln), project (.csproj), or 
directory</Description>
      </Argument>
      <Option Short="" Long="no-gc" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip GC pressure analysis</Description>
      </Option>
      <Option Short="o" Long="output" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output report file (html, md, or json)</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show verbose output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SCAN-->
  <Command Name="scan" IsBranch="false" 
ClrType="MemoryLeakDetector.Cli.Commands.ScanCommand" 
Settings="MemoryLeakDetector.Cli.Commands.ScanSettings">
    <Parameters>
      <Argument Name="PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to directory to scan</Description>
      </Argument>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show all matches</Description>
      </Option>
    </Parameters>
  </Command>
</Model>