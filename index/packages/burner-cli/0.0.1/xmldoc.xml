<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Burner.Commands.WelcomeCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--NEW-->
  <Command Name="new" IsBranch="false" ClrType="Burner.Commands.NewCommand" 
Settings="Burner.Commands.NewCommandSettings">
    <Description>Create a new burner project</Description>
    <Parameters>
      <Argument Name="TEMPLATE" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Template to use (dotnet, web, or custom). Shows available 
templates if not provided.</Description>
      </Argument>
      <Argument Name="NAME" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project name (auto-generated if not provided)</Description>
      </Argument>
      <Option Short="d" Long="directory" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target directory (uses default if not 
specified)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="new" />
      <Example commandLine="dotnet" />
      <Example commandLine="new" />
      <Example commandLine="dotnet" />
      <Example commandLine="my-experiment" />
      <Example commandLine="new" />
      <Example commandLine="web" />
      <Example commandLine="quick-test" />
      <Example commandLine="-d" />
      <Example commandLine="C:\Projects" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" ClrType="Burner.Commands.ListCommand" 
Settings="Burner.Commands.ListCommandSettings">
    <Description>List all burner projects</Description>
    <Parameters>
      <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show all details</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list" />
      <Example commandLine="list" />
      <Example commandLine="-a" />
    </Examples>
  </Command>
  <!--BURN-->
  <Command Name="burn" IsBranch="false" ClrType="Burner.Commands.BurnCommand" 
Settings="Burner.Commands.BurnCommandSettings">
    <Description>Delete projects (cleanup)</Description>
    <Parameters>
      <Argument Name="NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Specific project name to delete (optional)</Description>
      </Argument>
      <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Delete ALL burner projects</Description>
      </Option>
      <Option Short="d" Long="days" Value="DAYS" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Delete projects older than specified days</Description>
      </Option>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip confirmation prompt</Description>
      </Option>
      <Option Short="i" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Interactive mode: select projects to delete</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="burn" />
      <Example commandLine="--days" />
      <Example commandLine="30" />
      <Example commandLine="burn" />
      <Example commandLine="my-experiment" />
      <Example commandLine="burn" />
      <Example commandLine="-f" />
      <Example commandLine="--days" />
      <Example commandLine="7" />
    </Examples>
  </Command>
  <!--OPEN-->
  <Command Name="open" IsBranch="false" ClrType="Burner.Commands.OpenCommand" 
Settings="Burner.Commands.OpenCommandSettings">
    <Description>Open a project directory</Description>
    <Parameters>
      <Argument Name="NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project name to open (optional, interactive if not 
provided)</Description>
      </Argument>
      <Option Short="c" Long="code" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Open in editor (uses configured editor)</Description>
      </Option>
      <Option Short="e" Long="explorer" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Open in file explorer instead of terminal</Description>
      </Option>
      <Option Short="i" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Interactive mode: select project from list</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="open" />
      <Example commandLine="open" />
      <Example commandLine="-i" />
      <Example commandLine="open" />
      <Example commandLine="my-experiment" />
      <Example commandLine="open" />
      <Example commandLine="my-experiment" />
      <Example commandLine="-c" />
      <Example commandLine="open" />
      <Example commandLine="my-experiment" />
      <Example commandLine="-e" />
    </Examples>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="false" 
ClrType="Burner.Commands.ConfigCommand" 
Settings="Burner.Commands.ConfigCommandSettings">
    <Description>Configure burner settings</Description>
    <Parameters>
      <Option Short="" Long="auto-clean-days" Value="DAYS" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Set auto-cleanup age in days (0 to disable)</Description>
      </Option>
      <Option Short="" Long="editor" Value="EDITOR" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Set the default editor command (e.g., code, cursor, 
rider)</Description>
      </Option>
      <Option Short="" Long="home" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Set the burner home directory</Description>
      </Option>
      <Option Short="" Long="open-home" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Open the burner home directory in file 
explorer</Description>
      </Option>
      <Option Short="" Long="open-templates" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Open the templates directory in file explorer</Description>
      </Option>
      <Option Short="" Long="path" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show config file path</Description>
      </Option>
      <Option Short="" Long="show" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show current configuration</Description>
      </Option>
      <Option Short="" Long="templates" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Set the burner templates directory</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="config" />
      <Example commandLine="--show" />
      <Example commandLine="config" />
      <Example commandLine="--home" />
      <Example commandLine="C:\MyProjects" />
      <Example commandLine="config" />
      <Example commandLine="--auto-clean-days" />
      <Example commandLine="60" />
    </Examples>
  </Command>
  <!--TEMPLATES-->
  <Command Name="templates" IsBranch="false" 
ClrType="Burner.Commands.TemplatesCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>List available templates</Description>
  </Command>
  <!--STATS-->
  <Command Name="stats" IsBranch="false" ClrType="Burner.Commands.StatsCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Show project statistics and charts</Description>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="Burner.Commands.VersionCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Show version and info about Burner</Description>
  </Command>
</Model>