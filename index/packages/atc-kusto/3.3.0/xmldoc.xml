    <Description>Export Kusto database schemas</Description>
    <!--SCHEMA-->
    <Command Name="schema" IsBranch="false" 
ClrType="Atc.Kusto.CLI.Commands.Export.ExportSchemaCommand" 
Settings="Atc.Kusto.CLI.Commands.Settings.ExportBaseCommandSettings">
      <Description>Export the full database schema (tables, functions, 
materialized views, external tables, and policies)</Description>
      <Parameters>
        <Option Short="" Long="cluster-url" Value="URL" Required="false" 
Kind="scalar" ClrType="System.Uri">
          <Description>Kusto cluster URL (e.g. 
https://mycluster.kusto.windows.net)</Description>
        </Option>
        <Option Short="" Long="database" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Database name</Description>
        </Option>
        <Option Short="" Long="output-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output directory (defaults to current 
directory)</Description>
        </Option>
        <Option Short="" Long="tenant-id" Value="GUID" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Azure AD tenant ID</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Use verbose for more debug/trace 
information</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="export" />
        <Example commandLine="schema" />
        <Example commandLine="--tenant-id" />
        <Example commandLine="&lt;GUID&gt;" />
        <Example commandLine="--cluster-url" />
        <Example commandLine="https://mycluster.kusto.windows.net" />
        <Example commandLine="--database" />
        <Example commandLine="MyDb" />
        <Example commandLine="export" />
        <Example commandLine="schema" />
        <Example commandLine="--tenant-id" />
        <Example commandLine="&lt;GUID&gt;" />
        <Example commandLine="--cluster-url" />
        <Example commandLine="https://mycluster.kusto.windows.net" />
        <Example commandLine="--database" />
        <Example commandLine="MyDb" />
        <Example commandLine="--output-dir" />
        <Example commandLine="./kusto-export" />
      </Examples>
    </Command>
