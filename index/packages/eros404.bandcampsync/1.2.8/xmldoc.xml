<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--COMPARE-->
  <Command Name="compare" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.CompareCollectionsCommand"
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.CompareCollectionsSetting
s">
    <Parameters>
      <Option Short="s" Long="search" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Search into your Bandcamp collection</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SYNC-->
  <Command Name="sync" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.SyncCommand" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.SyncSettings">
    <Parameters>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="Eros404.BandcampSync.Core.Models.AudioFormat">
        <Description>Accepted values are `MP3320` (default), `MP3V0`, `FLAC`, 
`AAC`, `OggVorbis`, `ALAC`, `WAV`, `AIFF`</Description>
      </Option>
      <Option Short="s" Long="search" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Search into your Bandcamp collection</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.AddItemsCommand" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.AddItemsSettings">
    <Parameters>
      <Argument Name="downloadLink" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
        <Description>Download links provided by Bandcamp (usually sent by 
mail).</Description>
      </Argument>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="Eros404.BandcampSync.Core.Models.AudioFormat">
        <Description>Accepted values are `MP3320` (default), `MP3V0`, `FLAC`, 
`AAC`, `OggVorbis`, `ALAC`, `WAV`, `AIFF`</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SET-->
  <Command Name="set" IsBranch="true" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.Set.SetConfigSettings">
    <!--IDENTITY-->
    <Command Name="identity" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.Set.SetIdentityCookieComma
nd" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.Set.SetIdentityCookieSett
ings" />
    <!--EMAIL-->
    <Command Name="email" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.Set.SetEmailAddressCommand
" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.Set.SetEmailAddressSettin
gs">
      <Parameters>
        <Argument Name="newEmailAddress" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
          <Description>The email address linked with your Bandcamp 
account.</Description>
        </Argument>
      </Parameters>
    </Command>
  </Command>
  <!--SEE-->
  <Command Name="see" IsBranch="true" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.See.SeeCollectionSettings
">
    <!--BANDCAMP-->
    <Command Name="bandcamp" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.See.SeeBandcampCollectionC
ommand" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.See.SeeBandcampCollection
Settings">
      <Parameters>
        <Option Short="s" Long="search" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Search into your Bandcamp collection</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LOCAL-->
    <Command Name="local" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.See.SeeLocalCollectionComm
and" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.See.SeeLocalCollectionSet
tings">
      <Parameters>
        <Option Short="a" Long="as-albums" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Display your local collection as a list of albums 
(default is a list of tracks).</Description>
        </Option>
      </Parameters>
    </Command>
    <!--PHANTOMS-->
    <Command Name="phantoms" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.See.SeePhantomCollectionCo
mmand" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.See.SeePhantomCollectionS
ettings" />
  </Command>
  <!--PHANTOMS-->
  <Command Name="phantoms" IsBranch="true" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.Phantom.PhantomSettings">
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.Phantom.AddPhantomCommand"
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.Phantom.AddPhantomSetting
s">
      <Parameters>
        <Option Short="s" Long="search" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Search into your Bandcamp collection</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REMOVE-->
    <Command Name="remove" IsBranch="false" 
ClrType="Eros404.BandcampSync.ConsoleApp.Cli.Commands.Phantom.RemovePhantomComma
nd" 
Settings="Eros404.BandcampSync.ConsoleApp.Cli.Settings.Phantom.RemovePhantomSett
ings" />
  </Command>
</Model>