<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Garrard.CloudShare.Receiver.StartCommand" 
Settings="Garrard.CloudShare.Receiver.StartSettings">
    <Parameters>
      <Option Short="c" Long="code" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Tunnel shorthand: {id}.{region}:{port} (e.g. 
mtszwr0l.uks1:5000) — alternative to --url for DevTunnels</Description>
      </Option>
      <Option Short="l" Long="log" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Log level: verbose, warnings (default), 
errors</Description>
      </Option>
      <Option Short="" Long="no-auto-open" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't automatically open browser</Description>
      </Option>
      <Option Short="" Long="no-prompt" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't prompt for saved session, always use provided or 
saved credentials</Description>
      </Option>
      <Option Short="p" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Port number to run the receiver on</Description>
      </Option>
      <Option Short="s" Long="secret" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Secret token (optional, will prompt if not 
provided)</Description>
      </Option>
      <Option Short="u" Long="url" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Sender tunnel URL (optional, will prompt if not 
provided)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="cloud-share-receiver" />
      <Example commandLine="cloud-share-receiver" />
      <Example commandLine="--port" />
      <Example commandLine="8081" />
      <Example commandLine="cloud-share-receiver" />
      <Example commandLine="--log" />
      <Example commandLine="verbose" />
      <Example commandLine="cloud-share-receiver" />
      <Example commandLine="--url" />
      <Example commandLine="https://example.devtunnels.ms" />
      <Example commandLine="--secret" />
      <Example commandLine="mysecret123" />
      <Example commandLine="cloud-share-receiver" />
      <Example commandLine="--no-prompt" />
      <Example commandLine="--no-auto-open" />
      <Example commandLine="cloud-share-receiver" />
      <Example commandLine="--port" />
      <Example commandLine="8081" />
      <Example commandLine="--log" />
      <Example commandLine="errors" />
      <Example commandLine="--no-auto-open" />
    </Examples>
  </Command>
</Model>