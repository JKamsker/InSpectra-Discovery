<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--IMAGE-->
  <Command Name="image" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--UPDATE-->
    <Command Name="update" IsBranch="false" 
ClrType="GitOps.Updater.Cli.Commands.UpdateImageCommand" 
Settings="GitOps.Updater.Cli.Commands.UpdateImageCommand+Settings">
      <Description>Update image tags</Description>
      <Parameters>
        <Option Short="f" Long="" Value="FILE" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Path to tenants csv file</Description>
        </Option>
        <Option Short="c" Long="create" Value="CREATE" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Create tenant values file if missing?</Description>
        </Option>
        <Option Short="" Long="dryrun" Value="DRYRUN" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Perform a dry run?</Description>
        </Option>
        <Option Short="" Long="gitbranch" Value="GITBRANCH" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="gitmessage" Value="GITMESSAGE" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="gitpat" Value="GITPAT" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="gitpatname" Value="GITPATNAME" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="gitprojectpath" Value="GITPROJECTPATH" 
Required="false" Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="gitserverhost" Value="GITSERVERHOST" 
Required="false" Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="gituseremail" Value="GITUSEREMAIL" 
Required="false" Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="gitusername" Value="GITUSERNAME" Required="false"
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="imageyaml" Value="IMAGEYAML" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to image version in values file</Description>
        </Option>
        <Option Short="" Long="schema" Value="SCHEMAFILEPATTERN" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>File path to schema file</Description>
        </Option>
        <Option Short="" Long="template" Value="TEMPLATEPATTERN" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Directory path to versioned template 
directory</Description>
        </Option>
        <Option Short="" Long="templateyaml" Value="TEMPLATEYAML" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Path to template version in values file</Description>
        </Option>
        <Option Short="" Long="values" Value="VALUESPATTERN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>File path to versioned tenants values file</Description>
        </Option>
        <Option Short="v" Long="version" Value="VERSION" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Version number</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="image" />
        <Example commandLine="update" />
        <Example commandLine="-f" />
        <Example commandLine="c:\file.csv" />
      </Examples>
    </Command>
  </Command>
  <!--VALUES-->
  <Command Name="values" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--VALIDATE-->
    <Command Name="validate" IsBranch="false" 
ClrType="GitOps.Updater.Cli.Commands.ValidateValuesFileCommand" 
Settings="GitOps.Updater.Cli.Commands.ValidateValuesFileCommand+Settings">
      <Parameters>
        <Option Short="" Long="branchName" Value="BRANCHNAME" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="imageyaml" Value="IMAGEYAML" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to image version in values file</Description>
        </Option>
        <Option Short="" Long="mainBranchName" Value="MAINBRANCHNAME" 
Required="false" Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="root" Value="ROOTDIRECTORY" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Root directory to repo</Description>
        </Option>
        <Option Short="" Long="schema" Value="SCHEMAFILEPATTERN" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>File path to schema file</Description>
        </Option>
        <Option Short="" Long="template" Value="TEMPLATEPATTERN" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Directory path to versioned template 
directory</Description>
        </Option>
        <Option Short="" Long="templateyaml" Value="TEMPLATEYAML" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Path to template version in values file</Description>
        </Option>
        <Option Short="" Long="values" Value="VALUESPATTERN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>File path to versioned tenants values file</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--SCHEMA-->
  <Command Name="schema" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="GitOps.Updater.Cli.Commands.CreateSchemaFileCommand" 
Settings="GitOps.Updater.Cli.Commands.CreateSchemaFileCommand+Settings">
      <Parameters>
        <Option Short="f" Long="" Value="FILEPATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>File path to sample values file</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>