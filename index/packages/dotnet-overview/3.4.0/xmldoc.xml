<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DotNetOverview.OverviewCommand" 
Settings="DotNetOverview.OverviewCommand+Settings">
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to search. Defaults to current 
directory.</Description>
      </Argument>
      <Option Short="a" Long="absolute-paths" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show absolute paths instead of relative</Description>
      </Option>
      <Option Short="c" Long="count" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show number of projects found</Description>
      </Option>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Format the result as JSON</Description>
      </Option>
      <Option Short="p" Long="show-paths" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show project file paths (relative to search path) instead 
of name</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Print version of this tool and exit</Description>
      </Option>
    </Parameters>
  </Command>
</Model>