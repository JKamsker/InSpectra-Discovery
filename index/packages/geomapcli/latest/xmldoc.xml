<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VIEW-->
  <Command Name="view" IsBranch="false" ClrType="App.Commands.View.ViewCommand" 
Settings="App.Commands.View.ViewCommandSettings">
    <Description>View positions in the map</Description>
    <Parameters>
      <Option Short="b" Long="bounds" Value="BOUNDS" Required="false" 
Kind="vector" ClrType="Core.Maps.MapBounds[]">
        <Description>The bounds to view in the map.</Description>
      </Option>
      <Option Short="l" Long="line" Value="LINE" Required="false" Kind="scalar" 
ClrType="Core.Maps.MapLine">
        <Description>The line style to use: none, solid, dotted, 
dashed.</Description>
      </Option>
      <Option Short="p" Long="position" Value="POSITION" Required="false" 
Kind="vector" ClrType="Core.Maps.MapPosition[]">
        <Description>The positions to view in the map.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="v" />
      <Example commandLine="-p" />
      <Example commandLine="&quot;48.8566,2.3522&quot;" />
      <Example commandLine="v" />
      <Example commandLine="-p" />
      <Example commandLine="&quot;48.8566,2.3522,Paris&quot;" />
      <Example commandLine="v" />
      <Example commandLine="-p" />
      <Example commandLine="&quot;48.8566,2.3522,Paris&quot;" />
      <Example commandLine="-p" />
      <Example commandLine="&quot;49.1193,6.1757,Metz&quot;" />
      <Example commandLine="v" />
      <Example commandLine="-p" />
      <Example commandLine="&quot;48.8566,2.3522,Paris&quot;" />
      <Example commandLine="-p" />
      <Example commandLine="&quot;49.1193,6.1757,Metz&quot;" />
      <Example commandLine="-l" />
      <Example commandLine="&quot;solid,grey&quot;" />
      <Example commandLine="v" />
      <Example commandLine="-b" />
      <Example commandLine="&quot;30.55,50.72,1.98,3.13&quot;" />
      <Example commandLine="v" />
      <Example commandLine="-p" />
      <Example commandLine="&quot;48.8566,2.3522&quot;" />
      <Example commandLine="-b" />
      <Example commandLine="&quot;45.55,50.72,1.28,3.13&quot;" />
      <Example commandLine="-l" />
      <Example commandLine="&quot;dashed,green&quot;" />
      <Example commandLine="v" />
      <Example commandLine="-b" />
      <Example commandLine="&quot;40.18,44.94,2.51,3.13&quot;" />
      <Example commandLine="-b" />
      <Example commandLine="&quot;45.55,50.72,1.28,3.13&quot;" />
      <Example commandLine="-l" />
      <Example commandLine="&quot;dotted,blue&quot;" />
    </Examples>
  </Command>
</Model>