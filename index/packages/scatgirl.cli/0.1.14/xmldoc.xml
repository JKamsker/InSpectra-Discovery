<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--FIND-->
  <Command Name="find" IsBranch="false" 
ClrType="ScatGirl.Cli.Commands.FindDeclarationsCommand" 
Settings="ScatGirl.Cli.Commands.FindDeclarationsCommand+Settings">
    <Description>Find all declarations of a named symbol in a C# 
codebase.</Description>
    <Parameters>
      <Argument Name="root" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the repository root</Description>
      </Argument>
      <Argument Name="symbol" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Symbol name to find (e.g. IUserService, 
ProcessPayment)</Description>
      </Argument>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
      <Option Short="k" Long="kind" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by kind: class, interface, method, property, record,
struct, enum, field, constructor, delegate, event</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="find" />
      <Example commandLine="." />
      <Example commandLine="IUserService" />
      <Example commandLine="find" />
      <Example commandLine="." />
      <Example commandLine="ProcessPayment" />
      <Example commandLine="--kind" />
      <Example commandLine="method" />
    </Examples>
  </Command>
  <!--REFS-->
  <Command Name="refs" IsBranch="false" 
ClrType="ScatGirl.Cli.Commands.RefsCommand" 
Settings="ScatGirl.Cli.Commands.RefsCommand+Settings">
    <Description>Find all references to a named symbol in a C# 
codebase.</Description>
    <Parameters>
      <Argument Name="root" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the repository root</Description>
      </Argument>
      <Argument Name="symbol" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Symbol name to find references to</Description>
      </Argument>
      <Option Short="" Long="in-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Restrict search to files matching glob (e.g. 
"**/*Service.cs")</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
      <Option Short="k" Long="kind" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by reference kind: identifier, typeof, nameof, 
attribute, implementation, invocation, object-creation, 
type-argument</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="refs" />
      <Example commandLine="." />
      <Example commandLine="AudioCaptureService" />
      <Example commandLine="refs" />
      <Example commandLine="." />
      <Example commandLine="IMonitoringStateService" />
      <Example commandLine="--kind" />
      <Example commandLine="identifier" />
      <Example commandLine="refs" />
      <Example commandLine="." />
      <Example commandLine="NoiseDetector" />
      <Example commandLine="--in-file" />
      <Example commandLine="**/*Service.cs" />
    </Examples>
  </Command>
  <!--MEMBERS-->
  <Command Name="members" IsBranch="false" 
ClrType="ScatGirl.Cli.Commands.MembersCommand" 
Settings="ScatGirl.Cli.Commands.MembersCommand+Settings">
    <Description>List all members of a type declared in a C# 
codebase.</Description>
    <Parameters>
      <Argument Name="root" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the repository root</Description>
      </Argument>
      <Argument Name="symbol" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Type name to inspect (e.g. 
AudioCaptureService)</Description>
      </Argument>
      <Option Short="" Long="in-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Restrict search to files matching glob (e.g. 
"**/*Service.cs")</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON instead of formatted 
text</Description>
      </Option>
      <Option Short="k" Long="kind" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by member kind: method, property, field, 
constructor, event</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="members" />
      <Example commandLine="." />
      <Example commandLine="AudioCaptureService" />
      <Example commandLine="members" />
      <Example commandLine="." />
      <Example commandLine="AudioCaptureService" />
      <Example commandLine="--kind" />
      <Example commandLine="method" />
      <Example commandLine="members" />
      <Example commandLine="." />
      <Example commandLine="SyntaxNavigator" />
      <Example commandLine="--in-file" />
      <Example commandLine="**/ScatGirl.Core/**" />
    </Examples>
  </Command>
  <!--META-->
  <Command Name="meta" IsBranch="false" 
ClrType="ScatGirl.Cli.Commands.MetaCommand" 
Settings="ScatGirl.Cli.Commands.MetaCommand+Settings">
    <Description>Show metadata about the ScatGirl CLI tool, including version 
and build information.</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
</Model>