{
  "opencli": "0.1-draft",
  "info": {
    "title": "scatgirl",
    "version": "1.0"
  },
  "commands": [
    {
      "name": "find",
      "options": [
        {
          "name": "--json",
          "required": false,
          "description": "Output results as JSON instead of formatted text",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--kind",
          "required": false,
          "aliases": [
            "-k"
          ],
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Filter by kind: class, interface, method, property, \nrecord, struct, enum, field, constructor, delegate, event",
          "recursive": false,
          "hidden": false
        }
      ],
      "arguments": [
        {
          "name": "root",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Path to the repository root",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        },
        {
          "name": "symbol",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Symbol name to find (e.g. IUserService, \nProcessPayment)",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "Find all declarations of a named symbol in a C# \ncodebase.",
      "hidden": false,
      "examples": [
        "find . IUserService",
        "find . ProcessPayment --kind method"
      ]
    },
