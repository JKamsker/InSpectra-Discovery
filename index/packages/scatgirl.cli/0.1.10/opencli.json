        {
          "name": "symbol",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Type name to inspect (e.g. AudioCaptureService)",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "List all members of a type declared in a C# codebase.",
      "hidden": false,
      "examples": [
        "members . AudioCaptureService",
        "members . AudioCaptureService --kind method",
        "members . SyntaxNavigator --in-file **/ScatGirl.Core/**"
