<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SHOW-->
  <Command Name="show" IsBranch="false" 
ClrType="AzOps.Sb.Commands.ServiceBusOverviewCommand" 
Settings="AzOps.Sb.Commands.ServiceBusOverviewCommand+Settings">
    <Parameters>
      <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show all topics and subscriptions even if there's no dead 
letters</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NAMESPACE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>ServiceBus namespace</Description>
      </Option>
      <Option Short="r" Long="resource-group" Value="RESOURCEGROUP" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>ServiceBus resource group</Description>
      </Option>
      <Option Short="s" Long="subscription-id" Value="SUBSCRIPTIONID" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Azure Subscription Id</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DEADLETTER-->
  <Command Name="deadletter" IsBranch="true" 
Settings="AzOps.Sb.Commands.DeadLetterSettings">
    <Parameters>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Limit</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>ServiceBus namespace</Description>
      </Option>
      <Option Short="s" Long="subscription" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>ServiceBus subscription</Description>
      </Option>
      <Option Short="t" Long="topic" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>ServiceBus topic</Description>
      </Option>
    </Parameters>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="AzOps.Sb.Commands.DeadLetterListCommand" 
Settings="AzOps.Sb.Commands.DeadLetterSettings">
      <Parameters>
        <Option Shadowed="true" Short="l" Long="limit" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.Int32">
          <Description>Limit</Description>
        </Option>
        <Option Shadowed="true" Short="n" Long="namespace" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>ServiceBus namespace</Description>
        </Option>
        <Option Shadowed="true" Short="s" Long="subscription" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>ServiceBus subscription</Description>
        </Option>
        <Option Shadowed="true" Short="t" Long="topic" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>ServiceBus topic</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REQUEUE-->
    <Command Name="requeue" IsBranch="false" 
ClrType="AzOps.Sb.Commands.DeadLetterRequeueCommand" 
Settings="AzOps.Sb.Commands.DeadLetterSettings">
      <Parameters>
        <Option Shadowed="true" Short="l" Long="limit" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.Int32">
          <Description>Limit</Description>
        </Option>
        <Option Shadowed="true" Short="n" Long="namespace" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>ServiceBus namespace</Description>
        </Option>
        <Option Shadowed="true" Short="s" Long="subscription" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>ServiceBus subscription</Description>
        </Option>
        <Option Shadowed="true" Short="t" Long="topic" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>ServiceBus topic</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>