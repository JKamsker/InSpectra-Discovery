<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SHOW-->
  <Command Name="show" IsBranch="false" 
ClrType="AzOps.Sb.Commands.ServiceBusOverviewCommand" 
Settings="AzOps.Sb.Commands.ServiceBusOverviewCommand+Settings">
    <Description>Lists Topics and Subscriptions for a Azure Service Bus 
Namespace with Dead Letters
It's possible to omit `--subscription-id` and `--resource-group` by adding them 
to ~/.netconfig
[[namespace "sb-magic-bus-test"]]
  resource-group = "rg-integration-test"
  subscription-id = "00000000-1111-2222-3333-444444444444"</Description>
    <Parameters>
      <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show all topics and subscriptions even if there's no dead 
letters</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NAMESPACE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>ServiceBus namespace</Description>
      </Option>
      <Option Short="r" Long="resource-group" Value="RESOURCEGROUP" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>ServiceBus resource group</Description>
      </Option>
      <Option Short="s" Long="subscription-id" Value="SUBSCRIPTIONID" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Azure Subscription Id</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="show" />
      <Example commandLine="--namespace" />
      <Example commandLine="sb-magic-bus-test" />
      <Example commandLine="--subscription-id" />
      <Example commandLine="00000000-1111-2222-3333-444444444444" />
      <Example commandLine="--resource-group" />
      <Example commandLine="rg-integration-test" />
      <Example commandLine="show" />
      <Example commandLine="--namespace" />
      <Example commandLine="sb-magic-bus-test" />
      <Example commandLine="show" />
      <Example commandLine="--namespace" />
      <Example commandLine="sb-magic-bus-test" />
      <Example commandLine="--all" />
    </Examples>
  </Command>
