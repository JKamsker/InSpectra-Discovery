<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="MilkyWare.Sarif.Converter.Commands.ConvertSarifCommand" 
Settings="MilkyWare.Sarif.Converter.Commands.ConvertSarifSettings">
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Increase logging verbosity to show all debug 
logs.</Description>
      </Option>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="MilkyWare.Sarif.Converter.Enums.FormatType">
        <Description>Format to convert SARIF to. Allowed values: JUnit, 
NUnit</Description>
      </Option>
      <Option Short="i" Long="input-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the input SARIF file</Description>
      </Option>
      <Option Short="o" Long="output-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to output the converted file to. Outputs to stdout if 
not specified</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="-i" />
      <Example commandLine="./test.sarif.json" />
      <Example commandLine="-f" />
      <Example commandLine="JUnit" />
      <Example commandLine="-i" />
      <Example commandLine="./test.sarif.json" />
      <Example commandLine="-o" />
      <Example commandLine="./test.xml" />
      <Example commandLine="-f" />
      <Example commandLine="JUnit" />
    </Examples>
  </Command>
</Model>