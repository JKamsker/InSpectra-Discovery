<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--START-->
  <Command Name="start" IsBranch="false" 
ClrType="SqlServerCoverage.CommandLine.StartCoverageCommand" 
Settings="SqlServerCoverage.CommandLine.StartCoverageCommand+Settings">
    <Parameters>
      <Option Short="" Long="connection-string" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The connection string to the SQLServer 
instance.</Description>
      </Option>
      <Option Short="" Long="database" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name of the database to trace coverage 
events.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--COLLECT-->
  <Command Name="collect" IsBranch="false" 
ClrType="SqlServerCoverage.CommandLine.CollectCoverageCommand" 
Settings="SqlServerCoverage.CommandLine.CollectCoverageCommand+Settings">
    <Parameters>
      <Option Short="" Long="connection-string" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The connection string to the SQLServer 
instance.</Description>
      </Option>
      <Option Short="" Long="html" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Whether to write an HTML report.</Description>
      </Option>
      <Option Short="" Long="id" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The name of session started with the start 
command.</Description>
      </Option>
      <Option Short="" Long="opencover" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Whether to write an opencover report. Will also write 
source files.</Description>
      </Option>
      <Option Short="" Long="output" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>The directory the reports will be written to.</Description>
      </Option>
      <Option Short="" Long="sonar" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Whether to write a sonar report. Will also write source 
files.</Description>
      </Option>
      <Option Short="" Long="sonar-base" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path to prepend to the source files path. Should be 
absolute or relative to sonar-project.properties.</Description>
      </Option>
      <Option Short="" Long="summary" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Whether to write a summary to the console.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--STOP-->
  <Command Name="stop" IsBranch="false" 
ClrType="SqlServerCoverage.CommandLine.StopCoverageCommand" 
Settings="SqlServerCoverage.CommandLine.StopCoverageCommand+Settings">
    <Parameters>
      <Option Short="" Long="connection-string" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The connection string to the SQLServer 
instance.</Description>
      </Option>
      <Option Short="" Long="id" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The name of session started with the start 
command.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--STOP-ALL-->
  <Command Name="stop-all" IsBranch="false" 
ClrType="SqlServerCoverage.CommandLine.StopAllCoverageCommand" 
Settings="SqlServerCoverage.CommandLine.StopAllCoverageCommand+Settings">
    <Parameters>
      <Option Short="" Long="connection-string" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The connection string to the SQLServer 
instance.</Description>
      </Option>
      <Option Short="" Long="only-missing-dbs" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Only stop sessions of missing dbs.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="SqlServerCoverage.CommandLine.ListSessionsCommand" 
Settings="SqlServerCoverage.CommandLine.ListSessionsCommand+Settings">
    <Parameters>
      <Option Short="" Long="connection-string" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The connection string to the SQLServer 
instance.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>