<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--TEMPLATE-->
  <Command Name="template" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Template management</Description>
    <!--INSTALL-->
    <Command Name="install" IsBranch="false" 
ClrType="BlazoreDx.Cli.Commands.TemplateInstallCommand" 
Settings="BlazoreDx.Cli.Commands.TemplateInstallCommand+Settings">
      <Description>Installs local .nupkg templates 
(Templates/**/nupkgs)</Description>
      <Parameters>
        <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Suppress dotnet new install output</Description>
        </Option>
        <Option Short="" Long="root" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Root directory of templates. Default: 
Templates</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--MODULE-->
  <Command Name="module" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Module operations</Description>
    <!--NEW-->
    <Command Name="new" IsBranch="false" 
ClrType="BlazoreDx.Cli.Commands.ModuleNewCommand" 
Settings="BlazoreDx.Cli.Commands.ModuleNewCommand+Settings">
      <Description>Creates a new module from an installed template</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Module name to create (without suffix), e.g., 
BookStore</Description>
        </Argument>
        <Option Short="" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output directory. Default: 
Modules/&lt;Project&gt;.&lt;Name&gt; (or 
Modules/BlazoreDx.&lt;Name&gt;)</Description>
        </Option>
        <Option Short="" Long="project" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Project name to prefix module, e.g., MyApp → 
MyApp.&lt;Module&gt;</Description>
        </Option>
        <Option Short="" Long="skip-sln" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip adding the project to the solution</Description>
        </Option>
        <Option Short="" Long="template" Value="SHORTNAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Template short name to use (dotnet new short 
name)</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--SOLUTION-->
  <Command Name="solution" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Solution operations</Description>
    <!--NEW-->
    <Command Name="new" IsBranch="false" 
ClrType="BlazoreDx.Cli.Commands.SolutionNewCommand" 
Settings="BlazoreDx.Cli.Commands.SolutionNewCommand+Settings">
      <Description>Creates a new solution from an installed 
template</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution name to create, e.g., MyApp</Description>
        </Argument>
        <Option Short="" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output directory. Default: ./&lt;Name&gt;</Description>
        </Option>
        <Option Short="" Long="template" Value="SHORTNAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Template short name to use (dotnet new short 
name)</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>