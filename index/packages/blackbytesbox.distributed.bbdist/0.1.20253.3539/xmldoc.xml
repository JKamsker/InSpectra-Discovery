<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DUMP-->
  <Command Name="dump" IsBranch="false" 
ClrType="BlackBytesBox.Distributed.bbdist.Commands.DumpCommand" 
Settings="BlackBytesBox.Distributed.bbdist.Commands.DumpCommand+Settings">
    <Description>The dump command.</Description>
    <Parameters>
      <Argument Name="Target" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The target to dump e.g. osversion</Description>
      </Argument>
      <Option Short="d" Long="delay" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Command delay</Description>
      </Option>
      <Option Short="f" Long="forceSuccess" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Throws and errorcode if command is not found.</Description>
      </Option>
      <Option Short="l" Long="loglevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="Serilog.Events.LogEventLevel">
        <Description>Minimum loglevel, valid values =&gt; 
Verbose,Debug,Information,Warning,Error,Fatal</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="dump" />
      <Example commandLine="osversion" />
      <Example commandLine="dump" />
      <Example commandLine="envars" />
      <Example commandLine="dump" />
      <Example commandLine="osversion" />
      <Example commandLine="--loglevel verbose" />
      <Example commandLine="--forceSuccess true" />
    </Examples>
  </Command>
  <!--VSCODE-->
  <Command Name="vscode" IsBranch="false" 
ClrType="BlackBytesBox.Distributed.bbdist.Commands.VsCodeCommand" 
Settings="BlackBytesBox.Distributed.bbdist.Commands.VsCodeCommand+Settings">
    <Description>Installs vscode.</Description>
    <Parameters>
      <Option Short="f" Long="forceSuccess" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Throws and errorcode if command is not found.</Description>
      </Option>
      <Option Short="l" Long="loglevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="Serilog.Events.LogEventLevel">
        <Description>Minimum loglevel, valid values =&gt; 
Verbose,Debug,Information,Warning,Error,Fatal</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="vscode" />
      <Example commandLine="--loglevel verbose" />
      <Example commandLine="--forceSuccess true" />
    </Examples>
  </Command>
  <!--SLN-->
  <Command Name="sln" IsBranch="false" 
ClrType="BlackBytesBox.Distributed.bbdist.Commands.SlnCommand" 
Settings="BlackBytesBox.Distributed.bbdist.Commands.SlnCommand+Settings">
    <Description>Read solution information.</Description>
    <Parameters>
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The full path to the solution file.</Description>
      </Option>
      <Option Short="i" Long="ignoreerrors" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If true, any errors encountered will be ignored and a 
success exit code (0) is returned.</Description>
      </Option>
      <Option Short="m" Long="minLogLevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="Serilog.Events.LogEventLevel">
        <Description>The minimum log level, valid values: Verbose, Debug, 
Information, Warning, Error, Fatal. Default is Warning.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="--solution" />
      <Example commandLine="--loglevel verbose" />
      <Example commandLine="--forceSuccess true" />
    </Examples>
  </Command>
  <!--CSPROJ-->
  <Command Name="csproj" IsBranch="false" 
ClrType="BlackBytesBox.Distributed.bbdist.Commands.CsProjCommand" 
Settings="BlackBytesBox.Distributed.bbdist.Commands.CsProjCommand+Settings">
    <Description>Retrieve project property information from a csproj 
file.</Description>
    <Parameters>
      <Option Short="" Long="elementscope" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="System.Nullable`1[[BlackBytesBox.Distributed.bbdist.Commands.CsProjComm
and+Settings+ElementScope, BlackBytesBox.Distributed.bbdist, 
Version=0.1.20253.3539, Culture=neutral, PublicKeyToken=null]]">
        <Description>Specifies the element scope; valid values: InnerElement 
(default) or OuterElement.</Description>
      </Option>
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The full path to the project file.</Description>
      </Option>
      <Option Short="i" Long="ignoreerrors" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If true, any errors encountered will be ignored and a 
success exit code (0) is returned.</Description>
      </Option>
      <Option Short="m" Long="minLogLevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="Serilog.Events.LogEventLevel">
        <Description>The minimum log level, valid values: Verbose, Debug, 
Information, Warning, Error, Fatal. Default is Warning.</Description>
      </Option>
      <Option Short="" Long="property" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name of the property to retrieve.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="--location &lt;file-path&gt;" />
      <Example commandLine="--property &lt;property-name&gt;" />
      <Example commandLine="--loglevel verbose" />
      <Example commandLine="--forceSuccess true" />
    </Examples>
  </Command>
</Model>