<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SERVE-->
  <Command Name="serve" IsBranch="false" 
ClrType="QuickMCP.CLI.Commands.Serve.ServerCommand" 
Settings="QuickMCP.CLI.Commands.Serve.ServerCommandSettings">
    <Description>Starts the MCP server with the provided configuration or 
arguments.</Description>
    <Parameters>
      <Option Short="a" Long="api-base-url" Value="API_BASE_URL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Base URL for the API.</Description>
      </Option>
      <Option Short="e" Long="config-env-var" Value="CONFIG_ENV_VAR" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The environment variable name pointing to the configuration
file.</Description>
      </Option>
      <Option Short="c" Long="config-path" Value="CONFIG_PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path to the configuration file.</Description>
      </Option>
      <Option Short="h" Long="host-protocol" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Host Protocol.STDIO or HTTP.</Description>
      </Option>
      <Option Short="l" Long="logging" Value="NULL" Required="false" Kind="flag"
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Enable verbose console logging.</Description>
      </Option>
      <Option Short="i" Long="server-id" Value="SERVER_ID" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name of the server to use.</Description>
      </Option>
      <Option Short="p" Long="spec-path" Value="SPEC_PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Path of the OpenAPI or Google Discovery 
specification.</Description>
      </Option>
      <Option Short="s" Long="spec-url" Value="SPEC_URL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The URL of the OpenAPI or Google Discovery 
specification.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="serve" />
      <Example commandLine="-c mcp_server_config.json" />
    </Examples>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="true" 
Settings="QuickMCP.CLI.Commands.Build.BuildCommandSettings">
    <Description>Build a MCP server configuration file and more</Description>
    <!--CONFIG-->
    <Command Name="config" IsBranch="false" 
ClrType="QuickMCP.CLI.Commands.Build.BuildConfigCommand" 
Settings="QuickMCP.CLI.Commands.Build.BuildConfigCommandSettings">
      <Description>Build MCP Server configurations from an OpenAPI or Google 
Discovery specification.</Description>
      <Parameters>
        <Option Short="k" Long="ai-api-key" Value="AI_API_KEY" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Google Gemini API Key for the metadata 
generation.</Description>
        </Option>
        <Option Short="m" Long="ai-metadata" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Generate AI metadata for the methods and 
parameters.</Description>
        </Option>
        <Option Short="a" Long="api-base-url" Value="API_BASE_URL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Base URL for the API.</Description>
        </Option>
        <Option Short="t" Long="api-type" Value="API_TYPE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>API Specification type OpenAPI (openapi) or Google 
discovery (discovery).</Description>
        </Option>
        <Option Short="" Long="auth,auth-type" Value="AUTH_TYPE" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>The type of authentication to use.</Description>
        </Option>
        <Option Short="x" Long="exclude-paths" Value="EXCLUDE_PATHS" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>Exclude api paths from the generated 
client.</Description>
        </Option>
        <Option Short="h" Long="host-protocol" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Host Protocol.STDIO or HTTP.</Description>
        </Option>
        <Option Short="f" Long="only-for-paths" Value="ONLY_FOR_PATHS" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>Only generate api paths for the specified 
paths.</Description>
        </Option>
        <Option Short="o" Long="output-path" Value="OUTPUT_PATH" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Output directory path for the generated 
client.</Description>
        </Option>
        <Option Short="n" Long="server-name" Value="SERVER_NAME" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>The name of the server to use.</Description>
        </Option>
        <Option Short="" Long="skip-auth-config" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Skip the authentication configuration at the end of 
build.</Description>
        </Option>
        <Option Short="p" Long="spec-path" Value="SPEC_PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The Path of the OpenAPI or Google Discovery 
specification.</Description>
        </Option>
        <Option Short="s" Long="spec-url" Value="SPEC_URL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The URL of the OpenAPI or Google Discovery 
specification.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SPEC-->
    <Command Name="spec" IsBranch="false" 
ClrType="QuickMCP.CLI.Commands.Build.BuildSpecCommand" 
Settings="QuickMCP.CLI.Commands.Build.BuildSpecCommandSettings">
      <Description>Builds an openapi spec from a documentation url</Description>
      <Parameters>
        <Option Short="d" Long="documentation-url" Value="URL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The URL to the api documentation to create the openapi 
spec from</Description>
        </Option>
        <Option Short="f" Long="firecrawl-api-key" Value="KEY" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The firecrawl api key to use for scraping the 
documentation</Description>
        </Option>
        <Option Short="k" Long="google-api-key" Value="KEY" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The Google Gemini api key to convert the documentation to
openapi specs</Description>
        </Option>
        <Option Short="o" Long="output-file" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The output file to write the openapi spec 
to</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="build spec" />
        <Example commandLine="-d url_to_documentation" />
      </Examples>
    </Command>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="true" 
Settings="QuickMCP.CLI.Commands.List.ListCommandSettings">
    <Description>List available configuration options such as 
authenticators</Description>
    <!--AUTH-->
    <Command Name="auth" IsBranch="false" 
ClrType="QuickMCP.CLI.Commands.ListAuthenticatorsCommand" 
Settings="QuickMCP.CLI.Commands.List.ListAuthenticatorsCommandSettings">
      <Description>List available configuration options such as 
authenticators</Description>
      <Parameters>
        <Argument Name="AUTHENTICATOR" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Authenticator type to list</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--SERVER-->
    <Command Name="server" IsBranch="false" 
ClrType="QuickMCP.CLI.Commands.List.ListServerCommand" 
Settings="QuickMCP.CLI.Commands.List.ListServerCommandSettings">
      <Description>List available servers</Description>
      <Parameters>
        <Option Short="f" Long="filter" Value="FILTER" Required="false" 
Kind="scalar" ClrType="System.String" />
      </Parameters>
    </Command>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="true" 
Settings="QuickMCP.CLI.Commands.Add.AddCommandSettings">
    <Description>Add a new configuration option e.g. server</Description>
    <!--SERVER-->
    <Command Name="server" IsBranch="false" 
ClrType="QuickMCP.CLI.Commands.Add.AddServerCommand" 
Settings="QuickMCP.CLI.Commands.Add.AddServerSettings">
      <Description>Add/Install a new server to directly use with 
commandline.</Description>
      <Parameters>
        <Argument Name="configuration file" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the configuration file</Description>
        </Argument>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Name of the server</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="add server" />
        <Example commandLine="/path/to/config.json -n MyServer" />
      </Examples>
    </Command>
  </Command>
  <!--DELETE-->
  <Command Name="delete" IsBranch="true" 
Settings="QuickMCP.CLI.Commands.Delete.DeleteCommandSettings">
    <Description>Add a new configuration option e.g. server</Description>
    <!--SERVER-->
    <Command Name="server" IsBranch="false" 
ClrType="QuickMCP.CLI.Commands.Delete.DeleteServerCommand" 
Settings="QuickMCP.CLI.Commands.Delete.DeleteServerCommandSettings">
      <Description>Delete a stored server</Description>
      <Parameters>
        <Argument Name="server name" Position="0" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Server name or Id</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="add server" />
        <Example commandLine="/path/to/config.json -n MyServer" />
      </Examples>
    </Command>
  </Command>
</Model>