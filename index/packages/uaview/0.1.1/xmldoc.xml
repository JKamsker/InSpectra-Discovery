<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="UaView.Tui.AppCommand" Settings="UaView.Tui.StartupSettings">
    <Parameters>
      <Argument Name="url" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>OPC UA server URL (e.g., 
opc.tcp://localhost:4840)</Description>
      </Argument>
      <Option Short="u" Long="user" Value="USERNAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Username for authentication (prompts for 
password)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="opc.tcp://localhost:4840" />
      <Example commandLine="-u" />
      <Example commandLine="admin" />
      <Example commandLine="opc.tcp://server" />
    </Examples>
  </Command>
</Model>