<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="EasyBuild.ChangelogGen.Commands.Generate+GenerateCommand" 
Settings="EasyBuild.ChangelogGen.Generate.Types+GenerateSettings">
    <Description>Generate changelog based on the Git history.
Learn more at 
https://github.com/easybuild-org/EasyBuild.ChangelogGen</Description>
    <Parameters>
      <Argument Name="changelog" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the changelog file. Default is 
CHANGELOG.md</Description>
      </Argument>
      <Option Short="" Long="allow-branch" Value="VALUES" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>List of branches that are allowed to be used to generate 
the changelog. Default is 'main'</Description>
      </Option>
      <Option Short="" Long="allow-dirty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Allow to run in a dirty repository (having not commit 
changes in your reporitory)</Description>
      </Option>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.FSharp.Core.FSharpOption`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Path to the configuration file</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Run the command without writing to the changelog file, 
output the new version content to STDOUT instead</Description>
      </Option>
      <Option Short="" Long="force-version" Value="VERSION" Required="false" 
Kind="scalar" ClrType="Microsoft.FSharp.Core.FSharpOption`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Force the version to be used in the changelog</Description>
      </Option>
      <Option Short="" Long="github-repo" Value="REPO" Required="false" 
Kind="scalar" ClrType="Microsoft.FSharp.Core.FSharpOption`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>GitHub repository name in format 'owner/repo'</Description>
      </Option>
      <Option Short="" Long="pre-release" Value="PREFIX" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Indicate that the generated version is a pre-release 
version. Optionally, you can provide a prefix for the beta version. Default is 
'beta'</Description>
      </Option>
      <Option Short="" Long="skip-invalid-commit" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip invalid commits instead of failing</Description>
      </Option>
      <Option Short="" Long="tag" Value="VALUES" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>List of tags to include in the changelog</Description>
      </Option>
    </Parameters>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="EasyBuild.ChangelogGen.Commands.Version+VersionCommand" 
Settings="EasyBuild.ChangelogGen.Commands.Version+VersionSettings" />
</Model>