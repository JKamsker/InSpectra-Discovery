<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--AI-->
  <Command Name="ai" IsBranch="false" ClrType="SolarScope.Commands.AiCommand" 
Settings="SolarScope.Commands.AiCommand+Settings">
    <Parameters>
      <Argument Name="PROMPT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Natural language prompt - ask questions or describe what 
you want to do</Description>
      </Argument>
      <Option Short="d" Long="data" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path or URL to the solar data JSON file</Description>
      </Option>
      <Option Short="x" Long="execute" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Execute the suggested command directly (use with 
caution)</Description>
      </Option>
      <Option Short="m" Long="model" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>AI model to use (github/gpt-4o, 
github/o4-mini)</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="SolarScope.Commands.AnalyzeCommand" 
Settings="SolarScope.Commands.AnalyzeCommand+Settings">
    <Parameters>
      <Option Short="c" Long="count" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of days/records to analyze</Description>
      </Option>
      <Option Short="d" Long="data" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path or URL to the solar data JSON file</Description>
      </Option>
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Type of analysis: production, weather, anomalies, 
correlation</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ANOMALIES-->
  <Command Name="anomalies" IsBranch="false" 
ClrType="SolarScope.Commands.AnomaliesCommand" 
Settings="SolarScope.Commands.AnomaliesCommand+Settings">
    <Parameters>
      <Option Short="d" Long="data" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path or URL to the solar data JSON file</Description>
      </Option>
      <Option Short="i" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Run in interactive mode</Description>
      </Option>
      <Option Short="s" Long="severity" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum anomaly severity (Low, Medium, High)</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
      <Option Short="y" Long="year" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Year to analyze (default: latest year in 
data)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DASHBOARD-->
  <Command Name="dashboard" IsBranch="false" 
ClrType="SolarScope.Commands.DashboardCommand" 
Settings="SolarScope.Commands.DashboardCommand+Settings">
    <Parameters>
      <Option Short="a" Long="animated" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show animated dashboard</Description>
      </Option>
      <Option Short="d" Long="data" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path or URL to the solar data JSON file</Description>
      </Option>
      <Option Short="f" Long="full" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show full dashboard with all details</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DEMO-->
  <Command Name="demo" IsBranch="false" 
ClrType="SolarScope.Commands.DemoCommand" 
Settings="SolarScope.Commands.DemoCommand+Settings">
    <Parameters>
      <Option Short="d" Long="data" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path or URL to the solar data JSON file</Description>
      </Option>
      <Option Short="s" Long="speed" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Animation speed: slow, normal, fast</Description>
      </Option>
      <Option Short="t" Long="theme" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Demo theme: solar, matrix, rainbow</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--EXPLORE-->
  <Command Name="explore" IsBranch="false" 
ClrType="SolarScope.Commands.ExploreCommand" 
Settings="SolarScope.Commands.ExploreCommand+Settings">
    <Parameters>
      <Option Short="d" Long="data" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path or URL to the solar data JSON file</Description>
      </Option>
      <Option Short="" Long="mode" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Exploration mode: quick, guided, or full</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
      <Option Short="" Long="year" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Year to explore (optional)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REPORT-->
  <Command Name="report" IsBranch="false" 
ClrType="SolarScope.Commands.ReportCommand" 
Settings="SolarScope.Commands.ReportCommand+Settings">
    <Parameters>
      <Option Short="d" Long="data" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path or URL to the solar data JSON file</Description>
      </Option>
      <Option Short="" Long="end-day" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>End day for daily report (optional)</Description>
      </Option>
      <Option Short="" Long="period" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Report period: daily, weekly, monthly, or 
yearly</Description>
      </Option>
      <Option Short="" Long="start-day" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Start day for daily report (optional)</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
      <Option Short="" Long="year" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Year to report (optional)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="SolarScope.Commands.VersionCommand" 
Settings="SolarScope.Commands.VersionCommand+Settings">
    <Description>Display version information</Description>
  </Command>
  <!--WEATHER-->
  <Command Name="weather" IsBranch="false" 
ClrType="SolarScope.Commands.WeatherCommand" 
Settings="SolarScope.Commands.WeatherCommand+Settings">
    <Parameters>
      <Option Short="" Long="analysis" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Analysis type: overview, correlation, patterns, or 
recommendations</Description>
      </Option>
      <Option Short="d" Long="data" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path or URL to the solar data JSON file</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
      <Option Short="" Long="year" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Year to analyze (optional)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>