<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.InitCommand" 
Settings="SwarmBender.Cli.Commands.InitCommand+Settings">
    <Parameters>
      <Argument Name="STACK_ID" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Optional stack id to scaffold (e.g., 'sso'). If omitted, 
only repo layout is created.</Description>
      </Argument>
      <Option Short="e" Long="env" Value="CSV" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Environments CSV used for overlays (default: 
dev,prod)</Description>
      </Option>
      <Option Short="" Long="root" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Root path (defaults to cwd).</Description>
      </Option>
    </Parameters>
  </Command>
  <!--RENDER-->
  <Command Name="render" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.RenderCommand" 
Settings="SwarmBender.Cli.Commands.RenderCommand+Settings">
    <Parameters>
      <Argument Name="STACK_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="appsettings-mode" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Appsettings mode: env|config (default env).</Description>
      </Option>
      <Option Short="e" Long="env" Value="ENV" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Environment (e.g., dev, prod).</Description>
      </Option>
      <Option Short="" Long="out-dir" Value="DIR" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Out dir (default ops/state/last).</Description>
      </Option>
      <Option Short="" Long="root" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Root path (defaults to cwd).</Description>
      </Option>
      <Option Short="" Long="write-history" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Write history (default true).</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SECRET-->
  <Command Name="secret" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.SecretListCommand" 
Settings="SwarmBender.Cli.Commands.SecretListCommand+Settings">
      <Parameters>
        <Argument Name="STACK_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Option Short="e" Long="env" Value="ENV" Required="false" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="root" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String" />
        <Option Short="" Long="show-values" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      </Parameters>
    </Command>
    <!--SYNC-->
    <Command Name="sync" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.SecretSyncCommand" 
Settings="SwarmBender.Cli.Commands.SecretSyncCommand+Settings">
      <Parameters>
        <Argument Name="STACK_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
        <Option Short="e" Long="env" Value="ENV" Required="false" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="prune-old" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
        <Option Short="" Long="root" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String" />
        <Option Short="" Long="show-values" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      </Parameters>
    </Command>
    <!--PRUNE-->
    <Command Name="prune" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.SecretPruneCommand" 
Settings="SwarmBender.Cli.Commands.SecretPruneCommand+Settings">
      <Parameters>
        <Argument Name="STACK_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
        <Option Short="e" Long="env" Value="ENV" Required="false" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="root" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String" />
      </Parameters>
    </Command>
    <!--DIFF-->
    <Command Name="diff" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.SecretDiffCommand" 
Settings="SwarmBender.Cli.Commands.SecretDiffCommand+Settings">
      <Parameters>
        <Argument Name="STACK_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Option Short="e" Long="env" Value="ENV" Required="false" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="root" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String" />
        <Option Short="" Long="show-matches" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      </Parameters>
    </Command>
  </Command>
  <!--UTILS-->
  <Command Name="utils" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--INFISICAL-->
    <Command Name="infisical" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <!--UPLOAD-->
      <Command Name="upload" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.InfisicalUploadCommand" 
Settings="SwarmBender.Cli.Commands.InfisicalUploadCommand+Settings">
        <Description>Upload discovered secrets to Infisical using 
SDK.</Description>
        <Parameters>
          <Argument Name="STACK_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
          <Option Short="" Long="diff-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
          <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
          <Option Short="e" Long="env" Value="ENV" Required="false" 
Kind="scalar" ClrType="System.String" />
          <Option Short="" Long="force" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
          <Option Short="" Long="root" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
          <Option Short="" Long="show-values" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
          <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
        </Parameters>
      </Command>
    </Command>
  </Command>
  <!--AZDO-->
  <Command Name="azdo" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--PIPELINE-->
    <Command Name="pipeline" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <!--INIT-->
      <Command Name="init" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.AzdoPipelineInitCommand" 
Settings="SwarmBender.Cli.Commands.AzdoPipelineInitCommand+Settings">
        <Parameters>
          <Argument Name="STACK_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
          <Option Short="" Long="force" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
          <Option Short="" Long="non-interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
          <Option Short="" Long="root" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
        </Parameters>
      </Command>
    </Command>
  </Command>
  <!--DOCTOR-->
  <Command Name="doctor" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--STAGE-->
    <Command Name="stage" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <!--LIST-->
      <Command Name="list" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.DoctorStageListCommand" 
Settings="SwarmBender.Cli.Commands.DoctorStageListCommand+Settings">
        <Parameters>
          <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
          <Option Short="" Long="namespace-filter" Value="TEXT" Required="false"
Kind="scalar" ClrType="System.String" />
        </Parameters>
      </Command>
    </Command>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--EXPORT-->
    <Command Name="export" IsBranch="false" 
ClrType="SwarmBender.Cli.Commands.ConfigExportCommand" 
Settings="SwarmBender.Cli.Commands.ConfigExportCommand+Settings">
      <Description>Export merged appsettings.json (tokens &amp; envvars 
expanded)</Description>
      <Parameters>
        <Argument Name="STACK_ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Stack identifier (e.g., sso)</Description>
        </Argument>
        <Option Short="e" Long="env" Value="ENV" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Environment (default: dev)</Description>
        </Option>
        <Option Short="" Long="no-history" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Do not write history artifacts</Description>
        </Option>
        <Option Short="o" Long="out" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Output appsettings.json path (optional). If omitted, 
written under render outDir.</Description>
        </Option>
        <Option Short="" Long="root" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Repository root (default: current 
directory)</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>