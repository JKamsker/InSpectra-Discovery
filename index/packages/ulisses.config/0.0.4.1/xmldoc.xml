<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CONNECTION-->
  <Command Name="connection" IsBranch="false" 
ClrType="config.Features.ConnectionStrings.GenerateConnectionStringsCommand" 
Settings="config.Features.ConnectionStrings.ConnectionStringsSettings">
    <Parameters>
      <Argument Name="user" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Argument Name="password" Position="1" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Argument Name="instance" Position="2" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="d" Long="display" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Display result in the terminal</Description>
      </Option>
      <Option Short="e" Long="export" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Overwrite the values of app settings</Description>
      </Option>
      <Option Short="" Long="search" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Directory to search appsettings.json or 
.config</Description>
      </Option>
      <Option Short="s" Long="select" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Select which database connection string will be generated 
for</Description>
      </Option>
    </Parameters>
  </Command>
  <!--APPSETTINGS-->
  <Command Name="appsettings" IsBranch="false" 
ClrType="config.Features.AppSettings.GenerateAppSettingsCommand" 
Settings="config.Features.AppSettings.GenerateKeysSettings">
    <Parameters>
      <Option Short="d" Long="display" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Display result in terminal</Description>
      </Option>
      <Option Short="e" Long="export" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Generate keys for json file</Description>
      </Option>
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Overwrite the values of app settings</Description>
      </Option>
      <Option Short="" Long="search" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Directory to search appsettings.json or 
.config</Description>
      </Option>
      <Option Short="s" Long="select" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Select which keys will be generated</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DATA-->
  <Command Name="data" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="config.Features.Data.CreateDataFilesCommand" 
Settings="config.Features._Shared.BaseSettings" />
    <!--DATABASE-->
    <Command Name="database" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <!--CREATE-->
      <Command Name="create" IsBranch="false" 
ClrType="config.Features.Database.Create.CreateDatabaseCommand" 
Settings="config.Features.Database.Create.CreateDatabaseSettings">
        <Parameters>
          <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
          <Argument Name="catalog" Position="1" Required="true" Kind="scalar" 
ClrType="System.String" />
          <Argument Name="appname" Position="2" Required="true" Kind="scalar" 
ClrType="System.String" />
          <Option Short="t" Long="timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32" />
        </Parameters>
      </Command>
      <!--REMOVE-->
      <Command Name="remove" IsBranch="false" 
ClrType="config.Features.Database.Remove.RemoveDatabaseCommand" 
Settings="config.Features.Database.Remove.RemoveDatabaseSettings" />
      <!--DISPLAY-->
      <Command Name="display" IsBranch="false" 
ClrType="config.Features.Database.Display.DisplayDatabaseCommand" 
Settings="config.Features.Database.Display.DisplayDatabaseSettings">
        <Parameters>
          <Option Short="j" Long="json" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
        </Parameters>
      </Command>
    </Command>
    <!--SETTINGS-->
    <Command Name="settings" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <!--CREATE-->
      <Command Name="create" IsBranch="false" 
ClrType="config.Features.Settings.Create.CreateSettingsCommand" 
Settings="config.Features.Settings.Create.CreateSettingSettings">
        <Parameters>
          <Argument Name="group" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
          <Argument Name="key" Position="1" Required="true" Kind="scalar" 
ClrType="System.String" />
          <Argument Name="value" Position="2" Required="true" Kind="scalar" 
ClrType="System.String" />
        </Parameters>
      </Command>
      <!--UPDATE-->
      <Command Name="update" IsBranch="false" 
ClrType="config.Features.Settings.Update.UpdateSettingsCommand" 
Settings="config.Features.Settings.Update.UpdateSettingSettings" />
      <!--REMOVE-->
      <Command Name="remove" IsBranch="false" 
ClrType="config.Features.Settings.Remove.RemoveSettingsCommand" 
Settings="config.Features.Settings.Remove.RemoveSettingSettings" />
      <!--DISPLAY-->
      <Command Name="display" IsBranch="false" 
ClrType="config.Features.Settings.Display.DisplaySettingsCommand" 
Settings="config.Features.Settings.Display.DisplaySettingSettings">
        <Parameters>
          <Option Short="j" Long="json" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
        </Parameters>
      </Command>
    </Command>
  </Command>
</Model>