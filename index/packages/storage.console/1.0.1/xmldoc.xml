<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--UPLOAD-->
  <Command Name="upload" IsBranch="false" 
ClrType="Storage.Console.Commands.UploadCommand" 
Settings="Storage.Console.Commands.UploadCommand+Settings">
    <Description>Upload a file or folder to Azure Blob Storage and get a 
read-only SAS URL</Description>
    <Parameters>
      <Argument Name="PROFILE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Storage profile name from config.yaml</Description>
      </Argument>
      <Argument Name="PATH" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>File or folder path to upload</Description>
      </Argument>
      <Option Short="" Long="expires" Value="DATE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Expiry date for the SAS URL (YYYY-MM-DD). Defaults to 30 
days from now.</Description>
      </Option>
      <Option Short="" Long="zipped" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force zip even for single files</Description>
      </Option>
    </Parameters>
  </Command>
</Model>