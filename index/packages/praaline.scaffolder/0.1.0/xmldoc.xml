<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--MATRIX-->
  <Command Name="matrix" IsBranch="false" 
ClrType="Scaffolder.Tool.FeatureMatrixCommand" 
Settings="Scaffolder.Tool.FeatureMatrixCommandSettings">
    <Description>Show the feature matrix from a base folder.</Description>
    <Parameters>
      <Option Short="f" Long="format" Value="FORMAT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format: table (default) or json.</Description>
      </Option>
      <Option Short="i" Long="input" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Input base directory. Defaults to the current 
directory.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="matrix" />
      <Example commandLine="matrix" />
      <Example commandLine="--input" />
      <Example commandLine="./scaffolds" />
      <Example commandLine="matrix" />
      <Example commandLine="--format" />
      <Example commandLine="json" />
    </Examples>
  </Command>
  <!--FILELIST-->
  <Command Name="filelist" IsBranch="false" 
ClrType="Scaffolder.Tool.FileListCommand" 
Settings="Scaffolder.Tool.FileListCommandSettings">
    <Description>Show the list of files that will be generated, based on the 
feature matrix from a base folder.</Description>
    <Parameters>
      <Option Short="f" Long="format" Value="FORMAT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format: table (default) or json.</Description>
      </Option>
      <Option Short="i" Long="input" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Input base directory. Defaults to the current 
directory.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="filelist" />
      <Example commandLine="filelist" />
      <Example commandLine="--input" />
      <Example commandLine="./scaffolds" />
      <Example commandLine="filelist" />
      <Example commandLine="--format" />
      <Example commandLine="json" />
    </Examples>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Scaffolder.Tool.GenerateCommand" 
Settings="Scaffolder.Tool.GenerateCommandSettings">
    <Description>Generate output files from the scaffolds.</Description>
    <Parameters>
      <Option Short="" Long="feature" Value="FEATURE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Only generate for this feature.</Description>
      </Option>
      <Option Short="i" Long="input" Value="PATH" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Input base directory. Defaults to the current 
directory.</Description>
      </Option>
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output base directory. Defaults to 
'&lt;input&gt;/../src-gen'.</Description>
      </Option>
      <Option Short="" Long="scaffold" Value="SCAFFOLD" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Only generate for this scaffold.</Description>
      </Option>
      <Option Short="" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Only generate for this template.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="generate" />
      <Example commandLine="--feature" />
      <Example commandLine="Meetings" />
      <Example commandLine="generate" />
      <Example commandLine="--scaffold" />
      <Example commandLine="Meeting" />
      <Example commandLine="generate" />
      <Example commandLine="--template" />
      <Example commandLine="WebApi" />
    </Examples>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Inspect and manage configuration.</Description>
    <!--LIST-DIRECTORIES-->
    <Command Name="list-directories" IsBranch="false" 
ClrType="Scaffolder.Tool.ConfigListDirectoriesCommand" 
Settings="Scaffolder.Tool.ConfigListDirectoriesSettings">
      <Description>Show effective directories and their source.</Description>
      <Examples>
        <Example commandLine="config" />
        <Example commandLine="list-directories" />
      </Examples>
    </Command>
    <!--SET-->
    <Command Name="set" IsBranch="false" 
ClrType="Scaffolder.Tool.ConfigSetPathCommand" 
Settings="Scaffolder.Tool.ConfigSetPathSettings">
      <Description>Set a path override in config.json. Keys: 
templates|data|cache|temp</Description>
      <Parameters>
        <Argument Name="KEY" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path key to set: templates | data | cache | 
temp</Description>
        </Argument>
        <Argument Name="PATH" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Directory path (supports ~ and %ENV% 
expansion).</Description>
        </Argument>
        <Option Short="" Long="no-create" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Do not create the directory if it does not 
exist.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="config" />
        <Example commandLine="set" />
        <Example commandLine="templates" />
        <Example commandLine="~/dev/scaffolder-templates" />
      </Examples>
    </Command>
    <!--UNSET-->
    <Command Name="unset" IsBranch="false" 
ClrType="Scaffolder.Tool.ConfigUnsetPathCommand" 
Settings="Scaffolder.Tool.ConfigUnsetPathSettings">
      <Description>Remove a path override from config.json. Keys: 
templates|data|cache|temp</Description>
      <Parameters>
        <Argument Name="KEY" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Path key to unset: templates | data | cache | 
temp</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="config" />
        <Example commandLine="unset" />
        <Example commandLine="templates" />
      </Examples>
    </Command>
  </Command>
</Model>