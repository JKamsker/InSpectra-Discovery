<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="SqlChangeTracker.Commands.InitCommand" 
Settings="SqlChangeTracker.Commands.InitCommandSettings">
    <Description>Initialize project configuration and schema folder 
structure.</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="" Long="project-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="false" 
ClrType="SqlChangeTracker.Commands.ConfigCommand" 
Settings="SqlChangeTracker.Commands.ConfigCommandSettings">
    <Description>Parse, validate, and write project configuration.</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="" Long="project-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" 
ClrType="SqlChangeTracker.Commands.StatusCommand" 
Settings="SqlChangeTracker.Commands.StatusCommandSettings">
    <Description>Show object-level differences.</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="" Long="project-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="target" Value="DB|FOLDER" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
  <!--DIFF-->
  <Command Name="diff" IsBranch="false" 
ClrType="SqlChangeTracker.Commands.DiffCommand" 
Settings="SqlChangeTracker.Commands.DiffCommandSettings">
    <Description>Show textual diffs.</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="" Long="object" Value="SCHEMA_NAME" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="project-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="target" Value="DB|FOLDER" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
  <!--PULL-->
  <Command Name="pull" IsBranch="false" 
ClrType="SqlChangeTracker.Commands.PullCommand" 
Settings="SqlChangeTracker.Commands.PullCommandSettings">
    <Description>Write database changes into the schema folder.</Description>
    <Parameters>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="" Long="project-dir" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
    </Parameters>
  </Command>
</Model>