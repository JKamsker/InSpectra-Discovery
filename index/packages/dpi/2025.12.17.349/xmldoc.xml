<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--NUGET-->
  <Command Name="nuget" IsBranch="true" 
Settings="DPI.Commands.Settings.NuGet.NuGetSettings">
    <Description>NuGet dependency commands.</Description>
    <Parameters>
      <Argument Name="SourcePath" Position="0" Required="false" Kind="scalar" 
ClrType="Cake.Core.IO.DirectoryPath">
        <Description>Specifies source path to scan for NuGet dependencies, if 
not specified working direcory used.</Description>
        <Validators>
          <Validator 
ClrType="DPI.Commands.Settings.Validation.ValidatePathAttribute" Message="NULL" 
/>
        </Validators>
      </Argument>
      <Option Short="f" Long="file" Value="FILEPATH" Required="false" 
Kind="scalar" ClrType="Cake.Core.IO.FilePath">
        <Description>Specifies optional result output file path.</Description>
      </Option>
      <Option Short="o" Long="output" Value="FORMAT" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[DPI.Models.OutputFormat, DPI, 
Version=2025.12.17.349, Culture=neutral, PublicKeyToken=null]]">
        <Description>Specifies optional result output format 
JSON,TABLE,MARKDOWN.</Description>
      </Option>
      <Option Short="s" Long="silent" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Supresses console logging</Description>
      </Option>
    </Parameters>
    <!--ANALYZE-->
    <Command Name="analyze" IsBranch="false" 
ClrType="DPI.Commands.NuGet.NuGetAnalyzeCommand`1[[DPI.Commands.Settings.NuGet.N
uGetAnalyzeSettings, DPI, Version=2025.12.17.349, Culture=neutral, 
PublicKeyToken=null]]" 
Settings="DPI.Commands.Settings.NuGet.NuGetAnalyzeSettings">
      <Description>Inventories NuGet packages</Description>
      <Parameters>
        <Option Short="b" Long="buildversion" Value="BUILDVERSION" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Specifies optional version of current 
build.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="nuget" />
        <Example commandLine="&lt;SourcePath&gt;" />
        <Example commandLine="analyze" />
      </Examples>
    </Command>
    <!--REPORT-->
    <Command Name="report" IsBranch="false" 
ClrType="DPI.Commands.NuGet.NuGetReportCommand" 
Settings="DPI.Commands.Settings.NuGet.NuGetReportSettings">
      <Description>Inventories NuGet packages and reports to Azure Log 
Analytics</Description>
      <Parameters>
        <Option Short="b" Long="buildversion" Value="BUILDVERSION" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Specifies optional version of current 
build.</Description>
        </Option>
        <Option Short="" Long="sharedkey" Value="SHAREDKEY" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Specifies Azure Log Analytics shared key, defaults to 
environment variable NuGetReportSettings_SharedKey.</Description>
        </Option>
        <Option Short="" Long="workspace" Value="WORKSPACEID" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Specifies Azure Log Analytics workspace id to log to, 
defaults to environment variable NuGetReportSettings_WorkspaceId.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="nuget" />
        <Example commandLine="&lt;SourcePath&gt;" />
        <Example commandLine="report" />
      </Examples>
    </Command>
  </Command>
</Model>