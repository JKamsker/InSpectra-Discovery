      </Option>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
      <Option Short="o" Long="output" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path of output file, default value is same as input 
file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="remove" />
      <Example commandLine="app.mydomain.local" />
      <Example commandLine="remove" />
      <Example commandLine="app.mydomain.local" />
      <Example commandLine="127.0.0.2" />
    </Examples>
  </Command>
  <!--ENABLE-->
  <Command Name="enable" IsBranch="false" ClrType="EnableCommand" 
Settings="EnableCommand+Settings">
    <Description>Enables entry in hosts file</Description>
    <Parameters>
      <Argument Name="hostname" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Host name, ex. app.mydomain.local</Description>
      </Argument>
      <Argument Name="ip" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>IP address, default is 127.0.0.1</Description>
      </Argument>
      <Option Short="i" Long="input" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path of input file, default value depends on operating 
