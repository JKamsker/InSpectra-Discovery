<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--TEMPLATE-->
  <Command Name="template" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--NEW-->
    <Command Name="new" IsBranch="false" ClrType="TemplateNewCommand" 
Settings="TemplateNewCommand+Settings">
      <Description>Creates a new template file</Description>
      <Parameters>
        <Option Short="t" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path of template file, default value is hosts.ht in 
working directory</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="template" />
        <Example commandLine="new" />
        <Example commandLine="template" />
        <Example commandLine="new" />
        <Example commandLine="--template" />
        <Example commandLine="hosts.Staging.ht" />
      </Examples>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" ClrType="TemplateListCommand" 
Settings="TemplateListCommand+Settings">
      <Description>Lists entries in the template file</Description>
      <Parameters>
        <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="t" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path of template file, default value is hosts.ht in 
working directory</Description>
        </Option>
      </Parameters>
    </Command>
    <!--ADD-->
    <Command Name="add" IsBranch="false" ClrType="TemplateAddCommand" 
Settings="TemplateAddCommand+Settings">
      <Description>Adds entry to the template file</Description>
      <Parameters>
        <Argument Name="hostname" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Host name, ex. app.mydomain.local</Description>
        </Argument>
        <Argument Name="ip" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>IP address, default is 127.0.0.1</Description>
        </Argument>
        <Argument Name="comment" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Comment for the entry</Description>
        </Argument>
        <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="t" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path of template file, default value is hosts.ht in 
working directory</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="template" />
        <Example commandLine="add" />
        <Example commandLine="app.mydomain.local" />
        <Example commandLine="template" />
        <Example commandLine="add" />
        <Example commandLine="app.mydomain.local" />
      </Examples>
    </Command>
    <!--REMOVE-->
    <Command Name="remove" IsBranch="false" ClrType="TemplateRemoveCommand" 
Settings="TemplateRemoveCommand+Settings">
      <Description>Removes entry from the template file</Description>
      <Parameters>
        <Argument Name="hostname" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Host name, ex. app.mydomain.local</Description>
        </Argument>
        <Argument Name="ip" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>IP address, default is 127.0.0.1</Description>
        </Argument>
        <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="t" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path of template file, default value is hosts.ht in 
working directory</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="template" />
        <Example commandLine="remove" />
        <Example commandLine="app.mydomain.local" />
        <Example commandLine="template" />
        <Example commandLine="remove" />
        <Example commandLine="app.mydomain.local" />
      </Examples>
    </Command>
    <!--APPLY-->
    <Command Name="apply" IsBranch="false" ClrType="TemplateApplyCommand" 
Settings="TemplateApplyCommand+Settings">
      <Description>Applies the template file to the hosts file</Description>
      <Parameters>
        <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output file</Description>
        </Option>
        <Option Short="t" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path of template file, default value is hosts.ht in 
working directory</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="template" />
        <Example commandLine="apply" />
        <Example commandLine="-o" />
        <Example commandLine="../samples/hosts" />
        <Example commandLine="-t" />
        <Example commandLine="hosts.Staging.ht" />
      </Examples>
    </Command>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" ClrType="ListCommand" 
Settings="ListCommand+Settings">
    <Description>List the entries in the hosts file</Description>
    <Parameters>
      <Option Short="i" Long="input" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path of input file, default value depends on operating 
system</Description>
      </Option>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list" />
      <Example commandLine="-i" />
      <Example commandLine="../samples/hosts" />
    </Examples>
  </Command>
  <!--BACKUP-->
  <Command Name="backup" IsBranch="false" ClrType="BackupCommand" 
Settings="BackupCommand+Settings">
    <Description>Backups the hosts file</Description>
    <Parameters>
      <Option Short="i" Long="input" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path of input file, default value depends on operating 
system</Description>
      </Option>
      <Option Short="o" Long="output" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path of output file, default value is same as input 
file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="backup" />
      <Example commandLine="-i" />
      <Example commandLine="../samples/hosts" />
      <Example commandLine="-o" />
      <Example commandLine="../samples/hosts.bak" />
    </Examples>
  </Command>
  <!--RESTORE-->
  <Command Name="restore" IsBranch="false" ClrType="RestoreCommand" 
Settings="RestoreCommand+Settings">
    <Description>Restores the hosts file from a backup</Description>
    <Parameters>
      <Option Short="i" Long="input" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path of input file, default value depends on operating 
system</Description>
      </Option>
      <Option Short="o" Long="output" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path of output file, default value is same as input 
file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="restore" />
      <Example commandLine="-i" />
      <Example commandLine="../samples/hosts.bak" />
      <Example commandLine="-o" />
      <Example commandLine="../samples/hosts" />
    </Examples>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" ClrType="AddCommand" 
Settings="AddCommand+Settings">
    <Description>Adds entry to the hosts file</Description>
    <Parameters>
      <Argument Name="hostname" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Host name, ex. app.mydomain.local</Description>
      </Argument>
      <Argument Name="ip" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>IP address, default is 127.0.0.1</Description>
      </Argument>
      <Argument Name="comment" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Comment for the entry</Description>
      </Argument>
      <Option Short="i" Long="input" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path of input file, default value depends on operating 
system</Description>
      </Option>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
      <Option Short="o" Long="output" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path of output file, default value is same as input 
file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="add" />
      <Example commandLine="app.mydomain.local" />
      <Example commandLine="add" />
      <Example commandLine="app.mydomain.local" />
      <Example commandLine="127.0.0.2" />
    </Examples>
  </Command>
  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" ClrType="RemoveCommand" 
Settings="RemoveCommand+Settings">
    <Description>Removes entry from hosts file</Description>
    <Parameters>
      <Argument Name="hostname" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Host name, ex. app.mydomain.local</Description>
      </Argument>
      <Argument Name="ip" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>IP address, default is 127.0.0.1</Description>
      </Argument>
      <Option Short="i" Long="input" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path of input file, default value depends on operating 
