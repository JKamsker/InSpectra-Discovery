<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--IMPORT-->
  <Command Name="import" IsBranch="false" 
ClrType="CodexAuthManager.Cli.Commands.ImportCommand" 
Settings="CodexAuthManager.Cli.Commands.ImportSettings">
    <Description>Scan and import *auth.json files from the Codex 
folder</Description>
    <Parameters>
      <Option Short="f" Long="folder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Folder path to scan (defaults to Codex 
folder)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="import" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="CodexAuthManager.Cli.Commands.ListCommand" 
Settings="CodexAuthManager.Cli.Commands.ListSettings">
    <Description>List all stored identities/tokens</Description>
    <Examples>
      <Example commandLine="list" />
    </Examples>
  </Command>
  <!--SHOW-->
  <Command Name="show" IsBranch="false" 
ClrType="CodexAuthManager.Cli.Commands.ShowCommand" 
Settings="CodexAuthManager.Cli.Commands.ShowSettings">
    <Description>Show identity details (current one by default)</Description>
    <Parameters>
      <Argument Name="identifier" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Identity ID, email, or leave empty for active 
identity</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="show" />
      <Example commandLine="show" />
      <Example commandLine="2" />
      <Example commandLine="show" />
      <Example commandLine="user@example.com" />
    </Examples>
  </Command>
  <!--ACTIVATE-->
  <Command Name="activate" IsBranch="false" 
ClrType="CodexAuthManager.Cli.Commands.ActivateCommand" 
Settings="CodexAuthManager.Cli.Commands.ActivateSettings">
    <Description>Mark an identity as active and update auth.json</Description>
    <Parameters>
      <Argument Name="identifier" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Identity ID or email to activate</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="activate" />
      <Example commandLine="2" />
      <Example commandLine="activate" />
      <Example commandLine="user@example.com" />
    </Examples>
  </Command>
  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" 
ClrType="CodexAuthManager.Cli.Commands.RemoveCommand" 
Settings="CodexAuthManager.Cli.Commands.RemoveSettings">
    <Description>Delete one or more identities</Description>
    <Parameters>
      <Argument Name="identifiers" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
        <Description>One or more identity IDs or emails to remove</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="remove" />
      <Example commandLine="2" />
      <Example commandLine="remove" />
      <Example commandLine="user@example.com" />
      <Example commandLine="remove" />
      <Example commandLine="1" />
      <Example commandLine="2" />
      <Example commandLine="3" />
    </Examples>
  </Command>
  <!--ROLLBACK-->
  <Command Name="rollback" IsBranch="false" 
ClrType="CodexAuthManager.Cli.Commands.RollbackCommand" 
Settings="CodexAuthManager.Cli.Commands.RollbackSettings">
    <Description>Restore a previous version of an identity</Description>
    <Parameters>
      <Argument Name="identifier" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Identity ID, email, or leave empty for active 
identity</Description>
      </Argument>
      <Option Short="v" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Version number to rollback to (defaults to previous 
version)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="rollback" />
      <Example commandLine="rollback" />
      <Example commandLine="2" />
      <Example commandLine="rollback" />
      <Example commandLine="user@example.com" />
      <Example commandLine="--version" />
      <Example commandLine="3" />
    </Examples>
  </Command>
  <!--STATS-->
  <Command Name="stats" IsBranch="false" 
ClrType="CodexAuthManager.Cli.Commands.StatsCommand" 
Settings="CodexAuthManager.Cli.Commands.StatsSettings">
    <Description>Retrieve and save current usage statistics (5h limit, weekly 
limit)</Description>
    <Parameters>
      <Argument Name="identifier" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Identity ID, email, 'all' for all users, or leave empty for
active identity</Description>
      </Argument>
      <Option Short="r" Long="refresh" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Refresh stats from Codex before displaying</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="stats" />
      <Example commandLine="stats" />
      <Example commandLine="2" />
      <Example commandLine="stats" />
      <Example commandLine="user@example.com" />
    </Examples>
  </Command>
  <!--STATS-ENTRY-->
  <Command Name="stats-entry" IsBranch="false" 
ClrType="CodexAuthManager.Cli.Commands.StatsEntryCommand" 
Settings="CodexAuthManager.Cli.Commands.StatsEntrySettings">
    <Description>Manually enter usage statistics (interactive)</Description>
    <Parameters>
      <Argument Name="identifier" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Identity ID, email, or leave empty for active 
identity</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="stats-entry" />
      <Example commandLine="stats-entry" />
      <Example commandLine="2" />
      <Example commandLine="stats-entry" />
      <Example commandLine="user@example.com" />
    </Examples>
  </Command>
</Model>