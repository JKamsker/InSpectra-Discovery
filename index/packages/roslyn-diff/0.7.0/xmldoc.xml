<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DIFF-->
  <Command Name="diff" IsBranch="false" 
ClrType="RoslynDiff.Cli.Commands.DiffCommand" 
Settings="RoslynDiff.Cli.Commands.DiffCommand+Settings">
    <Description>Compare two files or directories and display the 
differences</Description>
    <Parameters>
      <Argument Name="old-file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the original file</Description>
      </Argument>
      <Argument Name="new-file" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the modified file</Description>
      </Argument>
      <Option Short="C" Long="context" Value="LINES" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Lines of context to show [[default: 3]]</Description>
      </Option>
      <Option Short="" Long="git" Value="PATH" Required="false" Kind="flagvalue"
ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, System.Private.CoreLib,
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Git-style unified diff (stdout if no file 
specified)</Description>
      </Option>
      <Option Short="" Long="html" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>HTML report to file (required: file path)</Description>
      </Option>
      <Option Short="w" Long="ignore-whitespace" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Ignore whitespace differences</Description>
      </Option>
      <Option Short="" Long="impact-level" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum impact level: breaking-public, breaking-internal, 
non-breaking, all [[default: all for HTML, breaking-internal for 
JSON]]</Description>
      </Option>
      <Option Short="" Long="include-formatting" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include formatting-only changes (whitespace, 
comments)</Description>
      </Option>
      <Option Short="" Long="include-non-impactful" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Include non-impactful changes in JSON output</Description>
      </Option>
      <Option Short="" Long="json" Value="PATH" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>JSON output (stdout if no file specified)</Description>
      </Option>
      <Option Short="m" Long="mode" Value="MODE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Diff mode: auto, roslyn, or line [[default: 
auto]]</Description>
      </Option>
      <Option Short="" Long="no-color" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Disable colored output</Description>
      </Option>
      <Option Short="" Long="open" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Open HTML in default browser after generation</Description>
      </Option>
      <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Suppress default console output</Description>
      </Option>
      <Option Short="" Long="text" Value="PATH" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Plain text diff (stdout if no file specified)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="diff" />
      <Example commandLine="old.cs" />
      <Example commandLine="new.cs" />
      <Example commandLine="diff" />
      <Example commandLine="--format" />
      <Example commandLine="json" />
      <Example commandLine="before/" />
      <Example commandLine="after/" />
      <Example commandLine="diff" />
      <Example commandLine="--ignore-whitespace" />
      <Example commandLine="file1.cs" />
      <Example commandLine="file2.cs" />
    </Examples>
  </Command>
  <!--CLASS-->
  <Command Name="class" IsBranch="false" 
ClrType="RoslynDiff.Cli.Commands.ClassCommand" 
Settings="RoslynDiff.Cli.Commands.ClassCommand+Settings">
    <Description>Compare specific classes between two files</Description>
    <Parameters>
      <Argument Name="OLD-SPEC" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Old file specification (file.cs:ClassName or 
file.cs)</Description>
      </Argument>
      <Argument Name="NEW-SPEC" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>New file specification (file.cs:ClassName or 
file.cs)</Description>
      </Argument>
      <Option Short="" Long="git" Value="PATH" Required="false" Kind="flagvalue"
ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, System.Private.CoreLib,
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Git-style unified diff (stdout if no file 
specified)</Description>
      </Option>
      <Option Short="" Long="html" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>HTML report to file (required: file path)</Description>
      </Option>
      <Option Short="i" Long="interface" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Interface name for interface matching 
strategy</Description>
      </Option>
      <Option Short="" Long="json" Value="PATH" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>JSON output (stdout if no file specified)</Description>
      </Option>
      <Option Short="m" Long="match-by" Value="STRATEGY" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Matching strategy: exact, interface, similarity, or 
auto</Description>
      </Option>
      <Option Short="" Long="no-color" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Disable colored output</Description>
      </Option>
      <Option Short="" Long="open" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Open HTML in default browser after generation</Description>
      </Option>
      <Option Short="" Long="quiet" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Suppress default console output</Description>
      </Option>
      <Option Short="s" Long="similarity" Value="THRESHOLD" Required="false" 
Kind="scalar" ClrType="System.Double">
        <Description>Similarity threshold for similarity matching 
(0.0-1.0)</Description>
      </Option>
      <Option Short="" Long="text" Value="PATH" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Plain text diff (stdout if no file specified)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="class" />
      <Example commandLine="old.cs:Foo" />
      <Example commandLine="new.cs:Foo" />
      <Example commandLine="class" />
      <Example commandLine="old.cs:Foo" />
      <Example commandLine="new.cs:Bar" />
      <Example commandLine="class" />
      <Example commandLine="old.cs:Foo" />
      <Example commandLine="new.cs" />
      <Example commandLine="--match-by" />
      <Example commandLine="similarity" />
      <Example commandLine="class" />
      <Example commandLine="old.cs" />
      <Example commandLine="new.cs" />
      <Example commandLine="--match-by" />
      <Example commandLine="interface" />
      <Example commandLine="--interface" />
      <Example commandLine="IRepository" />
      <Example commandLine="class" />
      <Example commandLine="old.cs:Foo" />
      <Example commandLine="new.cs:Foo" />
      <Example commandLine="--output" />
      <Example commandLine="json" />
      <Example commandLine="class" />
      <Example commandLine="old.cs:Foo" />
      <Example commandLine="new.cs:Foo" />
      <Example commandLine="--out-file" />
      <Example commandLine="result.html" />
      <Example commandLine="--output" />
      <Example commandLine="html" />
    </Examples>
  </Command>
</Model>