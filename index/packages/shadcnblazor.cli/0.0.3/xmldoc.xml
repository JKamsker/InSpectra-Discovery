<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--NEW-->
  <Command Name="new" IsBranch="false" 
ClrType="ShadcnBlazor.Cli.Commands.NewCommand" 
Settings="ShadcnBlazor.Cli.Commands.NewCommand+NewSettings">
    <Description>Creates a new Blazor project from a template.</Description>
    <Parameters>
      <Option Short="n" Long="namespace" Value="NS" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Root namespace for generated code.</Description>
      </Option>
      <Option Short="" Long="net" Value="VERSION" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Target .NET version (9 only for now).</Description>
      </Option>
      <Option Short="o" Long="out" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Output directory. Default: ./{proj}</Description>
      </Option>
      <Option Short="p" Long="proj" Value="NAME" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project name (also used as default output 
folder).</Description>
      </Option>
      <Option Short="" Long="server" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use the Blazor Server (global interactivity) 
template.</Description>
      </Option>
      <Option Short="" Long="wasm" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use the WebAssembly standalone template.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REPAIR-->
  <Command Name="repair" IsBranch="false" 
ClrType="ShadcnBlazor.Cli.Commands.RepairCommand" 
Settings="ShadcnBlazor.Cli.Commands.RepairCommand+RepairSettings">
    <Description>Re-add Shared component with overwrite. Use if setup was broken
or incomplete.</Description>
    <Parameters>
      <Option Short="" Long="silent" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Mutes output.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--COMPONENT-->
  <Command Name="component" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Component management. Shared and its dependencies are added 
automatically.</Description>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="ShadcnBlazor.Cli.Commands.Components.AddCommand" 
Settings="ShadcnBlazor.Cli.Commands.Components.AddCommand+AddSettings">
      <Description>Adds a component to a project. Runs first-time setup 
automatically if needed.</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The name of the component to add. (input, textarea, 
checkbox, etc.) Omit when using --all.</Description>
        </Argument>
        <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Adds all available components.</Description>
        </Option>
        <Option Short="" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Overwrite if component already exists (no 
prompt).</Description>
        </Option>
        <Option Short="" Long="silent" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Mutes output.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="ShadcnBlazor.Cli.Commands.Components.ListCommand" 
Settings="ShadcnBlazor.Cli.Commands.Components.ListCommand+ListSettings">
      <Description>Lists all available components.</Description>
    </Command>
    <!--INFO-->
    <Command Name="info" IsBranch="false" 
ClrType="ShadcnBlazor.Cli.Commands.Components.InfoCommand" 
Settings="ShadcnBlazor.Cli.Commands.Components.InfoCommand+InfoSettings">
      <Description>Displays details related to a component.</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The name of the component. (input, textarea, checkbox, 
etc.)</Description>
        </Argument>
      </Parameters>
    </Command>
  </Command>
</Model>