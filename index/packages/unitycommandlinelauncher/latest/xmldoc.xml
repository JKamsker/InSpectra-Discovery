<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--OPEN-->
  <Command Name="open" IsBranch="false" ClrType="OpenCommand" 
Settings="OpenSettings">
    <Description>Open Unity Editor for a project search path or via recent 
projects prompt</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Directory to be searched for a Unity project or path to 
ProjectVersion.txt (omit for interactive prompt)</Description>
      </Argument>
      <Option Short="c" Long="code-editor" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Open the solution file in the default code 
editor</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show what would be executed without actually running 
mutating commands.</Description>
      </Option>
      <Option Short="f" Long="favorite,favorites" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show only favorite projects in interactive 
selection</Description>
      </Option>
      <Option Short="" Long="no-hub-args" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Do not use CLI arguments from Unity Hub</Description>
      </Option>
      <Option Short="o" Long="only-code-editor" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Open only the code editor without launching 
Unity</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip interactive confirmation prompts and assume 
yes.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="open" />
      <Example commandLine="open" />
      <Example commandLine="--favorite" />
      <Example commandLine="open" />
      <Example commandLine="." />
      <Example commandLine="open" />
      <Example commandLine="searchPath" />
      <Example commandLine="--no-hub-args" />
      <Example commandLine="--" />
      <Example commandLine="-batchmode" />
      <Example commandLine="-quit" />
      <Example commandLine="open" />
      <Example commandLine="searchPath" />
      <Example commandLine="--no-hub-args" />
      <Example commandLine="open" />
      <Example commandLine="searchPath" />
      <Example commandLine="--code-editor" />
      <Example commandLine="open" />
      <Example commandLine="searchPath" />
      <Example commandLine="--only-code-editor" />
      <Example commandLine="open" />
      <Example commandLine="searchPath" />
      <Example commandLine="--" />
      <Example commandLine="-batchmode" />
      <Example commandLine="-quit" />
    </Examples>
  </Command>
  <!--CREATE-->
  <Command Name="create" IsBranch="false" ClrType="CreateCommand" 
Settings="CreateSettings">
    <Description>Create a new Unity project</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path where the Unity project should be 
created</Description>
      </Argument>
      <Argument Name="version" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Unity version (e.g., 2022.3.10f1)</Description>
      </Argument>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show what would be executed without actually running 
mutating commands.</Description>
      </Option>
      <Option Short="m" Long="minimal" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Creates a bare-minimum project (fast)</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip interactive confirmation prompts and assume 
yes.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="create" />
      <Example commandLine="path/to/new/project" />
      <Example commandLine="create" />
      <Example commandLine="path/to/new/project" />
      <Example commandLine="--minimal" />
      <Example commandLine="create" />
      <Example commandLine="path/to/new/project" />
      <Example commandLine="2023.2.10f1" />
    </Examples>
  </Command>
