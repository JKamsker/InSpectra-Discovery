<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CREATE-->
  <Command Name="create" IsBranch="false" 
ClrType="Noundry.Jobs.Cli.Commands.CreateCommand" 
Settings="Noundry.Jobs.Cli.Commands.CreateCommandSettings">
    <Description>Create a new scheduled job</Description>
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the job</Description>
      </Argument>
      <Argument Name="script-path" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the C# script file (.linq, .csx, .cs)</Description>
      </Argument>
      <Argument Name="schedule" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Cron schedule expression (e.g., '0 2 * * *' for daily at 2 
AM)</Description>
      </Argument>
      <Option Short="d" Long="description" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Description of the job</Description>
      </Option>
      <Option Short="w" Long="working-directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Working directory for the job</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="create" />
      <Example commandLine="MyJob" />
      <Example commandLine="script.csx" />
      <Example commandLine="0 2 * * *" />
      <Example commandLine="create" />
      <Example commandLine="MyJob" />
      <Example commandLine="script.linq" />
      <Example commandLine="*/15 * * * *" />
      <Example commandLine="-d" />
      <Example commandLine="Runs every 15 minutes" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="Noundry.Jobs.Cli.Commands.ListCommand" 
Settings="Noundry.Jobs.Cli.Commands.ListCommandSettings">
    <Description>List all scheduled jobs</Description>
    <Examples>
      <Example commandLine="list" />
    </Examples>
  </Command>
  <!--SHOW-->
  <Command Name="show" IsBranch="false" 
ClrType="Noundry.Jobs.Cli.Commands.ShowCommand" 
Settings="Noundry.Jobs.Cli.Commands.ShowCommandSettings">
    <Description>Show details of a specific job</Description>
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the job to show</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="show" />
      <Example commandLine="MyJob" />
    </Examples>
  </Command>
  <!--DELETE-->
  <Command Name="delete" IsBranch="false" 
ClrType="Noundry.Jobs.Cli.Commands.DeleteCommand" 
Settings="Noundry.Jobs.Cli.Commands.DeleteCommandSettings">
    <Description>Delete a scheduled job</Description>
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the job to delete</Description>
      </Argument>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip confirmation prompt</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="delete" />
      <Example commandLine="MyJob" />
      <Example commandLine="delete" />
      <Example commandLine="MyJob" />
      <Example commandLine="-y" />
    </Examples>
  </Command>
</Model>