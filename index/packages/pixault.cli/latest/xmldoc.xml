<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage CLI configuration</Description>
    <!--INIT-->
    <Command Name="init" IsBranch="false" 
ClrType="Pixault.Cli.Commands.Config.ConfigInitCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Interactive setup wizard</Description>
    </Command>
    <!--SHOW-->
    <Command Name="show" IsBranch="false" 
ClrType="Pixault.Cli.Commands.Config.ConfigShowCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Display current configuration</Description>
    </Command>
  </Command>
  <!--UPLOAD-->
  <Command Name="upload" IsBranch="false" 
ClrType="Pixault.Cli.Commands.Upload.UploadCommand" 
Settings="Pixault.Cli.Commands.Upload.UploadSettings">
    <Description>Upload file(s) to Pixault</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>File path or glob pattern to upload</Description>
      </Argument>
      <Option Short="" Long="alt" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Alt text / description</Description>
      </Option>
      <Option Short="" Long="folder" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Destination folder</Description>
      </Option>
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Project ID (overrides config default)</Description>
      </Option>
      <Option Short="" Long="tags" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Comma-separated tags</Description>
      </Option>
    </Parameters>
  </Command>
  <!--IMAGES-->
  <Command Name="images" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage images</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Pixault.Cli.Commands.Images.ImagesListCommand" 
Settings="Pixault.Cli.Commands.Images.ImagesListSettings">
      <Description>List images with pagination</Description>
      <Parameters>
        <Option Short="" Long="author" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter by author</Description>
        </Option>
        <Option Short="c" Long="category" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter by category</Description>
        </Option>
        <Option Short="" Long="cursor" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Pagination cursor</Description>
        </Option>
        <Option Short="" Long="folder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter by folder</Description>
        </Option>
        <Option Short="k" Long="keyword" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Filter by keyword</Description>
        </Option>
        <Option Short="l" Long="limit" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Number of images to return</Description>
        </Option>
        <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Project ID (overrides config default)</Description>
        </Option>
        <Option Short="s" Long="search" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Search query</Description>
        </Option>
        <Option Short="" Long="video" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Show only videos</Description>
        </Option>
      </Parameters>
    </Command>
    <!--GET-->
    <Command Name="get" IsBranch="false" 
ClrType="Pixault.Cli.Commands.Images.ImagesGetCommand" 
Settings="Pixault.Cli.Commands.Images.ImagesGetSettings">
      <Description>Get image details</Description>
      <Parameters>
        <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Image ID</Description>
        </Argument>
        <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Project ID (overrides config default)</Description>
        </Option>
