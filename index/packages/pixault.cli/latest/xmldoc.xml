    <!--URL-->
    <Command Name="url" IsBranch="false" 
ClrType="Pixault.Cli.Commands.Images.ImagesUrlCommand" 
Settings="Pixault.Cli.Commands.Images.ImagesUrlSettings">
      <Description>Generate CDN URL with transforms</Description>
      <Parameters>
        <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Image ID</Description>
        </Argument>
        <Option Short="" Long="blur" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Blur radius</Description>
        </Option>
        <Option Short="" Long="fit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Fit mode: cover, contain, fill, pad</Description>
        </Option>
        <Option Short="" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output format (webp, png, jpg, avif)</Description>
        </Option>
        <Option Short="h" Long="height" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Height in pixels</Description>
        </Option>
        <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Project ID (overrides config default)</Description>
        </Option>
        <Option Short="q" Long="quality" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Quality (1-100)</Description>
        </Option>
        <Option Short="t" Long="transform" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Named transform to apply</Description>
        </Option>
        <Option Short="w" Long="width" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Width in pixels</Description>
        </Option>
      </Parameters>
    </Command>
