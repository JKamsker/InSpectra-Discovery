        </Option>
        <Option Short="" Long="caption" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Image caption</Description>
        </Option>
        <Option Short="" Long="category" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Image category</Description>
        </Option>
        <Option Short="" Long="description" Value="NULL" Required="false" 
