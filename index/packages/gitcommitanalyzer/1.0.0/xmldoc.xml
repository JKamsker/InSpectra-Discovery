<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="GitCommitAnalyzer.Commands.AnalyzeCommand" 
Settings="GitCommitAnalyzer.Commands.AnalyzeSettings">
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the Git repository to analyze</Description>
      </Argument>
      <Option Short="d" Long="days" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of days to analyze (default: 90)</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output path for JSON export (optional)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="." />
      <Example commandLine="--days" />
      <Example commandLine="30" />
      <Example commandLine="/path/to/repo" />
      <Example commandLine="--days" />
      <Example commandLine="60" />
      <Example commandLine="--output" />
      <Example commandLine="stats.json" />
    </Examples>
  </Command>
</Model>