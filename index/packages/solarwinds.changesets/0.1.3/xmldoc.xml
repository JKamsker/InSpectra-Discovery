<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="SolarWinds.Changesets.Commands.Add.AddChangesetCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="SolarWinds.Changesets.Commands.Init.InitChangesetCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Sets up the .changeset folder and generates a default config 
file. You should run this command once when you are setting up 
changesets.</Description>
    <Examples>
      <Example commandLine="changeset" />
      <Example commandLine="init" />
    </Examples>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="SolarWinds.Changesets.Commands.Add.AddChangesetCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Used by contributors to add information about their changes by 
creating changeset files.</Description>
    <Examples>
      <Example commandLine="changeset" />
      <Example commandLine="add" />
    </Examples>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="SolarWinds.Changesets.Commands.Version.VersionChangesetCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Takes existing changeset files and updates versions and 
dependencies of packages, as well as writing changelogs.</Description>
    <Examples>
      <Example commandLine="changeset" />
      <Example commandLine="version" />
    </Examples>
  </Command>
  <!--PUBLISH-->
  <Command Name="publish" IsBranch="false" 
ClrType="SolarWinds.Changesets.Commands.Publish.PublishChangesetCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>This publishes changes to specified nuget 
repository.</Description>
    <Examples>
      <Example commandLine="changeset" />
      <Example commandLine="publish" />
    </Examples>
  </Command>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" 
ClrType="SolarWinds.Changesets.Commands.Status.StatusChangesetCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Provides information about the changesets that currently exist.
If there are no changesets present, it exits with an error status 
code.</Description>
    <Examples>
      <Example commandLine="changeset" />
      <Example commandLine="status" />
    </Examples>
  </Command>
</Model>