<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ENCODE-->
  <Command Name="encode" IsBranch="false" ClrType="deicrypt.EncodeCommand" 
Settings="deicrypt.EncodeSettings">
    <Description>Encode file</Description>
    <Parameters>
      <Argument Name="inputFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The unencoded source file.</Description>
      </Argument>
      <Argument Name="outputFile" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The encoded output file.</Description>
      </Argument>
      <Option Short="" Long="compress" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="encode" />
      <Example commandLine="inputfile" />
      <Example commandLine="outputfile" />
      <Example commandLine="encode" />
      <Example commandLine="inputfile" />
      <Example commandLine="outputfile" />
      <Example commandLine="--compress" />
    </Examples>
  </Command>
  <!--DECODE-->
  <Command Name="decode" IsBranch="false" ClrType="deicrypt.DecodeCommand" 
Settings="deicrypt.DecodeSettings">
    <Description>Decode file</Description>
    <Parameters>
      <Argument Name="inputFile" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The encoded source file.</Description>
      </Argument>
      <Argument Name="outputFile" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The decoded output file.</Description>
      </Argument>
      <Option Short="" Long="decompress" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="decode" />
      <Example commandLine="inputfile" />
      <Example commandLine="outputfile" />
      <Example commandLine="decode" />
      <Example commandLine="inputfile" />
      <Example commandLine="outputfile" />
      <Example commandLine="--decompress" />
    </Examples>
  </Command>
</Model>