<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Beeching.Commands.AxeCommand" Settings="Beeching.Commands.AxeSettings">
    <Parameters>
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Increase logging verbosity to show all debug 
logs</Description>
      </Option>
      <Option Short="e" Long="exclude" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name of resources to exclude from the axe. Multiple 
values can be specified separated by :</Description>
      </Option>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force the axe to delete the resources if 
locked</Description>
      </Option>
      <Option Short="i" Long="ignore-update" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Do not check for update on startup</Description>
      </Option>
      <Option Short="m" Long="max-retry" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Sets the maximum amount to retry attempts when axe 
fails</Description>
      </Option>
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The name (or partial name) of the resources to axe. 
Multiple values can be specified separated by :</Description>
      </Option>
      <Option Short="g" Long="resource-groups" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Axe resource groups and contents rather than individual 
resource types</Description>
      </Option>
      <Option Short="r" Long="resource-types" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Restrict the types of the resources to axe. Multiple values
can be specified separated by :</Description>
      </Option>
      <Option Short="p" Long="retry-pause" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Sets the pause in seconds for the retry 
attempts</Description>
      </Option>
      <Option Short="s" Long="subscription" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Guid">
        <Description>The subscription id to use. If not specified, the active 
Azure CLI subscription will be used</Description>
      </Option>
      <Option Short="t" Long="tag" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The tag key and value of the resources to axe. Values are 
case sensitive and must be supplied as a single string in the format 
key:value</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Reports the application version</Description>
      </Option>
      <Option Short="w" Long="what-if" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show which resources would face the axe without actually 
culling anything</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip the confirmation prompt</Description>
      </Option>
    </Parameters>
  </Command>
