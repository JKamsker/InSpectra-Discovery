  },
  "commands": [
    {
      "name": "build",
      "options": [
        {
          "name": "--config",
          "required": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Pass a custom config file at FILE_PATH.\r\nDefault: \nReleaseNote.config.toml",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--date",
          "required": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Render the news fragments using the given date.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--dir",
          "required": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Build fragment in directory. Default to current \ndirectory.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--keep",
          "required": false,
          "description": "Do not ask for confirmations. But keep news \nfragments.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--name",
          "required": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Pass a custom project name.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--version",
          "required": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Render the news fragments using given version.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--yes",
          "required": false,
          "description": "Do not ask for confirmation to remove news fragments",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "Build a release note.",
      "hidden": false,
      "examples": [
        "build --version 1.0.0"
