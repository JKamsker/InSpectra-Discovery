<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Init" 
Settings="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Init+Settings">
    <Description>Init release-note setup.</Description>
    <Parameters>
      <Option Short="" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Specify config file name.</Description>
      </Option>
      <Option Short="" Long="template" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Init+E_TEMPLATE_ENGINE">
        <Description>template engine (t4 | liquid)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="init" />
    </Examples>
  </Command>
  <!--CREATE-->
  <Command Name="create" IsBranch="false" 
ClrType="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Create" 
Settings="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Create+Settings">
    <Description>Create a new fragment.</Description>
    <Parameters>
      <Argument Name="FileName" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Fragment FileName</Description>
      </Argument>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Pass a custom config file at FILE_PATH.
Default: ReleaseNote.config.toml</Description>
      </Option>
      <Option Short="" Long="content" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sets the content of the new fragment.</Description>
      </Option>
      <Option Short="" Long="dir" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Create fragment in directory. Default to current 
directory.</Description>
      </Option>
      <Option Short="" Long="edit" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Open an editor for writing the newsfragment 
content.</Description>
      </Option>
      <Option Short="" Long="section" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The section display name to create the fragment 
for.</Description>
      </Option>
      <Option Short="" Long="show-available-type" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show Available Fragment Type.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="create" />
      <Example commandLine="--edit" />
      <Example commandLine="create" />
      <Example commandLine="1.added.md" />
      <Example commandLine="--content" />
      <Example commandLine="&quot;Hello World&quot;" />
    </Examples>
  </Command>
  <!--PREVIEW-->
  <Command Name="preview" IsBranch="false" 
ClrType="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Preview" 
Settings="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Preview+Settings">
    <Description>Preview a release note.</Description>
    <Parameters>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Pass a custom config file at FILE_PATH.
Default: ReleaseNote.config.toml</Description>
      </Option>
      <Option Short="" Long="date" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Render the news fragments using the given 
date.</Description>
      </Option>
      <Option Short="" Long="dir" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Build fragment in directory. Default to current 
directory.</Description>
      </Option>
      <Option Short="" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Pass a custom project name.</Description>
      </Option>
      <Option Short="" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Render the news fragments using given 
version.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Build" 
Settings="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Build+Settings">
    <Description>Build a release note.</Description>
    <Parameters>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Pass a custom config file at FILE_PATH.
Default: ReleaseNote.config.toml</Description>
      </Option>
      <Option Short="" Long="date" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Render the news fragments using the given 
date.</Description>
      </Option>
      <Option Short="" Long="dir" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Build fragment in directory. Default to current 
directory.</Description>
      </Option>
      <Option Short="" Long="keep" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Do not ask for confirmations. But keep news 
fragments.</Description>
      </Option>
      <Option Short="" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Pass a custom project name.</Description>
      </Option>
      <Option Short="" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Render the news fragments using given 
version.</Description>
      </Option>
      <Option Short="" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Do not ask for confirmation to remove news 
fragments</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="build --version 1.0.0" />
    </Examples>
  </Command>
  <!--READ-->
  <Command Name="read" IsBranch="false" 
ClrType="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Read" 
Settings="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Read+Settings">
    <Description>Read Release Note.</Description>
    <Parameters>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Pass a custom config file at FILE_PATH.
Default: ReleaseNote.config.toml</Description>
      </Option>
      <Option Short="" Long="dir" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Build fragment in directory. Default to current 
directory.</Description>
      </Option>
      <Option Short="" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path of release note.</Description>
      </Option>
      <Option Short="" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Read release note using given version.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="read --version 1.0.0" />
    </Examples>
  </Command>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Check" 
Settings="NF.Tool.ReleaseNoteMaker.CLI.Commands.Command_Check+Settings">
    <Description>Checks files changed.</Description>
    <Parameters>
      <Option Short="" Long="compare-with" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Checks files changed running git diff --name-only BRANCH...
BRANCH is the branch to be compared with.</Description>
      </Option>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Pass a custom config file at FILE_PATH.
Default: ReleaseNote.config.toml</Description>
      </Option>
      <Option Short="" Long="dir" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Build fragment in directory. Default to current 
directory.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="check" />
    </Examples>
  </Command>
</Model>