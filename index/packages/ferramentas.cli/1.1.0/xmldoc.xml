<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--RESUMIR-PR-->
  <Command Name="resumir-pr" IsBranch="false" 
ClrType="Ferramentas.Cli.Domínio.ResumirPr.ResumirPrComando" 
Settings="Ferramentas.Cli.Domínio.ResumirPr.ResumirPrComando+Parâmetros">
    <Description>Gera um markdown da descrição do PR.</Description>
    <Parameters>
      <Argument Name="DIRETÓRIO" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Caminho do diretório raíz do repositório.</Description>
      </Argument>
      <Argument Name="BRANCH" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Nome da branch.</Description>
      </Argument>
      <Option Short="o" Long="output" Value="CAMINHO" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Diretório onde o arquivo gerado será 
armazenado.</Description>
      </Option>
      <Option Short="t" Long="tarefa" Value="TAREFA" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Identificador da tarefa. Por padrão pega o nome da branch. 
Separar por ponto e vírgula (;) se forem múltiplos.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="resumir-pr" />
      <Example commandLine="D:\Temp\core" />
      <Example commandLine="tarefa/15860" />
      <Example commandLine="-t" />
      <Example commandLine="15970;16036;16202;16052" />
      <Example commandLine="-o" />
      <Example commandLine="C:\Temp\Output" />
    </Examples>
  </Command>
</Model>