<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="pkgchk.PackageCheckCommand" 
Settings="pkgchk.PackageCheckCommandSettings">
    <Parameters>
      <Argument Name="SOLUTION|PROJECT" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The solution or project file to check.</Description>
      </Argument>
      <Option Short="" Long="dependencies" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>List all dependency packagess. -d true to include, -d false
to exclude.</Description>
      </Option>
      <Option Short="" Long="deprecated" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Check deprecated packagess. -d true to include, -d false to
exclude.</Description>
      </Option>
      <Option Short="" Long="no-banner" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't show the banner.</Description>
      </Option>
      <Option Short="" Long="no-restore" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't automatically restore packages.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for reports.</Description>
      </Option>
      <Option Short="s" Long="severity" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Severity levels to scan for. Matches will return non-zero 
exit codes. Multiple levels can be specified.</Description>
      </Option>
      <Option Short="" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable trace logging.</Description>
      </Option>
      <Option Short="t" Long="transitive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Toggle transitive package checks. -t true to include them, 
-t false to exclude.</Description>
      </Option>
      <Option Short="" Long="vulnerable" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Toggle vulnerable package checks. -t true to include them, 
-t false to exclude.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>