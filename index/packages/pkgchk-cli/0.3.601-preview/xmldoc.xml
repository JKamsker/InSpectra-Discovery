<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SCAN-->
  <Command Name="scan" IsBranch="false" ClrType="pkgchk.PackageScanCommand" 
Settings="pkgchk.PackageScanCommandSettings">
    <Description>Check project dependency packages for vulnerabilities and 
deprecations.</Description>
    <Parameters>
      <Argument Name="SOLUTION|PROJECT" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The solution or project file to check.</Description>
      </Argument>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Configuration file path.</Description>
      </Option>
      <Option Short="d" Long="deprecated" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Check deprecated packagess. true to include, false to 
exclude.</Description>
      </Option>
      <Option Short="" Long="no-banner" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't show the banner.</Description>
      </Option>
      <Option Short="" Long="no-restore" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't automatically restore packages.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for reports.</Description>
      </Option>
      <Option Short="s" Long="severity" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Severity levels to scan for. Matches will return non-zero 
exit codes. Multiple levels can be specified.</Description>
      </Option>
      <Option Short="" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show detailed working and Nuget results.</Description>
      </Option>
      <Option Short="t" Long="transitive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Toggle transitive package checks. true to include them, 
false to exclude.</Description>
      </Option>
      <Option Short="v" Long="vulnerable" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Toggle vulnerable package checks. true to include them, 
false to exclude.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" ClrType="pkgchk.PackageListCommand" 
Settings="pkgchk.PackageListCommandSettings">
    <Description>List project dependency packages.</Description>
    <Parameters>
      <Argument Name="SOLUTION|PROJECT" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The solution or project file to check.</Description>
      </Argument>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Configuration file path.</Description>
      </Option>
      <Option Short="" Long="no-banner" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't show the banner.</Description>
      </Option>
      <Option Short="" Long="no-restore" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't automatically restore packages.</Description>
      </Option>
      <Option Short="" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show detailed working and Nuget results.</Description>
      </Option>
      <Option Short="t" Long="transitive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Toggle transitive package checks. true to include them, 
false to exclude.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UPGRADES-->
  <Command Name="upgrades" IsBranch="false" 
ClrType="pkgchk.PackageUpgradeCommand" 
Settings="pkgchk.PackageUpgradeCommandSettings">
    <Description>Find package upgrades.</Description>
    <Parameters>
      <Argument Name="SOLUTION|PROJECT" Position="0" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The solution or project file to check.</Description>
      </Argument>
      <Option Short="" Long="break-on-upgrades" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Break on outstanding package upgrades.</Description>
      </Option>
      <Option Short="" Long="config" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Configuration file path.</Description>
      </Option>
      <Option Short="x" Long="excluded-package" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>The name of a package to exclude from the scan. Multiple 
packages can be specified.</Description>
      </Option>
      <Option Short="i" Long="included-package" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>The name of a package to include in the scan. Multiple 
packages can be specified.</Description>
      </Option>
      <Option Short="" Long="no-banner" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't show the banner.</Description>
      </Option>
      <Option Short="" Long="no-restore" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't automatically restore packages.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for reports.</Description>
      </Option>
      <Option Short="" Long="trace" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show detailed working and Nuget results.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>