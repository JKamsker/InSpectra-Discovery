<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--BASES-->
  <Command Name="bases" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.BasesCommand" 
Settings="Ivy.Inspector.Airtable.Commands.BasesSettings">
    <Description>List all accessible bases</Description>
  </Command>
  <!--DISTINCT-->
  <Command Name="distinct" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.DistinctCommand" 
Settings="Ivy.Inspector.Airtable.Commands.DistinctSettings">
    <Description>Unique values with counts from a field</Description>
    <Parameters>
      <Argument Name="baseId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base ID (e.g. appXXXXXXXXXXXXXX)</Description>
      </Argument>
      <Argument Name="table" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Table name or ID</Description>
      </Argument>
      <Argument Name="field" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Field name to get distinct values for</Description>
      </Argument>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum distinct values to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of values to skip</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DOCS-->
  <Command Name="docs" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.DocsCommand" 
Settings="Ivy.Inspector.Airtable.Commands.DocsSettings">
    <Description>Output full tool specification in YAML</Description>
  </Command>
  <!--EXPORT-->
  <Command Name="export" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.ExportCommand" 
Settings="Ivy.Inspector.Airtable.Commands.ExportSettings">
    <Description>Export all records and attachments from a table to a local 
folder</Description>
    <Parameters>
      <Argument Name="baseId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base ID (e.g. appXXXXXXXXXXXXXX)</Description>
      </Argument>
      <Argument Name="table" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Table name or ID</Description>
      </Argument>
      <Argument Name="destination" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Destination folder for exported data</Description>
      </Argument>
      <Option Short="" Long="fields" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Comma-separated list of fields to include</Description>
      </Option>
      <Option Short="" Long="view" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>View name or ID to export from</Description>
      </Option>
    </Parameters>
  </Command>
  <!--FIELDS-->
  <Command Name="fields" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.FieldsCommand" 
Settings="Ivy.Inspector.Airtable.Commands.FieldsSettings">
    <Description>Detailed field info for a table</Description>
    <Parameters>
      <Argument Name="baseId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base ID (e.g. appXXXXXXXXXXXXXX)</Description>
      </Argument>
      <Argument Name="table" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Table name or ID</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--RECORD-->
  <Command Name="record" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.RecordCommand" 
Settings="Ivy.Inspector.Airtable.Commands.RecordSettings">
    <Description>Get a single record by ID</Description>
    <Parameters>
      <Argument Name="baseId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base ID (e.g. appXXXXXXXXXXXXXX)</Description>
      </Argument>
      <Argument Name="table" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Table name or ID</Description>
      </Argument>
      <Argument Name="recordId" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Record ID (e.g. recXXXXXXXXXXXXXX)</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--RECORDS-->
  <Command Name="records" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.RecordsCommand" 
Settings="Ivy.Inspector.Airtable.Commands.RecordsSettings">
    <Description>Read records from a table with pagination</Description>
    <Parameters>
      <Argument Name="baseId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base ID (e.g. appXXXXXXXXXXXXXX)</Description>
      </Argument>
      <Argument Name="table" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Table name or ID</Description>
      </Argument>
      <Option Short="" Long="direction" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sort direction (asc or desc)</Description>
      </Option>
      <Option Short="" Long="fields" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Comma-separated list of fields to include</Description>
      </Option>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Maximum number of records to return</Description>
      </Option>
      <Option Short="" Long="sort" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Field name to sort by</Description>
      </Option>
      <Option Short="" Long="view" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>View name or ID</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SCHEMA-->
  <Command Name="schema" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.SchemaCommand" 
Settings="Ivy.Inspector.Airtable.Commands.SchemaSettings">
    <Description>Full schema of a base (tables, fields, views)</Description>
    <Parameters>
      <Argument Name="baseId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base ID (e.g. appXXXXXXXXXXXXXX)</Description>
      </Argument>
      <Option Short="" Long="table" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by table name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SEARCH-->
  <Command Name="search" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.SearchCommand" 
Settings="Ivy.Inspector.Airtable.Commands.SearchSettings">
    <Description>Filter records using an Airtable formula</Description>
    <Parameters>
      <Argument Name="baseId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base ID (e.g. appXXXXXXXXXXXXXX)</Description>
      </Argument>
      <Argument Name="table" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Table name or ID</Description>
      </Argument>
      <Argument Name="formula" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Airtable formula (e.g. "{Status}='Done'")</Description>
      </Argument>
      <Option Short="" Long="direction" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sort direction (asc or desc)</Description>
      </Option>
      <Option Short="" Long="fields" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Comma-separated list of fields to include</Description>
      </Option>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Maximum number of records to return</Description>
      </Option>
      <Option Short="" Long="sort" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Field name to sort by</Description>
      </Option>
    </Parameters>
  </Command>
  <!--STATS-->
  <Command Name="stats" IsBranch="false" 
ClrType="Ivy.Inspector.Airtable.Commands.StatsCommand" 
Settings="Ivy.Inspector.Airtable.Commands.StatsSettings">
    <Description>Table overview with field types and record count</Description>
    <Parameters>
      <Argument Name="baseId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Base ID (e.g. appXXXXXXXXXXXXXX)</Description>
      </Argument>
      <Argument Name="table" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Table name or ID</Description>
      </Argument>
    </Parameters>
  </Command>
</Model>