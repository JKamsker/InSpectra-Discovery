<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="RouteCheck.Commands.CheckCommand" 
Settings="RouteCheck.Commands.Settings.CheckSettings">
    <Parameters>
      <Option Short="" Long="openApiEndpoint" Value="OPENAPIENDPOINT" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>OpenApi endpoint. If not specified, the default 
'/openapi/v1.json' will be used.</Description>
      </Option>
      <Option Short="p" Long="path" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to web app for which to check routes. If not 
specified, the current directory will be used. Can be a relative or absolute 
path.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="RouteCheck.Commands.CheckCommand" 
Settings="RouteCheck.Commands.Settings.CheckSettings">
    <Description>Check your routes. (default command)</Description>
    <Parameters>
      <Option Short="" Long="openApiEndpoint" Value="OPENAPIENDPOINT" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>OpenApi endpoint. If not specified, the default 
'/openapi/v1.json' will be used.</Description>
      </Option>
      <Option Short="p" Long="path" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to web app for which to check routes. If not 
specified, the current directory will be used. Can be a relative or absolute 
path.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="check" />
      <Example commandLine="--path" />
      <Example commandLine="/path/to/webapp" />
    </Examples>
  </Command>
</Model>