<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--PREFERENCES-->
  <Command Name="preferences" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Command to manage user preferences. </Description>
    <!--CULTURE-->
    <Command Name="culture" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Command to manage the application's language/culture. 
</Description>
      <!--SET-->
      <Command Name="set" IsBranch="false" 
ClrType="Tolitech.CodeGenerator.Cli.Commands.Preferences.Culture.SetCulture.SetC
ultureCommand" 
Settings="Tolitech.CodeGenerator.Cli.Commands.Preferences.Culture.SetCulture.Set
CultureSettings">
        <Description>Performs the change of language/culture used by the tool. 
</Description>
        <Parameters>
          <Option Short="n,c" Long="name,culture" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>en | pt | es | de | fr | it | ja | ko | ru | 
zh-Hans</Description>
          </Option>
        </Parameters>
      </Command>
      <Examples>
        <Example commandLine="preferences" />
        <Example commandLine="culture" />
        <Example commandLine="set" />
        <Example commandLine="-n" />
        <Example commandLine="en" />
      </Examples>
    </Command>
    <Examples>
      <Example commandLine="preferences" />
      <Example commandLine="culture" />
      <Example commandLine="set" />
      <Example commandLine="-n" />
      <Example commandLine="en" />
    </Examples>
  </Command>
</Model>