<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ASSEMBLY-->
  <Command Name="assembly" IsBranch="true" 
Settings="CilOut.Commands.AssemblySettings">
    <Parameters>
      <Argument Name="assembly" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Assembly to analyze</Description>
      </Argument>
    </Parameters>
    <!--FINGERPRINT-->
    <Command Name="fingerprint" IsBranch="false" 
ClrType="CilOut.Commands.AssemblyFingerprintCommand" 
Settings="CilOut.Commands.AssemblyFingerprintCommand+Settings">
      <Parameters>
        <Option Short="d" Long="diff-friendly" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Output using a diff-friendly, tab seperated values, 
format</Description>
        </Option>
      </Parameters>
    </Command>
    <!--IS-TRIMMABLE-->
    <Command Name="is-trimmable" IsBranch="false" 
ClrType="CilOut.Commands.AssemblyIsTrimmableCommand" 
Settings="CilOut.Commands.AssemblyIsTrimmableCommand+Settings">
      <Parameters>
        <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>No visible output. Use return code.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--HAS-ENTRYPOINT-->
    <Command Name="has-entrypoint" IsBranch="false" 
ClrType="CilOut.Commands.AssemblyHasEntryPointCommand" 
Settings="CilOut.Commands.AssemblyHasEntryPointCommand+Settings">
      <Parameters>
        <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>No visible output. Use return code.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REFERENCES-->
    <Command Name="references" IsBranch="false" 
ClrType="CilOut.Commands.AssemblyReferencesCommand" 
Settings="CilOut.Commands.AssemblyReferencesCommand+Settings">
      <Parameters>
        <Option Short="" Long="html" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Save output as HTML inside the specified 
file.</Description>
        </Option>
        <Option Short="l" Long="level" Value="NULL" Required="false" 
Kind="scalar" ClrType="CilOut.Commands.AssemblyTreeBaseSettings+MetadataLevel">
          <Description>Level: `assembly`, `types` or `members` 
(default)</Description>
        </Option>
        <Option Short="" Long="text" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Save output as text inside the specified 
file.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DEFINITIONS-->
    <Command Name="definitions" IsBranch="false" 
ClrType="CilOut.Commands.AssemblyDefinitionsCommand" 
Settings="CilOut.Commands.AssemblyDefinitionsCommand+Settings">
      <Parameters>
        <Option Short="" Long="html" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Save output as HTML inside the specified 
file.</Description>
        </Option>
        <Option Short="l" Long="level" Value="NULL" Required="false" 
Kind="scalar" ClrType="CilOut.Commands.AssemblyTreeBaseSettings+MetadataLevel">
          <Description>Level: `assembly`, `types` or `members` 
(default)</Description>
        </Option>
        <Option Short="" Long="text" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Save output as text inside the specified 
file.</Description>
        </Option>
        <Option Short="" Long="visible" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>List only types/members that are externally visible from 
the assembly</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--APPBUNDLE-->
  <Command Name="appbundle" IsBranch="true" 
Settings="CilOut.Commands.AppBundleSettings">
    <Parameters>
      <Argument Name="appbundle" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Application Bundle to analyze</Description>
      </Argument>
    </Parameters>
    <!--FINGERPRINT-->
    <Command Name="fingerprint" IsBranch="false" 
ClrType="CilOut.Commands.AppBundleFingerprintCommand" 
Settings="CilOut.Commands.AppBundleFingerprintCommand+Settings">
      <Parameters>
        <Option Short="d" Long="diff-friendly" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Output using a diff-friendly, tab seperated values, 
format</Description>
        </Option>
      </Parameters>
    </Command>
    <!--IS-TRIMMABLE-->
    <Command Name="is-trimmable" IsBranch="false" 
ClrType="CilOut.Commands.AppBundleIsTrimmableCommand" 
Settings="CilOut.Commands.AppBundleIsTrimmableCommand+Settings">
      <Parameters>
        <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>No visible output. Use return code.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--HAS-ENTRYPOINT-->
    <Command Name="has-entrypoint" IsBranch="false" 
ClrType="CilOut.Commands.AppBundleHasEntryPointCommand" 
Settings="CilOut.Commands.AppBundleHasEntryPointCommand+Settings">
      <Parameters>
        <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>No visible output. Use return code.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>