<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--EXTRACT-->
  <Command Name="extract" IsBranch="false" 
ClrType="DeadCode.CLI.Commands.ExtractCommand" 
Settings="DeadCode.CLI.Commands.ExtractCommand+Settings">
    <Description>Extract method inventory from assemblies</Description>
    <Parameters>
      <Argument Name="ASSEMBLIES" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Assembly file paths to analyze (supports 
wildcards)</Description>
      </Argument>
      <Option Short="" Long="include-generated" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include compiler-generated methods</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output path for the inventory JSON file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="extract" />
      <Example commandLine="bin/Release/net10.0/*.dll" />
      <Example commandLine="-o" />
      <Example commandLine="inventory.json" />
    </Examples>
  </Command>
  <!--PROFILE-->
  <Command Name="profile" IsBranch="false" 
ClrType="DeadCode.CLI.Commands.ProfileCommand" 
Settings="DeadCode.CLI.Commands.ProfileCommand+Settings">
    <Description>Profile application execution</Description>
    <Parameters>
      <Argument Name="EXECUTABLE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the executable to profile</Description>
      </Argument>
      <Option Short="" Long="args" Value="NULL" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Arguments to pass to the executable</Description>
      </Option>
      <Option Short="" Long="duration" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Duration to run the profiling in seconds (default: run to 
completion)</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for trace files</Description>
      </Option>
      <Option Short="" Long="scenarios" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to scenarios JSON file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="profile" />
      <Example commandLine="MyApp.exe" />
      <Example commandLine="--scenarios" />
      <Example commandLine="scenarios.json" />
      <Example commandLine="-o" />
      <Example commandLine="traces/" />
    </Examples>
  </Command>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="DeadCode.CLI.Commands.AnalyzeCommand" 
Settings="DeadCode.CLI.Commands.AnalyzeCommand+Settings">
    <Description>Analyze method usage</Description>
    <Parameters>
      <Option Short="i" Long="inventory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the method inventory JSON file</Description>
      </Option>
      <Option Short="" Long="min-confidence" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum confidence level to include in report (high, 
medium, low)</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output path for the redundancy report</Description>
      </Option>
      <Option Short="t" Long="traces" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Directory containing trace files or specific trace file 
paths</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="analyze" />
      <Example commandLine="-i" />
      <Example commandLine="inventory.json" />
      <Example commandLine="-t" />
      <Example commandLine="traces/" />
      <Example commandLine="-o" />
      <Example commandLine="report.json" />
    </Examples>
  </Command>
  <!--FULL-->
  <Command Name="full" IsBranch="false" 
ClrType="DeadCode.CLI.Commands.FullCommand" 
Settings="DeadCode.CLI.Commands.FullCommand+Settings">
    <Description>Run complete analysis pipeline</Description>
    <Parameters>
      <Option Short="" Long="assemblies" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Assembly file paths to analyze (supports 
wildcards)</Description>
      </Option>
      <Option Short="" Long="executable" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the executable to profile</Description>
      </Option>
      <Option Short="" Long="min-confidence" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum confidence level to include in report (high, 
medium, low)</Description>
      </Option>
      <Option Short="" Long="output" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Output directory for all artifacts</Description>
      </Option>
      <Option Short="" Long="scenarios" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to scenarios JSON file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="full" />
      <Example commandLine="--assemblies" />
      <Example commandLine="bin/Release/net10.0/*.dll" />
      <Example commandLine="--executable" />
      <Example commandLine="MyApp.exe" />
    </Examples>
  </Command>
</Model>