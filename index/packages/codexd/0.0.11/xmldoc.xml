<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--HTTP-->
  <Command Name="http" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Standalone HTTP + SSE runner.</Description>
    <!--RUNS-->
    <Command Name="runs" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>List and inspect runs known by the server.</Description>
      <!--LS-->
      <Command Name="ls" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.LsCommand" 
Settings="CodexD.HttpRunner.Commands.LsCommand+Settings">
        <Description>List runs known by the server.</Description>
        <Parameters>
          <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
          <Option Short="" Long="cd" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
            <Description>Working directory (exact-match filtering for 
ls/--last). Default: current directory</Description>
          </Option>
          <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Print JSONL events (client-side envelope) instead of 
human-friendly output.</Description>
          </Option>
          <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Bearer token. Default: env 
CODEX_D_TOKEN/CODEX_RUNNER_TOKEN</Description>
          </Option>
          <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar"
ClrType="System.String">
            <Description>Runner base URL. Default: env 
CODEX_D_URL/CODEX_RUNNER_URL or daemon-first discovery.</Description>
          </Option>
        </Parameters>
      </Command>
    </Command>
    <!--RUN-->
    <Command Name="run" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Operate on a single run.</Description>
      <!--ATTACH-->
      <Command Name="attach" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.AttachCommand" 
Settings="CodexD.HttpRunner.Commands.AttachCommand+Settings">
        <Description>Attach to an existing run and stream SSE 
output.</Description>
        <Parameters>
          <Argument Name="RUN_ID" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
          <Option Short="" Long="cd" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
            <Description>Working directory (exact-match filtering for 
ls/--last). Default: current directory</Description>
          </Option>
          <Option Short="" Long="follow-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Do not replay history; only stream new 
events.</Description>
          </Option>
          <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Print JSONL events (client-side envelope) instead of 
human-friendly output.</Description>
          </Option>
          <Option Short="" Long="last" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Attach to the most recent run for the current 
--cd/cwd.</Description>
          </Option>
          <Option Short="" Long="no-follow" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Replay (or tail) and then exit even if the run is still
running.</Description>
          </Option>
          <Option Short="" Long="tail" Value="N" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
            <Description>Replay only the last N events, then 
follow.</Description>
          </Option>
          <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Bearer token. Default: env 
CODEX_D_TOKEN/CODEX_RUNNER_TOKEN</Description>
          </Option>
          <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar"
ClrType="System.String">
            <Description>Runner base URL. Default: env 
CODEX_D_URL/CODEX_RUNNER_URL or daemon-first discovery.</Description>
          </Option>
        </Parameters>
      </Command>
      <!--INTERRUPT-->
      <Command Name="interrupt" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.Run.InterruptCommand" 
Settings="CodexD.HttpRunner.Commands.Run.InterruptCommand+Settings">
        <Description>Interrupt a running run.</Description>
        <Parameters>
          <Argument Name="RUN_ID" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
          <Option Short="" Long="cd" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
            <Description>Working directory (exact-match filtering for 
ls/--last). Default: current directory</Description>
          </Option>
          <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Print JSONL events (client-side envelope) instead of 
human-friendly output.</Description>
          </Option>
          <Option Short="" Long="last" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Interrupt the most recent run for the current 
--cd/cwd.</Description>
          </Option>
          <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Bearer token. Default: env 
CODEX_D_TOKEN/CODEX_RUNNER_TOKEN</Description>
          </Option>
          <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar"
ClrType="System.String">
            <Description>Runner base URL. Default: env 
CODEX_D_URL/CODEX_RUNNER_URL or daemon-first discovery.</Description>
          </Option>
        </Parameters>
      </Command>
      <!--MESSAGES-->
      <Command Name="messages" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.Run.RunMessagesCommand" 
Settings="CodexD.HttpRunner.Commands.Run.RunMessagesCommand+Settings">
        <Description>Print the last completed agent message(s) for a 
run.</Description>
        <Parameters>
          <Argument Name="RUN_ID" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
          <Option Short="" Long="cd" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
            <Description>Working directory (exact-match filtering for 
ls/--last). Default: current directory</Description>
          </Option>
          <Option Short="n" Long="count" Value="N" Required="false" 
Kind="scalar" ClrType="System.Int32">
            <Description>Number of messages to print (last N).</Description>
          </Option>
          <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Print JSONL events (client-side envelope) instead of 
human-friendly output.</Description>
          </Option>
          <Option Short="" Long="last" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Use the most recent run for the current 
--cd/cwd.</Description>
          </Option>
          <Option Short="" Long="tail-events" Value="N" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
            <Description>Only scan the last N events on the server (performance 
guard). Default: 20000.</Description>
          </Option>
          <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Bearer token. Default: env 
CODEX_D_TOKEN/CODEX_RUNNER_TOKEN</Description>
          </Option>
          <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar"
ClrType="System.String">
            <Description>Runner base URL. Default: env 
CODEX_D_URL/CODEX_RUNNER_URL or daemon-first discovery.</Description>
          </Option>
        </Parameters>
      </Command>
      <!--THINKING-->
      <Command Name="thinking" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.Run.RunThinkingCommand" 
Settings="CodexD.HttpRunner.Commands.Run.RunThinkingCommand+Settings">
        <Description>Print one-line summaries from thinking blocks (bold **...**
headings).</Description>
        <Parameters>
          <Argument Name="RUN_ID" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
          <Option Short="" Long="cd" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
            <Description>Working directory (exact-match filtering for 
ls/--last). Default: current directory</Description>
          </Option>
          <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Print JSONL events (client-side envelope) instead of 
human-friendly output.</Description>
          </Option>
          <Option Short="" Long="last" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
            <Description>Use the most recent run for the current 
--cd/cwd.</Description>
          </Option>
          <Option Short="" Long="tail-events" Value="N" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
            <Description>Only scan the last N events on the server (performance 
guard). Default: 20000.</Description>
          </Option>
          <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Bearer token. Default: env 
CODEX_D_TOKEN/CODEX_RUNNER_TOKEN</Description>
          </Option>
          <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar"
ClrType="System.String">
            <Description>Runner base URL. Default: env 
CODEX_D_URL/CODEX_RUNNER_URL or daemon-first discovery.</Description>
          </Option>
        </Parameters>
      </Command>
    </Command>
    <!--SERVE-->
    <Command Name="serve" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.ServeCommand" 
Settings="CodexD.HttpRunner.Commands.ServeCommand+Settings">
      <Description>Start the HTTP/SSE runner.</Description>
      <Parameters>
        <Option Short="d" Long="daemon" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Run as a detached daemon (Windows only).</Description>
        </Option>
        <Option Short="" Long="daemon-child" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Internal. Used by --daemon.</Description>
        </Option>
        <Option Short="" Long="daemon-version" Value="VERSION" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Internal. Used by --daemon.</Description>
        </Option>
        <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Daemon only. Force-stop an existing daemon and reinstall 
binaries before starting.</Description>
        </Option>
        <Option Short="" Long="listen" Value="IP" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Listen address. Default: 127.0.0.1</Description>
        </Option>
        <Option Short="" Long="persist-raw-events" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
          <Description>Persist raw differential events to events.jsonl 
(debugging). Default: false (rollup only).</Description>
        </Option>
        <Option Short="" Long="port" Value="PORT" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>TCP port. Foreground default: 8787. Daemon default: 0 
(ephemeral).</Description>
        </Option>
        <Option Short="" Long="require-auth" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Require Bearer token auth even on loopback.</Description>
        </Option>
        <Option Short="" Long="state-dir" Value="DIR" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override the state directory (identity + runs). 
Foreground default: &lt;cwd&gt;/.codex-d. Daemon default: 
%LOCALAPPDATA%/codex-d/daemon/config</Description>
        </Option>
        <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override the persisted token (also persists the 
override).</Description>
        </Option>
      </Parameters>
    </Command>
    <!--EXEC-->
    <Command Name="exec" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.ExecCommand" 
Settings="CodexD.HttpRunner.Commands.ExecCommand+Settings">
      <Description>Start a new run via HTTP (optionally detached).</Description>
      <Parameters>
        <Argument Name="PROMPT" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]" />
        <Option Short="" Long="approval-policy" Value="POLICY" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="cd" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Working directory (exact-match filtering for ls/--last). 
Default: current directory</Description>
        </Option>
        <Option Short="d" Long="detach" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Detach after creating the run (does not stream 
output).</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Print JSONL events (client-side envelope) instead of 
human-friendly output.</Description>
        </Option>
        <Option Short="" Long="model" Value="MODEL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="p" Long="prompt" Value="PROMPT" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Prompt text (alternative to positional PROMPT). Use '-' 
to read stdin.</Description>
        </Option>
        <Option Short="" Long="sandbox" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Bearer token. Default: env 
CODEX_D_TOKEN/CODEX_RUNNER_TOKEN</Description>
        </Option>
        <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Runner base URL. Default: env 
CODEX_D_URL/CODEX_RUNNER_URL or daemon-first discovery.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REVIEW-->
    <Command Name="review" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.ReviewCommand" 
Settings="CodexD.HttpRunner.Commands.ReviewCommand+Settings">
      <Description>Run a non-interactive `codex review` on the runner and stream
output.</Description>
      <Parameters>
        <Argument Name="PROMPT" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
          <Description>Optional custom review instructions. Use '-' to read 
stdin.</Description>
        </Argument>
        <Option Short="" Long="approval-policy" Value="POLICY" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Runner approval policy (generally keep this as 'never' 
for non-interactive review runs).</Description>
        </Option>
        <Option Short="" Long="arg" Value="ARG" Required="false" Kind="vector" 
ClrType="System.String[]">
          <Description>Additional raw args forwarded to `codex review` 
(repeatable).</Description>
        </Option>
        <Option Short="" Long="base" Value="BRANCH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Review changes against base branch.</Description>
        </Option>
        <Option Short="" Long="cd" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Working directory (exact-match filtering for ls/--last). 
Default: current directory</Description>
        </Option>
        <Option Short="" Long="commit" Value="SHA" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Review a specific commit SHA.</Description>
        </Option>
        <Option Short="c" Long="config" Value="KEY=VALUE" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Forward a `--config &lt;key=value&gt;` option to `codex 
review` (repeatable).</Description>
        </Option>
        <Option Short="d" Long="detach" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Detach after creating the review run (does not stream 
output).</Description>
        </Option>
        <Option Short="" Long="disable" Value="FEATURE" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Forward a `--disable &lt;feature&gt;` option to `codex 
review` (repeatable).</Description>
        </Option>
        <Option Short="" Long="enable" Value="FEATURE" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Forward an `--enable &lt;feature&gt;` option to `codex 
review` (repeatable).</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Print JSONL events (client-side envelope) instead of 
human-friendly output.</Description>
        </Option>
        <Option Short="" Long="model" Value="MODEL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Model the review should use (forwarded to `codex 
review`).</Description>
        </Option>
        <Option Short="p" Long="prompt" Value="PROMPT" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Optional custom review instructions. Use '-' to read 
stdin.</Description>
        </Option>
        <Option Short="" Long="title" Value="TITLE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Optional review title.</Description>
        </Option>
        <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Bearer token. Default: env 
CODEX_D_TOKEN/CODEX_RUNNER_TOKEN</Description>
        </Option>
        <Option Short="" Long="uncommitted" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Review staged/unstaged/untracked changes.</Description>
        </Option>
        <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Runner base URL. Default: env 
CODEX_D_URL/CODEX_RUNNER_URL or daemon-first discovery.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--STATUS-->
    <Command Name="status" IsBranch="false" 
ClrType="CodexD.HttpRunner.Commands.StatusCommand" 
Settings="CodexD.HttpRunner.Commands.StatusCommand+Settings">
      <Description>Show runner discovery + health/info (doctor).</Description>
      <Parameters>
        <Option Short="" Long="cd" Value="DIR" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Working directory (exact-match filtering for ls/--last). 
Default: current directory</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Print JSONL events (client-side envelope) instead of 
human-friendly output.</Description>
        </Option>
        <Option Short="" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Bearer token. Default: env 
CODEX_D_TOKEN/CODEX_RUNNER_TOKEN</Description>
        </Option>
        <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Runner base URL. Default: env 
CODEX_D_URL/CODEX_RUNNER_URL or daemon-first discovery.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Print all probe attempts even when a runner is 
reachable.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CLOUD-->
  <Command Name="cloud" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Runner that connects to CodexWebUi.Api via 
SignalR.</Description>
    <!--SERVE-->
    <Command Name="serve" IsBranch="false" 
ClrType="CodexD.CloudRunner.Cli.ServeCommand" 
Settings="CodexD.CloudRunner.Cli.ServeCommand+Settings">
      <Description>Run the Cloud runner (connects to CodexWebUi.Api via 
SignalR).</Description>
      <Parameters>
        <Option Short="" Long="api-key" Value="KEY" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Runner API key. Env: 
CODEXWEBUI_RUNNER_API_KEY</Description>
        </Option>
        <Option Short="" Long="heartbeat-interval" Value="DURATION" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Heartbeat interval. Examples: 5s, 250ms, 00:00:05. Env: 
CODEXWEBUI_RUNNER_HEARTBEAT_INTERVAL</Description>
        </Option>
        <Option Short="" Long="identity-file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Identity file path. Env: 
CODEXWEBUI_RUNNER_IDENTITY_FILE</Description>
        </Option>
        <Option Short="" Long="name" Value="NAME" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Runner display name. Env: CODEXWEBUI_RUNNER_NAME 
(default: hostname)</Description>
        </Option>
        <Option Short="" Long="server-url" Value="URL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>CodexWebUi.Api base URL. Env: 
CODEXWEBUI_RUNNER_SERVER_URL</Description>
        </Option>
        <Option Short="" Long="workspace-root" Value="PATH" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Allowed workspace root (repeatable). Env: 
CODEXWEBUI_RUNNER_WORKSPACE_ROOTS (semicolon-separated)</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>