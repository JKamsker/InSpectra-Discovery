<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--NEW-->
  <Command Name="new" IsBranch="false" 
ClrType="VarcalSys.Cli.Commands.NewCommand" 
Settings="VarcalSys.Cli.Commands.NewCommand+Settings">
    <Description>Cria um novo projeto a partir de um template VarcalSys (wizard 
interativo).</Description>
    <Parameters>
      <Option Short="c" Long="company" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Company/organization name</Description>
      </Option>
      <Option Short="" Long="no-git" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip git init after project creation</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory (defaults to current 
directory/solution-name)</Description>
      </Option>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution/project name</Description>
      </Option>
      <Option Short="t" Long="template" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Short name of the template (e.g. varcal-ddd)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="new" />
      <Example commandLine="new" />
      <Example commandLine="-t" />
      <Example commandLine="varcal-ddd" />
      <Example commandLine="-c" />
      <Example commandLine="Acme" />
      <Example commandLine="-s" />
      <Example commandLine="OrderService" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="VarcalSys.Cli.Commands.ListCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Lista todos os templates disponíveis.</Description>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" 
ClrType="VarcalSys.Cli.Commands.InfoCommand" 
Settings="VarcalSys.Cli.Commands.InfoCommand+Settings">
    <Description>Exibe detalhes de um template específico.</Description>
    <Parameters>
      <Argument Name="template" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Short name of the template (e.g. varcal-ddd)</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="info" />
      <Example commandLine="varcal-ddd" />
    </Examples>
  </Command>
</Model>