<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Nukit.Clearance.ClearanceCommand" 
Settings="Nukit.Clearance.ClearanceSettings">
    <Description>A command line tool to nuke build clutter. 
[italic]https://github.com/tonycknight/nukit[/]</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The path to clear. Optional.</Description>
      </Argument>
      <Option Short="" Long="bin" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Nuke binary directories.</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Runs a scan, without any effect.</Description>
      </Option>
      <Option Short="f" Long="force" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Force clearance without prompting.</Description>
      </Option>
      <Option Short="" Long="glob" Value="GLOB" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Nuke directories matching a glob pattern. Multiple patterns
may be given.</Description>
      </Option>
      <Option Short="" Long="no-banner" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show or hide the application banner.</Description>
      </Option>
      <Option Short="" Long="obj" Value="TRUE|FALSE" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Nuke object directories.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>