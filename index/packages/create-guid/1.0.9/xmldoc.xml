<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="D20Tek.Tools.CreateGuid.Commands.CreateGuidCommand" 
Settings="D20Tek.Tools.CreateGuid.Commands.GuidSettings">
    <Parameters>
      <Option Short="p" Long="clipboard-copy" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Defines whether the output of this command should be copied
to the system clipboard.</Description>
      </Option>
      <Option Short="c" Long="count" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The number of GUIDs to generate (defaults to 
1).</Description>
      </Option>
      <Option Short="e" Long="empty" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Defines if the GUIDs should be empty (using 
zero-values).</Description>
      </Option>
      <Option Short="f" Long="format" Value="GUID-FORMAT" Required="false" 
Kind="scalar" ClrType="D20Tek.Tools.CreateGuid.GuidFormat">
        <Description>Defines how the GUIDs are formatted in string form 
(Default, Number, Braces, Parens, Hex).</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filename for output file used to save generated 
guids.</Description>
      </Option>
      <Option Short="u" Long="upper" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Defines if the generated GUIDs should be upper-cased 
(defaults to lower-cased).</Description>
      </Option>
      <Option Short="s" Long="uuid-v7" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Generates a UUID v7 compliant GUID for sortable unique 
identifiers.</Description>
      </Option>
      <Option Short="v" Long="verbosity" Value="VERBOSITY-LEVEL" 
Required="false" Kind="scalar" 
ClrType="D20Tek.Spectre.Console.Extensions.Settings.VerbosityLevel">
        <Description>The verbosity level for this operation: q(uiet), m(inimal),
n(ormal), d(etailed), and diag(nostic).</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="D20Tek.Tools.CreateGuid.Commands.CreateGuidCommand" 
Settings="D20Tek.Tools.CreateGuid.Commands.GuidSettings">
    <Description>Default command that generates GUIDs in the appropriate 
format.</Description>
    <Parameters>
      <Option Short="p" Long="clipboard-copy" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Defines whether the output of this command should be copied
to the system clipboard.</Description>
      </Option>
      <Option Short="c" Long="count" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The number of GUIDs to generate (defaults to 
1).</Description>
      </Option>
      <Option Short="e" Long="empty" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Defines if the GUIDs should be empty (using 
zero-values).</Description>
      </Option>
      <Option Short="f" Long="format" Value="GUID-FORMAT" Required="false" 
Kind="scalar" ClrType="D20Tek.Tools.CreateGuid.GuidFormat">
        <Description>Defines how the GUIDs are formatted in string form 
(Default, Number, Braces, Parens, Hex).</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filename for output file used to save generated 
guids.</Description>
      </Option>
      <Option Short="u" Long="upper" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Defines if the generated GUIDs should be upper-cased 
(defaults to lower-cased).</Description>
      </Option>
      <Option Short="s" Long="uuid-v7" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Generates a UUID v7 compliant GUID for sortable unique 
identifiers.</Description>
      </Option>
      <Option Short="v" Long="verbosity" Value="VERBOSITY-LEVEL" 
Required="false" Kind="scalar" 
ClrType="D20Tek.Spectre.Console.Extensions.Settings.VerbosityLevel">
        <Description>The verbosity level for this operation: q(uiet), m(inimal),
n(ormal), d(etailed), and diag(nostic).</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="gen" />
      <Example commandLine="-c" />
      <Example commandLine="1" />
      <Example commandLine="-f" />
      <Example commandLine="default" />
      <Example commandLine="-v" />
      <Example commandLine="normal" />
    </Examples>
  </Command>
</Model>