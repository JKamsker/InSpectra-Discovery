<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="TsGenCli.Commands.GenerateCommand" 
Settings="TsGenCli.Commands.GenerateCommandSettings">
    <Parameters>
      <Option Short="o" Long="out-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specifies the base output directory to save 
to</Description>
      </Option>
      <Option Short="p" Long="project-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specifies the project to build (default is the project in 
this directory)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>