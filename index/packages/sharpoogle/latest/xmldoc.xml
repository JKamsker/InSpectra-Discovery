<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="RunSearchCommand" Settings="RunSearchCommand+Settings">
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to search (file or directory). Defaults to current 
directory.</Description>
      </Argument>
      <Option Short="p" Long="pattern" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Pattern to search files in. Defaults to *.cs</Description>
      </Option>
      <Option Short="q" Long="query" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Signature to search for. It should be in format of: 
"returnType (arg1, arg2)".</Description>
      </Option>
    </Parameters>
  </Command>
</Model>