<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="ReqnRollBindingDocumentationGenerator.DocumentationGeneratorCommand" 
Settings="ReqnRollBindingDocumentationGenerator.DocumentationGeneratorSettings">
    <Parameters>
      <Option Short="i" Long="input" Value="NULL" Required="true" Kind="vector" 
ClrType="System.String[]">
        <Description>Pairs of DLL paths and their corresponding XML doc file. 
Multiple usages possible. Example: -i a.dll;a.xml -i b.dll;b.xml</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="true" Kind="scalar"
ClrType="System.String">
        <Description>Output file name for the generated markdown 
documentation.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>