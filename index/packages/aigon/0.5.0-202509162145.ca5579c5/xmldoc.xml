<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="Aigon.Commands.AigonVersionCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Print version information</Description>
  </Command>
  <!--MCP-->
  <Command Name="mcp" IsBranch="false" 
ClrType="Aigon.Commands.ModelContextProtocol.McpCommand" 
Settings="Aigon.Commands.ModelContextProtocol.McpCommand+McpSettings">
    <Description>Start the Model Context Protocol server</Description>
    <Parameters>
      <Option Short="" Long="url" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>If running as a HTTP server, specify the URL to bind to. If
not specified, it will use stdio.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SOLUTION-->
  <Command Name="solution" IsBranch="false" 
ClrType="Aigon.Commands.Solution.ChatWithSolutionCommand" 
Settings="Aigon.Commands.Solution.ChatWithSolutionCommand+ChatSettings">
    <Description>Select a solution to open</Description>
    <Parameters>
      <Argument Name="Solution" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Solution path</Description>
      </Argument>
      <Option Short="" Long="a2a" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Allow instances of aigon to communicate with each 
other</Description>
      </Option>
      <Option Short="a" Long="ask-before-update" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Ask before updating the solution</Description>
      </Option>
      <Option Short="" Long="budget" Value="USD" Required="false" Kind="scalar" 
ClrType="System.Decimal">
        <Description>API budget $ amount. If using paid API's this will limit 
the cost of the agent, and will stop after the budget is reached.</Description>
      </Option>
      <Option Short="c" Long="cli" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use CLI only. This will disable the web interface and use 
the CLI for all interactions.</Description>
      </Option>
      <Option Short="" Long="connection" Value="CONNECTIONSTRING" 
Required="false" Kind="vector" ClrType="System.String[]">
        <Description>If using a local model, you can configure the path it is 
available at. Example: 
"https://localhost:11434/v1;models=llama3.1:8b;token=&lt;apitoken&gt;". If you 
provide multiple models, separate them with a comma.</Description>
      </Option>
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable debug output</Description>
      </Option>
      <Option Short="" Long="mcp" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Serve as a Model Context Protocol (MCP) server. This allows
other agents to leverage Aigon analysis capabilities</Description>
      </Option>
      <Option Short="o" Long="ollama-model" Value="MODEL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Override the ollama models to provide. Default is 
llama3.1:8b. If you provide multiple models, pass multiple times.</Description>
      </Option>
      <Option Short="" Long="ollama-path" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>If hosting ollama anywhere but http://localhost:11434, 
specify it here.</Description>
      </Option>
      <Option Short="" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Specify the port to use for the web interface / MCP API. By
default it will bind to any available port.</Description>
      </Option>
      <Option Short="" Long="public" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>If this is enabled, the web interface will mount to 
0.0.0.0. If disabled, it will only be accessible from localhost.</Description>
      </Option>
      <Option Short="" Long="skip-browser" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip opening the browser when starting the web 
interface.</Description>
      </Option>
      <Option Short="t" Long="token" Value="TOKEN" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Your inference API key(s).' Supported providers are OpenAI,
Anthropic, Groq, Cerebras and SambaNova. You can specify this multiple times if 
you have more than one provider.</Description>
      </Option>
      <Option Short="w" Long="voice" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable Whisper voice input</Description>
      </Option>
    </Parameters>
  </Command>
</Model>