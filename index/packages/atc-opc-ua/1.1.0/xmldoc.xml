<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--TESTCONNECTION-->
  <Command Name="testconnection" IsBranch="false" 
ClrType="Atc.Opc.Ua.CLI.Commands.TestConnectionCommand" 
Settings="Atc.Opc.Ua.CLI.Commands.Settings.OpcUaBaseCommandSettings">
    <Description>Tests if a connection can be made to a given 
server.</Description>
    <Parameters>
      <Option Short="p" Long="password" Value="PASSWORD" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>OPC UA Password</Description>
      </Option>
      <Option Short="s" Long="server-url" Value="SERVER-URL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>OPC UA Server Url</Description>
      </Option>
      <Option Short="u" Long="username" Value="USERNAME" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>OPC UA UserName</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use verbose for more debug/trace information</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="testconnection -s opc.tcp://opcuaserver.com:48010" 
/>
      <Example commandLine="testconnection -s opc.tcp://opcuaserver.com:48010 -u
username -p password" />
    </Examples>
  </Command>
  <!--NODE-->
  <Command Name="node" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Operations related to nodes.</Description>
    <!--READ-->
    <Command Name="read" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Operations related to reading nodes.</Description>
      <!--OBJECT-->
      <Command Name="object" IsBranch="false" 
ClrType="Atc.Opc.Ua.CLI.Commands.NodeReadObjectCommand" 
Settings="Atc.Opc.Ua.CLI.Commands.Settings.ReadObjectNodeCommandSettings">
        <Description>Reads a given node object.</Description>
        <Parameters>
          <Option Short="" Long="include-objects" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Indicates if child objects should be 
included.</Description>
          </Option>
          <Option Short="" Long="include-sample-values" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
            <Description>Indicates if sample values for the node(s) should be 
included. Only Relevant if IncludeVariables is set.</Description>
          </Option>
          <Option Short="" Long="include-variables" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
            <Description>Indicates if child variables should be 
included.</Description>
          </Option>
          <Option Short="n" Long="node-id" Value="NODE-ID" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>OPC UA NodeId</Description>
          </Option>
          <Option Short="" Long="node-object-read-depth" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.Int32">
            <Description>Sets the max depth for object hierarchy retrieval. 
Default set to 1.</Description>
          </Option>
          <Option Short="p" Long="password" Value="PASSWORD" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
            <Description>OPC UA Password</Description>
          </Option>
          <Option Short="s" Long="server-url" Value="SERVER-URL" 
Required="false" Kind="scalar" ClrType="System.String">
            <Description>OPC UA Server Url</Description>
          </Option>
          <Option Short="u" Long="username" Value="USERNAME" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
            <Description>OPC UA UserName</Description>
          </Option>
          <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Use verbose for more debug/trace 
information</Description>
          </Option>
        </Parameters>
        <Examples>
          <Example commandLine="node read object -s 
opc.tcp://opcuaserver.com:48010 -n &quot;ns=2;s=Demo.Dynamic.Scalar&quot;" />
        </Examples>
      </Command>
      <!--VARIABLE-->
      <Command Name="variable" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
        <Description>Reads one or more node variable(s).</Description>
        <!--SINGLE-->
        <Command Name="single" IsBranch="false" 
ClrType="Atc.Opc.Ua.CLI.Commands.NodeReadVariableSingleCommand" 
Settings="Atc.Opc.Ua.CLI.Commands.Settings.SingleNodeCommandSettings">
          <Description>Reads a single node variable.</Description>
          <Parameters>
            <Option Short="" Long="include-sample-value" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
              <Description>Indicates if sample value for the node should be 
included.</Description>
            </Option>
            <Option Short="n" Long="node-id" Value="NODE-ID" Required="false" 
Kind="scalar" ClrType="System.String">
              <Description>OPC UA NodeId</Description>
            </Option>
            <Option Short="p" Long="password" Value="PASSWORD" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
              <Description>OPC UA Password</Description>
            </Option>
            <Option Short="s" Long="server-url" Value="SERVER-URL" 
Required="false" Kind="scalar" ClrType="System.String">
              <Description>OPC UA Server Url</Description>
            </Option>
            <Option Short="u" Long="username" Value="USERNAME" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
              <Description>OPC UA UserName</Description>
            </Option>
            <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
              <Description>Use verbose for more debug/trace 
information</Description>
            </Option>
          </Parameters>
          <Examples>
            <Example commandLine="node read variable single -s 
opc.tcp://opcuaserver.com:48010 -n &quot;ns=2;s=Demo.Dynamic.Scalar.Float&quot;"
/>
          </Examples>
        </Command>
        <!--MULTI-->
        <Command Name="multi" IsBranch="false" 
ClrType="Atc.Opc.Ua.CLI.Commands.NodeReadVariableMultiCommand" 
Settings="Atc.Opc.Ua.CLI.Commands.Settings.MultiNodeCommandSettings">
          <Description>Reads a list of node variables.</Description>
          <Parameters>
            <Option Short="" Long="include-sample-values" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
              <Description>Indicates if sample values for the nodes should be 
included.</Description>
            </Option>
            <Option Short="n" Long="node-id" Value="NODE-ID" Required="false" 
Kind="vector" ClrType="System.String[]">
              <Description>OPC UA NodeIds</Description>
            </Option>
            <Option Short="p" Long="password" Value="PASSWORD" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
              <Description>OPC UA Password</Description>
            </Option>
            <Option Short="s" Long="server-url" Value="SERVER-URL" 
Required="false" Kind="scalar" ClrType="System.String">
              <Description>OPC UA Server Url</Description>
            </Option>
            <Option Short="u" Long="username" Value="USERNAME" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
              <Description>OPC UA UserName</Description>
            </Option>
            <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
              <Description>Use verbose for more debug/trace 
information</Description>
            </Option>
          </Parameters>
          <Examples>
            <Example commandLine="node read variable multi -s 
opc.tcp://opcuaserver.com:48010 -n &quot;ns=2;s=Demo.Dynamic.Scalar.Float&quot; 
-n &quot;ns=2;s=Demo.Dynamic.Scalar.Int32&quot;" />
          </Examples>
        </Command>
      </Command>
    </Command>
    <!--WRITE-->
    <Command Name="write" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Operations related to writing nodes.</Description>
      <!--VARIABLE-->
      <Command Name="variable" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
        <Description>Writes a value to one or more node 
variable(s).</Description>
        <!--SINGLE-->
        <Command Name="single" IsBranch="false" 
ClrType="Atc.Opc.Ua.CLI.Commands.NodeWriteVariableSingleCommand" 
Settings="Atc.Opc.Ua.CLI.Commands.Settings.WriteNodeCommandSettings">
          <Description>Write a value to a single node variable.</Description>
          <Parameters>
            <Option Short="" Long="data-type" Value="DATA-TYPE" Required="false"
Kind="scalar" ClrType="System.String">
              <Description>OPC UA DataType</Description>
            </Option>
            <Option Short="" Long="data-value" Value="DATA-VALUE" 
Required="false" Kind="scalar" ClrType="System.String">
              <Description>OPC UA DataValue</Description>
            </Option>
            <Option Short="n" Long="node-id" Value="NODE-ID" Required="false" 
Kind="scalar" ClrType="System.String">
              <Description>OPC UA NodeId</Description>
            </Option>
            <Option Short="p" Long="password" Value="PASSWORD" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
              <Description>OPC UA Password</Description>
            </Option>
            <Option Short="s" Long="server-url" Value="SERVER-URL" 
Required="false" Kind="scalar" ClrType="System.String">
              <Description>OPC UA Server Url</Description>
            </Option>
            <Option Short="u" Long="username" Value="USERNAME" Required="false" 
Kind="flagvalue" ClrType="Spectre.Console.Cli.FlagValue`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
              <Description>OPC UA UserName</Description>
            </Option>
            <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
              <Description>Use verbose for more debug/trace 
information</Description>
            </Option>
          </Parameters>
          <Examples>
            <Example commandLine="node write variable single -s 
opc.tcp://opcuaserver.com:48010 -n &quot;ns=2;s=Demo.Dynamic.Scalar.Float&quot; 
-d float --value &quot;100.5&quot;" />
          </Examples>
        </Command>
      </Command>
    </Command>
  </Command>
