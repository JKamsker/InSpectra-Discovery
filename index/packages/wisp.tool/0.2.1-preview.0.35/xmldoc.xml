<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--OPEN-->
  <Command Name="open" IsBranch="true" Settings="Wisp.Cli.OpenSettings">
    <Parameters>
      <Argument Name="INPUT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
    <!--SAVE-->
    <Command Name="save" IsBranch="false" ClrType="Wisp.Cli.SaveCommand" 
Settings="Wisp.Cli.SaveCommand+Settings">
      <Parameters>
        <Argument Name="OUTPUT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The output file</Description>
        </Argument>
        <Option Short="" Long="compression" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The compression to use: [blue]none[/], [blue]fastest[/], 
[blue]optimal[/], [blue]smallest[/]</Description>
        </Option>
        <Option Short="" Long="unpack" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Unpacks object streams during write</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SHOW-->
    <Command Name="show" IsBranch="true" Settings="Wisp.Cli.ShowSettings">
      <!--XREF-->
      <Command Name="xref" IsBranch="false" 
ClrType="Wisp.Cli.Show.ShowXRefTableCommand" 
Settings="Wisp.Cli.Show.ShowXRefTableCommand+Settings" />
      <!--OBJECTS-->
      <Command Name="objects" IsBranch="false" 
ClrType="Wisp.Cli.Show.ShowObjectsCommand" 
Settings="Wisp.Cli.Show.ShowObjectsCommand+Settings" />
    </Command>
  </Command>
</Model>