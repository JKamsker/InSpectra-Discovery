<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="ChooseALicense.Commands.ListCommand" 
Settings="ChooseALicense.Commands.ListCommand+Settings">
    <Parameters>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=6.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>limit the number of results returned</Description>
      </Option>
      <Option Short="s" Long="search" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>search id/title for a specific license</Description>
      </Option>
    </Parameters>
  </Command>
  <!--NEW-->
  <Command Name="new" IsBranch="false" 
ClrType="ChooseALicense.Commands.NewCommand" 
Settings="ChooseALicense.Commands.NewCommand+Settings">
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>id of the license. Use [underline]list[/] to find id 
values.</Description>
      </Argument>
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the license holder (will replace any instance of 
[name] in license).
Also Reads Environment Variable: CHOOSELICENSE_NAME</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>relative file path to create the license file (include the 
file name). default: "License.md"</Description>
      </Option>
      <Option Short="y" Long="year" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the license holder (will replace any instance of 
[name] in license).</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" 
ClrType="ChooseALicense.Commands.InfoCommand" 
Settings="ChooseALicense.Commands.InfoCommand+Settings">
    <Parameters>
      <Argument Name="id" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>id of the license. Use [underline]list[/] to find id 
values.</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--RULES-->
  <Command Name="rules" IsBranch="false" 
ClrType="ChooseALicense.Commands.RulesCommand" 
Settings="ChooseALicense.Commands.RulesCommand+Settings" />
</Model>