<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="ErikLieben.FA.ES.CLI.Commands.GenerateCommand" 
Settings="ErikLieben.FA.ES.CLI.Commands.GenerateCommand+Settings">
    <Parameters>
      <Argument Name="Path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="d" Long="with-diff" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
    </Parameters>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="ErikLieben.FA.ES.CLI.Commands.GenerateCommand" 
Settings="ErikLieben.FA.ES.CLI.Commands.GenerateCommand+Settings">
    <Description>Generate supporting code for ErikLieben.ES.FA</Description>
    <Parameters>
      <Argument Name="Path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="d" Long="with-diff" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="Solution.sln" />
      <Example commandLine="generate" />
      <Example commandLine="Solution.slnx" />
    </Examples>
  </Command>
  <!--WATCH-->
  <Command Name="watch" IsBranch="false" 
ClrType="ErikLieben.FA.ES.CLI.Commands.WatchCommand" 
Settings="ErikLieben.FA.ES.CLI.Commands.WatchCommand+Settings">
    <Description>Watch for file changes and automatically regenerate 
code</Description>
    <Parameters>
      <Argument Name="Path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the solution file (.sln or .slnx)</Description>
      </Argument>
      <Option Short="" Long="simple" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use simple output mode without full-screen 
TUI</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show verbose output including all file 
changes</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="watch" />
      <Example commandLine="Solution.sln" />
      <Example commandLine="watch" />
      <Example commandLine="--verbose" />
    </Examples>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="ErikLieben.FA.ES.CLI.Commands.UpdateCommand" 
Settings="ErikLieben.FA.ES.CLI.Commands.UpdateCommand+Settings">
    <Description>Update ErikLieben.FA.ES packages and migrate code for breaking 
changes</Description>
    <Parameters>
      <Argument Name="Path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the solution file (.sln or .slnx)</Description>
      </Argument>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show what would be changed without making actual 
changes</Description>
      </Option>
      <Option Short="" Long="skip-generate" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip running 'dotnet faes generate' after 
update</Description>
      </Option>
      <Option Short="" Long="skip-git-check" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip the git clean working directory check (not 
recommended)</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target version to update to (default: latest)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="update" />
      <Example commandLine="update" />
      <Example commandLine="--version 2.0.0" />
      <Example commandLine="update" />
      <Example commandLine="--dry-run" />
    </Examples>
  </Command>
</Model>