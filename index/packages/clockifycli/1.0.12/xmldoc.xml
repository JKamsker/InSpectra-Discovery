    <!--SCHEDULE-MONITOR-->
    <Command Name="schedule-monitor" IsBranch="false" 
ClrType="ClockifyCli.Commands.ConfigScheduleCommand" 
Settings="ClockifyCli.Commands.ConfigScheduleCommand+Settings">
      <Description>Set up scheduled task for timer monitoring</Description>
      <Parameters>
        <Option Short="i" Long="interval" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Interval in minutes for the scheduled task (15, 30, 60, 
120, 240)</Description>
        </Option>
        <Option Short="r" Long="remove" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Remove/delete the scheduled task instead of creating 
it</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="config" />
        <Example commandLine="schedule-monitor" />
        <Example commandLine="config" />
        <Example commandLine="schedule-monitor" />
        <Example commandLine="--interval" />
        <Example commandLine="60" />
        <Example commandLine="config" />
        <Example commandLine="schedule-monitor" />
        <Example commandLine="--remove" />
      </Examples>
    </Command>
  </Command>
</Model>