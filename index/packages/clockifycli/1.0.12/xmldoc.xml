  <!--WEEK-VIEW-->
  <Command Name="week-view" IsBranch="false" 
ClrType="ClockifyCli.Commands.WeekViewCommand" 
Settings="ClockifyCli.Commands.WeekViewCommand+Settings">
    <Description>Display current week's time entries from Clockify</Description>
    <Parameters>
      <Option Short="" Long="detailed" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show detailed view with start time, end time, and duration 
for each entry</Description>
      </Option>
      <Option Short="" Long="include-current" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include the currently running time entry in the 
view</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="week-view" />
      <Example commandLine="week-view" />
      <Example commandLine="--include-current" />
      <Example commandLine="week-view" />
      <Example commandLine="--detailed" />
      <Example commandLine="week-view" />
      <Example commandLine="--include-current" />
      <Example commandLine="--detailed" />
    </Examples>
  </Command>
