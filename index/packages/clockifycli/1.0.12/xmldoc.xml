  <!--TIMER-MONITOR-->
  <Command Name="timer-monitor" IsBranch="false" 
ClrType="ClockifyCli.Commands.TimerMonitorCommand" 
Settings="ClockifyCli.Commands.TimerMonitorCommand+Settings">
    <Description>Monitor timer status and show notifications (ideal for 
scheduled tasks)</Description>
    <Parameters>
      <Option Short="" Long="always-notify" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show notification even when timer is running (for status 
updates)</Description>
      </Option>
      <Option Short="s" Long="silent" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Silent mode - suppress console output (useful for scheduled
tasks)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="timer-monitor" />
      <Example commandLine="timer-monitor" />
      <Example commandLine="--silent" />
      <Example commandLine="timer-monitor" />
      <Example commandLine="--always-notify" />
    </Examples>
  </Command>
