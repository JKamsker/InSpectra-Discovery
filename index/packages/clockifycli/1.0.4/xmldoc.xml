<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--UPLOAD-TO-TEMPO-->
  <Command Name="upload-to-tempo" IsBranch="false" 
ClrType="ClockifyCli.Commands.UploadToTempoCommand" 
Settings="ClockifyCli.Commands.UploadToTempoCommand+Settings">
    <Description>Upload time entries from Clockify to Tempo</Description>
    <Parameters>
      <Option Short="" Long="cleanup-orphaned" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Clean up orphaned entries without Clockify IDs (use with 
caution)</Description>
      </Option>
      <Option Short="d" Long="days" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of days to upload time entries for</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="upload-to-tempo" />
      <Example commandLine="upload-to-tempo" />
      <Example commandLine="--days" />
      <Example commandLine="7" />
      <Example commandLine="upload-to-tempo" />
      <Example commandLine="--days" />
      <Example commandLine="30" />
      <Example commandLine="--cleanup-orphaned" />
    </Examples>
  </Command>
  <!--ADD-TASK-->
  <Command Name="add-task" IsBranch="false" 
ClrType="ClockifyCli.Commands.AddTaskCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Add a new task to Clockify from a Jira issue</Description>
    <Examples>
      <Example commandLine="add-task" />
    </Examples>
  </Command>
  <!--ARCHIVE-LIST-->
  <Command Name="archive-list" IsBranch="false" 
ClrType="ClockifyCli.Commands.ArchiveListCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>List tasks that can be archived based on Jira 
status</Description>
    <Examples>
      <Example commandLine="archive-list" />
    </Examples>
  </Command>
  <!--WEEK-VIEW-->
  <Command Name="week-view" IsBranch="false" 
ClrType="ClockifyCli.Commands.WeekViewCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Display current week's time entries from Clockify</Description>
    <Examples>
      <Example commandLine="week-view" />
    </Examples>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Configuration management commands</Description>
    <!--SET-->
    <Command Name="set" IsBranch="false" 
ClrType="ClockifyCli.Commands.ConfigSetCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Set API keys and credentials (required first 
step)</Description>
      <Examples>
        <Example commandLine="config" />
        <Example commandLine="set" />
      </Examples>
    </Command>
    <!--VIEW-->
    <Command Name="view" IsBranch="false" 
ClrType="ClockifyCli.Commands.ConfigViewCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>View current configuration</Description>
      <Examples>
        <Example commandLine="config" />
        <Example commandLine="view" />
      </Examples>
    </Command>
  </Command>
</Model>