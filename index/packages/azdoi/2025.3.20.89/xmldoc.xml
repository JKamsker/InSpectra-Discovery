<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INVENTORY-->
  <Command Name="inventory" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--REPOSITORIES-->
    <Command Name="repositories" IsBranch="false" 
ClrType="AZDOI.Commands.InventoryRepositoriesCommand" 
Settings="AZDOI.Commands.Settings.AZDOISettings">
      <Description>Example get repositories command.</Description>
      <Parameters>
        <Argument Name="devopsorg" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Azure DevOps organization name</Description>
          <Validators>
            <Validator ClrType="ValidateOrgAttribute" Message="NULL" />
          </Validators>
        </Argument>
        <Argument Name="outputpath" Position="1" Required="true" Kind="scalar" 
ClrType="Cake.Core.IO.DirectoryPath">
          <Description>Target directory for generated markdown 
files</Description>
          <Validators>
            <Validator ClrType="AZDOI.Commands.Validation.ValidatePathAttribute"
Message="NULL" />
          </Validators>
        </Argument>
        <Option Short="" Long="azure-tenant-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Entra Azure Tenant Id for Azure Devops 
Autentication</Description>
        </Option>
        <Option Short="" Long="entra-id-auth" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Use Entra Id for Azure Devops Autentication</Description>
        </Option>
        <Option Short="" Long="exclude-project" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Exclude specific projects</Description>
        </Option>
        <Option Short="" Long="exclude-repository" Value="NULL" Required="false"
Kind="vector" ClrType="System.String[]">
          <Description>Exclude specific repositories</Description>
        </Option>
        <Option Short="" Long="exclude-repository-readme" Value="NULL" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>Exclude specific repository README</Description>
        </Option>
        <Option Short="" Long="include-project" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Include specific projects</Description>
        </Option>
        <Option Short="" Long="include-repository" Value="NULL" Required="false"
Kind="vector" ClrType="System.String[]">
          <Description>Include specific repositories</Description>
        </Option>
        <Option Short="" Long="include-repository-readme" Value="NULL" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>Include specific repository README</Description>
        </Option>
        <Option Short="" Long="pat" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Personal Access Token for Azure Devops 
Autentication</Description>
        </Option>
        <Option Short="" Long="run-in-parallel" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Flag for if generation should be 
parallelized.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="inventory" />
        <Example commandLine="repositories" />
      </Examples>
    </Command>
  </Command>
</Model>