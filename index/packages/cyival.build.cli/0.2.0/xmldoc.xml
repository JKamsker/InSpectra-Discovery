<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Cyival.Build.Cli.Command.RootCommand" 
Settings="Cyival.Build.Cli.Command.RootCommand+Settings">
    <Parameters>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
    </Parameters>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="Cyival.Build.Cli.Command.BuildCommand" 
Settings="Cyival.Build.Cli.Command.BuildCommand+Settings">
    <Description>Build a cybuild project.</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="dep-only" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
      <Option Short="" Long="mode" Value="MODE" Required="false" Kind="scalar" 
ClrType="Cyival.Build.Build.BuildSettings+Mode" />
      <Option Short="o" Long="out" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="platform" Value="PLATFORM" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="t" Long="target" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--CLEAN-->
  <Command Name="clean" IsBranch="false" 
ClrType="Cyival.Build.Cli.Command.CleanCommand" 
Settings="Cyival.Build.Cli.Command.CleanCommand+Settings">
    <Description>Clean output directories</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="y" Long="" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Delete EVERYTHING without confirmation.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>