  "commands": [
    {
      "name": "init",
      "hidden": false,
      "description": "Creates a pre-push git hook.\nBy default the hook will both build and test your code unless specified otherwise with the -b and -t flags.\nAlternatively you can point to a config yml file using the -f flag.\nBy default, you will be asked whether you want to run builds and tests which is great if you are using the terminal\nbut will probably cause issues with GUIs. Be sure to use the -y flag if you are using GUIs.",
      "options": [
        {
          "name": "--build",
          "recursive": false,
          "hidden": false,
          "description": "Only enables the Build task (disables Test) Default: \"True\".",
          "aliases": [
            "-b"
          ]
        },
        {
          "name": "--test",
          "recursive": false,
          "hidden": false,
          "description": "Only enables the Test task (disables Build) Default: \"True\".",
          "aliases": [
            "-t"
          ]
        },
        {
          "name": "--file",
          "recursive": false,
          "hidden": false,
          "description": "Point to a yml config file Default: \"None\".",
          "aliases": [
            "-f"
          ]
        },
        {
          "name": "--yes",
          "recursive": false,
          "hidden": false,
          "description": "Always runs the tasks without asking you. Default: \"False\".",
          "aliases": [
            "-y"
          ]
        },
        {
          "name": "--help",
          "recursive": false,
          "hidden": false,
          "description": "Shows help text.",
