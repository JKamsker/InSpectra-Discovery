<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VISUALIZE-->
  <Command Name="visualize" IsBranch="false" 
ClrType="ProjGraph.Cli.Commands.VisualizeCommand" 
Settings="ProjGraph.Cli.Commands.VisualizeCommand+Settings">
    <Description>Visualize the dependency graph of a solution or 
project</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The path to the .sln, .slnx, or .csproj file</Description>
      </Argument>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output format (tree, mermaid)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="visualize" />
      <Example commandLine="MySolution.sln" />
      <Example commandLine="visualize" />
      <Example commandLine="MySolution.sln" />
      <Example commandLine="--format" />
      <Example commandLine="mermaid" />
    </Examples>
  </Command>
  <!--ERD-->
  <Command Name="erd" IsBranch="false" 
ClrType="ProjGraph.Cli.Commands.ErdCommand" 
Settings="ProjGraph.Cli.Commands.ErdCommand+Settings">
    <Description>Generate a Mermaid ERD for an Entity Framework Core 
DbContext</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to a .cs file containing a DbContext or ModelSnapshot 
(optional, searches current directory if not specified)</Description>
      </Argument>
      <Option Short="c" Long="context" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name of the DbContext or ModelSnapshot to analyze 
(optional)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="erd" />
      <Example commandLine="Data/AppDbContext.cs" />
      <Example commandLine="erd" />
      <Example commandLine="Data/AppDbContext.cs" />
      <Example commandLine="--context" />
      <Example commandLine="BlogContext" />
    </Examples>
  </Command>
  <!--CLASSDIAGRAM-->
  <Command Name="classdiagram" IsBranch="false" 
ClrType="ProjGraph.Cli.Commands.ClassDiagramCommand" 
Settings="ProjGraph.Cli.Commands.ClassDiagramCommand+Settings">
    <Description>Generate a Mermaid Class Diagram for a C# file</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .cs file to analyze.</Description>
      </Argument>
      <Option Short="d" Long="dependencies" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Discover dependent types in the workspace 
(optional)</Description>
      </Option>
      <Option Short="" Long="depth" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Max depth for relationship discovery (default 
1)</Description>
      </Option>
      <Option Short="i" Long="inheritance" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Discover base classes and interfaces in the workspace 
(optional)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="classdiagram" />
      <Example commandLine="Services/UserService.cs" />
      <Example commandLine="classdiagram" />
      <Example commandLine="Models/User.cs" />
      <Example commandLine="--inheritance" />
      <Example commandLine="--dependencies" />
    </Examples>
  </Command>
</Model>