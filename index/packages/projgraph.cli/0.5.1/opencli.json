{
  "opencli": "0.1-draft",
  "info": {
    "title": "projgraph",
    "version": "1.0"
  },
  "commands": [
    {
      "name": "classdiagram",
      "options": [
        {
          "name": "--dependencies",
          "required": false,
          "aliases": [
            "-d"
          ],
          "description": "Discover dependent types in the workspace (optional)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--depth",
          "required": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.Int32"
                }
              ]
            }
          ],
          "description": "Max depth for relationship discovery (default 1)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--functions",
          "required": false,
          "description": "Show functions and methods in the diagram (default \ntrue)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--inheritance",
          "required": false,
          "aliases": [
            "-i"
          ],
          "description": "Discover base classes and interfaces in the workspace \n(optional)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--properties",
          "required": false,
          "description": "Show properties and fields in the diagram (default \ntrue)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--show-title",
          "required": false,
          "description": "Include the diagram title (default true)",
          "recursive": false,
          "hidden": false
        }
      ],
      "arguments": [
        {
          "name": "path",
          "required": false,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Path to the .cs file to analyze.",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "Generate a Mermaid Class Diagram for a C# file",
      "hidden": false,
      "examples": [
        "classdiagram Services/UserService.cs",
        "classdiagram Models/User.cs --inheritance --dependencies --depth 10"
      ]
    },
    {
      "name": "erd",
      "options": [
        {
          "name": "--context",
          "required": false,
          "aliases": [
            "-c"
          ],
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "The name of the DbContext or ModelSnapshot to analyze \n(optional)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--show-title",
          "required": false,
          "description": "Include the diagram title (default true)",
          "recursive": false,
          "hidden": false
        }
      ],
      "arguments": [
        {
          "name": "path",
          "required": false,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Path to a .cs file containing a DbContext or \nModelSnapshot (optional, searches current directory if not specified)",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "Generate a Mermaid ERD for an Entity Framework Core \nDbContext",
      "hidden": false,
      "examples": [
        "erd Data/AppDbContext.cs",
        "erd Data/AppDbContext.cs --context BlogContext"
      ]
    },
    {
      "name": "visualize",
      "options": [
        {
          "name": "--format",
          "required": false,
          "aliases": [
            "-f"
          ],
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "The output format (flat, tree, mermaid)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--show-title",
          "required": false,
          "description": "Include the diagram title (default true)",
          "recursive": false,
          "hidden": false
        }
      ],
      "arguments": [
        {
          "name": "path",
          "required": false,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "The path to the .sln, .slnx, or .csproj file",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "Visualize the dependency graph of a solution or project",
      "hidden": false,
      "examples": [
        "visualize MySolution.sln",
        "visualize MySolution.sln --format tree"
      ]
    }
  ]
}
