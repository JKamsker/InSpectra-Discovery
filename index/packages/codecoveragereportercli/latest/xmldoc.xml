<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="CodeCoverageReporter.CLI.Commands.DefaultCommand" 
Settings="CodeCoverageReporter.CLI.Commands.DefaultCommand+Settings">
    <Description>CLI tool for reporting missing code coverage from Cobertura XML
reports.</Description>
    <Parameters>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Display the version number only.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REPORT-->
  <Command Name="report" IsBranch="false" 
ClrType="CodeCoverageReporter.CLI.Commands.ReportCommand" 
Settings="CodeCoverageReporter.CLI.Commands.ReportCommand+Settings">
    <Description>Generate a code coverage report.</Description>
    <Parameters>
      <Argument Name="files" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Cobertura XML file paths or glob patterns.</Description>
      </Argument>
      <Option Short="" Long="absolute-paths" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show full absolute file paths instead of relative 
paths.</Description>
      </Option>
      <Option Short="" Long="base-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Base directory for calculating relative paths (defaults to 
current directory).</Description>
      </Option>
      <Option Short="" Long="exclude" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Glob patterns to exclude files (can be specified multiple 
times).</Description>
      </Option>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of rows to output.</Description>
      </Option>
      <Option Short="" Long="output" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Output format: table (default), json, or 
markdown.</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show verbose processing information.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>