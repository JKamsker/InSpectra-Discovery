{
  "opencli": "0.1-draft",
  "info": {
    "title": "cover",
    "version": "1.0.1",
    "description": "CLI tool for reporting missing code coverage from Cobertura XML\nreports."
  },
  "x-inspectra": {
    "synthesized": true,
    "artifactSource": "synthesized-from-xmldoc",
    "sourceArtifact": "xmldoc.xml",
    "generator": "InSpectra.Discovery"
  },
  "commands": [
    {
      "name": "report",
      "options": [
        {
          "name": "--absolute-paths",
          "recursive": false,
          "hidden": false,
          "description": "Show full absolute file paths instead of relative \npaths."
        },
        {
          "name": "--base-path",
          "recursive": false,
          "hidden": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Base directory for calculating relative paths (defaults to \ncurrent directory)."
        },
        {
          "name": "--exclude",
          "recursive": false,
          "hidden": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String[]"
                }
              ]
            }
          ],
          "description": "Glob patterns to exclude files (can be specified multiple \ntimes)."
        },
        {
          "name": "--limit",
          "recursive": false,
          "hidden": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.Nullable<System.Int32>"
                }
              ]
            }
          ],
          "description": "Maximum number of rows to output."
        },
        {
          "name": "--output",
          "recursive": false,
          "hidden": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Output format: table (default), json, or \nmarkdown."
        },
        {
          "name": "--verbose",
          "recursive": false,
          "hidden": false,
          "description": "Show verbose processing information."
        }
      ],
      "arguments": [
        {
          "name": "files",
          "required": false,
          "arity": {
            "minimum": 0
          },
          "hidden": false,
          "description": "Cobertura XML file paths or glob patterns.",
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String[]"
            }
          ]
        }
      ],
      "description": "Generate a code coverage report.",
      "hidden": false
    }
  ],
  "options": [
    {
      "name": "--version",
      "recursive": false,
      "hidden": false,
      "aliases": [
        "-v"
      ],
      "description": "Display the version number only."
    }
  ]
}
