<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--PACK-->
  <Command Name="pack" IsBranch="false" 
ClrType="DeHive.Cli.CreateDataBankCommand" 
Settings="DeHive.Cli.CreateDataBankCommandSettings">
    <Description>Create databank</Description>
    <Parameters>
      <Argument Name="NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Package name</Description>
      </Argument>
      <Option Short="f" Long="folder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to folder</Description>
      </Option>
      <Option Short="o" Long="outputFolder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to output folder</Description>
      </Option>
    </Parameters>
  </Command>
  <!--PUBLISH-->
  <Command Name="publish" IsBranch="false" 
ClrType="DeHive.Cli.PublishDataBankCommand" 
Settings="DeHive.Cli.PublishDataBankCommandSettings">
    <Description>Create databank by manifest</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Manifest path</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--VIEW-->
  <Command Name="view" IsBranch="false" 
ClrType="DeHive.Cli.ViewBankDetailsCommand" 
Settings="DeHive.Cli.ViewBankDetailsCommandSettings">
    <Description>View details about bank</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Bank path</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--CERT-->
  <Command Name="cert" IsBranch="false" 
ClrType="DeHive.Cli.ViewBankDetailsCommand" 
Settings="DeHive.Cli.ViewBankDetailsCommandSettings">
    <Description>Generate certificate pair</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Bank path</Description>
      </Argument>
    </Parameters>
  </Command>
</Model>