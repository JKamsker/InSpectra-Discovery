<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--PACK-->
  <Command Name="pack" IsBranch="false" 
ClrType="DeHive.Cli.CreateDataBankCommand" 
Settings="DeHive.Cli.CreateDataBankCommandSettings">
    <Description>Create databank</Description>
    <Parameters>
      <Argument Name="NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Package name</Description>
      </Argument>
      <Option Short="f" Long="folder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to folder</Description>
      </Option>
      <Option Short="o" Long="outputFolder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to output folder</Description>
      </Option>
    </Parameters>
  </Command>
  <!--PUBLISH-->
  <Command Name="publish" IsBranch="false" 
ClrType="DeHive.Cli.PublishDataBankCommand" 
Settings="DeHive.Cli.PublishDataBankCommandSettings">
    <Description>Create databank by manifest</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Manifest path</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--VIEW-->
  <Command Name="view" IsBranch="false" 
ClrType="DeHive.Cli.ViewBankDetailsCommand" 
Settings="DeHive.Cli.ViewBankDetailsCommandSettings">
    <Description>View details about bank</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Bank path</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--CERT-->
  <Command Name="cert" IsBranch="false" 
ClrType="DeHive.Cli.ViewBankDetailsCommand" 
Settings="DeHive.Cli.ViewBankDetailsCommandSettings">
    <Description>Generate certificate pair</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Bank path</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--S3-->
  <Command Name="s3" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage S3 buckets</Description>
    <!--UPLOAD-->
    <Command Name="upload" IsBranch="false" 
ClrType="DeHive.Cli.UploadToS3Command" 
Settings="DeHive.Cli.UploadToS3CommandOptions">
      <Description>Upload file to S3</Description>
      <Parameters>
        <Argument Name="file" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Package file</Description>
        </Argument>
        <Option Short="u" Long="baseUrl" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>S3 baseUrl</Description>
        </Option>
        <Option Short="b" Long="bucket" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>S3 Bucket Name</Description>
        </Option>
        <Option Short="k" Long="key" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>S3 access key</Description>
        </Option>
        <Option Short="r" Long="region" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>S3 region</Description>
        </Option>
        <Option Short="s" Long="secret" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>S3 Secret Access</Description>
        </Option>
        <Option Short="v" Long="virtual-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>S3 Virtual Path</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>