<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="dotnet.openapi.generator.Cli.GenerateCommand" 
Settings="dotnet.openapi.generator.Cli.Options">
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the project</Description>
      </Argument>
      <Argument Name="document" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Location of the JSON swagger document. Can be both an http 
location or a local one</Description>
      </Argument>
      <Option Short="a" Long="additional-document" Value="NULL" Required="false"
Kind="scalar" ClrType="System.Collections.Generic.IList`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Location of additional swagger document, used to merge into
the main one. Can be both an http location or a local one and can be used 
multiple times</Description>
      </Option>
      <Option Short="c" Long="clean-directory" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Delete folder before generating</Description>
      </Option>
      <Option Short="" Long="client-modifier" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[dotnet.openapi.generator.Modifier, 
dotnet-openapi-generator, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=null]]">
        <Description>(Default: -m) The modifier for the generated clients; 
Useful when generating with interfaces. Can be Public or Internal</Description>
      </Option>
      <Option Short="d" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>(Default: Current Directory) The directory to place the 
files in</Description>
      </Option>
      <Option Short="f" Long="filter" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Text.RegularExpressions.Regex">
        <Description>(Default: No filter) Only generate Clients that match the 
supplied regex filter</Description>
      </Option>
      <Option Short="" Long="include-options-params" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Generate key value option params on each method to pass to 
each HttpRequestMessage.Options</Description>
      </Option>
      <Option Short="i" Long="interfaces" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Generate interfaces for the clients</Description>
      </Option>
      <Option Short="" Long="json-constructor-attribute" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Json Constructor Attribute. Constructors are generated when
the class contains required properties</Description>
      </Option>
      <Option Short="" Long="json-derived-type-attribute" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Json Derived Type Attribute. Marks the derived types of the
generated types using the specified attribute. {type} and {value} are used as 
template placeholders</Description>
      </Option>
      <Option Short="" Long="json-polymorphic-attribute" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Json Polymorphic Attribute. Marks the generated types as 
polymorphic using the specified attribute. {name} is used as a template 
placeholder</Description>
      </Option>
      <Option Short="" Long="json-property-name-attribute" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Json Property Name Attribute. Some property names are not 
valid in C#. This will make sure serialization works out. {name} is used as a 
template placeholder</Description>
      </Option>
      <Option Short="j" Long="json-source-generators" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Include dotnet 7.0+ Json Source Generators</Description>
      </Option>
      <Option Short="m" Long="modifier" Value="NULL" Required="false" 
Kind="scalar" ClrType="dotnet.openapi.generator.Modifier">
        <Description>The modifier for the generated files. Can be Public or 
Internal</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>(Default: Project name) The namespace used for the 
generated files</Description>
      </Option>
      <Option Short="o" Long="no-obsolete" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Do not generate obsolete endpoints</Description>
      </Option>
      <Option Short="p" Long="no-project" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Do not generate project</Description>
      </Option>
      <Option Short="" Long="oauth-client-credential-style" Value="NULL" 
Required="false" Kind="scalar" 
ClrType="dotnet.openapi.generator.ClientCredentialStyle">
        <Description>When including an OAuth Client, we can either pass values 
in the body or as a basic auth header. Can be PostBody or 
AuthorizationHeader</Description>
      </Option>
      <Option Short="" Long="oauth-type" Value="NULL" Required="false" 
Kind="scalar" ClrType="dotnet.openapi.generator.OAuthType">
        <Description>Includes an OAuth Client. Can be ClientCredentials, 
ClientCredentialsWithCertificate, TokenExchange or 
CachedTokenExchange</Description>
      </Option>
      <Option Short="r" Long="required-properties" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
        <Description>Include C# 11 Required keywords</Description>
      </Option>
      <Option Short="" Long="stringbuilder-pool-size" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.Int32">
        <Description>StringBuilder pool size for building query params. If 0, a 
simple string concat is used instead</Description>
      </Option>
      <Option Short="s" Long="tree-shake" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip generating unused models</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Verbose logging</Description>
      </Option>
    </Parameters>
  </Command>
</Model>