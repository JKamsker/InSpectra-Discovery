<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="WatchCommand" Settings="WatchCommandSettings">
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Test project path</Description>
      </Argument>
      <Argument Name="filter" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Show only tests that contain this text</Description>
      </Argument>
      <Option Short="e" Long="expand" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Displays test list for a class even if it does not have 
failed tests</Description>
      </Option>
      <Option Short="n" Long="no-output" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Hide test output for failed tests</Description>
      </Option>
      <Option Short="s" Long="show" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Only show test lists when matching this results (p|f|i) ex.
'--show fi' would only show failed and ignored tests.</Description>
      </Option>
      <Option Short="w" Long="watch-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Starts watching for changes in the set path</Description>
      </Option>
    </Parameters>
  </Command>
</Model>