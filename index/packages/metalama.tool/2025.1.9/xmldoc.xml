<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LICENSE-->
  <Command Name="license" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Register or unregister a license key, switch to Metalama Free 
or Metalama Trial, analyzes license usage.</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.ListLicensesCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Lists registered license.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REGISTER-->
    <Command Name="register" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.RegisterLicenseCommand" 
Settings="Metalama.Backstage.Commands.Licensing.RegisterLicenseCommandSettings">
      <Description>Registers a license key.</Description>
      <Parameters>
        <Argument Name="license" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The license key to be registered or unregistered, or 
'trial' or 'free'.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--UNREGISTER-->
    <Command Name="unregister" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.UnregisterCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Unregisters all license keys.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--TRY-->
    <Command Name="try" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.RegisterTrialCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Starts the trial period.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--COMMUNITY-->
    <Command Name="community" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.RegisterCommunityCommand" 
Settings="Metalama.Backstage.Commands.Licensing.RegisterCommunityCommandSettings
">
      <Description>Switches to Metalama Community.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="reason" Value="NULL" Required="false" 
Kind="scalar" ClrType="Metalama.Backstage.Licensing.CommunityLicenseReason">
          <Description>Prints trace messages.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--FREE-->
    <Command Name="free" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.RegisterLegacyFreeCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Registers the legacy to Metalama Free license (for Metalama 
2025.0 and earlier).</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Lists, edits, prints, resets configuration 
settings.</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Configuration.ListConfigurationsCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Lists the supported JSON configuration files</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--EDIT-->
    <Command Name="edit" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Configuration.EditConfigurationCommand" 
Settings="Metalama.Backstage.Commands.Configuration.ConfigurationCommandSettings
">
      <Description>Opens a given JSON configuration file in the default text 
editor.</Description>
      <Parameters>
        <Argument Name="alias" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The alias of the configuration file. Use the 
'configuration list' command to list available configuration 
files.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESET-->
    <Command Name="reset" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Configuration.ResetConfigurationCommand" 
Settings="Metalama.Backstage.Commands.Configuration.ConfigurationCommandSettings
">
      <Description>Resets a given configuration file to its default 
value.</Description>
      <Parameters>
        <Argument Name="alias" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The alias of the configuration file. Use the 
'configuration list' command to list available configuration 
files.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--PRINT-->
    <Command Name="print" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Configuration.PrintConfigurationCommand" 
Settings="Metalama.Backstage.Commands.Configuration.ConfigurationCommandSettings
">
      <Description>Prints the content of the given configuration file to the 
console.</Description>
      <Parameters>
        <Argument Name="alias" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The alias of the configuration file. Use the 
'configuration list' command to list available configuration 
files.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--VALIDATE-->
    <Command Name="validate" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Configuration.ValidateConfigurationCommand"
Settings="Metalama.Backstage.Commands.Configuration.ConfigurationCommandSettings
">
      <Description>Validates the content of the given configuration 
file.</Description>
      <Parameters>
        <Argument Name="alias" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The alias of the configuration file. Use the 
'configuration list' command to list available configuration 
files.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CLEANUP-->
  <Command Name="cleanup" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Maintenance.CleanUpCommand" 
Settings="Metalama.Backstage.Commands.Maintenance.CleanUpCommandSettings">
    <Description>Cleans up temporary files generated by Metalama.</Description>
    <Parameters>
      <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Deletes all directories and files ignoring clean-up 
policies.</Description>
      </Option>
      <Option Short="" Long="no-kill" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Does not kill processes before clean-up.</Description>
      </Option>
      <Option Short="" Long="no-warn" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Does not report any warnings.</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Prints trace messages.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--KILL-->
  <Command Name="kill" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Maintenance.KillCommand" 
Settings="Metalama.Backstage.Commands.Maintenance.KillCommandSettings">
    <Description>Shuts down or kills processes that may be locking Metalama 
packages.</Description>
    <Parameters>
      <Option Short="" Long="no-warn" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Does not report any warnings.</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Prints trace messages.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--TELEMETRY-->
  <Command Name="telemetry" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manages the telemetry options and upload queue.</Description>
    <!--ENABLE-->
    <Command Name="enable" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.EnableTelemetryCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Enables telemetry.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DISABLE-->
    <Command Name="disable" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.DisableTelemetryCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Disables telemetry.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESET-DEVICE-ID-->
    <Command Name="reset-device-id" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.ResetDeviceIdCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Resets the identifier that telemetry uses to uniquely 
identify the current device.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--UPLOAD-->
    <Command Name="upload" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.UploadTelemetryCommand" 
Settings="Metalama.Backstage.Commands.Telemetry.UploadTelemetryCommandSettings">
      <Description>Uploads all telemetry data present in the 
queue.</Description>
      <Parameters>
        <Option Short="a" Long="async" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Run the upload asynchronously in a background 
process.</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force the upload even if another upload has been 
performed recently.</Description>
        </Option>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--STATUS-->
    <Command Name="status" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.TelemetryStatusCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Displays the configuration and the status of 
telemetry.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
