  <!--DIVORCE-->
  <Command Name="divorce" IsBranch="false" 
ClrType="Metalama.Tool.Divorce.DivorceCommand" 
Settings="Metalama.Tool.Divorce.DivorceCommandSettings">
    <Description>Copies code generated by Metalama back into your source code, 
in case you wanted to stop using Metalama.</Description>
    <Parameters>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force the divorce feature, even if the working directory is
