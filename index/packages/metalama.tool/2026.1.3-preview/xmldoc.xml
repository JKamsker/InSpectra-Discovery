        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESET-->
    <Command Name="reset" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Configuration.ResetConfigurationCommand" 
Settings="Metalama.Backstage.Commands.Configuration.ConfigurationCommandSettings
">
      <Description>Resets a configuration file to its default 
values.</Description>
      <Parameters>
        <Argument Name="alias" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The alias of the configuration file. Use the 
'configuration list' command to list available configuration 
files.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--PRINT-->
    <Command Name="print" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Configuration.PrintConfigurationCommand" 
Settings="Metalama.Backstage.Commands.Configuration.ConfigurationCommandSettings
">
      <Description>Displays the contents of a configuration file in the 
console.</Description>
      <Parameters>
        <Argument Name="alias" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The alias of the configuration file. Use the 
'configuration list' command to list available configuration 
files.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--VALIDATE-->
    <Command Name="validate" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Configuration.ValidateConfigurationCommand"
Settings="Metalama.Backstage.Commands.Configuration.ConfigurationCommandSettings
">
      <Description>Validates a configuration file against its 
schema.</Description>
      <Parameters>
        <Argument Name="alias" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The alias of the configuration file. Use the 
'configuration list' command to list available configuration 
files.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CLEANUP-->
  <Command Name="cleanup" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Maintenance.CleanUpCommand" 
Settings="Metalama.Backstage.Commands.Maintenance.CleanUpCommandSettings">
    <Description>Removes temporary files and cache generated by 
Metalama.</Description>
    <Parameters>
      <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Deletes all directories and files ignoring clean-up 
policies.</Description>
      </Option>
      <Option Short="" Long="no-kill" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Does not kill processes before clean-up.</Description>
      </Option>
      <Option Short="" Long="no-warn" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Does not report any warnings.</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Prints trace messages.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--KILL-->
  <Command Name="kill" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Maintenance.KillCommand" 
Settings="Metalama.Backstage.Commands.Maintenance.KillCommandSettings">
    <Description>Terminates processes that may be locking Metalama 
packages.</Description>
    <Parameters>
      <Option Short="" Long="no-warn" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Does not report any warnings.</Description>
