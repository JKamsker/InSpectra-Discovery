<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LICENSE-->
  <Command Name="license" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manages license keys and switch between Metalama 
editions.</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.ListLicensesCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Lists all registered licenses.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REGISTER-->
    <Command Name="register" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.RegisterLicenseCommand" 
Settings="Metalama.Backstage.Commands.Licensing.RegisterLicenseCommandSettings">
      <Description>Registers a new license key.</Description>
      <Parameters>
        <Argument Name="license" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The license key to be registered or unregistered, or 
'trial' or 'free'.</Description>
        </Argument>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--UNREGISTER-->
    <Command Name="unregister" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.UnregisterCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Unregisters all license keys.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--TRY-->
    <Command Name="try" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.RegisterTrialCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Activates the Metalama trial period.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--COMMUNITY-->
    <Command Name="community" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.RegisterCommunityCommand" 
Settings="Metalama.Backstage.Commands.Licensing.RegisterCommunityCommandSettings
">
      <Description>Switches to the Metalama Community edition.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="reason" Value="NULL" Required="false" 
Kind="scalar" ClrType="Metalama.Backstage.Licensing.CommunityLicenseReason">
          <Description>Prints trace messages.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--FREE-->
    <Command Name="free" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Licensing.RegisterLegacyFreeCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Registers the legacy Metalama Free license (for Metalama 
2025.0 and earlier).</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CONFIG-->
