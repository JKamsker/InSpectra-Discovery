Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DISABLE-->
    <Command Name="disable" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.DisableTelemetryCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Disables anonymous usage telemetry.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESET-DEVICE-ID-->
    <Command Name="reset-device-id" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.ResetDeviceIdCommand" 
Settings="Metalama.Backstage.Commands.BaseCommandSettings">
      <Description>Generates a new anonymous device identifier for 
telemetry.</Description>
      <Parameters>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--UPLOAD-->
    <Command Name="upload" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.UploadTelemetryCommand" 
Settings="Metalama.Backstage.Commands.Telemetry.UploadTelemetryCommandSettings">
      <Description>Uploads all queued telemetry data immediately.</Description>
      <Parameters>
        <Option Short="a" Long="async" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Run the upload asynchronously in a background 
process.</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force the upload even if another upload has been 
performed recently.</Description>
        </Option>
        <Option Short="" Long="no-warn" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Does not report any warnings.</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Prints trace messages.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--STATUS-->
    <Command Name="status" IsBranch="false" 
ClrType="Metalama.Backstage.Commands.Telemetry.TelemetryStatusCommand" 
