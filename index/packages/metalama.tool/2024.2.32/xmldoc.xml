        <Parameters>
          <Option Short="c" Long="configuration" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Includes only the specified build configurations 
(typically Debug or Release).  May be a comma-separated list.</Description>
          </Option>
          <Option Short="d" Long="days" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Double, System.Private.CoreLib,
