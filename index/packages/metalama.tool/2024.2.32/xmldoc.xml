Kind="flag" ClrType="System.Boolean">
            <Description>Does not report any warnings.</Description>
          </Option>
          <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Includes only the specified projects, specified by file
name without extension. You can use `*` to match any substring. May be a 
comma-separated list.</Description>
          </Option>
          <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Prints trace messages.</Description>
