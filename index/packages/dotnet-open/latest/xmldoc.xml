<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DotNetOpen.OpenSolutionCommand" 
Settings="DotNetOpen.OpenSolutionCommand+Settings">
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to search. Defaults to current 
directory.</Description>
      </Argument>
      <Option Short="f" Long="first" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Open first solution if multiple are found.</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Print version of this tool and exit</Description>
      </Option>
    </Parameters>
  </Command>
</Model>