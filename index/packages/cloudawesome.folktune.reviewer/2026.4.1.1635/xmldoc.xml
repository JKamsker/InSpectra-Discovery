<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--REVIEW-->
  <Command Name="review" IsBranch="false" 
ClrType="CloudAwesome.FolkTune.Reviewer.Commands.ReviewCommand" 
Settings="CloudAwesome.FolkTune.Reviewer.Settings.ReviewSettings">
    <Description>Start an interactive review session</Description>
    <Parameters>
      <Option Short="" Long="count" Value="N" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of tunes to select</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Do not save any changes</Description>
      </Option>
      <Option Short="" Long="include-excluded" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include tunes marked as excluded</Description>
      </Option>
      <Option Short="" Long="include-session" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include tunes marked as session-maintained</Description>
      </Option>
      <Option Short="" Long="origin" Value="TEXT" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Filter by origin</Description>
      </Option>
      <Option Short="" Long="store" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the review store JSON file</Description>
      </Option>
      <Option Short="" Long="tune" Value="NAME_OR_ID" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Review a specific tune by its title or ID, bypassing 
automated selection logic</Description>
      </Option>
      <Option Short="" Long="vault" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the Obsidian vault root</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ADMIN-->
  <Command Name="admin" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Automate administrative tasks with your vault required to use 
and maintain this CLI</Description>
    <!--ID-INIT-->
    <Command Name="id-init" IsBranch="false" 
ClrType="CloudAwesome.FolkTune.Reviewer.Commands.IdsInitCommand" 
Settings="CloudAwesome.FolkTune.Reviewer.Settings.IdsInitSettings">
      <Description>Initialize missing tune IDs in markdown files</Description>
      <Parameters>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Do not save any changes</Description>
        </Option>
        <Option Short="" Long="include-existing" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Re-generate IDs even for files that already have one 
(default false)</Description>
        </Option>
        <Option Short="" Long="limit" Value="N" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Limit the number of files to update</Description>
        </Option>
        <Option Short="r" Long="root" Value="SUBFOLDER" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Subfolder within the vault to scan (optional; default 
scans all)</Description>
        </Option>
        <Option Short="" Long="store" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the review store JSON file</Description>
        </Option>
        <Option Short="" Long="vault" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the Obsidian vault root</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--PICK-->
  <Command Name="pick" IsBranch="false" 
ClrType="CloudAwesome.FolkTune.Reviewer.Commands.PickCommand" 
Settings="CloudAwesome.FolkTune.Reviewer.Settings.PickSettings">
    <Description>Show which tunes would be selected for review</Description>
    <Parameters>
      <Option Short="" Long="count" Value="N" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of tunes to select</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Do not save any changes</Description>
      </Option>
      <Option Short="" Long="include-excluded" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include tunes marked as excluded</Description>
      </Option>
      <Option Short="" Long="include-session" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include tunes marked as session-maintained</Description>
      </Option>
      <Option Short="" Long="origin" Value="TEXT" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Filter by origin</Description>
      </Option>
      <Option Short="" Long="store" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the review store JSON file</Description>
      </Option>
      <Option Short="" Long="vault" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the Obsidian vault root</Description>
      </Option>
    </Parameters>
  </Command>
  <!--STATS-->
  <Command Name="stats" IsBranch="false" 
ClrType="CloudAwesome.FolkTune.Reviewer.Commands.StatsCommand" 
Settings="CloudAwesome.FolkTune.Reviewer.Settings.BaseSettings">
    <Description>Show repertoire health statistics</Description>
    <Parameters>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Do not save any changes</Description>
      </Option>
      <Option Short="" Long="store" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the review store JSON file</Description>
      </Option>
      <Option Short="" Long="vault" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the Obsidian vault root</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SESSION-->
  <Command Name="session" IsBranch="false" 
ClrType="CloudAwesome.FolkTune.Reviewer.Commands.SessionCommand" 
Settings="CloudAwesome.FolkTune.Reviewer.Settings.SessionSettings">
    <Description>Mark tunes as played at a session</Description>
    <Parameters>
      <Option Short="" Long="count" Value="N" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Number of tunes to mark (used with --origin)</Description>
      </Option>
      <Option Short="" Long="date" Value="YYYY-MM-DD" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Date the tunes were played (default today)</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Do not save any changes</Description>
      </Option>
      <Option Short="" Long="from-file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to a file containing ids or titles (one per 
line)</Description>
      </Option>
      <Option Short="" Long="origin" Value="TEXT" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Select tunes by origin for bulk marking</Description>
      </Option>
      <Option Short="" Long="store" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the review store JSON file</Description>
      </Option>
      <Option Short="" Long="vault" Value="PATH" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the Obsidian vault root</Description>
      </Option>
    </Parameters>
  </Command>
</Model>