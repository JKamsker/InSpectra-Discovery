<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="BingChat.Cli.Commands.ConversationCommand" 
Settings="BingChat.Cli.Commands.ConversationCommand+Settings">
    <Parameters>
      <Option Short="t" Long="theme" Value="NULL" Required="false" Kind="scalar"
ClrType="BingChat.Cli.ChatTheme">
        <Description>Specify the theme to use</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ASK-->
  <Command Name="ask" IsBranch="false" 
ClrType="BingChat.Cli.Commands.AskCommand" 
Settings="BingChat.Cli.Commands.AskCommand+Settings">
    <Parameters>
      <Argument Name="message" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
        <Description>The message to ask</Description>
      </Argument>
      <Option Short="t" Long="theme" Value="NULL" Required="false" Kind="scalar"
ClrType="BingChat.Cli.ChatTheme">
        <Description>Specify the theme to use</Description>
      </Option>
    </Parameters>
  </Command>
</Model>