<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LOGIN-->
  <Command Name="login" IsBranch="false" 
ClrType="Coldbase.DevelopmentTool.Commands.LoginCommand" 
Settings="Coldbase.DevelopmentTool.Commands.LoginCommand+Settings">
    <Parameters>
      <Option Short="" Long="code" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The authentication code to use. May be used instead of the 
interactive login.</Description>
      </Option>
      <Option Short="" Long="instance" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Coldbase instance to use. Must be in the format of 
'host:port' or 'host'.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DEPLOY-->
  <Command Name="deploy" IsBranch="false" 
ClrType="Coldbase.DevelopmentTool.Commands.Deploy.DeployCommand`1[[Coldbase.Deve
lopmentTool.Commands.Deploy.DeployCommandSettings, Coldbase.DevelopmentTool, 
Version=1.0.0.0, Culture=neutral, PublicKeyToken=null]]" 
Settings="Coldbase.DevelopmentTool.Commands.Deploy.DeployCommandSettings">
    <Parameters>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force the deployment even if the instance already has the 
same version.</Description>
      </Option>
      <Option Short="" Long="instance" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Coldbase instance to use. Must be in the format of 
'host:port' or 'host'.</Description>
      </Option>
      <Option Short="" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The id of the project to deploy modules to.</Description>
      </Option>
      <Option Short="" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path of the solution where the modules are 
located.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DEV-->
  <Command Name="dev" IsBranch="false" 
ClrType="Coldbase.DevelopmentTool.Commands.DevCommand" 
Settings="Coldbase.DevelopmentTool.Commands.DevCommand+Settings">
    <Parameters>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force the deployment even if the instance already has the 
same version.</Description>
      </Option>
      <Option Short="" Long="generated-sdk-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path where the generated SDK should be 
