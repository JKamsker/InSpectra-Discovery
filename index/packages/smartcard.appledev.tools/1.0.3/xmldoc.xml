    <!--PARSE-->
    <Command Name="parse" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.ParseProvisioningProfileCommand" 
Settings="AppleDev.Tool.Commands.ParseProvisioningProfileCommandSettings">
      <Description>Parses and displays information from a .mobileprovision 
file</Description>
      <Parameters>
        <Argument Name="provisioningprofile_file" Position="0" Required="true" 
Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Provisioning Profile file to parse</Description>
        </Argument>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AppleDev.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="i" Long="issuer-id,app-store-connect-issuer-id" 
Value="ISSUER_ID" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Issuer ID value or environment variable 
name (Can also be supplied via the 'APP_STORE_CONNECT_ISSUER_ID' environment 
variable)</Description>
        </Option>
        <Option Short="k" Long="key-id,app-store-connect-key-id" Value="KEY_ID" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Key ID value or environment variable name
(Can also be supplied via the 'APP_STORE_CONNECT_KEY_ID' environment 
variable)</Description>
        </Option>
        <Option Short="p" Long="private-key,app-store-connect-private-key" 
Value="PRIVATE_KEY" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Private Key (.p8) filename or environment
variable name with (.p8) file contents (Can also be supplied via the 
'APP_STORE_CONNECT_PRIVATE_KEY' environment variable)</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Verbose</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="provisioning" />
        <Example commandLine="parse" />
        <Example commandLine="MyApp_Development.mobileprovision" />
        <Example commandLine="provisioning" />
        <Example commandLine="parse" />
        <Example commandLine="~/Downloads/MyApp_AppStore.mobileprovision" />
        <Example commandLine="--format" />
        <Example commandLine="json" />
      </Examples>
    </Command>
  </Command>
  <!--BUNDLEIDS-->
