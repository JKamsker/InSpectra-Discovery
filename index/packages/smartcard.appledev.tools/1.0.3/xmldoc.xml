<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--PROVISIONING-->
  <Command Name="provisioning" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.ListProvisioningProfilesCommand" 
Settings="AppleDev.Tool.Commands.ListProvisioningProfilesCommandSettings">
      <Description>Lists App Store Connect provisioning profiles with download 
option</Description>
      <Parameters>
        <Option Short="a" Long="active" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Only list active</Description>
        </Option>
        <Option Short="b" Long="bundle-id" Value="BUNDLE-ID" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Filter Profiles by BundleID</Description>
        </Option>
        <Option Short="d" Long="download" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Download and install the profiles locally</Description>
        </Option>
        <Option Short="" Long="download-path" Value="DIRECTORY" Required="false"
Kind="scalar" ClrType="System.IO.DirectoryInfo">
          <Description>Override default directory to save downloaded profiles 
to</Description>
        </Option>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AppleDev.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="i" Long="issuer-id,app-store-connect-issuer-id" 
Value="ISSUER_ID" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Issuer ID value or environment variable 
name (Can also be supplied via the 'APP_STORE_CONNECT_ISSUER_ID' environment 
variable)</Description>
        </Option>
        <Option Short="k" Long="key-id,app-store-connect-key-id" Value="KEY_ID" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Key ID value or environment variable name
(Can also be supplied via the 'APP_STORE_CONNECT_KEY_ID' environment 
variable)</Description>
        </Option>
        <Option Short="p" Long="private-key,app-store-connect-private-key" 
Value="PRIVATE_KEY" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Private Key (.p8) filename or environment
variable name with (.p8) file contents (Can also be supplied via the 
'APP_STORE_CONNECT_PRIVATE_KEY' environment variable)</Description>
        </Option>
        <Option Short="t" Long="type" Value="TYPE" Required="false" 
Kind="vector" ClrType="AppleAppStoreConnect.ProfileType[]">
          <Description>Filter to provisioning profile type</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Verbose</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="provisioning" />
        <Example commandLine="list" />
        <Example commandLine="provisioning" />
        <Example commandLine="list" />
        <Example commandLine="--download" />
        <Example commandLine="provisioning" />
        <Example commandLine="list" />
        <Example commandLine="--format" />
        <Example commandLine="json" />
      </Examples>
    </Command>
