<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="SrcSet.Command" Settings="SrcSet.Settings">
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>the file or directory to resize</Description>
      </Argument>
      <Argument Name="sizes" Position="1" Required="false" Kind="vector" 
ClrType="System.UInt16[]">
        <Description>the set of widths to resize the image(s) to</Description>
      </Argument>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>recurse subdirectories</Description>
      </Option>
    </Parameters>
  </Command>
</Model>