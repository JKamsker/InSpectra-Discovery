<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="CliTodoSharp.Commands.AddCommand" 
Settings="CliTodoSharp.Commands.AddCommand+Settings">
    <Description>Add a new task.</Description>
    <Parameters>
      <Argument Name="TITLE" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Short title of the task (prompted if 
omitted).</Description>
      </Argument>
      <Option Short="d" Long="description" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional longer description.</Description>
      </Option>
      <Option Short="" Long="due" Value="DATE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Due date in ISO format: yyyy-MM-dd or 
yyyy-MM-ddTHH:mm</Description>
      </Option>
      <Option Short="p" Long="priority" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>none | low | medium (default) | high | 
critical</Description>
      </Option>
      <Option Short="" Long="storage" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Override the path to the tasks JSON file for this 
invocation.</Description>
      </Option>
      <Option Short="t" Long="tags" Value="TAGS" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Comma-separated tags, e.g. work,home</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="todo" />
      <Example commandLine="add" />
      <Example commandLine="&quot;Buy milk&quot;" />
      <Example commandLine="--priority" />
      <Example commandLine="low" />
      <Example commandLine="--due" />
      <Example commandLine="2025-03-15" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="CliTodoSharp.Commands.ListCommand" 
Settings="CliTodoSharp.Commands.ListCommand+Settings">
    <Description>List tasks.</Description>
    <Parameters>
      <Option Short="" Long="detail" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>When set, render a full detail panel for each task instead 
of a table row.</Description>
      </Option>
      <Option Short="" Long="sort" Value="FIELD" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Sort by: created (default) | due | priority | title | 
status</Description>
      </Option>
      <Option Short="s" Long="status" Value="STATUS" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by: pending | inprogress | done | canceled | overdue
| all (default)</Description>
      </Option>
      <Option Short="" Long="storage" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Override the path to the tasks JSON file for this 
invocation.</Description>
      </Option>
      <Option Short="t" Long="tag" Value="TAG" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Show only tasks that contain this tag.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="todo" />
      <Example commandLine="list" />
      <Example commandLine="--status" />
      <Example commandLine="overdue" />
      <Example commandLine="todo" />
      <Example commandLine="list" />
      <Example commandLine="--tag" />
      <Example commandLine="work" />
      <Example commandLine="--sort" />
      <Example commandLine="priority" />
    </Examples>
  </Command>
  <!--SHOW-->
  <Command Name="show" IsBranch="false" 
ClrType="CliTodoSharp.Commands.ShowCommand" 
Settings="CliTodoSharp.Commands.ShowCommand+Settings">
    <Description>Show full detail of a task.</Description>
    <Parameters>
      <Argument Name="INDEX" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
        <Description>Display index of the task.</Description>
      </Argument>
      <Option Short="" Long="storage" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Override the path to the tasks JSON file for this 
invocation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="todo" />
      <Example commandLine="show" />
      <Example commandLine="3" />
    </Examples>
  </Command>
  <!--START-->
  <Command Name="start" IsBranch="false" 
ClrType="CliTodoSharp.Commands.StartCommand" 
Settings="CliTodoSharp.Commands.StartCommand+Settings">
    <Description>Mark a task as In Progress.</Description>
    <Parameters>
      <Argument Name="INDEX" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
        <Description>Display index of the task (see 'todo list').</Description>
      </Argument>
      <Option Short="" Long="storage" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Override the path to the tasks JSON file for this 
invocation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="todo" />
      <Example commandLine="start" />
      <Example commandLine="2" />
    </Examples>
  </Command>
