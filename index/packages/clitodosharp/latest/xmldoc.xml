  <!--REOPEN-->
  <Command Name="reopen" IsBranch="false" 
ClrType="CliTodoSharp.Commands.ReopenCommand" 
Settings="CliTodoSharp.Commands.ReopenCommand+Settings">
    <Description>Reopen a Done or Canceled task.</Description>
    <Parameters>
      <Argument Name="INDEX" Position="0" Required="true" Kind="scalar" 
