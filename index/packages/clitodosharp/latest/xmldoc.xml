  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" 
ClrType="CliTodoSharp.Commands.RemoveCommand" 
Settings="CliTodoSharp.Commands.RemoveCommand+Settings">
    <Description>Permanently remove a task.</Description>
    <Parameters>
      <Argument Name="INDEX" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
        <Description>Display index of the task.</Description>
      </Argument>
      <Option Short="" Long="storage" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Override the path to the tasks JSON file for this 
invocation.</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip the confirmation prompt.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="todo" />
      <Example commandLine="remove" />
      <Example commandLine="3" />
      <Example commandLine="--yes" />
    </Examples>
  </Command>
  <!--EDIT-->
  <Command Name="edit" IsBranch="false" 
ClrType="CliTodoSharp.Commands.EditCommand" 
Settings="CliTodoSharp.Commands.EditCommand+Settings">
    <Description>Edit task fields.</Description>
    <Parameters>
      <Argument Name="INDEX" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
        <Description>Display index of the task.</Description>
      </Argument>
      <Option Short="" Long="clear-description" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Remove the description entirely.</Description>
      </Option>
      <Option Short="" Long="clear-due" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Remove the due date entirely.</Description>
      </Option>
      <Option Short="" Long="description" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New description.</Description>
      </Option>
      <Option Short="" Long="due" Value="DATE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>New due date (yyyy-MM-dd). Use --clear-due to remove the 
due date.</Description>
      </Option>
      <Option Short="p" Long="priority" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>none | low | medium | high | critical</Description>
      </Option>
      <Option Short="" Long="storage" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Override the path to the tasks JSON file for this 
invocation.</Description>
      </Option>
      <Option Short="t" Long="tags" Value="TAGS" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Replace all tags with this comma-separated 
list.</Description>
      </Option>
      <Option Short="" Long="title" Value="TEXT" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>New title for the task.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="todo" />
      <Example commandLine="edit" />
      <Example commandLine="1" />
      <Example commandLine="--title" />
      <Example commandLine="&quot;New title&quot;" />
      <Example commandLine="--priority" />
      <Example commandLine="critical" />
    </Examples>
  </Command>
  <!--DESC-->
  <Command Name="desc" IsBranch="false" 
ClrType="CliTodoSharp.Commands.DescCommand" 
Settings="CliTodoSharp.Commands.DescCommand+Settings">
    <Description>View or set the description of a task.</Description>
    <Parameters>
      <Argument Name="INDEX" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
        <Description>Display index of the task.</Description>
      </Argument>
      <Argument Name="TEXT" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>New description text.  Omit to print the current 
description.</Description>
      </Argument>
      <Option Short="" Long="clear" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Remove the description entirely.</Description>
      </Option>
      <Option Short="" Long="storage" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Override the path to the tasks JSON file for this 
invocation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="todo" />
      <Example commandLine="desc" />
      <Example commandLine="1" />
      <Example commandLine="&quot;Detailed notes here...&quot;" />
      <Example commandLine="todo" />
      <Example commandLine="desc" />
      <Example commandLine="1" />
      <Example commandLine="--clear" />
    </Examples>
  </Command>
