ClrType="Adeotek.DevOpsTools.Commands.Containers.ContainersUpCommand" 
Settings="Adeotek.DevOpsTools.CommandsSettings.Containers.ContainersUpSettings">
      <Parameters>
        <Argument Name="config_file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Config file (with absolute/relative path)</Description>
        </Argument>
        <Option Short="b" Long="backup" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Backup container volumes before updating
Only works together with the '--update' option</Description>
        </Option>
        <Option Short="l" Long="backup-location" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Volumes backup location (absolute/relative 
path)</Description>
        </Option>
        <Option Short="" Long="cfg-v1" Value="NULL" Required="false" Kind="flag"
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Flag for using old configuration file (v1)</Description>
        </Option>
        <Option Short="d" Long="do-not-start" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Don't start the container after creation</Description>
        </Option>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Don't apply any changes, just print the 
commands</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force container recreation (update), even if the 
container is on the latest image
Only works together with the '--update' option</Description>
        </Option>
        <Option Short="n" Long="name" Value="VALUE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Execute the command only for the service with the 
provided name</Description>
        </Option>
        <Option Short="r" Long="replace" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Replace existing container, instead of demoting it to 
'previous'
Only works together with the '--update' option</Description>
        </Option>
        <Option Short="" Long="show-cfg" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Display loaded configuration</Description>
        </Option>
        <Option Short="s" Long="silent" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Don't output any messages except errors
(only outputs 0/1 depending if anything got changed or not)</Description>
        </Option>
        <Option Short="u" Long="upgrade" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Upgrade container if it exists</Description>
        </Option>
        <Option Short="" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Output all messages, including external commands 
output</Description>
        </Option>
      </Parameters>
    </Command>
