{
  "opencli": "0.1-draft",
  "info": {
    "title": "Ninjadog.dll",
    "version": "1.0"
  },
  "commands": [
    {
      "name": "add-entity",
      "arguments": [
        {
          "name": "entityName",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "The name of the entity to add (PascalCase).",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "Adds a new entity to the ninjadog.json file.",
      "hidden": false,
      "examples": [
        "add-entity Product"
      ]
    },
    {
      "name": "build",
      "description": "Builds and compiles the project.",
      "hidden": false,
      "examples": [
        "build"
      ]
    },
    {
      "name": "init",
      "options": [
        {
          "name": "--default",
          "required": false,
          "description": "Use default values without prompting",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--name",
          "required": false,
          "aliases": [
            "-n"
          ],
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Project name (skips prompt)",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--namespace",
          "required": false,
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Root namespace (skips prompt)",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "Initializes a new Ninjadog project.",
      "hidden": false,
      "examples": [
        "init"
      ]
    },
    {
      "name": "ui",
      "options": [
        {
          "name": "--no-browser",
          "required": false,
          "description": "Don't open browser automatically",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--port",
          "required": false,
          "aliases": [
            "-p"
          ],
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.Int32"
                }
              ]
            }
          ],
          "description": "Port to run the web server on",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "Opens a web-based configuration builder.",
      "hidden": false,
      "examples": [
        "ui"
      ]
    },
    {
      "name": "validate",
      "options": [
        {
          "name": "--file",
          "required": false,
          "aliases": [
            "-f"
          ],
          "arguments": [
            {
              "name": "VALUE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Path to the ninjadog.json file to validate.",
          "recursive": false,
          "hidden": false
        },
        {
          "name": "--strict",
          "required": false,
          "description": "Treat warnings as errors.",
          "recursive": false,
          "hidden": false
        }
      ],
      "description": "Validates a ninjadog.json configuration file.",
      "hidden": false,
      "examples": [
        "validate",
        "validate --file path/to/ninjadog.json",
        "validate --strict"
      ]
    }
  ]
}
