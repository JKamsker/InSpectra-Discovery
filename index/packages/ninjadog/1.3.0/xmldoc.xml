<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Ninjadog.CLI.Commands.InitCommand" 
Settings="Ninjadog.CLI.Commands.InitCommandSettings">
    <Description>Initializes a new Ninjadog project.</Description>
    <Parameters>
      <Option Short="" Long="default" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use default values without prompting</Description>
      </Option>
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project name (skips prompt)</Description>
      </Option>
      <Option Short="" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Root namespace (skips prompt)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="init" />
    </Examples>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="Ninjadog.CLI.Commands.BuildCommand" 
Settings="Ninjadog.CLI.Commands.BuildCommandSettings">
    <Description>Builds and compiles the project.</Description>
    <Parameters>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show detailed output including per-file generation info and
dotnet CLI output.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="build" />
    </Examples>
  </Command>
  <!--ADD-ENTITY-->
  <Command Name="add-entity" IsBranch="false" 
ClrType="Ninjadog.CLI.Commands.AddEntityCommand" 
Settings="Ninjadog.CLI.Commands.AddEntityCommandSettings">
    <Description>Adds a new entity to the ninjadog.json file.</Description>
    <Parameters>
      <Argument Name="entityName" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The name of the entity to add (PascalCase).</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="add-entity" />
      <Example commandLine="Product" />
    </Examples>
  </Command>
  <!--VALIDATE-->
  <Command Name="validate" IsBranch="false" 
ClrType="Ninjadog.CLI.Commands.ValidateCommand" 
Settings="Ninjadog.CLI.Commands.ValidateCommandSettings">
    <Description>Validates a ninjadog.json configuration file.</Description>
    <Parameters>
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the ninjadog.json file to validate.</Description>
      </Option>
      <Option Short="" Long="strict" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Treat warnings as errors.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="validate" />
      <Example commandLine="validate" />
      <Example commandLine="--file" />
      <Example commandLine="path/to/ninjadog.json" />
      <Example commandLine="validate" />
      <Example commandLine="--strict" />
    </Examples>
  </Command>
  <!--UI-->
  <Command Name="ui" IsBranch="false" ClrType="Ninjadog.CLI.Commands.UiCommand" 
Settings="Ninjadog.CLI.Commands.UiCommandSettings">
    <Description>Opens a web-based configuration builder.</Description>
    <Parameters>
      <Option Short="" Long="no-browser" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't open browser automatically</Description>
      </Option>
      <Option Short="p" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Port to run the web server on</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="ui" />
    </Examples>
  </Command>
</Model>