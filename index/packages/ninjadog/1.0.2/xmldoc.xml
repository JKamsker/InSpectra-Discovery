<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Ninjadog.CLI.Commands.InitCommand" 
Settings="Ninjadog.CLI.Commands.InitCommandSettings">
    <Description>Initializes a new Ninjadog project.</Description>
    <Examples>
      <Example commandLine="init" />
    </Examples>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="Ninjadog.CLI.Commands.BuildCommand" 
Settings="Ninjadog.CLI.Commands.BuildCommandSettings">
    <Description>Builds and compiles the project.</Description>
    <Examples>
      <Example commandLine="build" />
    </Examples>
  </Command>
  <!--NINJADOG-->
  <Command Name="ninjadog" IsBranch="false" 
ClrType="Ninjadog.CLI.Commands.NinjadogCommand" 
Settings="Ninjadog.CLI.Commands.NinjadogCommandSettings">
    <Description>Generates a new Ninjadog project.</Description>
    <Parameters>
      <Option Short="d" Long="disk" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="i" Long="in-memory" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="ninjadog" />
    </Examples>
  </Command>
</Model>