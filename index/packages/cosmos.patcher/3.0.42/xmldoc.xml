<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--PATCH-->
  <Command Name="patch" IsBranch="false" ClrType="Cosmos.Patcher.PatchCommand" 
Settings="Cosmos.Patcher.PatchCommand+Settings">
    <Parameters>
      <Option Short="" Long="coverage" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable plug-map generation for coverage 
tracking.</Description>
      </Option>
      <Option Short="" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output path for the patched dll</Description>
      </Option>
      <Option Short="" Long="plugs" Value="PLUGS" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Plug assemblies, separated by ';' or ','.</Description>
      </Option>
      <Option Short="" Long="target" Value="TARGET" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the target assembly.</Description>
      </Option>
      <Option Short="" Long="target-platform" Value="TARGET-PLATFORM" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Target platform for the patching process.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INSTRUMENT-COVERAGE-->
  <Command Name="instrument-coverage" IsBranch="false" 
ClrType="Cosmos.Patcher.Coverage.InstrumentCoverageCommand" 
Settings="Cosmos.Patcher.Coverage.InstrumentCoverageCommand+Settings">
    <Parameters>
      <Option Short="" Long="assembly-dir" Value="DIR" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Directory containing assemblies to instrument (e.g. 
obj/.../cosmos/).</Description>
      </Option>
      <Option Short="" Long="include" Value="PREFIX" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Assembly name prefix to include (default: 
Cosmos.Kernel).</Description>
      </Option>
      <Option Short="" Long="output-map" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to write the coverage map file.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>