<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Blueflow.Chopper.Cli.SplitCommand" 
Settings="Blueflow.Chopper.Cli.SplitCommand+Settings">
    <Parameters>
      <Option Short="" Long="clean" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Delete the output directory before writing new 
files.</Description>
      </Option>
      <Option Short="i" Long="input" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Path to the source OpenAPI YAML file.</Description>
      </Option>
      <Option Short="o" Long="output" Value="DIR" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Directory where split files will be created.</Description>
      </Option>
      <Option Short="s" Long="sections" Value="SECTIONS" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of sections to export 
(paths,schemas).</Description>
      </Option>
      <Option Short="u" Long="url" Value="URL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>URL to the source OpenAPI YAML file.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>