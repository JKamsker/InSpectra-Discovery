<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Trpc.Net.Cli.GenerateCommand" 
Settings="Trpc.Net.Cli.GenerateCommand+Settings">
    <Description>Generate TypeScript definitions from C# files 
(one-time)</Description>
    <Parameters>
      <Argument Name="DIRECTORY" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The directory path to scan for C# files</Description>
      </Argument>
      <Option Short="" Long="ts-output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output directory for generated TypeScript 
files</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="./src" />
      <Example commandLine="--ts-output" />
      <Example commandLine="./ts-generated" />
    </Examples>
  </Command>
  <!--WATCH-->
  <Command Name="watch" IsBranch="false" ClrType="Trpc.Net.Cli.WatchCommand" 
Settings="Trpc.Net.Cli.WatchCommand+Settings">
    <Description>Watch directory for changes and regenerate TypeScript 
definitions automatically</Description>
    <Parameters>
      <Argument Name="DIRECTORY" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The directory path to watch for C# file 
changes</Description>
      </Argument>
      <Option Short="d" Long="delay" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Debounce delay in milliseconds before processing 
changes</Description>
      </Option>
      <Option Short="" Long="ts-output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output directory for generated TypeScript 
files</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="watch" />
      <Example commandLine="./src" />
      <Example commandLine="--ts-output" />
      <Example commandLine="./ts-generated" />
      <Example commandLine="--delay" />
      <Example commandLine="1000" />
    </Examples>
  </Command>
</Model>