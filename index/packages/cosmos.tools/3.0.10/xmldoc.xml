<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="Cosmos.Tools.Commands.CheckCommand" 
Settings="Cosmos.Tools.Commands.CheckSettings">
    <Description>Check if required development tools are installed</Description>
    <Parameters>
      <Option Short="a" Long="arch" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Target architecture (x64, arm64, or 'all' for 
both)</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output results as JSON</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INSTALL-->
  <Command Name="install" IsBranch="false" 
ClrType="Cosmos.Tools.Commands.InstallCommand" 
Settings="Cosmos.Tools.Commands.InstallSettings">
    <Description>Install required development tools</Description>
    <Parameters>
      <Option Short="a" Long="arch" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Target architecture (x64, arm64, or 'all' for 
both)</Description>
      </Option>
      <Option Short="y" Long="auto" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Automatically install without prompting</Description>
      </Option>
      <Option Short="t" Long="tool" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Specific tool to install (e.g., 'yasm', 
'lld')</Description>
      </Option>
    </Parameters>
  </Command>
  <!--NEW-->
  <Command Name="new" IsBranch="false" 
ClrType="Cosmos.Tools.Commands.NewCommand" 
Settings="Cosmos.Tools.Commands.NewSettings">
    <Description>Create a new Cosmos kernel project</Description>
    <Parameters>
      <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the new kernel project</Description>
      </Argument>
      <Option Short="a" Long="arch" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Target architecture (x64, arm64)</Description>
      </Option>
      <Option Short="g" Long="graphics" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include graphics support</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory (defaults to current 
directory)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="Cosmos.Tools.Commands.BuildCommand" 
Settings="Cosmos.Tools.Commands.BuildSettings">
    <Description>Build a Cosmos kernel project</Description>
    <Parameters>
      <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Build for all supported architectures</Description>
      </Option>
      <Option Short="a" Long="arch" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Target architecture (x64, arm64). If not specified, builds 
for detected/default arch</Description>
      </Option>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Build configuration (Debug, Release)</Description>
      </Option>
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the kernel project (default: current 
directory)</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show detailed build output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--RUN-->
  <Command Name="run" IsBranch="false" 
ClrType="Cosmos.Tools.Commands.RunCommand" 
Settings="Cosmos.Tools.Commands.RunSettings">
    <Description>Run a Cosmos kernel in QEMU</Description>
    <Parameters>
      <Option Short="a" Long="arch" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Target architecture (x64, arm64)</Description>
      </Option>
      <Option Short="b" Long="build" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Build before running</Description>
      </Option>
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Start QEMU with GDB server for debugging (-s 
-S)</Description>
      </Option>
      <Option Short="i" Long="iso" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Direct path to ISO file (overrides project 
detection)</Description>
      </Option>
      <Option Short="m" Long="memory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Amount of memory for the VM</Description>
      </Option>
      <Option Short="n" Long="no-graphics" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Run without graphical display (serial only)</Description>
      </Option>
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the kernel project (default: current 
directory)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>