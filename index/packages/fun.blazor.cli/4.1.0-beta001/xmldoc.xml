<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--WATCH-->
  <Command Name="watch" IsBranch="false" ClrType="Program+WatchCommand" 
Settings="Fun.Blazor.Cli.WatchSettings">
    <Description>Used for hot-reload (obsolete)</Description>
    <Parameters>
      <Argument Name="PROJECT" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project you want to watch</Description>
      </Argument>
      <Option Short="s" Long="server" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Server host will be used to host the cli. Default value is 
http://localhost:9025</Description>
      </Option>
      <Option Short="" Long="staticAssetsDir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Static assets directory which contains file like css. 
Default value will be the wwwroot under the project folder.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="watch" />
      <Example commandLine="{your fsharp project}" />
      <Example commandLine="--server" />
      <Example commandLine="https://localhost:5001" />
    </Examples>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" ClrType="Program+GenerateCommand" 
Settings="Fun.Blazor.Cli.CodeGenSettings">
    <Description>Generate DSL for blazor libraries like 
Microsoft.AspNetCore.Components.Web, MudBlazor etc.</Description>
    <Parameters>
      <Argument Name="PROJECT" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project you want to add bindings</Description>
      </Argument>
      <Option Short="" Long="generator-version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Fun.Blazor.Generator version</Description>
      </Option>
      <Option Short="" Long="inline" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Turn on inline option for generated code</Description>
      </Option>
      <Option Short="" Long="keep-code-gen-proj" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Keep code generation project, it is under bin folder of the
target project</Description>
      </Option>
      <Option Short="o" Long="outDir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory of generated codes</Description>
      </Option>
      <Option Short="" Long="sdk" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>.NET SDK version</Description>
      </Option>
      <Option Short="s" Long="style" Value="NULL" Required="false" Kind="scalar"
ClrType="Fun.Blazor.Generator.Style">
        <Description>Dsl style CE</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
    </Examples>
  </Command>
</Model>