<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SCAN-->
  <Command Name="scan" IsBranch="false" 
ClrType="Locale.CLI.Commands.ScanCommand" 
Settings="Locale.CLI.Commands.ScanSettings">
    <Description>Scan and compare localization files across 
cultures.</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the directory or file to scan.</Description>
      </Argument>
      <Option Short="b" Long="base" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Base culture to compare against (e.g., 'en').</Description>
      </Option>
      <Option Short="" Long="check-placeholders" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Check for placeholder mismatches.</Description>
      </Option>
      <Option Short="" Long="ignore" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Ignore patterns (comma-separated).</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output results to a JSON file.</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Scan directories recursively.</Description>
      </Option>
      <Option Short="t" Long="targets" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target cultures to compare (comma-separated, e.g., 
'tr,de,fr').</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="scan" />
      <Example commandLine="./locales" />
      <Example commandLine="--base" />
      <Example commandLine="en" />
      <Example commandLine="--targets" />
      <Example commandLine="tr,de" />
    </Examples>
  </Command>
  <!--DIFF-->
  <Command Name="diff" IsBranch="false" 
ClrType="Locale.CLI.Commands.DiffCommand" 
Settings="Locale.CLI.Commands.DiffSettings">
    <Description>Compare two localization files.</Description>
    <Parameters>
      <Argument Name="first" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>First localization file to compare.</Description>
      </Argument>
      <Argument Name="second" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Second localization file to compare.</Description>
      </Argument>
      <Option Short="" Long="check-placeholders" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Check for placeholder mismatches.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output results to a JSON file.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="diff" />
      <Example commandLine="en.json" />
      <Example commandLine="tr.json" />
    </Examples>
  </Command>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="Locale.CLI.Commands.CheckCommand" 
Settings="Locale.CLI.Commands.CheckSettings">
    <Description>Validate localization files against rules.</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the directory or file to check.</Description>
      </Argument>
      <Option Short="b" Long="base" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Base culture for orphan key and placeholder 
checks.</Description>
      </Option>
      <Option Short="" Long="ci" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>CI mode: return non-zero exit code on 
violations.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output results to a JSON file.</Description>
      </Option>
      <Option Short="" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Check directories recursively.</Description>
      </Option>
      <Option Short="r" Long="rules" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Rules to check (comma-separated). Available: 
no-empty-values, no-duplicate-keys, no-orphan-keys, consistent-placeholders, 
no-trailing-whitespace.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="check" />
      <Example commandLine="./locales" />
      <Example commandLine="--rules" />
      <Example commandLine="no-empty-values,no-duplicate-keys" />
    </Examples>
  </Command>
  <!--CONVERT-->
  <Command Name="convert" IsBranch="false" 
ClrType="Locale.CLI.Commands.ConvertCommand" 
Settings="Locale.CLI.Commands.ConvertSettings">
    <Description>Convert localization files between formats.</Description>
    <Parameters>
      <Argument Name="source" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Source file or directory.</Description>
      </Argument>
      <Argument Name="destination" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Destination file or directory.</Description>
      </Argument>
      <Option Short="c" Long="culture" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Override culture for the output file.</Description>
      </Option>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Overwrite existing files.</Description>
      </Option>
      <Option Short="f" Long="from" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Source format (auto-detected if not 
specified).</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Process directories recursively.</Description>
      </Option>
      <Option Short="t" Long="to" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Target format (required).</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="convert" />
      <Example commandLine="en.json" />
      <Example commandLine="en.yaml" />
    </Examples>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Locale.CLI.Commands.GenerateCommand" 
Settings="Locale.CLI.Commands.GenerateSettings">
    <Description>Generate skeleton target files from a base 
language.</Description>
    <Parameters>
      <Argument Name="target" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Target culture to generate files for (e.g., 'tr', 'de', 
'fr').</Description>
      </Argument>
      <Option Short="" Long="empty" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use empty values instead of placeholders.</Description>
      </Option>
      <Option Short="f" Long="from" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Base culture to generate from.</Description>
      </Option>
      <Option Short="i" Long="in" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Input directory or file.</Description>
      </Option>
      <Option Short="o" Long="out" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Output directory.</Description>
      </Option>
      <Option Short="" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Overwrite existing keys.</Description>
      </Option>
      <Option Short="" Long="placeholder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Custom placeholder pattern (use {0} for base 
value).</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Process directories recursively.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="generate" />
      <Example commandLine="tr" />
      <Example commandLine="--from" />
      <Example commandLine="en" />
      <Example commandLine="--in" />
      <Example commandLine="./locales" />
      <Example commandLine="--out" />
      <Example commandLine="./locales" />
    </Examples>
  </Command>
  <!--WATCH-->
  <Command Name="watch" IsBranch="false" 
ClrType="Locale.CLI.Commands.WatchCommand" 
Settings="Locale.CLI.Commands.WatchSettings">
    <Description>Watch localization files for changes and re-run scan or 
check.</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the directory to watch.</Description>
      </Argument>
      <Option Short="b" Long="base" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Base culture to compare against (e.g., 'en').</Description>
      </Option>
      <Option Short="" Long="debounce" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Debounce interval in milliseconds.</Description>
      </Option>
      <Option Short="m" Long="mode" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Watch mode: 'scan' or 'check'.</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include subdirectories.</Description>
      </Option>
      <Option Short="t" Long="targets" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target cultures to compare (comma-separated, e.g., 
'tr,de,fr').</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="watch" />
      <Example commandLine="./locales" />
      <Example commandLine="--base" />
      <Example commandLine="en" />
      <Example commandLine="--mode" />
      <Example commandLine="scan" />
    </Examples>
  </Command>
  <!--TRANSLATE-->
  <Command Name="translate" IsBranch="false" 
ClrType="Locale.CLI.Commands.TranslateCommand" 
Settings="Locale.CLI.Commands.TranslateSettings">
    <Description>Automatically translate localization files using external 
APIs.</Description>
    <Parameters>
      <Argument Name="target" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Target language to translate to (e.g., 'tr', 'de', 
'fr').</Description>
      </Argument>
      <Option Short="k" Long="api-key" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>API key for the translation service (required for most 
providers).</Description>
      </Option>
      <Option Short="" Long="delay" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Delay between API calls in milliseconds (for rate 
limiting).</Description>
      </Option>
      <Option Short="" Long="endpoint" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>API endpoint URL (for self-hosted services like 
LibreTranslate, Ollama, or Azure OpenAI).</Description>
      </Option>
      <Option Short="f" Long="from" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Source language to translate from.</Description>
      </Option>
      <Option Short="i" Long="in" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Input directory or file.</Description>
      </Option>
      <Option Short="m" Long="model" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Model name for AI providers (e.g., 'gpt-4o', 
'claude-3-5-sonnet-latest', 'gemini-2.0-flash').</Description>
      </Option>
      <Option Short="" Long="only-missing" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Only translate missing keys.</Description>
      </Option>
      <Option Short="o" Long="out" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Output directory.</Description>
      </Option>
      <Option Short="" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Overwrite existing translations.</Description>
      </Option>
      <Option Short="" Long="parallel" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Degree of parallelism for concurrent translations (1 = 
sequential, higher = faster but may hit rate limits).</Description>
      </Option>
      <Option Short="p" Long="provider" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Translation provider: google, deepl, bing, yandex, 
libretranslate, openai, claude, gemini, azure-openai, ollama.</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Process directories recursively.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="translate" />
      <Example commandLine="tr" />
      <Example commandLine="--from" />
      <Example commandLine="en" />
      <Example commandLine="--in" />
      <Example commandLine="./locales" />
      <Example commandLine="--provider" />
      <Example commandLine="google" />
    </Examples>
  </Command>
</Model>