<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Momentum.Extensions.EventMarkdownGenerator.GenerateCommand" 
Settings="Momentum.Extensions.EventMarkdownGenerator.GenerateCommand+Settings">
    <Description>Generate markdown documentation from event 
assemblies</Description>
    <Parameters>
      <Option Short="a" Long="assemblies" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of assembly paths to 
analyze</Description>
      </Option>
      <Option Short="" Long="github-url" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Base GitHub URL for source code links (e.g., 
https://github.com/org/repo/blob/main/src)</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for generated markdown files</Description>
      </Option>
      <Option Short="" Long="sidebar-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the JSON sidebar file</Description>
      </Option>
      <Option Short="" Long="templates" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Custom templates directory to override default 
templates</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
      <Option Short="" Long="xml-docs" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of XML documentation file paths 
(auto-discovered if not provided)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--TEMPLATES-->
  <Command Name="templates" IsBranch="false" 
ClrType="Momentum.Extensions.EventMarkdownGenerator.CopyTemplatesCommand" 
Settings="Momentum.Extensions.EventMarkdownGenerator.CopyTemplatesCommand+Settin
gs">
    <Description>Copy default templates to a local directory for 
customization</Description>
    <Parameters>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Overwrite existing template files if they 
exist</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for template files (defaults to 
./templates)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>