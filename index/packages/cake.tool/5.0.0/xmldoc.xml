<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Cake.Commands.DefaultCommand" 
Settings="Cake.Commands.DefaultCommandSettings">
    <Parameters>
      <Argument Name="SCRIPT" Position="0" Required="false" Kind="scalar" 
ClrType="Cake.Core.IO.FilePath">
        <Description>The Cake script. Defaults to 
[grey]build.cake[/]</Description>
      </Argument>
      <Option Short="" Long="bootstrap" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Download/install modules defined by [grey]#module[/] 
directives, but do not run build.</Description>
      </Option>
      <Option Short="d" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Launches script in debug mode.</Description>
      </Option>
      <Option Short="" 
Long="description,descriptions,showdescription,showdescriptions" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Shows description for each task.</Description>
      </Option>
      <Option Short="" Long="dryrun,noop,whatif" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Performs a dry run.</Description>
      </Option>
      <Option Short="e" Long="exclusive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Executes the target task without any 
dependencies.</Description>
      </Option>
      <Option Short="" Long="info" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Displays additional information about Cake.</Description>
      </Option>
      <Option Short="" Long="invalidate-script-cache" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Forces the script to be recompiled if caching is 
enabled.</Description>
      </Option>
      <Option Short="" Long="skip-bootstrap" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skips bootstrapping when running build.</Description>
      </Option>
      <Option Short="" Long="tree,showtree" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Shows the task dependency tree.</Description>
      </Option>
      <Option Short="v" Long="verbosity" Value="VERBOSITY" Required="false" 
Kind="scalar" ClrType="Cake.Core.Diagnostics.Verbosity">
        <Description>Specifies the amount of information to be displayed.
(Quiet, Minimal, Normal, Verbose, Diagnostic)</Description>
      </Option>
      <Option Short="" Long="version,ver" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Displays version information.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="build.cake" />
      <Example commandLine="--verbosity" />
      <Example commandLine="quiet" />
      <Example commandLine="build.cake" />
      <Example commandLine="--tree" />
    </Examples>
  </Command>
</Model>