<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DiceCli.Commands.InteractiveCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--START-->
  <Command Name="start" IsBranch="false" 
ClrType="DiceCli.Commands.InteractiveCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Starts an interactive prompt for this sample CLI.</Description>
    <Examples>
      <Example commandLine="start" />
    </Examples>
  </Command>
  <!--ROLL-->
  <Command Name="roll" IsBranch="false" ClrType="DiceCli.Commands.RollCommand" 
Settings="DiceCli.Commands.RollCommand+Request">
    <Description>Rolls the dice described by the notation string.</Description>
    <Parameters>
      <Argument Name="DICE-NOTATION" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Dice notation string to roll (ex: 1d20, 1d8+3, 
etc).</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="roll" />
      <Example commandLine="1d20+5" />
    </Examples>
  </Command>
  <!--NOTATION-->
  <Command Name="notation" IsBranch="false" 
ClrType="DiceCli.Commands.NotationCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Display details about how dice notations are defined and 
written.</Description>
    <Examples>
      <Example commandLine="notation" />
    </Examples>
  </Command>
</Model>