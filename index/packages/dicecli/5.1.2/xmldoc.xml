<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DiceCli.Commands.InteractiveCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--START-->
  <Command Name="start" IsBranch="false" 
ClrType="DiceCli.Commands.InteractiveCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Starts an interactive prompt for this sample CLI.</Description>
    <Examples>
      <Example commandLine="start" />
    </Examples>
  </Command>
  <!--ROLL-->
  <Command Name="roll" IsBranch="false" ClrType="DiceCli.Commands.RollCommand" 
Settings="DiceCli.Commands.RollCommand+Request">
    <Description>Rolls the dice described by the notation string.</Description>
    <Parameters>
      <Argument Name="DICE-NOTATION" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Dice notation string to roll (ex: 1d20, 1d8+3, 
etc).</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="roll" />
      <Example commandLine="1d20+5" />
    </Examples>
  </Command>
  <!--NOTATION-->
  <Command Name="notation" IsBranch="false" 
ClrType="DiceCli.Commands.NotationCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Display details about how dice notations are defined and 
written.</Description>
    <Examples>
      <Example commandLine="notation" />
    </Examples>
  </Command>
  <!--FAVORITES-->
  <Command Name="favorites" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Commands to manage and use favorite rolls.</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="DiceCli.Commands.Favorites.ListFavoritesCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Lists all favorite rolls.</Description>
      <Examples>
        <Example commandLine="favorites" />
        <Example commandLine="list" />
      </Examples>
    </Command>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="DiceCli.Commands.Favorites.AddFavoriteCommand" 
Settings="DiceCli.Commands.Favorites.AddFavoriteCommand+Settings">
      <Description>Adds a new favorite roll.</Description>
      <Parameters>
        <Option Short="e" Long="expression" Value="EXPRESSION" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The dice notation expression for the favorite 
roll.</Description>
        </Option>
        <Option Short="i" Long="id" Value="IDENTIFIER" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The unique identifier for this favorite 
roll.</Description>
        </Option>
        <Option Short="n" Long="name" Value="DISPLAY-NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The display name for the favorite roll.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="favorites" />
        <Example commandLine="add" />
        <Example commandLine="-i" />
        <Example commandLine="attack-roll" />
        <Example commandLine="-n" />
        <Example commandLine="Attack (Longsword)" />
        <Example commandLine="-e" />
        <Example commandLine="1d20+5" />
      </Examples>
    </Command>
    <!--EDIT-->
    <Command Name="edit" IsBranch="false" 
ClrType="DiceCli.Commands.Favorites.EditFavoriteCommand" 
Settings="DiceCli.Commands.Favorites.EditFavoriteCommand+Settings">
      <Description>Edits an existing favorite roll.</Description>
      <Parameters>
        <Option Short="e" Long="expression" Value="EXPRESSION" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Updated dice notation expression for the favorite 
roll.</Description>
        </Option>
        <Option Short="i" Long="id" Value="IDENTIFIER" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The unique identifier for the favorite roll to 
edit.</Description>
        </Option>
        <Option Short="n" Long="name" Value="DISPLAY-NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Updated display name for the favorite roll.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="favorites" />
        <Example commandLine="edit" />
        <Example commandLine="-i" />
        <Example commandLine="attack-roll" />
        <Example commandLine="-n" />
        <Example commandLine="Attack (Short sword)" />
        <Example commandLine="-e" />
        <Example commandLine="1d20+7" />
      </Examples>
    </Command>
    <!--DELETE-->
    <Command Name="delete" IsBranch="false" 
ClrType="DiceCli.Commands.Favorites.DeleteFavoriteCommand" 
Settings="DiceCli.Commands.Favorites.DeleteFavoriteCommand+Settings">
      <Description>Removes a favorite roll by name.</Description>
      <Parameters>
        <Option Short="i" Long="id" Value="IDENTIFIER" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The unique identifier of favorite roll to 
delete.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="favorites" />
        <Example commandLine="delete" />
        <Example commandLine="-i" />
        <Example commandLine="damage-roll" />
      </Examples>
    </Command>
    <!--ROLL-->
    <Command Name="roll" IsBranch="false" 
ClrType="DiceCli.Commands.Favorites.RollFavoriteCommand" 
Settings="DiceCli.Commands.Favorites.RollFavoriteCommand+Settings">
      <Description>Rolls a favorite roll by name.</Description>
      <Parameters>
        <Option Short="i" Long="id" Value="IDENTIFIER" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The unique identifier of favorite to roll.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="favorites" />
        <Example commandLine="roll" />
        <Example commandLine="-i" />
        <Example commandLine="attack-roll" />
      </Examples>
    </Command>
  </Command>
</Model>