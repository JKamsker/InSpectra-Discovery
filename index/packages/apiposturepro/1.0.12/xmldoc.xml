<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SCAN-->
  <Command Name="scan" IsBranch="false" 
ClrType="ApiPosturePro.Commands.ProScanCommand" 
Settings="ApiPosturePro.Commands.ProScanCommand+Settings">
    <Description>Scan ASP.NET Core API project with Pro rules</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the project or directory to scan</Description>
      </Argument>
      <Option Short="" Long="api-style" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Filter by API style (controller, minimal)</Description>
      </Option>
      <Option Short="" Long="classification" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Filter by security classification (public, authenticated, 
role-restricted, policy-restricted)</Description>
      </Option>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to configuration file (.apiposture.json)</Description>
      </Option>
      <Option Short="" Long="controller" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Filter by controller name</Description>
      </Option>
      <Option Short="" Long="fail-on" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Fail with exit code 1 if findings at or above this 
severity</Description>
      </Option>
      <Option Short="" Long="group-by" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Group endpoints by field (controller, classification, 
severity, method)</Description>
      </Option>
      <Option Short="" Long="group-findings-by" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Group findings by field (severity, controller, 
classification)</Description>
      </Option>
      <Option Short="" Long="method" Value="NULL" Required="false" Kind="vector"
ClrType="System.String[]">
        <Description>Filter by HTTP method (GET, POST, PUT, DELETE, 
PATCH)</Description>
      </Option>
      <Option Short="" Long="no-color" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Disable colored output</Description>
      </Option>
      <Option Short="" Long="no-icons" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Disable icons/emojis in output</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format (terminal, json, markdown)</Description>
      </Option>
      <Option Short="f" Long="output-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path</Description>
      </Option>
      <Option Short="" Long="route-contains" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter routes containing substring 
(case-insensitive)</Description>
      </Option>
      <Option Short="" Long="rule" Value="NULL" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Filter by rule ID (AP001, AP002, etc.)</Description>
      </Option>
      <Option Short="" Long="severity" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum severity to report (info, low, medium, high, 
critical)</Description>
      </Option>
      <Option Short="" Long="sort-by" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sort by field (severity, route, method, classification, 
controller, location)</Description>
      </Option>
      <Option Short="" Long="sort-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sort direction (asc, desc)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="scan" />
      <Example commandLine="." />
      <Example commandLine="scan" />
      <Example commandLine="./src/MyApi" />
      <Example commandLine="scan" />
      <Example commandLine="." />
      <Example commandLine="--output" />
      <Example commandLine="json" />
      <Example commandLine="--output-file" />
      <Example commandLine="report.json" />
      <Example commandLine="scan" />
      <Example commandLine="." />
      <Example commandLine="--fail-on" />
      <Example commandLine="high" />
    </Examples>
  </Command>
  <!--DIFF-->
  <Command Name="diff" IsBranch="false" 
ClrType="ApiPosturePro.Features.DiffMode.DiffCommand" 
Settings="ApiPosturePro.Features.DiffMode.DiffCommand+Settings">
    <Description>Compare two scan results to identify security posture 
changes</Description>
    <Parameters>
      <Argument Name="baseline" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to baseline scan result (JSON)</Description>
      </Argument>
      <Argument Name="current" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to current scan result (JSON)</Description>
      </Argument>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format (console, json)</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path (optional)</Description>
      </Option>
      <Option Short="" Long="summary-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show only summary</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="diff" />
      <Example commandLine="baseline.json" />
      <Example commandLine="current.json" />
      <Example commandLine="diff" />
      <Example commandLine="--format" />
      <Example commandLine="json" />
      <Example commandLine="baseline.json" />
      <Example commandLine="current.json" />
      <Example commandLine="diff" />
      <Example commandLine="--summary-only" />
      <Example commandLine="baseline.json" />
      <Example commandLine="current.json" />
    </Examples>
  </Command>
  <!--HISTORY-->
  <Command Name="history" IsBranch="false" 
ClrType="ApiPosturePro.Features.HistoricalTracking.HistoryCommand" 
Settings="ApiPosturePro.Features.HistoricalTracking.HistoryCommand+Settings">
    <Description>View and manage historical scan records</Description>
    <Parameters>
      <Argument Name="subcommand" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Subcommand: list, show, trend, cleanup</Description>
      </Argument>
      <Argument Name="id" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Scan ID (for show subcommand)</Description>
      </Argument>
      <Option Short="b" Long="branch" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by Git branch</Description>
      </Option>
      <Option Short="d" Long="days" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of days (for trend/cleanup)</Description>
      </Option>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format (console, json)</Description>
      </Option>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Maximum records to show</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by scanned path</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="history" />
      <Example commandLine="list" />
      <Example commandLine="history" />
      <Example commandLine="list" />
      <Example commandLine="-p" />
      <Example commandLine="/path/to/project" />
      <Example commandLine="history" />
      <Example commandLine="show" />
      <Example commandLine="abc123" />
      <Example commandLine="history" />
      <Example commandLine="trend" />
      <Example commandLine="-p" />
      <Example commandLine="/path/to/project" />
      <Example commandLine="history" />
      <Example commandLine="cleanup" />
      <Example commandLine="--days" />
      <Example commandLine="90" />
    </Examples>
  </Command>
  <!--ACTIVATE-->
  <Command Name="activate" IsBranch="false" 
ClrType="ApiPosturePro.Commands.ActivateCommand" 
Settings="ApiPosturePro.Commands.ActivateCommand+Settings">
    <Description>Activate ApiPosture Pro license</Description>
    <Parameters>
      <Argument Name="key" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The license key to activate</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="activate" />
      <Example commandLine="XXXX-XXXX-XXXX-XXXX" />
    </Examples>
  </Command>
  <!--DEACTIVATE-->
  <Command Name="deactivate" IsBranch="false" 
ClrType="ApiPosturePro.Commands.DeactivateCommand" 
Settings="ApiPosturePro.Commands.DeactivateCommand+Settings">
    <Description>Deactivate the current license</Description>
  </Command>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" 
ClrType="ApiPosturePro.Commands.StatusCommand" 
Settings="ApiPosturePro.Commands.StatusCommand+Settings">
    <Description>Show license status and installed extensions</Description>
  </Command>
</Model>