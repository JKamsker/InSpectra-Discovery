<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DcmFind.FindCommand" Settings="DcmFind.FindCommand+Settings">
    <Parameters>
      <Option Short="d" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Search for *.dcm files in this directory</Description>
      </Option>
      <Option Short="f" Long="file-pattern" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Only query files that satisfy this file 
pattern</Description>
      </Option>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=7.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Limit results and stop finding after this many 
results</Description>
      </Option>
      <Option Short="" Long="no-progress" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=7.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Disables printing the file currently being inspected. 
Automatically disabled if the output is piped.</Description>
      </Option>
      <Option Short="p" Long="parallelism" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=7.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Parse files in parallel</Description>
      </Option>
      <Option Short="q" Long="query" Value="QUERY" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>The query that should be applied</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=7.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Search recursively in nested directories</Description>
      </Option>
    </Parameters>
  </Command>
</Model>