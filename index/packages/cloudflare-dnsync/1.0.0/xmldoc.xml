<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="CloudflareDnsync.Cli.Commands.SyncCommand" 
Settings="CloudflareDnsync.Cli.Commands.SyncCommand+Settings" />
  <!--SYNC-->
  <Command Name="sync" IsBranch="false" 
ClrType="CloudflareDnsync.Cli.Commands.SyncCommand" 
Settings="CloudflareDnsync.Cli.Commands.SyncCommand+Settings" />
  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="CloudflareDnsync.Cli.Commands.ConfigurationCommand+ConfigurationSettin
gs">
    <!--__DEFAULT_COMMAND-->
    <Command Name="__default_command" IsBranch="false" 
ClrType="CloudflareDnsync.Cli.Commands.ListCommand" 
Settings="CloudflareDnsync.Cli.Commands.ListCommand+Settings">
      <Parameters>
        <Option Short="i" Long="id" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The ID of the configuration.</Description>
        </Option>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The name of the configuration.</Description>
        </Option>
        <Option Short="r" Long="reveal-token" Value="REVEAL_TOKEN" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Reveal the API token.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="CloudflareDnsync.Cli.Commands.AddCommand" 
Settings="CloudflareDnsync.Cli.Commands.AddCommand+Settings">
      <Parameters>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Configuration name.</Description>
        </Option>
        <Option Short="p" Long="proxy" Value="PROXY" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Use proxy for the record.</Description>
        </Option>
        <Option Short="r" Long="record" Value="RECORD" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Record ID to add. If specified, zone id must also be 
specified.</Description>
        </Option>
        <Option Short="t" Long="token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>API token to use.</Description>
        </Option>
        <Option Short="" Long="validate" Value="VALIDATE" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Validate options. If set to false, no validation will be 
performed.</Description>
        </Option>
        <Option Short="z" Long="zone" Value="ZONE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Zone ID to add. If specified, record id must also be 
specified.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="CloudflareDnsync.Cli.Commands.ListCommand" 
Settings="CloudflareDnsync.Cli.Commands.ListCommand+Settings">
      <Parameters>
        <Option Short="i" Long="id" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The ID of the configuration.</Description>
        </Option>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The name of the configuration.</Description>
        </Option>
        <Option Short="r" Long="reveal-token" Value="REVEAL_TOKEN" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Reveal the API token.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REMOVE-->
    <Command Name="remove" IsBranch="false" 
ClrType="CloudflareDnsync.Cli.Commands.RemoveCommand" 
Settings="CloudflareDnsync.Cli.Commands.RemoveCommand+Settings" />
  </Command>
</Model>