<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Releasator.Application.ReleasatorCommand" 
Settings="Releasator.Application.ReleasatorCommand+Settings">
    <Parameters>
      <Argument Name="configFile" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Configuration file path.</Description>
      </Argument>
      <Option Short="i" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Run in interactive mode, user confirms 
options.</Description>
      </Option>
      <Option Short="n" Long="no-colors" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>No colors. Avoid using ANSI characters (usefull on CI 
environments).</Description>
      </Option>
      <Option Short="p" Long="pre-release" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Define pre-release suffix. Ignored if 'ReleaseVersion' is 
defined.</Description>
      </Option>
      <Option Short="r" Long="release" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Release version. Overrides next version.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>