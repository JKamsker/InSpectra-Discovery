<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="Cute.Commands.VersionCommand" 
Settings="Cute.Commands.VersionCommand+Settings">
    <Description>Displays the current cut cli version.</Description>
  </Command>
  <!--LOGIN-->
  <Command Name="login" IsBranch="false" ClrType="Cute.Commands.LoginCommand" 
Settings="Cute.Commands.LoginCommand+Settings">
    <Description>Login to a Contentful account.</Description>
    <Parameters>
      <Option Short="d" Long="cf-delivery-api-key" Value="NULL" Required="false"
Kind="scalar" ClrType="System.String">
        <Description>The Contentful delivery API key.</Description>
      </Option>
      <Option Short="e" Long="cf-environment" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The default Contentful environment to use.</Description>
      </Option>
      <Option Short="m" Long="cf-mangagement-api-key" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The Contentful management API key.</Description>
      </Option>
      <Option Short="p" Long="cf-preview-api-key" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Contentful preview API key.</Description>
      </Option>
      <Option Short="s" Long="cf-space" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The default Contentful space to use.</Description>
      </Option>
      <Option Short="k" Long="openai-apiKey" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The OpenAI Api key.</Description>
      </Option>
      <Option Short="n" Long="openai-deployment-name" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The OpenAI deployment name.</Description>
      </Option>
      <Option Short="a" Long="openai-endpoint" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The OpenAI endpoint.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" ClrType="Cute.Commands.InfoCommand" 
Settings="Cute.Commands.InfoCommand+Settings">
    <Description>Display information about the default or specified 
space.</Description>
  </Command>
  <!--DOWNLOAD-->
  <Command Name="download" IsBranch="false" 
ClrType="Cute.Commands.DownloadCommand" 
Settings="Cute.Commands.DownloadCommand+Settings">
    <Description>Downloads content from the default or specified 
space.</Description>
    <Parameters>
      <Option Short="c" Long="content-type" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specifies the content type to download data 
for</Description>
      </Option>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[Cute.Lib.Enums.OutputFileFormat, 
Cute.Lib, Version=1.0.39.0, Culture=neutral, PublicKeyToken=null]]">
        <Description>The output format for the download operation 
(Excel/Csv/Tsv/Json/Yaml)</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The output path and filename for the download 
operation</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UPLOAD-->
  <Command Name="upload" IsBranch="false" ClrType="Cute.Commands.UploadCommand" 
Settings="Cute.Commands.UploadCommand+Settings">
    <Description>Uploads local content to the default or specified 
space.</Description>
    <Parameters>
      <Option Short="a" Long="apply" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Apply and publish all the calculated changes. The default 
behaviour is to only list the detected changes.</Description>
      </Option>
      <Option Short="c" Long="content-type" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specifies the content type to download data 
for</Description>
      </Option>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[Cute.Lib.Enums.InputFileFormat, 
Cute.Lib, Version=1.0.39.0, Culture=neutral, PublicKeyToken=null]]">
        <Description>The format of the file specified in '--path' 
(Excel/Csv/Tsv/Json/Yaml)</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The local path to the file containg the data to 
sync</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Cute.Commands.GenerateCommand" 
Settings="Cute.Commands.GenerateCommand+Settings">
    <Description>Use generative AI to help build drafts of your 
content.</Description>
    <Parameters>
      <Option Short="d" Long="delay" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>The delay in milliseconds between retrieving generated 
tokens.</Description>
      </Option>
      <Option Short="e" Long="entry-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The field containing language targets for translated 
content.</Description>
      </Option>
      <Option Short="a" Long="frequency-penalty-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The field containing frequency penalty setting for the 
LLM.</Description>
      </Option>
      <Option Short="g" Long="generator-language-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The field containing language target for generated 
content.</Description>
      </Option>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>The total number of entries to generate content for before 
stopping. Default is five.</Description>
      </Option>
      <Option Short="t" Long="output-content-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The target field of the Contentful content type to generate
content for.</Description>
      </Option>
      <Option Short="o" Long="output-content-type-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The field containing the id of the Contentful content type 
to generate content for.</Description>
      </Option>
      <Option Short="c" Long="prompt-content-type" Value="NULL" Required="false"
Kind="scalar" ClrType="System.String">
        <Description>The id of the content type containing prompts. Default is 
'metaPrompts'.</Description>
      </Option>
      <Option Short="p" Long="prompt-field" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The field containing the prompt template for the 
LLM.</Description>
      </Option>
      <Option Short="i" Long="prompt-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The id of the Contentful prompt entry to generate prompts 
from.</Description>
      </Option>
      <Option Short="f" Long="prompt-id-field" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The id of the field that contains the prompt key/title/id. 
Default is 'key'.</Description>
      </Option>
      <Option Short="r" Long="related-entry-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The field containing language targets for translated 
content.</Description>
      </Option>
      <Option Short="k" Long="skip" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>The total number of entries to skip before starting. 
Default is zero.</Description>
      </Option>
      <Option Short="s" Long="system-message-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The field containing the system prompt for the 
LLM.</Description>
      </Option>
      <Option Short="m" Long="temperature-field" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The field containing temperature setting for the 
LLM.</Description>
      </Option>
      <Option Short="n" Long="translator-language-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The field containing language targets for translated 
content.</Description>
      </Option>
      <Option Short="" Long="use-azure-translator" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
        <Description>Use Azure Translator service, otherwise let the LLM handle 
translations.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--JOIN-->
  <Command Name="join" IsBranch="false" ClrType="Cute.Commands.JoinCommand" 
Settings="Cute.Commands.JoinCommand+Settings">
    <Description>Join and generate content entries from multiple content 
types.</Description>
    <Parameters>
      <Option Short="e" Long="entry-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The field containing language targets for translated 
content.</Description>
      </Option>
      <Option Short="c" Long="join-content-type" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The id of the content type containing join definitions. 
Default is 'metaJoin'.</Description>
      </Option>
      <Option Short="i" Long="join-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The id of the Contentful join entry to generate content 
for.</Description>
      </Option>
      <Option Short="f" Long="join-id-field" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The id of the field that contains the join key/title/id. 
Default is 'key'.</Description>
      </Option>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>The total number of entries to generate content for before 
stopping. Default is 100.</Description>
      </Option>
      <Option Short="" Long="source1-content-type-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The field containing the first Contentful content type to 
join content from.</Description>
      </Option>
      <Option Short="" Long="source1-keys-field" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The field containing the keys of the first Contentful 
content type to join content from.</Description>
      </Option>
      <Option Short="" Long="source2-content-type-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The field containing the second Contentful content type to 
join content from.</Description>
      </Option>
      <Option Short="" Long="source2-keys-field" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The field containing the keys of the second Contentful 
content type to join content from.</Description>
      </Option>
      <Option Short="t" Long="target-content-type-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The field containing the id of the Contentful content type 
to join content for.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--TYPEGEN-->
  <Command Name="typegen" IsBranch="false" 
ClrType="Cute.Commands.TypeGenCommand" 
Settings="Cute.Commands.TypeGenCommand+Settings">
    <Description>Generate language types from Contentful content 
types.</Description>
    <Parameters>
      <Option Short="c" Long="content-type" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specifies the content type to generate types for. Default 
is all.</Description>
      </Option>
      <Option Short="l" Long="language" Value="NULL" Required="false" 
Kind="scalar" ClrType="Cute.Lib.Enums.GenTypeLanguage">
        <Description>The language to generate types for 
(TypeScript/CSharp)</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The optional namespace for the generated type</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The local path to output the generated types 
to</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GETDATA-->
  <Command Name="getdata" IsBranch="false" 
ClrType="Cute.Commands.GetDataCommand" 
Settings="Cute.Commands.GetDataCommand+Settings">
    <Description>Sync Contentful content with WikiData.</Description>
    <Parameters>
      <Option Short="" Long="as-server" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>The field containing the yaml template for the the data 
sync.</Description>
      </Option>
      <Option Short="c" Long="getdata-content-type" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The id of the content type containing data sync 
definitions. Default is 'metaGetData'.</Description>
      </Option>
      <Option Short="r" Long="getdata-frequency-field" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The id of the field that contains the data sync frequency 
as a phrase. Default is 'frequency'.</Description>
      </Option>
      <Option Short="i" Long="getdata-id" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The id of the Contentful data sync entry to generate 
prompts from.</Description>
      </Option>
      <Option Short="f" Long="getdata-id-field" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The id of the field that contains the data sync 
key/title/id. Default is 'key'.</Description>
      </Option>
      <Option Short="y" Long="getdata-yaml-field" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The field containing the yaml template for the the data 
sync.</Description>
      </Option>
      <Option Short="p" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>The port to listen on</Description>
      </Option>
    </Parameters>
  </Command>
  <!--WEBSERVER-->
  <Command Name="webserver" IsBranch="false" 
ClrType="Cute.Commands.WebserverCommand" 
Settings="Cute.Commands.WebserverCommand+Settings">
    <Description>Launch web server and listen to http requests and webhook 
calls.</Description>
    <Parameters>
      <Option Short="p" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>The port to listen on</Description>
      </Option>
    </Parameters>
  </Command>
</Model>