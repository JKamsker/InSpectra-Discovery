<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="D20Tek.Tools.DevPassword.Commands.GeneratePasswordCommand" 
Settings="D20Tek.Tools.DevPassword.Commands.PasswordSettings">
    <Parameters>
      <Option Short="c" Long="count" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The number of passwords to generate (defaults to 
1).</Description>
      </Option>
      <Option Short="l" Long="length" Value="PASSWORD-LENGTH" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The number of characters to use in the generated password 
(defaults to 25).</Description>
      </Option>
      <Option Short="v" Long="verbosity" Value="VERBOSITY-LEVEL" 
Required="false" Kind="scalar" 
ClrType="D20Tek.Spectre.Console.Extensions.Settings.VerbosityLevel">
        <Description>The verbosity level for this operation: q(uiet), m(inimal),
n(ormal), d(etailed), and diag(nostic).</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="D20Tek.Tools.DevPassword.Commands.GeneratePasswordCommand" 
Settings="D20Tek.Tools.DevPassword.Commands.PasswordSettings">
    <Description>Default command that a generates password based on defined 
settings.</Description>
    <Parameters>
      <Option Short="c" Long="count" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The number of passwords to generate (defaults to 
1).</Description>
      </Option>
      <Option Short="l" Long="length" Value="PASSWORD-LENGTH" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The number of characters to use in the generated password 
(defaults to 25).</Description>
      </Option>
      <Option Short="v" Long="verbosity" Value="VERBOSITY-LEVEL" 
Required="false" Kind="scalar" 
ClrType="D20Tek.Spectre.Console.Extensions.Settings.VerbosityLevel">
        <Description>The verbosity level for this operation: q(uiet), m(inimal),
n(ormal), d(etailed), and diag(nostic).</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="gen" />
      <Example commandLine="-c" />
      <Example commandLine="1" />
    </Examples>
  </Command>
  <!--CONFIGURE-->
  <Command Name="configure" IsBranch="false" 
ClrType="D20Tek.Tools.DevPassword.Commands.UpdateConfigCommand" 
Settings="D20Tek.Spectre.Console.Extensions.Settings.VerbositySettings">
    <Description>Configure various properties of the dev 
passwords.</Description>
    <Parameters>
      <Option Short="v" Long="verbosity" Value="VERBOSITY-LEVEL" 
Required="false" Kind="scalar" 
ClrType="D20Tek.Spectre.Console.Extensions.Settings.VerbosityLevel">
        <Description>The verbosity level for this operation: q(uiet), m(inimal),
n(ormal), d(etailed), and diag(nostic).</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="configure" />
    </Examples>
  </Command>
</Model>