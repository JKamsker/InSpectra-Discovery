    <Parameters>
      <Argument Name="ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Issue ID</Description>
      </Argument>
      <Option Short="" Long="answer" Value="QUESTION_ID" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Answer a question (use with --text)</Description>
      </Option>
      <Option Short="" Long="ask" Value="TEXT" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Ask a new question</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
      <Option Short="" Long="list" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>List all questions on the issue</Description>
      </Option>
      <Option Short="" Long="text" Value="TEXT" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Answer text (use with --answer)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="question" />
      <Example commandLine="abc123" />
      <Example commandLine="--list" />
      <Example commandLine="question" />
      <Example commandLine="abc123" />
      <Example commandLine="--ask" />
      <Example commandLine="What is the expected behavior?" />
      <Example commandLine="question" />
      <Example commandLine="abc123" />
      <Example commandLine="--answer" />
      <Example commandLine="Q12345" />
      <Example commandLine="--text" />
      <Example commandLine="It should return a 200 status" />
    </Examples>
