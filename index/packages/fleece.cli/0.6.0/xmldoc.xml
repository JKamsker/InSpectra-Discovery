<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CREATE-->
  <Command Name="create" IsBranch="false" 
ClrType="Fleece.Cli.Commands.CreateCommand" 
Settings="Fleece.Cli.Settings.CreateSettings">
    <Description>Create a new issue. Run without options to open an interactive 
editor with a YAML template.</Description>
    <Parameters>
      <Option Short="a" Long="assign" Value="USER" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Username to assign the issue to</Description>
      </Option>
      <Option Short="d" Long="description" Value="DESC" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Issue description</Description>
      </Option>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Issue group for categorization</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
      <Option Short="" Long="json-verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Output as JSON with all metadata fields</Description>
      </Option>
      <Option Short="" Long="linked-issues" Value="ISSUES" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated linked issue IDs</Description>
      </Option>
      <Option Short="" Long="linked-pr" Value="PR" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Associated PR number</Description>
      </Option>
      <Option Short="" Long="parent-issues" Value="ISSUES" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated parent issue IDs</Description>
      </Option>
      <Option Short="" Long="previous" Value="ISSUES" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated IDs of issues that should be done before 
this one</Description>
      </Option>
      <Option Short="p" Long="priority" Value="PRIORITY" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Priority 1-5 (1=highest)</Description>
      </Option>
      <Option Short="s" Long="status" Value="STATUS" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Initial status (default: idea)</Description>
      </Option>
      <Option Short="" Long="tags" Value="TAGS" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Comma-separated tags (no whitespace allowed in 
tags)</Description>
      </Option>
      <Option Short="t" Long="title" Value="TITLE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Issue title (required)</Description>
      </Option>
      <Option Short="" Long="type" Value="TYPE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Issue type: task, bug, chore, feature 
(required)</Description>
      </Option>
      <Option Short="b" Long="working-branch" Value="BRANCH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Working branch ID (valid Git branch name characters 
only)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="create" />
      <Example commandLine="create" />
      <Example commandLine="--title" />
      <Example commandLine="Fix login bug" />
      <Example commandLine="--type" />
      <Example commandLine="bug" />
      <Example commandLine="-p" />
      <Example commandLine="1" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="Fleece.Cli.Commands.ListCommand" 
Settings="Fleece.Cli.Settings.ListSettings">
    <Description>List issues with optional filters</Description>
    <Parameters>
      <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show all issues including all statuses</Description>
      </Option>
      <Option Short="" Long="assigned" Value="USER" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by assignee</Description>
      </Option>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by group</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
      <Option Short="" Long="json-verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Output as JSON with all metadata fields</Description>
      </Option>
      <Option Short="" Long="linked-pr" Value="PR" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Filter by linked PR number</Description>
      </Option>
      <Option Short="" Long="one-line" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Output each issue on a single line: &lt;id&gt; 
&lt;status&gt; &lt;group&gt; &lt;type&gt; &lt;title&gt;</Description>
      </Option>
      <Option Short="p" Long="priority" Value="PRIORITY" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Filter by priority</Description>
      </Option>
      <Option Short="s" Long="status" Value="STATUS" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter by status: idea, spec, next, progress, review, 
complete, archived, closed</Description>
      </Option>
      <Option Short="" Long="tag" Value="TAG" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Filter by tag (can specify multiple times)</Description>
      </Option>
      <Option Short="t" Long="type" Value="TYPE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by type: task, bug, chore, feature</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list" />
      <Example commandLine="--status" />
      <Example commandLine="open" />
      <Example commandLine="--type" />
      <Example commandLine="bug" />
    </Examples>
  </Command>
