  <!--EDIT-->
  <Command Name="edit" IsBranch="false" 
ClrType="Fleece.Cli.Commands.EditCommand" 
Settings="Fleece.Cli.Settings.EditSettings">
    <Description>Edit an existing issue. Run with only an ID to open an 
interactive editor with the issue's current values.</Description>
    <Parameters>
      <Argument Name="ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Issue ID to edit</Description>
      </Argument>
      <Option Short="a" Long="assign" Value="USER" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New assignee username</Description>
      </Option>
      <Option Short="d" Long="description" Value="DESC" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New description</Description>
      </Option>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New issue group</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output as JSON</Description>
      </Option>
      <Option Short="" Long="json-verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Output as JSON with all metadata fields</Description>
      </Option>
      <Option Short="" Long="linked-issues" Value="ISSUES" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Replace linked issue IDs (comma-separated)</Description>
      </Option>
      <Option Short="" Long="linked-pr" Value="PR" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>New associated PR number</Description>
      </Option>
      <Option Short="" Long="parent-issues" Value="ISSUES" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Replace parent issue IDs (comma-separated)</Description>
      </Option>
      <Option Short="" Long="previous" Value="ISSUES" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Replace previous issue IDs (issues that should be done 
before this one, comma-separated)</Description>
      </Option>
      <Option Short="p" Long="priority" Value="PRIORITY" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>New priority 1-5</Description>
      </Option>
      <Option Short="s" Long="status" Value="STATUS" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New status: idea, spec, next, progress, review, complete, 
archived, closed</Description>
      </Option>
      <Option Short="" Long="tags" Value="TAGS" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Replace tags (comma-separated, no whitespace allowed in 
tags)</Description>
      </Option>
      <Option Short="t" Long="title" Value="TITLE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New title</Description>
      </Option>
      <Option Short="" Long="type" Value="TYPE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>New type: task, bug, chore, feature</Description>
      </Option>
      <Option Short="b" Long="working-branch" Value="BRANCH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New working branch ID (valid Git branch name characters 
only)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="edit" />
      <Example commandLine="abc123" />
      <Example commandLine="edit" />
      <Example commandLine="abc123" />
      <Example commandLine="--status" />
      <Example commandLine="complete" />
    </Examples>
  </Command>
