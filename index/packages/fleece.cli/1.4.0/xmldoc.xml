      </Option>
      <Option Short="" Long="tags" Value="TAGS" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Replace tags (comma-separated, no whitespace allowed in 
tags)</Description>
      </Option>
      <Option Short="t" Long="title" Value="TITLE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New title</Description>
      </Option>
      <Option Short="y" Long="type" Value="TYPE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>New type: task, bug, chore, feature, idea</Description>
      </Option>
      <Option Short="b" Long="working-branch" Value="BRANCH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New working branch ID (valid Git branch name characters 
only)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="edit" />
      <Example commandLine="abc123" />
      <Example commandLine="edit" />
      <Example commandLine="abc123" />
      <Example commandLine="--status" />
      <Example commandLine="complete" />
    </Examples>
