Kind="scalar" ClrType="System.String">
        <Description>New assignee username</Description>
      </Option>
      <Option Short="d" Long="description" Value="DESC" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>New description</Description>
      </Option>
      <Option Short="e" Long="execution-mode" Value="MODE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Execution mode for child issues: series, 
parallel</Description>
