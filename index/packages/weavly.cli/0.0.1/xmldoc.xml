<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Weavly.Cli.Commands.InitCommand" 
Settings="Weavly.Cli.Commands.InitCommand+Settings">
    <Description>Initialize a new Weavly solution</Description>
    <Parameters>
      <Argument Name="name" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Solution name</Description>
      </Argument>
      <Option Short="p" Long="project" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Project name (for the initial project)</Description>
      </Option>
      <Option Short="x" Long="slnx" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use new solution (.slnx) format</Description>
      </Option>
    </Parameters>
  </Command>
  <!--MODULE-->
  <Command Name="module" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manages modules</Description>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="Weavly.Cli.Commands.Module.AddCommand" 
Settings="Weavly.Cli.Commands.Module.AddCommand+Settings">
      <Description>Adds an existing Weavly module to the solution</Description>
      <Parameters>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Module name</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="Weavly.Cli.Commands.Module.CreateCommand" 
Settings="Weavly.Cli.Commands.Module.CreateCommand+Settings">
      <Description>Initialized a custom module project for the current 
solution</Description>
      <Parameters>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Module name</Description>
        </Option>
      </Parameters>
    </Command>
    <!--MIGRATE-->
    <Command Name="migrate" IsBranch="false" 
ClrType="Weavly.Cli.Commands.Module.MigrateCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Add database migrations for selected providers to a 
module</Description>
    </Command>
  </Command>
</Model>