<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Docfx.DefaultCommand" Settings="Docfx.DefaultCommand+Options">
    <Parameters>
      <Argument Name="config" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to docfx.json</Description>
      </Argument>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Run in debug mode. With debug mode, raw model and view 
model will be exported automatically when it encounters error when applying 
templates. If not specified, it is false.</Description>
      </Option>
      <Option Short="" Long="debugOutput" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output folder for files generated for debugging purpose
when in debug mode. If not specified, it is ${TempPath}/docfx</Description>
      </Option>
      <Option Short="" Long="disableGitFeatures" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Disable fetching Git related information for articles. By 
default it is enabled and may have side effect on performance when the repo is 
large.</Description>
      </Option>
      <Option Short="" Long="dryRun" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>If set to true, template will not be actually applied to 
the documents. This option is always used with --exportRawModel or 
--exportViewModel is set so that only raw model files or view model files are 
generated.</Description>
      </Option>
      <Option Short="" Long="exportRawModel" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If set to true, data model to run template script will be 
extracted in .raw.model.json extension</Description>
      </Option>
      <Option Short="" Long="exportViewModel" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If set to true, data model to apply template will be 
extracted in .view.model.json extension</Description>
      </Option>
      <Option Short="n" Long="hostname" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specify the hostname of the hosted website (e.g., 
'localhost' or '*')</Description>
      </Option>
      <Option Short="l" Long="log" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Save log as structured JSON to the specified 
file</Description>
      </Option>
      <Option Short="" Long="logLevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[Docfx.Common.LogLevel, Docfx.Common, 
Version=2.78.5.0, Culture=neutral, PublicKeyToken=null]]">
        <Description>Set log level to error, warning, info, verbose or 
diagnostic</Description>
      </Option>
      <Option Short="" Long="markdownEngineProperties" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Set the parameters for markdown engine, value should be a 
JSON string.</Description>
      </Option>
      <Option Short="" Long="maxParallelism" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Set the max parallelism, 0 is auto.</Description>
      </Option>
      <Option Short="m" Long="metadata" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Specify a list of global metadata in key value pairs (e.g. 
--metadata _appTitle="My App" --metadata _disableContribution)</Description>
      </Option>
      <Option Short="" Long="open-browser" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Open a web browser when the hosted website 
starts.</Description>
      </Option>
      <Option Short="" Long="open-file" Value="RELATIVE_PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Open a file in a web browser when the hosted website 
starts.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specify the output base directory</Description>
      </Option>
      <Option Short="p" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Specify the port of the hosted website</Description>
      </Option>
      <Option Short="" Long="postProcessors" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Collections.Generic.IEnumerable`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Set the order of post processors in plugins</Description>
      </Option>
      <Option Short="" Long="rawModelOutputFolder" Value="NULL" Required="false"
Kind="scalar" ClrType="System.String">
        <Description>Specify the output folder for the raw model. If not set, 
the raw model will be generated to the same folder as the output 
documentation</Description>
      </Option>
      <Option Short="s" Long="serve" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Host the generated documentation to a website</Description>
      </Option>
      <Option Short="t" Long="template" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Collections.Generic.IEnumerable`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Specify the template name to apply to. If not specified, 
output YAML file will not be transformed.</Description>
      </Option>
      <Option Short="" Long="theme" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.IEnumerable`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Specify which theme to use. By default 'default' theme is 
offered.</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Set log level to verbose</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Prints version information</Description>
      </Option>
      <Option Short="" Long="viewModelOutputFolder" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Specify the output folder for the view model. If not set, 
the view model will be generated to the same folder as the output 
documentation</Description>
      </Option>
      <Option Short="" Long="warningsAsErrors" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Treats warnings as errors</Description>
      </Option>
      <Option Short="x" Long="xref" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.IEnumerable`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Specify the urls of xrefmap used by content 
files.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="Docfx.InitCommand" 
Settings="Docfx.InitCommandOptions">
    <Parameters>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specify the output directory of the generated 
