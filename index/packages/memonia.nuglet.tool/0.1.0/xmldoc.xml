<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Nuglet.NugletCommand" Settings="Nuglet.NugletCommandSettings">
    <Parameters>
      <Argument Name="targets" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
        <Description>NuGet packages to be included</Description>
      </Argument>
      <Option Short="d" Long="destination" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Directory where the new nuglet project will be 
created</Description>
      </Option>
      <Option Short="l" Long="log-severity" Value="NULL" Required="false" 
Kind="scalar" ClrType="Nuglet.Logging.LogSeverity">
        <Description>Log Severity level to output. The values are: Error, 
Warning, Information, Debug</Description>
      </Option>
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The name of the nuglet project</Description>
      </Option>
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If the --name option is specified, clears the directory in 
destination with this name</Description>
      </Option>
      <Option Short="t" Long="timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Time in seconds for each individual command to be executed 
before it is aborted</Description>
      </Option>
      <Option Short="" Long="vs-sln" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Create a Visual Studio solution</Description>
      </Option>
    </Parameters>
    <Examples>
