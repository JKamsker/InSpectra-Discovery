    <!--DISABLE-CPM-->
    <Command Name="disable-cpm" IsBranch="false" 
ClrType="CsProj.Commands.Modify.DontUseCentralPackageManagementCommand" 
Settings="CsProj.Commands.Modify.DontUseCentralPackageManagementCommand+Settings
">
      <Description>Convert projects to not use central package 
