      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
        <Option Short="b" Long="backup" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Create a backup of the modified project 
file(s)</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force run, even if not in a git repo</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="modify disable-cpm solution.slnx" />
      </Examples>
    </Command>
    <!--PRUNE-LINKS-->
    <Command Name="prune-links" IsBranch="false" 
ClrType="CsProj.Commands.Modify.PruneLinksCommand" 
Settings="CsProj.Commands.Modify.PruneLinksCommand+Settings">
      <Description>Inspect and remove redundant project/NuGet references in 
solution projects</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
        <Option Short="b" Long="backup" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Create a backup of the modified project 
file(s)</Description>
        </Option>
        <Option Short="D" Long="dryrun" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Dryrun mode. Only show what would be 
changed.</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force run, even if not in a git repo</Description>
        </Option>
        <Option Short="" Long="graph-md" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output the dependency graph as a Markdown file with 
Mermaid syntax.</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show the reference tree for each project.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Display various information about multiple 
projects</Description>
    <!--NUGETS-->
    <Command Name="nugets" IsBranch="false" 
ClrType="CsProj.Commands.Info.NugetsCommand" 
Settings="CsProj.Commands.BaseReadSettings">
      <Description>List all NuGet package references in the 
project(s)</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="info nugets solution.sln" />
      </Examples>
    </Command>
    <!--DEPENDENCIES-->
    <Command Name="dependencies" IsBranch="false" 
ClrType="CsProj.Commands.Info.DependenciesCommand" 
Settings="CsProj.Commands.Info.DependenciesCommand+Settings">
      <Description>Visualize project or package dependencies</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
        <Option Short="d" Long="dependency-type" Value="NULL" Required="false" 
Kind="scalar" ClrType="CsProj.Commands.Info.DependenciesCommand+DependencyType">
          <Description>Dependency type to visualize. Can be project or 
package</Description>
        </Option>
        <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="CsProj.Commands.Info.DependenciesCommand+OutputType">
          <Description>Output type, can be console, mermaid or 
nomnoml</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="info dependencies solution.sln -d project" />
      </Examples>
    </Command>
  </Command>
</Model>