<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--MODIFY-->
  <Command Name="modify" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Modify various properties of multiple projects</Description>
    <!--IMPLICITUSINGS-->
    <Command Name="implicitusings" IsBranch="false" 
ClrType="CsProj.Commands.Modify.NullableCommand" 
Settings="CsProj.Commands.Modify.NullableCommand+Settings">
      <Description>Enable or disable implicit usings</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
        <Option Short="b" Long="backup" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Create a backup of the modified project 
file(s)</Description>
        </Option>
        <Option Short="e" Long="enable" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable or disable nullable reference types</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force run, even if not in a git repo</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="modify implicitusings solution.sln --enable" />
      </Examples>
    </Command>
    <!--LANGVERSION-->
    <Command Name="langversion" IsBranch="false" 
ClrType="CsProj.Commands.Modify.LangVersionCommand" 
Settings="CsProj.Commands.Modify.LangVersionCommand+Settings">
      <Description>Set the C# language version for the project</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
        <Option Short="b" Long="backup" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Create a backup of the modified project 
file(s)</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force run, even if not in a git repo</Description>
        </Option>
        <Option Short="v" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Set the C# language version. Can be a major.minor number 
or preview, latest, latestmajor</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="modify langversion solution.slnx -v preview" />
      </Examples>
    </Command>
    <!--NULLABLE-->
    <Command Name="nullable" IsBranch="false" 
ClrType="CsProj.Commands.Modify.NullableCommand" 
Settings="CsProj.Commands.Modify.NullableCommand+Settings">
      <Description>Enable or disable nullable reference types</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
        <Option Short="b" Long="backup" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Create a backup of the modified project 
file(s)</Description>
        </Option>
        <Option Short="e" Long="enable" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable or disable nullable reference types</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force run, even if not in a git repo</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="modify nullable c:\folder --enable" />
      </Examples>
    </Command>
    <!--TARGETFRAMEWORK-->
    <Command Name="targetframework" IsBranch="false" 
ClrType="CsProj.Commands.Modify.TargetFrameworkCommand" 
Settings="CsProj.Commands.Modify.TargetFrameworkCommand+Settings">
      <Description>Set the target framework for the project</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
        <Option Short="b" Long="backup" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Create a backup of the modified project 
file(s)</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force run, even if not in a git repo</Description>
        </Option>
        <Option Short="o" Long="old" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>The old target framework to upgrade from</Description>
        </Option>
        <Option Short="t" Long="target" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The target framework to upgrade to</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="modify targetframework solution.slnx --old net8.0 
--target net10.0" />
      </Examples>
    </Command>
    <!--VERSION-->
    <Command Name="version" IsBranch="false" 
ClrType="CsProj.Commands.Modify.VersionCommand" 
Settings="CsProj.Commands.Modify.VersionCommand+Settings">
      <Description>Set project versions</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Solution or project file name or a directory containing 
one</Description>
        </Argument>
        <Option Short="" Long="assembly" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Version">
          <Description>The assembly version to set</Description>
        </Option>
        <Option Short="b" Long="backup" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Create a backup of the modified project 
file(s)</Description>
        </Option>
        <Option Short="" Long="file" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Version">
          <Description>The file version to set</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force run, even if not in a git repo</Description>
        </Option>
        <Option Short="v" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Version">
          <Description>The version prefix to set</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="modify version solution.slnx -v 1.0.0.0" />
      </Examples>
    </Command>
    <!--ENABLE-CPM-->
