<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--TARGETFRAMEWORK-->
  <Command Name="targetframework" IsBranch="false" 
ClrType="Csproj.Commands.TargetFrameworkCommand" 
Settings="Csproj.Commands.TargetFrameworkCommand+Settings">
    <Description>Set the target framework for the project</Description>
    <Parameters>
      <Option Short="b" Long="backup" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Create a backup of the project file</Description>
      </Option>
      <Option Short="f" Long="filter" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter project files by name. Wildcards like * and ? are 
supported</Description>
      </Option>
      <Option Short="o" Long="old" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The old target framework to upgrade from</Description>
      </Option>
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Project File Path. Can be a directory or a single project 
file. If not provided, the current directory is used</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Recursive search for csproj files.</Description>
      </Option>
      <Option Short="t" Long="target" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The target framework to upgrade to</Description>
      </Option>
    </Parameters>
  </Command>
  <!--NULLABLE-->
  <Command Name="nullable" IsBranch="false" 
ClrType="Csproj.Commands.NullabilityCommand" 
Settings="Csproj.Commands.NullabilityCommand+Settings">
    <Description>Set the nullable context for the project</Description>
    <Parameters>
      <Option Short="b" Long="backup" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Create a backup of the project file</Description>
      </Option>
      <Option Short="f" Long="filter" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter project files by name. Wildcards like * and ? are 
supported</Description>
      </Option>
      <Option Short="n" Long="nullability" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>The nullability to upgrade to</Description>
      </Option>
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Project File Path. Can be a directory or a single project 
file. If not provided, the current directory is used</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Recursive search for csproj files.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>