<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Cranky.Commands.AnalyzeCommand" 
Settings="Cranky.Commands.AnalyzeCommand+Settings">
    <Parameters>
      <Option Short="" Long="azure" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Format output for Azure Pipelines.</Description>
      </Option>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable debug output for MSBuild.</Description>
      </Option>
      <Option Short="x" Long="exclude" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Patterns to exclude projects. (e.g.: 
'*.Test')</Description>
      </Option>
      <Option Short="" Long="github" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Format output for GitHub Actions.</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Format output as JSON.</Description>
      </Option>
      <Option Short="" Long="percentages" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum and acceptable documentation coverage percentages. 
Default: 50,90</Description>
      </Option>
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.FileInfo">
        <Description>Path to the project file.</Description>
      </Option>
      <Option Short="e" Long="set-exit-code" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Set exit code to 1 if documentation coverage is below 
minimum threshold.</Description>
      </Option>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.FileInfo">
        <Description>Path to the solution file.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>