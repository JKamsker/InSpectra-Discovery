<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="AspireRunner.Tool.Commands.RunCommand" 
Settings="AspireRunner.Tool.Commands.RunCommand+Settings">
    <Description>Aspire Runner v2.0.2</Description>
    <Parameters>
      <Argument Name="version" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The version of the dashboard to run</Description>
      </Argument>
      <Option Short="a" Long="auth" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use browser token authentication for the 
dashboard</Description>
      </Option>
      <Option Short="" Long="auto-update" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Automatically update the dashboard to the latest 
version</Description>
      </Option>
      <Option Short="b" Long="browser" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Launch the dashboard in the default browser</Description>
      </Option>
      <Option Short="" Long="cors-headers" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The allowed headers for CORS requests, separated by a 
comma</Description>
      </Option>
      <Option Short="" Long="cors-origins" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The allowed origins for CORS requests, separated by a 
comma. A wildcard (*) can be used to allow any domain</Description>
      </Option>
      <Option Short="" Long="dashboard-https" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Use HTTPS instead of HTTP for the dashboard, overrides the 
global HTTPS option</Description>
      </Option>
      <Option Short="" Long="hostname" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The hostname used for the dashboard and OTLP 
server</Description>
      </Option>
      <Option Short="s" Long="https" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Use HTTPS instead of HTTP, this applies to both the 
dashboard and the OTLP server</Description>
      </Option>
      <Option Short="m" Long="multiple" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Allow running multiple instances of the dashboard, if not 
passed, existing instances will be replaced</Description>
      </Option>
      <Option Short="" Long="otlp-http-port" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>The port the OTLP/HTTP server will listen on, by default, 
only the gRPC server is started</Description>
      </Option>
      <Option Short="" Long="otlp-https" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Use HTTPS instead of HTTP for the OTLP/gRPC and OTLP/HTTP 
endpoints, overrides the global HTTPS option</Description>
      </Option>
      <Option Short="" Long="otlp-key" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The API key to use for the OTLP server</Description>
      </Option>
      <Option Short="" Long="otlp-port" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The port the OTLP/gRPC server will listen on, can be 
disabled by passing 0</Description>
      </Option>
      <Option Short="p" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>The port the dashboard will be available on</Description>
      </Option>
      <Option Short="t" Long="token" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>The token to use for dashboard authentication, if not 
passed, the token will be randomly generated by the dashboard</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Enable verbose logging</Description>
      </Option>
    </Parameters>
  </Command>
