  <!--INSTALL-->
  <Command Name="install" IsBranch="false" 
ClrType="AspireRunner.Tool.Commands.InstallCommand" 
Settings="AspireRunner.Tool.Commands.InstallCommand+Settings">
    <Parameters>
      <Argument Name="version" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The version of the dashboard to install, pass 'latest' to 
install the latest version available</Description>
      </Argument>
      <Option Short="p" Long="allow-prerelease" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Allow prerelease versions when installing</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UNINSTALL-->
  <Command Name="uninstall" IsBranch="false" 
ClrType="AspireRunner.Tool.Commands.UninstallCommand" 
Settings="AspireRunner.Tool.Commands.UninstallCommand+Settings">
    <Parameters>
      <Argument Name="version" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The version of the dashboard to uninstall, pass 'all' or 
'*' to uninstall all versions</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--CLEANUP-->
  <Command Name="cleanup" IsBranch="false" 
ClrType="AspireRunner.Tool.Commands.CleanupCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Remove old versions of the dashboard and other temporary 
files</Description>
  </Command>
