<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.InitCommand" 
Settings="FilmStruck.Cli.Commands.InitCommand+Settings">
    <Description>Initialize a new filmstruck repository</Description>
    <Parameters>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Overwrite existing files</Description>
      </Option>
      <Option Short="u" Long="username" Value="USERNAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Your username displayed on the site</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.AddCommand" 
Settings="FilmStruck.Cli.Commands.AddCommand+Settings">
    <Description>Add a new film entry with TMDB lookup</Description>
    <Parameters>
      <Option Short="c" Long="companions" Value="COMPANIONS" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of companions</Description>
      </Option>
      <Option Short="d" Long="date" Value="DATE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Watch date in M/d/yyyy format (default: 
today)</Description>
      </Option>
      <Option Short="" Long="default-poster" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Use the default/first poster without 
prompting</Description>
      </Option>
      <Option Short="l" Long="location" Value="LOCATION" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Where the film was watched</Description>
      </Option>
      <Option Short="t" Long="title" Value="TITLE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Film title for TMDB search</Description>
      </Option>
      <Option Short="" Long="tmdb-id" Value="ID" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>TMDB movie ID (skips search and confirmation)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ENRICH-->
  <Command Name="enrich" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.EnrichCommand" 
Settings="FilmStruck.Cli.Commands.EnrichCommand+Settings">
    <Description>Look up TMDB IDs for existing log entries</Description>
    <Parameters>
      <Option Short="" Long="default-poster" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Use the default poster without prompting</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CALCULATE-->
  <Command Name="calculate" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.CalculateCommand" 
Settings="FilmStruck.Cli.Commands.CalculateCommand+Settings">
    <Description>Calculate and write statistics to stats.csv</Description>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.BuildCommand" 
Settings="FilmStruck.Cli.Commands.BuildCommand+Settings">
    <Description>Generate static site from CSV data</Description>
  </Command>
  <!--IMPORT-LETTERBOXD-DIARY-->
  <Command Name="import-letterboxd-diary" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.ImportLetterboxdCommand" 
Settings="FilmStruck.Cli.Commands.ImportLetterboxdCommand+Settings">
    <Description>Import films from Letterboxd diary CSV export</Description>
    <Parameters>
      <Argument Name="FILE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to Letterboxd diary CSV export</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--HEARTS-->
  <Command Name="hearts" IsBranch="true" 
Settings="FilmStruck.Cli.Commands.Hearts.HeartsSettings">
    <Description>Manage favorite films</Description>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.Hearts.HeartsAddCommand" 
Settings="FilmStruck.Cli.Commands.Hearts.HeartsAddCommand+Settings">
      <Description>Add a film to favorites</Description>
      <Parameters>
        <Option Short="" Long="tmdb-id" Value="ID" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>TMDB movie ID to add to hearts</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REMOVE-->
    <Command Name="remove" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.Hearts.HeartsRemoveCommand" 
Settings="FilmStruck.Cli.Commands.Hearts.HeartsRemoveCommand+Settings">
      <Description>Remove a film from favorites</Description>
      <Parameters>
        <Option Short="" Long="tmdb-id" Value="ID" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>TMDB movie ID to remove from hearts</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>