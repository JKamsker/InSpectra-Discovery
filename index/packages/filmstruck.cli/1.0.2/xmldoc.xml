<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.InitCommand" 
Settings="FilmStruck.Cli.Commands.InitCommand+Settings">
    <Description>Initialize a new filmstruck repository</Description>
    <Parameters>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Overwrite existing files</Description>
      </Option>
      <Option Short="u" Long="username" Value="USERNAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Your username displayed on the site</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.AddCommand" 
Settings="FilmStruck.Cli.Commands.AddCommand+Settings">
    <Description>Add a new film entry with TMDB lookup</Description>
  </Command>
  <!--ENRICH-->
  <Command Name="enrich" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.EnrichCommand" 
Settings="FilmStruck.Cli.Commands.EnrichCommand+Settings">
    <Description>Look up TMDB IDs for existing log entries</Description>
  </Command>
  <!--CALCULATE-->
  <Command Name="calculate" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.CalculateCommand" 
Settings="FilmStruck.Cli.Commands.CalculateCommand+Settings">
    <Description>Calculate and write statistics to stats.csv</Description>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="FilmStruck.Cli.Commands.BuildCommand" 
Settings="FilmStruck.Cli.Commands.BuildCommand+Settings">
    <Description>Generate static site from CSV data</Description>
  </Command>
</Model>