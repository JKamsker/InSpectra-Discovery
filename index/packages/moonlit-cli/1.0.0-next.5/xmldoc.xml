<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Wolfware.Moonlit.Cli.Commands.VersionCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="Wolfware.Moonlit.Cli.Commands.VersionCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Show the version of the Moonlit CLI</Description>
  </Command>
  <!--RELEASE-->
  <Command Name="release" IsBranch="false" 
ClrType="Wolfware.Moonlit.Cli.Commands.ReleaseCommand" 
Settings="Wolfware.Moonlit.Cli.Commands.ReleaseCommand+Settings">
    <Description>Executes a release pipeline</Description>
    <Parameters>
      <Option Short="a" Long="arg" Value="ARGUMENT" Required="false" 
Kind="vector" ClrType="System.String[]" />
      <Option Short="f" Long="file" Value="FILENAME" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="s" Long="stages" Value="STAGES" Required="false" 
Kind="vector" ClrType="System.String[]" />
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
      <Option Short="w" Long="working-directory" Value="WORKINGDIRECTORY" 
Required="false" Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
</Model>