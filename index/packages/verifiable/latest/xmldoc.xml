<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DID-->
  <Command Name="did" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="Verifiable.DidCreateCommand" 
Settings="Verifiable.DidCreateCommand+DidSettings">
      <Parameters>
        <Argument Name="ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
          <Description>Identifier for the new DID document.</Description>
        </Argument>
        <Argument Name="Param" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>New DID document parameter.</Description>
        </Argument>
        <Option Short="e" Long="extraParam" Value="SOMEPARAM" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Some extra parameter.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--REVOKE-->
    <Command Name="revoke" IsBranch="false" 
ClrType="Verifiable.DidRevokeCommand" 
Settings="Verifiable.DidRevokeCommand+Settings">
      <Parameters>
        <Argument Name="ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
          <Description>Identifier to revoke a DID document.</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" ClrType="Verifiable.DidListCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
    <!--VIEW-->
    <Command Name="view" IsBranch="false" ClrType="Verifiable.DidViewCommand" 
Settings="Verifiable.DidViewCommand+Settings">
      <Parameters>
        <Argument Name="ID" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
          <Description>DID identifier for a document to view.</Description>
        </Argument>
      </Parameters>
    </Command>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--TPM-->
    <Command Name="tpm" IsBranch="false" ClrType="Verifiable.InfoTpmCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  </Command>
</Model>