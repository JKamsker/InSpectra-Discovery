<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--IDL-->
  <Command Name="idl" IsBranch="false" ClrType="AvroTool.Commands.IdlCommand" 
Settings="AvroTool.Commands.IdlCommand+Settings">
    <Description>Generates a JSON protocol file from an Avro IDL 
file.</Description>
    <Parameters>
      <Argument Name="IDL_FILE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>An IDL file to compile.</Description>
      </Argument>
      <Option Short="d" Long="output-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.DirectoryInfo">
        <Description>Directory to save generated JSON.</Description>
      </Option>
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Overwrite any existing types.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--IDL2SCHEMATA-->
  <Command Name="idl2schemata" IsBranch="false" 
ClrType="AvroTool.Commands.IdlToSchemataCommand" 
Settings="AvroTool.Commands.IdlToSchemataCommand+Settings">
    <Description>Extract JSON schemata of the types from an Avro IDL 
file.</Description>
    <Parameters>
      <Argument Name="IDL_FILE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>An IDL file to compile.</Description>
      </Argument>
      <Option Short="d" Long="output-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.DirectoryInfo">
        <Description>Directory to save schemata.</Description>
      </Option>
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Overwrite any existing types.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CODEGEN-->
  <Command Name="codegen" IsBranch="false" 
ClrType="AvroTool.Commands.CodeGenCommand" 
Settings="AvroTool.Commands.CodeGenCommand+Settings">
    <Description>Generates C# code for a given Avro IDL, protocol or 
schema.</Description>
    <Parameters>
      <Argument Name="INPUT_FILE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>An IDL, protocol or schema file to generate C# code 
from.</Description>
      </Argument>
      <Argument Name="NAMESPACE" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>A base namespace to use for generated files. Only used when
a defined namespace is not present.</Description>
      </Argument>
      <Option Short="d" Long="output-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.DirectoryInfo">
        <Description>Directory to save generated C# files.</Description>
      </Option>
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Overwrite any existing generated code.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>