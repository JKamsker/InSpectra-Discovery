<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="DependencyPath.ScanCommand" 
Settings="DependencyPath.ScanCommandSettings">
    <Parameters>
      <Argument Name="assemblies" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Assemblies</Description>
      </Argument>
      <Argument Name="dependency" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Dependency to search</Description>
      </Argument>
      <Option Short="d" Long="depth" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Max search depth</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Assembly search path</Description>
      </Option>
      <Option Short="r" Long="recurse" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Recurse sub-directories</Description>
      </Option>
      <Option Short="t" Long="token" Value="NULL" Required="false" Kind="vector"
ClrType="System.String[]">
        <Description>Skip public key token</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Verbose</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Display resolved versions</Description>
      </Option>
      <Option Short="a" Long="version-all" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Display expected and resolved versions</Description>
      </Option>
    </Parameters>
  </Command>
