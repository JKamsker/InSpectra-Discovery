<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="PackCheck.Commands.CheckCommand" 
Settings="PackCheck.Commands.Settings.CheckSettings">
    <Parameters>
      <Option Short="" Long="cpmFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to Directory.Packages.props file. (default 
.\Directory.Packages.props)</Description>
      </Option>
      <Option Short="" Long="csprojFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.csproj file. (default .\*.csproj)</Description>
      </Option>
      <Option Short="" Long="slnFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.sln file. (default .\*.sln)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="PackCheck.Commands.CheckCommand" 
Settings="PackCheck.Commands.Settings.CheckSettings">
    <Parameters>
      <Option Short="" Long="cpmFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to Directory.Packages.props file. (default 
.\Directory.Packages.props)</Description>
      </Option>
      <Option Short="" Long="csprojFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.csproj file. (default .\*.csproj)</Description>
      </Option>
      <Option Short="" Long="slnFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.sln file. (default .\*.sln)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UPGRADE-->
  <Command Name="upgrade" IsBranch="false" 
ClrType="PackCheck.Commands.UpgradeCommand" 
Settings="PackCheck.Commands.Settings.UpgradeSettings">
    <Parameters>
      <Argument Name="package_name" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of package to upgrade</Description>
      </Argument>
      <Option Short="" Long="cpmFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to Directory.Packages.props file. (default 
.\Directory.Packages.props)</Description>
      </Option>
      <Option Short="" Long="csprojFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.csproj file. (default .\*.csproj)</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Only show the result without actually changing the .csproj 
file</Description>
      </Option>
      <Option Short="i" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Interactively decide for each package if it should be 
upgraded</Description>
      </Option>
      <Option Short="" Long="slnFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.sln file. (default .\*.sln)</Description>
      </Option>
      <Option Short="" Long="target" Value="TARGET_VERSION" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Upgrade version number to latest stable version (stable) or
latest version (latest)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>