<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="PackCheck.Commands.CheckCommand" 
Settings="PackCheck.Commands.Settings.CheckSettings">
    <Parameters>
      <Option Short="" Long="cpmFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to Directory.Packages.props file. (default 
.\Directory.Packages.props)</Description>
      </Option>
      <Option Short="" Long="csprojFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.csproj file. (default .\*.csproj)</Description>
      </Option>
      <Option Short="x" Long="exclude" Value="PACKAGE_NAME" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Exclude packages matching the given name (can be used 
multiple times)</Description>
      </Option>
      <Option Short="f" Long="filter" Value="PACKAGE_NAME" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Include only packages matching the given name (can be used 
multiple times)</Description>
      </Option>
      <Option Short="" Long="slnFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.sln file. (default .\*.sln)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CHECK-->
  <Command Name="check" IsBranch="false" 
ClrType="PackCheck.Commands.CheckCommand" 
Settings="PackCheck.Commands.Settings.CheckSettings">
    <Description>Check for newer versions. (default command)</Description>
    <Parameters>
      <Option Short="" Long="cpmFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to Directory.Packages.props file. (default 
.\Directory.Packages.props)</Description>
      </Option>
      <Option Short="" Long="csprojFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.csproj file. (default .\*.csproj)</Description>
      </Option>
      <Option Short="x" Long="exclude" Value="PACKAGE_NAME" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Exclude packages matching the given name (can be used 
multiple times)</Description>
      </Option>
      <Option Short="f" Long="filter" Value="PACKAGE_NAME" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Include only packages matching the given name (can be used 
multiple times)</Description>
      </Option>
      <Option Short="" Long="slnFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.sln file. (default .\*.sln)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="check" />
      <Example commandLine="--csprojFile" />
      <Example commandLine=".\examples\csproj.xml" />
    </Examples>
  </Command>
  <!--UPGRADE-->
  <Command Name="upgrade" IsBranch="false" 
ClrType="PackCheck.Commands.UpgradeCommand" 
Settings="PackCheck.Commands.Settings.UpgradeSettings">
    <Description>Upgrade the *.csproj (or Directory.Packages.props) 
file</Description>
    <Parameters>
      <Argument Name="Package_Name" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of package to upgrade</Description>
      </Argument>
      <Option Short="" Long="cpmFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to Directory.Packages.props file. (default 
.\Directory.Packages.props)</Description>
      </Option>
      <Option Short="" Long="csprojFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.csproj file. (default .\*.csproj)</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Only show the result without actually changing the .csproj 
file</Description>
      </Option>
      <Option Short="x" Long="exclude" Value="PACKAGE_NAME" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Exclude packages matching the given name (can be used 
multiple times)</Description>
      </Option>
      <Option Short="f" Long="filter" Value="PACKAGE_NAME" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Include only packages matching the given name (can be used 
multiple times)</Description>
      </Option>
      <Option Short="i" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Interactively decide for each package if it should be 
upgraded</Description>
      </Option>
      <Option Short="" Long="slnFile" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to *.sln file. (default .\*.sln)</Description>
      </Option>
      <Option Short="t" Long="target" Value="TARGET_VERSION" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Upgrade version number to latest stable version (stable) or
latest version (latest)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="upgrade" />
      <Example commandLine="upgrade" />
      <Example commandLine="--target" />
      <Example commandLine="stable" />
      <Example commandLine="upgrade" />
      <Example commandLine="--target" />
      <Example commandLine="latest" />
      <Example commandLine="upgrade" />
      <Example commandLine="Microsoft.Extensions.Logging" />
      <Example commandLine="--target" />
      <Example commandLine="stable" />
      <Example commandLine="upgrade" />
      <Example commandLine="Microsoft.Extensions.Logging" />
      <Example commandLine="--target" />
      <Example commandLine="latest" />
      <Example commandLine="upgrade" />
      <Example commandLine="--dry-run" />
      <Example commandLine="upgrade" />
      <Example commandLine="-i" />
      <Example commandLine="upgrade" />
      <Example commandLine="--target" />
      <Example commandLine="latest" />
      <Example commandLine="-i" />
    </Examples>
  </Command>
</Model>