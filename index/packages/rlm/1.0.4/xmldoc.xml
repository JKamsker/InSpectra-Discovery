<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LOAD-->
  <Command Name="load" IsBranch="false" ClrType="Rlm.Cli.Commands.LoadCommand" 
Settings="Rlm.Cli.Commands.LoadCommand+Settings">
    <Description>Load a document into the session</Description>
    <Parameters>
      <Argument Name="source" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>File path, directory path, or '-' for stdin</Description>
      </Argument>
      <Option Short="" Long="merge" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>When loading multiple files, merge them into a single 
document with separators</Description>
      </Option>
      <Option Short="p" Long="pattern" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Glob pattern for filtering files when loading a directory 
(e.g., '*.md', '**/*.txt')</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="load" />
      <Example commandLine="document.txt" />
      <Example commandLine="load" />
      <Example commandLine="-" />
    </Examples>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" ClrType="Rlm.Cli.Commands.InfoCommand" 
Settings="Rlm.Cli.Commands.InfoCommand+Settings">
    <Description>Show information about the current session</Description>
    <Parameters>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output in JSON format for machine parsing</Description>
      </Option>
      <Option Short="" Long="progress" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show processing progress summary</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SLICE-->
  <Command Name="slice" IsBranch="false" ClrType="Rlm.Cli.Commands.SliceCommand"
Settings="Rlm.Cli.Commands.SliceCommand+Settings">
    <Description>View a slice of the document</Description>
    <Parameters>
      <Argument Name="range" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Slice range (e.g., '0:1000', '-500:', 
':1000')</Description>
      </Argument>
      <Option Short="" Long="raw" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output raw content for piping/scripts.</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="slice" />
      <Example commandLine="0:1000" />
      <Example commandLine="slice" />
      <Example commandLine="-500:" />
    </Examples>
  </Command>
  <!--CHUNK-->
  <Command Name="chunk" IsBranch="false" ClrType="Rlm.Cli.Commands.ChunkCommand"
Settings="Rlm.Cli.Commands.ChunkCommand+Settings">
    <Description>Split document into chunks using a strategy</Description>
    <Parameters>
      <Option Short="c" Long="context" Value="CONTEXT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Context size around matches for filter strategy (default: 
500)</Description>
      </Option>
      <Option Short="" Long="max-level" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum header level for semantic strategy (default: 
3)</Description>
      </Option>
      <Option Short="" Long="max-size" Value="SIZE" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum chunk size for semantic strategy. Larger chunks 
will be split (default: 0)</Description>
      </Option>
      <Option Short="" Long="max-tokens" Value="TOKENS" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum tokens per chunk for token strategy (default: 
512)</Description>
      </Option>
      <Option Short="" Long="merge-small" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Merge consecutive small sections (use with 
--min-size)</Description>
      </Option>
      <Option Short="" Long="min-level" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Minimum header level for semantic strategy (default: 
1)</Description>
      </Option>
      <Option Short="" Long="min-size" Value="SIZE" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Minimum chunk size for semantic strategy. Smaller chunks 
will be merged (default: 0)</Description>
      </Option>
      <Option Short="" Long="overlap" Value="OVERLAP" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Overlap size for uniform strategy (default: 
0)</Description>
      </Option>
      <Option Short="" Long="overlap-tokens" Value="TOKENS" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Overlap tokens for token strategy (default: 
50)</Description>
      </Option>
      <Option Short="p" Long="pattern" Value="PATTERN" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Regex pattern for filter strategy (or hybrid filter with 
semantic)</Description>
      </Option>
      <Option Short="q" Long="query" Value="QUERY" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Query text for auto strategy selection</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
      <Option Short="" Long="size" Value="SIZE" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Chunk size for uniform strategy (default: 
50000)</Description>
      </Option>
      <Option Short="s" Long="strategy" Value="STRATEGY" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Chunking strategy: uniform, filter, semantic, token, 
recursive, auto</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="chunk" />
      <Example commandLine="--strategy" />
      <Example commandLine="uniform" />
      <Example commandLine="--size" />
      <Example commandLine="50000" />
      <Example commandLine="chunk" />
      <Example commandLine="--strategy" />
      <Example commandLine="filter" />
      <Example commandLine="--pattern" />
      <Example commandLine="email|@" />
      <Example commandLine="chunk" />
      <Example commandLine="--strategy" />
      <Example commandLine="semantic" />
    </Examples>
  </Command>
  <!--FILTER-->
  <Command Name="filter" IsBranch="false" 
ClrType="Rlm.Cli.Commands.FilterCommand" 
Settings="Rlm.Cli.Commands.FilterCommand+Settings">
    <Description>Filter document by regex pattern</Description>
    <Parameters>
      <Argument Name="pattern" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Regex pattern to search for</Description>
      </Argument>
      <Option Short="c" Long="context" Value="CONTEXT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Context size around matches (default: 500)</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="filter" />
      <Example commandLine="alice|email|@" />
    </Examples>
  </Command>
  <!--NEXT-->
  <Command Name="next" IsBranch="false" ClrType="Rlm.Cli.Commands.NextCommand" 
Settings="Rlm.Cli.Commands.NextCommand+Settings">
    <Description>Get the next chunk from the buffer</Description>
    <Parameters>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output in JSON format for machine parsing</Description>
      </Option>
      <Option Short="" Long="raw" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output raw content for piping/scripts.</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SKIP-->
  <Command Name="skip" IsBranch="false" ClrType="Rlm.Cli.Commands.SkipCommand" 
Settings="Rlm.Cli.Commands.SkipCommand+Settings">
    <Description>Skip a specified number of chunks</Description>
    <Parameters>
      <Argument Name="count" Position="0" Required="true" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of chunks to skip (positive = forward, negative = 
backward)</Description>
      </Argument>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output in JSON format for machine parsing</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
      <Option Short="" Long="skip-empty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip empty or very small chunks (&lt; 100 
chars)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="skip" />
      <Example commandLine="10" />
      <Example commandLine="skip" />
      <Example commandLine="-5" />
      <Example commandLine="skip" />
      <Example commandLine="10" />
      <Example commandLine="--skip-empty" />
    </Examples>
  </Command>
  <!--JUMP-->
  <Command Name="jump" IsBranch="false" ClrType="Rlm.Cli.Commands.JumpCommand" 
Settings="Rlm.Cli.Commands.JumpCommand+Settings">
    <Description>Jump to a specific chunk index or percentage</Description>
    <Parameters>
      <Argument Name="index" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Target chunk index (1-based) or percentage with % suffix 
(e.g., 50%)</Description>
      </Argument>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output in JSON format for machine parsing</Description>
      </Option>
      <Option Short="" Long="raw" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output raw content for piping/scripts.</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="jump" />
      <Example commandLine="50" />
      <Example commandLine="jump" />
      <Example commandLine="50%" />
    </Examples>
  </Command>
  <!--STORE-->
  <Command Name="store" IsBranch="false" ClrType="Rlm.Cli.Commands.StoreCommand"
Settings="Rlm.Cli.Commands.StoreCommand+Settings">
    <Description>Store a partial result</Description>
    <Parameters>
      <Argument Name="key" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Key to identify this result (e.g., 'chunk_0', 
'section_intro')</Description>
      </Argument>
      <Argument Name="value" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The result value to store</Description>
      </Argument>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="store" />
      <Example commandLine="chunk_0" />
      <Example commandLine="Found: alice@example.com" />
    </Examples>
  </Command>
  <!--RESULTS-->
  <Command Name="results" IsBranch="false" 
ClrType="Rlm.Cli.Commands.ResultsCommand" 
Settings="Rlm.Cli.Commands.ResultsCommand+Settings">
    <Description>List all stored results</Description>
    <Parameters>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--IMPORT-->
  <Command Name="import" IsBranch="false" 
ClrType="Rlm.Cli.Commands.ImportCommand" 
Settings="Rlm.Cli.Commands.ImportCommand+Settings">
    <Description>Bulk import results from files matching a pattern</Description>
    <Parameters>
      <Argument Name="pattern" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Glob pattern for result files (e.g., 
'results/*.txt')</Description>
      </Argument>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="import" />
      <Example commandLine="results/*.txt" />
    </Examples>
  </Command>
  <!--AGGREGATE-->
  <Command Name="aggregate" IsBranch="false" 
ClrType="Rlm.Cli.Commands.AggregateCommand" 
Settings="Rlm.Cli.Commands.AggregateCommand+Settings">
    <Description>Combine all stored results for final synthesis</Description>
    <Parameters>
      <Option Short="f" Long="final" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Wrap output with FINAL signal for completion 
detection</Description>
      </Option>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output in JSON format for machine parsing</Description>
      </Option>
      <Option Short="" Long="raw" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output raw content for piping/scripts.</Description>
      </Option>
      <Option Short="s" Long="separator" Value="SEPARATOR" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Separator between results (default: newline with 
dashes)</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CLEAR-->
  <Command Name="clear" IsBranch="false" ClrType="Rlm.Cli.Commands.ClearCommand"
Settings="Rlm.Cli.Commands.ClearCommand+Settings">
    <Description>Clear the session state</Description>
    <Parameters>
      <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Delete ALL RLM sessions found in the storage 
location.</Description>
      </Option>
      <Option Short="" Long="session" Value="ID" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Session identifier or path for state 
isolation.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>