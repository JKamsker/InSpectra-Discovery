  <!--CODE-->
  <Command Name="code" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--__DEFAULT_COMMAND-->
    <Command Name="__default_command" IsBranch="false" 
ClrType="Ivy.Console.Commands.Agent.CodeCommand" 
Settings="Ivy.Console.Commands.Agent.CodeCommand+AgentArgs">
      <Description>Build with Ivy Code</Description>
      <Parameters>
        <Argument Name="projectPath" Position="0" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Path to the project</Description>
        </Argument>
        <Option Short="" Long="approve-plans" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Auto-approve all plans presented in the TUI without 
prompting.</Description>
        </Option>
        <Option Short="" Long="exit-on-complete" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Close the TUI after the first prompt 
completes</Description>
        </Option>
        <Option Short="" Long="ignore-git" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip Git checks and commit</Description>
        </Option>
        <Option Short="p" Long="prompt" Value="PROMPT" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Prompt with instructions for the agent</Description>
        </Option>
        <Option Short="" Long="prompt-file" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to a file containing the prompt</Description>
        </Option>
        <Option Short="" Long="read-allow" Value="PATTERNS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Glob patterns for files allowed to be read 
(comma-separated)</Description>
        </Option>
        <Option Short="" Long="read-disallow" Value="PATTERNS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Glob patterns for files NOT allowed to be read 
(comma-separated)</Description>
        </Option>
        <Option Short="" Long="reasoning" Value="EFFORT" Required="false" 
Kind="scalar" 
ClrType="System.Nullable`1[[Ivy.Agent.Shared.Models.ReasoningEffort, 
Ivy.Agent.Shared, Version=1.0.79.0, Culture=neutral, PublicKeyToken=null]]">
          <Description>Reasoning effort (off, low, medium, high, max). Default: 
persona default</Description>
        </Option>
        <Option Short="" Long="timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Timeout in seconds (default: 600)</Description>
        </Option>
        <Option Short="" Long="tools-allow" Value="TOOLS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Tool names allowed to be used 
(comma-separated)</Description>
        </Option>
        <Option Short="" Long="tools-disallow" Value="TOOLS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Tool names NOT allowed to be used 
(comma-separated)</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable verbose logging</Description>
        </Option>
        <Option Short="" Long="write-allow" Value="PATTERNS" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Glob patterns for files allowed to be written 
(comma-separated)</Description>
        </Option>
        <Option Short="" Long="write-disallow" Value="PATTERNS" Required="false"
Kind="scalar" ClrType="System.String">
          <Description>Glob patterns for files NOT allowed to be written 
(comma-separated)</Description>
        </Option>
        <Option Short="" Long="yes-to-all" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Auto-approve all plans and select the first option for 
questions. Free text and secret questions are still asked.</Description>
        </Option>
      </Parameters>
    </Command>
