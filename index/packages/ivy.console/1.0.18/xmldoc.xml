<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="Ivy.Console.Init.InitCommand" 
Settings="Ivy.Console.Init.InitCommand+InitSettings">
    <Description>Create a new Ivy project.</Description>
    <Parameters>
      <Option Short="" Long="dangerous-clear" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Clear the current folder before creating the new 
project.</Description>
      </Option>
      <Option Short="" Long="dangerous-overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Clear the current folder before creating the new 
project.</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NAMESPACE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The namespace for the new Ivy project.</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--AUTH-->
  <Command Name="auth" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage auth providers</Description>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="Ivy.Console.Auth.AuthAddCommand" 
Settings="Ivy.Console.Auth.AuthAddCommand+Settings">
      <Description>Add a auth provider</Description>
      <Parameters>
        <Option Short="" Long="connection-string" Value="CONNECTION_STRING" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Auth provider specific options using a connection string 
syntax</Description>
        </Option>
        <Option Short="p" Long="provider" Value="PROVIDER" Required="false" 
Kind="scalar" 
ClrType="System.Nullable`1[[Ivy.Console.Auth.Providers.AuthProviders, 
Ivy.Console, Version=1.0.18.0, Culture=neutral, PublicKeyToken=null]]" />
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable verbose output</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--APP-->
  <Command Name="app" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Create or modify an Ivy app using the Ivy agent</Description>
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="Ivy.Console.App.AppCreateCommand" 
Settings="Ivy.Console.App.AppCreateCommand+AppCreateSettings">
      <Description>Create an new Ivy app using the Ivy agent</Description>
      <Parameters>
        <Option Short="" Long="connection" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="from-models" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Select models to create app from</Description>
        </Option>
        <Option Short="" Long="group" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="icon" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String" />
        <Option Short="" Long="model" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Model to create app from</Description>
        </Option>
        <Option Short="p" Long="prompt" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Prompt for the agent</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable verbose output</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--DEPLOY-->
  <Command Name="deploy" IsBranch="false" 
ClrType="Ivy.Console.Deploy.DeployCommand" 
Settings="Ivy.Console.Deploy.DeployCommand+Settings">
    <Description>Deploy Ivy project</Description>
    <Parameters>
      <Option Short="p" Long="project-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the project directory. Defaults to the current 
directory.</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DOCS-->
  <Command Name="docs" IsBranch="false" ClrType="Ivy.Console.DocsCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Open documentation</Description>
  </Command>
  <!--SAMPLES-->
  <Command Name="samples" IsBranch="false" ClrType="Ivy.Console.SamplesCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Open samples</Description>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" ClrType="Ivy.Console.VersionCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Show Ivy version</Description>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" ClrType="Ivy.Console.UpdateCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Update Ivy to the latest version</Description>
  </Command>
  <!--UPGRADE-->
  <Command Name="upgrade" IsBranch="false" ClrType="Ivy.Console.UpgradeCommand" 
Settings="Ivy.Console.UpgradeCommand+Settings">
    <Description>Upgrade Ivy project to the latest version</Description>
    <Parameters>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--FIX-->
  <Command Name="fix" IsBranch="false" ClrType="Ivy.Console.FixCommand" 
Settings="Ivy.Console.FixCommand+FixSettings">
    <Parameters>
      <Argument Name="projectPath" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the project to fix.</Description>
      </Argument>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable debug logging (same as --verbose)</Description>
      </Option>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Allow more than 30 iterations</Description>
      </Option>
      <Option Short="i" Long="iterations" Value="ITERATIONS" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of fix iterations (1-30, unless --force is 
specified)</Description>
      </Option>
      <Option Short="" Long="no-logging" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Disable all logging output (for clean spinner 
UI)</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable verbose logging (same as --debug)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CONNECT-->
  <Command Name="connect" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage Ivy connections</Description>
    <!--REMOVE-->
    <Command Name="remove" IsBranch="false" 
ClrType="Ivy.Console.Connect.ConnectRemoveCommand" 
Settings="Ivy.Console.Connect.ConnectRemoveCommand+ConnectRemoveSettings">
      <Description>List all Ivy connections</Description>
      <Parameters>
        <Option Short="n" Long="connection-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable verbose output</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Ivy.Console.Connect.ConnectListCommand" 
Settings="Ivy.Console.Connect.ConnectListCommand+ConnectListSettings">
      <Description>List all Ivy connections</Description>
      <Parameters>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable verbose output</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DB-->
    <Command Name="db" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Manage database connections</Description>
      <!--__DEFAULT_COMMAND-->
      <Command Name="__default_command" IsBranch="false" 
ClrType="Ivy.Console.Db.DbAddCommand" 
Settings="Ivy.Console.Db.DbAddCommand+DbAddSettings">
        <Description>Add a database provider to your Ivy project.</Description>
        <Parameters>
          <Option Short="" Long="connection-string" Value="CONNECTION_STRING" 
Required="false" Kind="scalar" ClrType="System.String" />
          <Option Short="n" Long="name" Value="CONNECTION_NAME" Required="false"
Kind="scalar" ClrType="System.String" />
          <Option Short="p" Long="provider" Value="PROVIDER" Required="false" 
Kind="scalar" 
ClrType="System.Nullable`1[[Ivy.Console.Db.Generators.DbContextGenerators, 
Ivy.Console, Version=1.0.18.0, Culture=neutral, PublicKeyToken=null]]" />
          <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Enable verbose output</Description>
          </Option>
        </Parameters>
      </Command>
      <!--ADD-->
      <Command Name="add" IsBranch="false" ClrType="Ivy.Console.Db.DbAddCommand"
Settings="Ivy.Console.Db.DbAddCommand+DbAddSettings">
        <Description>Add a database provider to your Ivy project.</Description>
        <Parameters>
          <Option Short="" Long="connection-string" Value="CONNECTION_STRING" 
Required="false" Kind="scalar" ClrType="System.String" />
          <Option Short="n" Long="name" Value="CONNECTION_NAME" Required="false"
Kind="scalar" ClrType="System.String" />
          <Option Short="p" Long="provider" Value="PROVIDER" Required="false" 
Kind="scalar" 
ClrType="System.Nullable`1[[Ivy.Console.Db.Generators.DbContextGenerators, 
Ivy.Console, Version=1.0.18.0, Culture=neutral, PublicKeyToken=null]]" />
          <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Enable verbose output</Description>
          </Option>
        </Parameters>
      </Command>
      <!--GENERATE-->
      <Command Name="generate" IsBranch="false" 
ClrType="Ivy.Console.Db.DbGenerateCommand" 
Settings="Ivy.Console.Db.DbGenerateCommand+DbGenerateSettings">
        <Description>Interactive tool to build database generators</Description>
      </Command>
    </Command>
  </Command>
</Model>