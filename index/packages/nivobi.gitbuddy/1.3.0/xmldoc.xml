<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.StatusCommand" 
Settings="GitBuddy.Commands.Git.StatusCommand+Settings">
    <Description>Check the current state of the repo.</Description>
  </Command>
  <!--SAVE-->
  <Command Name="save" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.SaveCommand" 
Settings="GitBuddy.Commands.Git.SaveCommand+Settings">
    <Description>Stage and commit all changes.</Description>
    <Parameters>
      <Option Short="a" Long="ai" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use AI to suggest a commit message.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SETUP-->
  <Command Name="setup" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.SetupCommand" 
Settings="GitBuddy.Commands.Git.SetupCommand+Settings">
    <Description>Initialize the repository for the first time.</Description>
  </Command>
  <!--SYNC-->
  <Command Name="sync" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.SyncCommand" 
Settings="GitBuddy.Commands.Git.SyncCommand+Settings">
    <Description>Pull latest changes and push your work.</Description>
  </Command>
  <!--BRANCH-->
  <Command Name="branch" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.BranchCommand" 
Settings="GitBuddy.Commands.Git.BranchCommand+Settings">
    <Description>Smart branch management (create, switch, list, 
clean).</Description>
    <Parameters>
      <Argument Name="action" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Action: create, switch, list, clean, delete, or 
rename</Description>
      </Argument>
      <Argument Name="name" Position="1" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Branch name (for create/delete) or old name (for 
rename)</Description>
      </Argument>
      <Argument Name="newname" Position="2" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>New branch name (for rename action)</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--MERGE-->
  <Command Name="merge" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.MergeCommand" 
Settings="GitBuddy.Commands.Git.MergeCommand+Settings">
    <Description>Merge branches with conflict detection and AI-powered 
messages.</Description>
    <Parameters>
      <Argument Name="branch" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Branch name - source in normal mode, target in --into 
mode</Description>
      </Argument>
      <Option Short="" Long="ai" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use AI to generate merge commit message</Description>
      </Option>
      <Option Short="" Long="into" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Reverse merge: merge current branch into target 
(interactive if branch not specified)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--STASH-->
  <Command Name="stash" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.StashCommand" 
Settings="GitBuddy.Commands.Git.StashCommand+Settings">
    <Description>Manage stashes (push, pop, apply, list).</Description>
    <Parameters>
      <Argument Name="action" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Action: push, pop, apply, list</Description>
      </Argument>
      <Argument Name="index" Position="1" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Stash index (e.g., 0 for stash@{0})</Description>
      </Argument>
      <Option Short="u" Long="include-untracked" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include untracked files (push action)</Description>
      </Option>
      <Option Short="m" Long="message" Value="MESSAGE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Message for new stash (push action)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UNDO-->
  <Command Name="undo" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.UndoCommand" 
Settings="GitBuddy.Commands.Git.UndoCommand+Settings">
    <Description>Go back in time (safely).</Description>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="false" 
ClrType="GitBuddy.Commands.Config.ConfigCommand" 
Settings="GitBuddy.Commands.Config.ConfigCommand+Settings">
    <Description>Setup your AI provider and keys.</Description>
  </Command>
  <!--DESCRIBE-->
  <Command Name="describe" IsBranch="false" 
ClrType="GitBuddy.Commands.Config.DescribeCommand" 
Settings="GitBuddy.Commands.Config.DescribeCommand+Settings">
    <Description>Analyze the project and update .buddycontext.</Description>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="GitBuddy.Commands.Utility.UpdateCommand" 
Settings="GitBuddy.Commands.Utility.UpdateCommand+Settings">
    <Description>Updates GitBuddy to the latest version from NuGet</Description>
  </Command>
  <!--CICD-->
  <Command Name="cicd" IsBranch="false" 
ClrType="GitBuddy.Commands.CICD.CiCdCommand" 
Settings="GitBuddy.Commands.CICD.CiCdCommand+Settings">
    <Description>Generate a CI/CD workflow for your project.</Description>
    <Parameters>
      <Option Short="n" Long="dry-run" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show what would be generated without writing 
files</Description>
      </Option>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Overwrite existing workflow file without 
prompting</Description>
      </Option>
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path (default: 
.github/workflows/ci.yml)</Description>
      </Option>
      <Option Short="t" Long="type" Value="TYPE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project type (dotnet, nodejs, python, go, docker, 
generic)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CICD-INIT-->
  <Command Name="cicd-init" IsBranch="false" 
ClrType="GitBuddy.Commands.CICD.CiCdInitCommand" 
Settings="GitBuddy.Commands.CICD.CiCdInitCommand+Settings">
    <Description>Interactive CI/CD setup wizard.</Description>
    <Parameters>
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
  <!--CICD-EXPORT-->
  <Command Name="cicd-export" IsBranch="false" 
ClrType="GitBuddy.Commands.CICD.CiCdExportCommand" 
Settings="GitBuddy.Commands.CICD.CiCdExportCommand+Settings">
    <Description>Export CI/CD templates for customization.</Description>
    <Parameters>
      <Argument Name="TYPE" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="a" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
  <!--RELEASE-->
  <Command Name="release" IsBranch="false" 
ClrType="GitBuddy.Commands.Git.ReleaseCommand" 
Settings="GitBuddy.Commands.Git.ReleaseCommand+Settings">
    <Description>Create a new release (manage version tags).</Description>
    <Parameters>
      <Argument Name="BUMP" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Version bump type: patch, minor, or major</Description>
      </Argument>
      <Option Short="n" Long="dry-run" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show what would happen without making changes</Description>
      </Option>
      <Option Short="m" Long="message" Value="MESSAGE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Custom tag message</Description>
      </Option>
      <Option Short="p" Long="push" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Push tag to remote immediately</Description>
      </Option>
    </Parameters>
  </Command>
</Model>