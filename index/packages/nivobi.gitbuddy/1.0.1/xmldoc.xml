<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" ClrType="GitBuddy.StatusCommand" 
Settings="GitBuddy.StatusCommand+Settings">
    <Description>Check the current state of the repo.</Description>
  </Command>
  <!--SAVE-->
  <Command Name="save" IsBranch="false" ClrType="GitBuddy.SaveCommand" 
Settings="GitBuddy.SaveCommand+Settings">
    <Description>Stage and commit all changes.</Description>
    <Parameters>
      <Option Short="a" Long="ai" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Use AI to suggest a commit message.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SETUP-->
  <Command Name="setup" IsBranch="false" ClrType="GitBuddy.SetupCommand" 
Settings="GitBuddy.SetupCommand+Settings">
    <Description>Initialize the repository for the first time.</Description>
  </Command>
  <!--SYNC-->
  <Command Name="sync" IsBranch="false" ClrType="GitBuddy.SyncCommand" 
Settings="GitBuddy.SyncCommand+Settings">
    <Description>Pull latest changes and push your work.</Description>
  </Command>
  <!--UNDO-->
  <Command Name="undo" IsBranch="false" ClrType="GitBuddy.UndoCommand" 
Settings="GitBuddy.UndoCommand+Settings">
    <Description>Go back in time (safely).</Description>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="false" ClrType="GitBuddy.ConfigCommand" 
Settings="GitBuddy.ConfigCommand+Settings">
    <Description>Setup your AI provider and keys.</Description>
  </Command>
  <!--DESCRIBE-->
  <Command Name="describe" IsBranch="false" ClrType="GitBuddy.DescribeCommand" 
Settings="GitBuddy.DescribeCommand+Settings">
    <Description>Analyze the project and update .buddycontext.</Description>
  </Command>
</Model>