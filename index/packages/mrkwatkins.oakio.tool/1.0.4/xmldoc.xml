<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INFO-->
  <Command Name="info" IsBranch="false" 
ClrType="MrKWatkins.OakIO.Tool.Info.InfoCommand" 
Settings="MrKWatkins.OakIO.Tool.Info.InfoSettings">
    <Description>Display information about a file.</Description>
    <Parameters>
      <Argument Name="input" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the input file.</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--CONVERT-->
  <Command Name="convert" IsBranch="false" 
ClrType="MrKWatkins.OakIO.Tool.Convert.ConvertCommand" 
Settings="MrKWatkins.OakIO.Tool.Convert.ConvertSettings">
    <Description>Convert a file from one format to another.</Description>
    <Parameters>
      <Argument Name="input" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the input file.</Description>
      </Argument>
      <Argument Name="output" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the output file.</Description>
      </Argument>
    </Parameters>
  </Command>
</Model>