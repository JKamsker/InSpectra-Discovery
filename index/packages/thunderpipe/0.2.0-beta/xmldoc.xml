<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VALIDATE-->
  <Command Name="validate" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--PACKAGE-->
    <Command Name="package" IsBranch="false" 
ClrType="ThunderPipe.Commands.Validate.PackageCommand" 
Settings="ThunderPipe.Settings.Validate.PackageSettings">
      <Description>Checks if the package meets the server's 
requirements</Description>
      <Parameters>
        <Argument Name="package-folder" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
          <Description>Folder containg the package's files</Description>
        </Argument>
        <Option Short="" Long="icon" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Path from the package folder to the icon 
file</Description>
        </Option>
        <Option Short="" Long="manifest" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path from the package folder to the manifest 
file</Description>
        </Option>
        <Option Short="" Long="readme" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path from the package folder to the README 
file</Description>
        </Option>
        <Option Short="" Long="repository" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Uri">
          <Description>URL of the server hosting the package</Description>
        </Option>
        <Option Short="" Long="team" Value="NULL" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Team that will publish the package</Description>
        </Option>
        <Option Short="" Long="token" Value="NULL" Required="true" Kind="scalar"
ClrType="System.String">
          <Description>Authentication token used to publish the 
package</Description>
        </Option>
      </Parameters>
    </Command>
    <!--COMMUNITY-->
    <Command Name="community" IsBranch="false" 
ClrType="ThunderPipe.Commands.Validate.CommunityCommand" 
Settings="ThunderPipe.Settings.Validate.CommunitySettings">
      <Description>Checks if a community slug exists</Description>
      <Parameters>
        <Argument Name="community" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Community where the package will be 
published</Description>
        </Argument>
        <Option Short="" Long="repository" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Uri">
          <Description>URL of the server hosting the package</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CATEGORIES-->
    <Command Name="categories" IsBranch="false" 
ClrType="ThunderPipe.Commands.Validate.CategoriesCommand" 
Settings="ThunderPipe.Settings.Validate.CategoriesSettings">
      <Description>Checks if every category slug exists</Description>
      <Parameters>
        <Argument Name="community" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Community where the package will be 
published</Description>
        </Argument>
        <Option Short="" Long="category" Value="CATEGORY" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Categories that will be used to label the 
package</Description>
        </Option>
        <Option Short="" Long="repository" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Uri">
          <Description>URL of the server hosting the package</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DEPENDENCIES-->
    <Command Name="dependencies" IsBranch="false" 
ClrType="ThunderPipe.Commands.Validate.DependenciesCommand" 
Settings="ThunderPipe.Settings.Validate.DependenciesSettings">
      <Description>Checks if every dependency exists</Description>
      <Parameters>
        <Argument Name="dependencies" Position="0" Required="true" Kind="vector"
ClrType="System.String[]">
          <Description>Dependencies needed by the package</Description>
        </Argument>
        <Option Short="" Long="repository" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Uri">
          <Description>URL of the server hosting the package</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CREATE-->
  <Command Name="create" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--MANIFEST-->
    <Command Name="manifest" IsBranch="false" 
ClrType="ThunderPipe.Commands.Create.ManifestCommand" 
Settings="ThunderPipe.Settings.Create.ManifestSettings">
      <Description>Creates a 'manifest.json' file</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Name of the package</Description>
        </Argument>
        <Argument Name="version" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Version of the package</Description>
        </Argument>
        <Option Short="" Long="dependency" Value="DEPENDENCY" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Dependencies needed by the package</Description>
        </Option>
        <Option Short="" Long="description" Value="DESCRIPTION" Required="false"
Kind="scalar" ClrType="System.String">
          <Description>Description of the package</Description>
        </Option>
        <Option Short="" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Directory from which the relative paths 
begin</Description>
        </Option>
        <Option Short="" Long="website" Value="WEBSITE" Required="false" 
Kind="scalar" ClrType="System.Uri">
          <Description>URL of the package's website</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--PUBLISH-->
  <Command Name="publish" IsBranch="false" 
ClrType="ThunderPipe.Commands.Publish.Command" 
Settings="ThunderPipe.Settings.Publish.Settings">
    <Description>Publish a package to Thunderstore.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the package file to publish</Description>
      </Argument>
      <Argument Name="team" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Team to publish the package for</Description>
      </Argument>
      <Argument Name="community" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Community where to publish the package</Description>
      </Argument>
      <Option Short="" Long="category" Value="CATEGORY" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Categories used to label this package</Description>
      </Option>
      <Option Short="" Long="has-nsfw,nsfw" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Determines if this package has NSFW content</Description>
      </Option>
      <Option Short="" Long="repository" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Uri">
        <Description>URL of the server hosting the package</Description>
      </Option>
      <Option Short="" Long="token" Value="NULL" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Authentication token used to publish the 
package</Description>
      </Option>
    </Parameters>
  </Command>
</Model>