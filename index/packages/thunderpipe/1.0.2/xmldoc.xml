<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VALIDATE-->
  <Command Name="validate" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Check that values and package files meet Thunderstore's 
requirements</Description>
    <!--PACKAGE-->
    <Command Name="package" IsBranch="false" 
ClrType="ThunderPipe.Commands.Validate.PackageCommand" 
Settings="ThunderPipe.Settings.Validate.PackageSettings">
      <Description>Check that a package and its metadata are valid before 
publishing</Description>
      <Parameters>
        <Argument Name="package-folder" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the folder containing the package 
files</Description>
        </Argument>
        <Argument Name="team" Position="1" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.Team">
          <Description>Team that will publish the package</Description>
        </Argument>
        <Option Short="" Long="host" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Uri">
          <Description>URL of the Thunderstore server to validate 
against</Description>
        </Option>
        <Option Short="" Long="icon-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Relative path to the package icon</Description>
        </Option>
        <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.Extensions.Logging.LogLevel">
          <Description>Minimum level of messages to display</Description>
        </Option>
        <Option Short="" Long="manifest-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Relative path to the manifest file</Description>
        </Option>
        <Option Short="" Long="readme-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Relative path to the README file</Description>
        </Option>
        <Option Short="" Long="token" Value="NULL" Required="true" Kind="scalar"
ClrType="System.String">
          <Description>Service account API token for 
authentication</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="validate" />
        <Example commandLine="package" />
        <Example commandLine="./my-mod" />
        <Example commandLine="MyTeam" />
        <Example commandLine="--token" />
        <Example commandLine="$THUNDERSTORE_TOKEN" />
      </Examples>
    </Command>
    <!--COMMUNITY-->
    <Command Name="community" IsBranch="false" 
ClrType="ThunderPipe.Commands.Validate.CommunityCommand" 
Settings="ThunderPipe.Settings.Validate.CommunitySettings">
      <Description>Check that a community slug corresponds to an existing 
community on Thunderstore</Description>
      <Parameters>
        <Argument Name="community" Position="0" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.Community">
          <Description>Slug of the community to validate</Description>
        </Argument>
        <Option Short="" Long="host" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Uri">
          <Description>URL of the Thunderstore server to validate 
against</Description>
        </Option>
        <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.Extensions.Logging.LogLevel">
          <Description>Minimum level of messages to display</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="validate" />
        <Example commandLine="community" />
        <Example commandLine="risk-of-rain2" />
        <Example commandLine="validate" />
        <Example commandLine="community" />
        <Example commandLine="lethal-company" />
      </Examples>
    </Command>
    <!--CATEGORIES-->
    <Command Name="categories" IsBranch="false" 
ClrType="ThunderPipe.Commands.Validate.CategoriesCommand" 
Settings="ThunderPipe.Settings.Validate.CategoriesSettings">
      <Description>Check that all category slugs exist within a given 
community</Description>
      <Parameters>
        <Argument Name="community" Position="0" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.Community">
          <Description>Slug of the community to validate categories 
against</Description>
        </Argument>
        <Argument Name="categories" Position="1" Required="true" Kind="vector" 
ClrType="ThunderPipe.Core.Models.API.Category[]">
          <Description>Slugs of the categories to validate</Description>
        </Argument>
        <Option Short="" Long="host" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Uri">
          <Description>URL of the Thunderstore server to validate 
against</Description>
        </Option>
        <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.Extensions.Logging.LogLevel">
          <Description>Minimum level of messages to display</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="validate" />
        <Example commandLine="categories" />
        <Example commandLine="risk-of-rain2" />
        <Example commandLine="tools" />
        <Example commandLine="validate" />
        <Example commandLine="categories" />
        <Example commandLine="risk-of-rain2" />
        <Example commandLine="tools" />
        <Example commandLine="mods" />
      </Examples>
    </Command>
    <!--DEPENDENCIES-->
    <Command Name="dependencies" IsBranch="false" 
ClrType="ThunderPipe.Commands.Validate.DependenciesCommand" 
Settings="ThunderPipe.Settings.Validate.DependenciesSettings">
      <Description>Check that all dependency strings resolve to existing 
packages on Thunderstore</Description>
      <Parameters>
        <Argument Name="dependencies" Position="0" Required="true" Kind="vector"
ClrType="ThunderPipe.Core.Models.API.PackageDependency[]">
          <Description>Dependency strings to validate</Description>
        </Argument>
        <Option Short="" Long="host" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Uri">
          <Description>URL of the Thunderstore server to validate 
against</Description>
        </Option>
        <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.Extensions.Logging.LogLevel">
          <Description>Minimum level of messages to display</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="validate" />
        <Example commandLine="dependencies" />
        <Example commandLine="AuthorName-PackageName-1.0.0" />
        <Example commandLine="validate" />
        <Example commandLine="dependencies" />
        <Example commandLine="AuthorName-PackageName-1.0.0" />
        <Example commandLine="OtherAuthor-OtherPackage-2.1.0" />
      </Examples>
    </Command>
  </Command>
  <!--CREATE-->
  <Command Name="create" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Generate files required by Thunderstore packages</Description>
    <!--MANIFEST-->
    <Command Name="manifest" IsBranch="false" 
ClrType="ThunderPipe.Commands.Create.ManifestCommand" 
Settings="ThunderPipe.Settings.Create.ManifestSettings">
      <Description>Generate a manifest.json file with the required package 
metadata</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.PackageName">
          <Description>Name of the package</Description>
        </Argument>
        <Argument Name="version" Position="1" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.PackageVersion">
          <Description>Version of the package</Description>
        </Argument>
        <Option Short="" Long="dependency" Value="DEPENDENCY" Required="false" 
Kind="vector" ClrType="ThunderPipe.Core.Models.API.PackageDependency[]">
          <Description>Dependency string for a required package</Description>
        </Option>
        <Option Short="" Long="description" Value="DESCRIPTION" Required="false"
Kind="scalar" ClrType="System.String">
          <Description>Short description of the package</Description>
        </Option>
        <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.Extensions.Logging.LogLevel">
          <Description>Minimum level of messages to display</Description>
        </Option>
        <Option Short="" Long="output-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Directory used to resolve output file paths</Description>
        </Option>
        <Option Short="" Long="website" Value="WEBSITE" Required="false" 
Kind="scalar" ClrType="System.Uri">
          <Description>URL of the package's homepage or source 
repository</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="create" />
        <Example commandLine="manifest" />
        <Example commandLine="MyMod" />
        <Example commandLine="1.0.0" />
        <Example commandLine="create" />
        <Example commandLine="manifest" />
        <Example commandLine="MyMod" />
        <Example commandLine="2.0.0" />
        <Example commandLine="--description" />
        <Example commandLine="&quot;A great mod&quot;" />
        <Example commandLine="--website" />
        <Example commandLine="https://thunderstore.io/" />
        <Example commandLine="create" />
        <Example commandLine="manifest" />
        <Example commandLine="MyMod" />
        <Example commandLine="1.3.0" />
        <Example commandLine="--dependency" />
        <Example commandLine="AuthorName-PackageName-1.0.0" />
        <Example commandLine="--dependency" />
        <Example commandLine="OtherAuthor-OtherPackage-2.1.0" />
      </Examples>
    </Command>
  </Command>
  <!--FETCH-->
  <Command Name="fetch" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Retrieve information about packages from 
Thunderstore</Description>
    <!--VERSION-->
    <Command Name="version" IsBranch="false" 
ClrType="ThunderPipe.Commands.Fetch.LatestVersionCommand" 
Settings="ThunderPipe.Settings.Fetch.LatestVersionSettings">
      <Description>Print the latest published version number of a 
package</Description>
      <Parameters>
        <Argument Name="team" Position="0" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.Team">
          <Description>Team that owns the package</Description>
        </Argument>
        <Argument Name="name" Position="1" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.PackageName">
          <Description>Name of the package</Description>
        </Argument>
        <Option Short="" Long="host" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Uri">
          <Description>URL of the Thunderstore server</Description>
        </Option>
        <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.Extensions.Logging.LogLevel">
          <Description>Minimum level of messages to display</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="fetch" />
        <Example commandLine="version" />
        <Example commandLine="MyTeam" />
        <Example commandLine="MyMod" />
      </Examples>
    </Command>
  </Command>
  <!--PUBLISH-->
  <Command Name="publish" IsBranch="false" 
ClrType="ThunderPipe.Commands.Publish.PackageCommand" 
Settings="ThunderPipe.Settings.Publish.PackageSettings">
    <Description>Upload a zipped package to Thunderstore.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the '.zip' file to publish</Description>
      </Argument>
      <Argument Name="team" Position="1" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.Team">
        <Description>Team that will own the published package</Description>
      </Argument>
      <Argument Name="community" Position="2" Required="true" Kind="scalar" 
ClrType="ThunderPipe.Core.Models.API.Community">
        <Description>Slug of the community to publish the package 
to</Description>
      </Argument>
      <Option Short="" Long="category" Value="CATEGORY" Required="false" 
Kind="vector" ClrType="ThunderPipe.Core.Models.API.Category[]">
        <Description>Category slug to label the package with</Description>
      </Option>
      <Option Short="" Long="has-nsfw,nsfw" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Mark the package as containing NSFW content</Description>
      </Option>
      <Option Short="" Long="host" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Uri">
        <Description>URL of the Thunderstore server to publish to</Description>
      </Option>
      <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Microsoft.Extensions.Logging.LogLevel">
        <Description>Minimum level of messages to display</Description>
      </Option>
      <Option Short="" Long="token" Value="NULL" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Service account API token for authentication</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="publish" />
      <Example commandLine="my-mod.zip" />
      <Example commandLine="MyTeam" />
      <Example commandLine="risk-of-rain2" />
      <Example commandLine="--token" />
      <Example commandLine="$THUNDERSTORE_TOKEN" />
      <Example commandLine="publish" />
      <Example commandLine="my-mod.zip" />
      <Example commandLine="MyTeam" />
      <Example commandLine="lethal-company" />
      <Example commandLine="--token" />
      <Example commandLine="$THUNDERSTORE_TOKEN" />
      <Example commandLine="--category" />
      <Example commandLine="moons" />
      <Example commandLine="--has-nsfw" />
    </Examples>
  </Command>
</Model>