<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--IMPORT-->
  <Command Name="import" IsBranch="false" ClrType="Soddi.ImportHandler" 
Settings="Soddi.ImportOptions">
    <Description>Import a Stack Overflow archive</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>File or folder containing xml archives. The file must be a 
.7z file. If using a folder it can contain either .7z or .xml 
content</Description>
      </Argument>
      <Option Short="" Long="blockSize" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Advanced. Block size used for concurrent read/write of 7z 
archives.</Description>
      </Option>
      <Option Short="c" Long="connectionString" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Connection string to server. Initial catalog will be 
ignored and the database parameter will be used for the database 
name.</Description>
      </Option>
      <Option Short="d" Long="database" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of database. If omitted the name of the file or folder
will be used.</Description>
      </Option>
      <Option Short="" Long="dropAndCreate" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Drop and recreate database. If a database already exists 
with this name it will be dropped. Then a database will be created in the 
default server file location with the default server options.</Description>
      </Option>
      <Option Short="l" Long="logLevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="Soddi.LogLevel">
        <Description>Minimum level for logging</Description>
      </Option>
      <Option Short="" Long="provider" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Database provider to use (sqlserver, postgres, cosmos). 
Default: sqlserver</Description>
      </Option>
      <Option Short="" Long="sequential" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Advanced. Force sequential import of files from the same 7z
archive.</Description>
      </Option>
      <Option Short="" Long="skipConstraints" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip adding primary keys and unique 
constraints.</Description>
      </Option>
      <Option Short="" Long="skipTags" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Skip adding PostTags table.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="import" />
      <Example commandLine="iota" />
      <Example commandLine="import" />
      <Example commandLine="iota.stackexchange.co.7z" />
      <Example commandLine="--dropAndCreate" />
      <Example commandLine="import" />
      <Example commandLine="/data/iota.stackexchange.co/" />
      <Example commandLine="--skipTags" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" ClrType="Soddi.ListHandler" 
Settings="Soddi.ListOptions">
    <Description>List available Stack Overflow archives</Description>
    <Parameters>
      <Argument Name="PATTERN" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Pattern to include (e.g. "av" includes all archives 
containing "av").</Description>
      </Argument>
      <Option Short="" Long="includeMeta" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include meta databases.</Description>
      </Option>
      <Option Short="l" Long="logLevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="Soddi.LogLevel">
        <Description>Minimum level for logging</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list" />
      <Example commandLine="list" />
      <Example commandLine="spa" />
    </Examples>
  </Command>
  <!--DOWNLOAD-->
  <Command Name="download" IsBranch="false" ClrType="Soddi.DownloadHandler" 
Settings="Soddi.DownloadOptions">
    <Description>Download a Stack Overflow archive</Description>
    <Parameters>
      <Argument Name="ARCHIVE_NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Archive to download</Description>
      </Argument>
      <Option Short="l" Long="logLevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="Soddi.LogLevel">
        <Description>Minimum level for logging</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output folder</Description>
      </Option>
      <Option Short="p" Long="pick" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Pick from a list of archives to download</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="download" />
      <Example commandLine="iota" />
      <Example commandLine="download" />
      <Example commandLine="iota" />
      <Example commandLine="-o" />
      <Example commandLine="&quot;/data/&quot;" />
      <Example commandLine="download" />
      <Example commandLine="spa" />
      <Example commandLine="-p" />
    </Examples>
  </Command>
  <!--TORRENT-->
  <Command Name="torrent" IsBranch="false" ClrType="Soddi.TorrentHandler" 
Settings="Soddi.TorrentOptions">
    <Description>Download Stack Overflow archive via BitTorrent</Description>
    <Parameters>
      <Argument Name="ARCHIVE_NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Archive to download</Description>
      </Argument>
      <Option Short="l" Long="logLevel" Value="NULL" Required="false" 
Kind="scalar" ClrType="Soddi.LogLevel">
        <Description>Minimum level for logging</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output folder</Description>
      </Option>
      <Option Short="p" Long="pick" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Pick from a list of archives to download</Description>
      </Option>
      <Option Short="f" Long="portForward" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>[red]Experimental[/]. Enable port forwarding</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="torrent" />
      <Example commandLine="iota" />
      <Example commandLine="torrent" />
      <Example commandLine="iota" />
      <Example commandLine="-o" />
      <Example commandLine="/data/" />
      <Example commandLine="torrent" />
      <Example commandLine="spa" />
      <Example commandLine="-p" />
      <Example commandLine="-f" />
    </Examples>
  </Command>
</Model>