          "recursive": false,
          "hidden": false
        },
        {
          "name": "--dropAndCreate",
          "required": false,
          "description": "Drop and recreate database. If a database already \nexists with this name it will be dropped. Then a database will be created in the\ndefault server file location with the default server options.",
          "recursive": false,
          "hidden": false
        },
