      "arguments": [
        {
          "name": "PATH",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "File or folder containing xml archives. The file must \nbe a .7z file. If using a folder it can contain either .7z or .xml content",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
