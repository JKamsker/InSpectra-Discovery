<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="DotAdr.Commands.Init.InitAdrCommand" 
Settings="DotAdr.Commands.Init.InitAdrSettings">
    <Description>Initialize the ADR directory.</Description>
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable debug logging for troubleshooting</Description>
      </Option>
      <Option Short="d" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The directory to initialize.</Description>
      </Option>
      <Option Short="" Long="logfile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The file to send the log output to.</Description>
      </Option>
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Whether to overwrite existing files.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="init" />
      <Example commandLine="init" />
      <Example commandLine="-d" />
      <Example commandLine="./doc/arch/adr" />
      <Example commandLine="-o" />
      <Example commandLine="true" />
      <Example commandLine="init" />
      <Example commandLine="--debug" />
      <Example commandLine="true" />
      <Example commandLine="--logfile" />
      <Example commandLine="log.txt" />
    </Examples>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="DotAdr.Commands.Add.AddAdrCommand" 
Settings="DotAdr.Commands.Add.AddAdrSettings">
    <Description>Add a new decision record.</Description>
    <Parameters>
      <Argument Name="title" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The title of the new decision record.</Description>
      </Argument>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable debug logging for troubleshooting</Description>
      </Option>
      <Option Short="" Long="logfile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The file to send the log output to.</Description>
      </Option>
      <Option Short="s" Long="supersedes" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The ID of the decision record this decision record 
supersedes.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="add" />
      <Example commandLine="&quot;Implement Circuit Breaker Pattern for External
Service Calls&quot;" />
      <Example commandLine="add" />
      <Example commandLine="&quot;Separate Read and Write Data Models&quot;" />
      <Example commandLine="-s" />
      <Example commandLine="002" />
      <Example commandLine="add" />
      <Example commandLine="&quot;Use Database Per Service Pattern&quot;" />
      <Example commandLine="--debug" />
      <Example commandLine="true" />
      <Example commandLine="--logfile" />
      <Example commandLine="log.txt" />
      <Example commandLine="new" />
      <Example commandLine="&quot;Implement Request Rate Limiting&quot;" />
    </Examples>
  </Command>
</Model>