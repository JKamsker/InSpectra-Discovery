  "options": [
    {
      "name": "--resource-type",
      "recursive": false,
      "hidden": false,
      "description": "Azure Resource Type\nAzure Resource Type SHOULD be one of the types in the\nMicrosoft list of Azure resource type abbreviations\n(https://tinyurl.com/az-abbr).\nIf the azure type is not in the list, you should make\nup your own abbreviation that doesn't conflict with\nany of the official ones.",
      "aliases": [
        "-r"
      ],
      "arguments": [
        {
          "name": "RESOURCETYPE",
          "required": false,
          "arity": {
            "minimum": 0,
            "maximum": 1
          },
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ]
    },
    {
      "name": "--project-name",
      "recursive": false,
      "hidden": false,
      "description": "Project Name\nYou MUST include a project that MAY be the application\nname.\nYou SHOULD find a short name for your project or\napplication that is easy to understand without\nspecific domain knowledge.\nYou SHOULD NOT include redundant information in your\nname, i.e. the name of your company.\nYou SHOULD NOT use abbreviations in your name.",
      "aliases": [
        "-p"
      ],
      "arguments": [
        {
          "name": "PROJECTNAME",
          "required": false,
          "arity": {
            "minimum": 0,
            "maximum": 1
          },
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ]
    },
    {
      "name": "--component-name",
      "recursive": false,
      "hidden": false,
      "description": "Component Name\nYou SHOULD include a component name if your project or\napplication consists of several components. Examples\nof components are web, api, service.\nYou SHOULD NOT use resource type as component name,\ni.e. database, function, insights, vm.\nYou MAY omit the component name if the project name is\nsufficient.",
      "aliases": [
        "-c"
      ],
      "arguments": [
        {
          "name": "COMPONENTNAME",
          "required": false,
          "arity": {
            "minimum": 0,
            "maximum": 1
          },
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ]
    },
    {
      "name": "--environment",
      "recursive": false,
      "hidden": false,
      "description": "Environment\nYou MUST use the correct environment specifier for\nyour environment.\nSpecifier:\tEnvironment:\ndev\t\tDevelopment\ntest\t\tTest\nstage\t\tStaging\nprod\t\tProduction\nYou MAY add custom environment specifiers to your\nnaming convention.",
      "aliases": [
        "-e"
      ],
