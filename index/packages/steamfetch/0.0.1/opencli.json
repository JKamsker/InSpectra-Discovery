{
  "opencli": "0.1-draft",
  "info": {
    "title": "steam_fetch",
    "version": "0.0.1"
  },
  "commands": [
    {
      "name": "available",
      "options": [
        {
          "name": "--filter-type",
          "arguments": [
            {
              "name": "TYPE",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Optional filter by artwork type (e.g.,\nlibrary_capsule, library_hero)",
          "recursive": false,
          "hidden": false
        }
      ],
      "arguments": [
        {
          "name": "appid",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Steam App ID of the game.",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.UInt32"
            }
          ]
        }
      ],
      "description": "List available artworks (types, variants, languages) for \nan app",
      "hidden": false,
      "examples": [
        "available 570",
        "available 570 --filter-type library_capsule"
      ]
    },
    {
      "name": "batch",
      "options": [
        {
          "name": "--delimiter",
          "arguments": [
            {
              "name": "CHAR",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.Char"
                }
              ]
            }
          ],
          "description": "CSV delimiter character (default: ,)",
          "recursive": false,
          "hidden": false
        }
      ],
      "arguments": [
        {
          "name": "csv",
          "required": false,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Path to CSV file. If omitted, reads CSV from stdin.",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "Process a CSV of appids and artwork specs, downloading \neach",
      "hidden": false,
      "examples": [
        "batch apps.csv"
      ]
    },
    {
      "name": "single",
      "options": [
        {
          "name": "--output",
          "aliases": [
            "-o"
          ],
          "arguments": [
            {
              "name": "OUTPUT",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Output file path or directory. If omitted, the URL is\nprinted.",
          "recursive": false,
          "hidden": false
        }
      ],
      "arguments": [
        {
          "name": "appid",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Steam App ID of the game.",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.UInt32"
            }
          ]
        },
        {
          "name": "type",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Artwork type (e.g., library_capsule, library_hero, \nlibrary_logo, library_header)",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        },
        {
          "name": "variant",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Artwork variant (e.g., image, image2x)",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        },
        {
          "name": "language",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          },
          "description": "Language key (e.g., english, schinese, tchinese)",
          "hidden": false,
          "metadata": [
            {
              "name": "ClrType",
              "value": "System.String"
            }
          ]
        }
      ],
      "description": "Fetch a single app artwork (library capsule)",
      "hidden": false,
      "examples": [
        "single 570 library_capsule image2x english -o out/"
      ]
    }
  ],
  "x-inspectra": {
    "artifactSource": "tool-output"
  }
}
