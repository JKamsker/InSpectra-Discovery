<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--BATCH-->
  <Command Name="batch" IsBranch="false" ClrType="BatchCommand" 
Settings="BatchCommand+Settings">
    <Description>Process a CSV of appids and artwork specs, downloading 
each</Description>
    <Parameters>
      <Argument Name="csv" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to CSV file. If omitted, reads CSV from 
stdin.</Description>
      </Argument>
      <Option Short="" Long="delimiter" Value="CHAR" Required="false" 
Kind="scalar" ClrType="System.Char">
        <Description>CSV delimiter character (default: ,)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="batch" />
      <Example commandLine="apps.csv" />
    </Examples>
  </Command>
  <!--SINGLE-->
  <Command Name="single" IsBranch="false" ClrType="SingleCommand" 
Settings="SingleCommand+Settings">
    <Description>Fetch a single app artwork (library capsule)</Description>
    <Parameters>
      <Argument Name="appid" Position="0" Required="true" Kind="scalar" 
ClrType="System.UInt32">
        <Description>Steam App ID of the game.</Description>
      </Argument>
      <Argument Name="type" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Artwork type (e.g., library_capsule, library_hero, 
library_logo, library_header)</Description>
      </Argument>
      <Argument Name="variant" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Artwork variant (e.g., image, image2x)</Description>
      </Argument>
      <Argument Name="language" Position="3" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Language key (e.g., english, schinese, 
tchinese)</Description>
      </Argument>
      <Option Short="o" Long="output" Value="OUTPUT" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path or directory. If omitted, the URL is 
printed.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="single" />
      <Example commandLine="570" />
      <Example commandLine="library_capsule" />
      <Example commandLine="image2x" />
      <Example commandLine="english" />
      <Example commandLine="-o" />
      <Example commandLine="out/" />
    </Examples>
  </Command>
  <!--AVAILABLE-->
  <Command Name="available" IsBranch="false" ClrType="AvailableCommand" 
Settings="AvailableCommand+Settings">
    <Description>List available artworks (types, variants, languages) for an 
app</Description>
    <Parameters>
      <Argument Name="appid" Position="0" Required="true" Kind="scalar" 
ClrType="System.UInt32">
        <Description>Steam App ID of the game.</Description>
      </Argument>
      <Option Short="" Long="filter-type" Value="TYPE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional filter by artwork type (e.g., library_capsule, 
library_hero)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="available" />
      <Example commandLine="570" />
      <Example commandLine="available" />
      <Example commandLine="570" />
      <Example commandLine="--filter-type" />
      <Example commandLine="library_capsule" />
    </Examples>
  </Command>
</Model>