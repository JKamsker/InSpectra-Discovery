<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INVENTORY-->
  <Command Name="inventory" IsBranch="false" 
ClrType="ARI.Commands.InventoryCommand" 
Settings="ARI.Commands.Settings.InventorySettings">
    <Parameters>
      <Argument Name="tenantId" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Azure Tenant Id</Description>
        <Validators>
          <Validator ClrType="ARI.Commands.Validation.ValidateStringAttribute" 
Message="NULL" />
        </Validators>
      </Argument>
      <Argument Name="outputpath" Position="1" Required="true" Kind="scalar" 
ClrType="Cake.Core.IO.DirectoryPath">
        <Description>Output path</Description>
        <Validators>
          <Validator ClrType="ARI.Commands.Validation.ValidatePathAttribute" 
Message="NULL" />
        </Validators>
      </Argument>
      <Option Short="" Long="allowed-site-properties" Value="NULL" 
Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.ICollection`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Web Site properties allowed to be documented</Description>
      </Option>
      <Option Short="" Long="allowed-site-setting-value-keys" Value="NULL" 
Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.ICollection`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Web Site setting keys where values are allowed to be 
documented</Description>
      </Option>
      <Option Short="" Long="allowed-site-setting-values" Value="NULL" 
Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.ICollection`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Web Site setting values allowed to be 
documented</Description>
      </Option>
      <Option Short="" Long="include-site-application-settings" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Flag for if app setting keys should be documented (requires
at least Website Contributor role)</Description>
      </Option>
      <Option Short="" Long="markdown-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Markdown file prefix (default "index")</Description>
      </Option>
      <Option Short="" Long="run-in-parallel" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Flag for if generation should be parallized.</Description>
      </Option>
      <Option Short="" Long="skip-frontmatter" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Skip frontmatter generation</Description>
      </Option>
      <Option Short="" Long="skip-frontmatter-modifed" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Exclude modfied from frontmatter</Description>
      </Option>
      <Option Short="" Long="skip-frontmatter-order" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Exclude order from frontmatter</Description>
      </Option>
      <Option Short="" Long="skip-frontmatter-summary" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Exclude summary from frontmatter</Description>
      </Option>
      <Option Short="" Long="skip-tenant-overview" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
        <Description>Skip tenant information in overview</Description>
      </Option>
    </Parameters>
  </Command>
</Model>