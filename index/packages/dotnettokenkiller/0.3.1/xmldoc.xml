  <!--CONFIG-->
  <Command Name="config" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>View or modify dtk configuration</Description>
    <!--SHOW-->
    <Command Name="show" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.ConfigShowCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
