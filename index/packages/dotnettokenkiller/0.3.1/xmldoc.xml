    <!--SET-->
    <Command Name="set" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.ConfigSetCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.ConfigSetCommandSettings">
      <Description>Set a configuration value</Description>
      <Parameters>
        <Argument Name="key" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Configuration key in dot-notation (e.g. 
tracking.enabled)</Description>
        </Argument>
        <Argument Name="value" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>New value to assign (use empty string to reset to 
default)</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="config" />
        <Example commandLine="set" />
        <Example commandLine="tracking.enabled" />
        <Example commandLine="false" />
        <Example commandLine="config" />
        <Example commandLine="set" />
        <Example commandLine="display.width" />
        <Example commandLine="100" />
        <Example commandLine="config" />
        <Example commandLine="set" />
        <Example commandLine="tee.mode" />
        <Example commandLine="Always" />
