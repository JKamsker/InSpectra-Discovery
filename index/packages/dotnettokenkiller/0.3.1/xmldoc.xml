<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DOTNET-->
  <Command Name="dotnet" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Run dotnet commands with filtered output</Description>
    <!--BUILD-->
    <Command Name="build" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.DotnetBuildCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.DotnetCommandSettings">
      <Description>Run dotnet build with filtered output</Description>
      <Parameters>
        <Argument Name="args" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
          <Description>Arguments to forward to the underlying dotnet 
process</Description>
        </Argument>
        <Option Short="q" Long="quiet" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Suppress all DTK meta-output; forward only the filtered 
content</Description>
        </Option>
        <Option Short="" Long="show-log" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Print the path to the full log file when the output was 
saved</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="vector" ClrType="System.Boolean[]">
          <Description>Increase verbosity (use -v for level 1, -v -v for level 
2)</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="dotnet" />
        <Example commandLine="build" />
        <Example commandLine="MyApp.slnx" />
        <Example commandLine="dotnet" />
        <Example commandLine="build" />
        <Example commandLine="src/MyApp.csproj" />
        <Example commandLine="--no-restore" />
      </Examples>
    </Command>
