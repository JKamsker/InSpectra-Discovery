  <!--GAIN-->
  <Command Name="gain" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.GainCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.GainCommandSettings">
    <Description>Show token savings analytics</Description>
    <Parameters>
      <Option Short="" Long="command" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter results to a specific command (e.g. build, test, 
restore, clean)</Description>
      </Option>
      <Option Short="" Long="days" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of days of history to include (default: 
30)</Description>
      </Option>
      <Option Short="" Long="export" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Export raw tracking records in the given format 
(csv)</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output raw JSON instead of table</Description>
      </Option>
      <Option Short="" Long="project" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Filter by current project directory</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="gain" />
      <Example commandLine="gain" />
      <Example commandLine="--days" />
      <Example commandLine="7" />
      <Example commandLine="gain" />
      <Example commandLine="--project" />
      <Example commandLine="gain" />
      <Example commandLine="--json" />
    </Examples>
  </Command>
