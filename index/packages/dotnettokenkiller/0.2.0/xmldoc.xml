<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DOTNET-->
  <Command Name="dotnet" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Run dotnet commands with filtered output</Description>
    <!--BUILD-->
    <Command Name="build" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.DotnetBuildCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.DotnetCommandSettings">
      <Description>Run dotnet build with filtered output</Description>
      <Parameters>
        <Argument Name="args" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
          <Description>Arguments to forward to the underlying dotnet 
process</Description>
        </Argument>
        <Option Short="" Long="show-log" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Print the path to the full log file when the output was 
saved</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="vector" ClrType="System.Boolean[]">
          <Description>Increase verbosity (use -v for level 1, -v -v for level 
2)</Description>
        </Option>
      </Parameters>
    </Command>
    <!--TEST-->
    <Command Name="test" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.DotnetTestCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.DotnetCommandSettings">
      <Description>Run dotnet test with filtered output</Description>
      <Parameters>
        <Argument Name="args" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
          <Description>Arguments to forward to the underlying dotnet 
process</Description>
        </Argument>
        <Option Short="" Long="show-log" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Print the path to the full log file when the output was 
saved</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="vector" ClrType="System.Boolean[]">
          <Description>Increase verbosity (use -v for level 1, -v -v for level 
2)</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESTORE-->
    <Command Name="restore" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.DotnetRestoreCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.DotnetCommandSettings">
      <Description>Run dotnet restore with filtered output</Description>
      <Parameters>
        <Argument Name="args" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
          <Description>Arguments to forward to the underlying dotnet 
process</Description>
        </Argument>
        <Option Short="" Long="show-log" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Print the path to the full log file when the output was 
saved</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="vector" ClrType="System.Boolean[]">
          <Description>Increase verbosity (use -v for level 1, -v -v for level 
2)</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CLEAN-->
    <Command Name="clean" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.DotnetCleanCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.DotnetCommandSettings">
      <Description>Run dotnet clean with filtered output</Description>
      <Parameters>
        <Argument Name="args" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
          <Description>Arguments to forward to the underlying dotnet 
process</Description>
        </Argument>
        <Option Short="" Long="show-log" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Print the path to the full log file when the output was 
saved</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="vector" ClrType="System.Boolean[]">
          <Description>Increase verbosity (use -v for level 1, -v -v for level 
2)</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--INTEGRATE-->
  <Command Name="integrate" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Install dtk integration artifacts for an AI assistant 
provider</Description>
    <!--CLAUDE-->
    <Command Name="claude" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.ClaudeIntegrateCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.IntegrateCommandSettings">
      <Description>Install dtk skill and hook for Claude Code</Description>
      <Parameters>
        <Option Short="d" Long="dir" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Target project root directory (default: current 
directory)</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Overwrite existing files instead of skipping 
them</Description>
        </Option>
      </Parameters>
    </Command>
    <!--COPILOT-->
    <Command Name="copilot" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.CopilotIntegrateCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.IntegrateCommandSettings">
      <Description>Install dtk instructions for GitHub Copilot</Description>
      <Parameters>
        <Option Short="d" Long="dir" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Target project root directory (default: current 
directory)</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Overwrite existing files instead of skipping 
them</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--GAIN-->
  <Command Name="gain" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.GainCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.GainCommandSettings">
    <Description>Show token savings analytics</Description>
    <Parameters>
      <Option Short="" Long="days" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of days of history to include (default: 
30)</Description>
      </Option>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Output raw JSON instead of table</Description>
      </Option>
      <Option Short="" Long="project" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Filter by current project directory</Description>
      </Option>
    </Parameters>
  </Command>
  <!--RESET-->
  <Command Name="reset" IsBranch="false" 
ClrType="DotnetTokenKiller.Cli.Commands.ResetCommand" 
Settings="DotnetTokenKiller.Cli.Commands.Settings.ResetCommandSettings">
    <Description>Clear all tracking data</Description>
    <Parameters>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip confirmation prompt</Description>
      </Option>
    </Parameters>
  </Command>
</Model>