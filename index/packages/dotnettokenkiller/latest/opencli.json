    {
      "name": "config",
      "commands": [
        {
          "name": "set",
          "arguments": [
            {
              "name": "key",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "description": "Configuration key in dot-notation (e.g. \ntracking.enabled)",
              "hidden": false,
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            },
            {
              "name": "value",
              "required": true,
              "arity": {
                "minimum": 1,
                "maximum": 1
              },
              "description": "New value to assign (use empty string to reset to \ndefault)",
              "hidden": false,
              "metadata": [
                {
                  "name": "ClrType",
                  "value": "System.String"
                }
              ]
            }
          ],
          "description": "Set a configuration value",
          "hidden": false,
          "examples": [
            "config set tracking.enabled false",
            "config set display.width 100",
            "config set tee.mode Always"
          ]
        },
        {
          "name": "show",
          "description": "Display the current configuration",
          "hidden": false,
          "examples": [
            "config show"
          ]
        }
      ],
      "description": "View or modify dtk configuration",
      "hidden": false
