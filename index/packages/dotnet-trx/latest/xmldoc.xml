<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Devlooped.TrxCommand" Settings="Devlooped.TrxCommand+TrxSettings">
    <Parameters>
      <Option Short="" Long="gh-comment" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Report as GitHub PR comment</Description>
      </Option>
      <Option Short="" Long="gh-summary" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Report as GitHub step summary</Description>
      </Option>
      <Option Short="" Long="no-exit-code" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Do not return a -1 exit code on test failures</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Include test output</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Optional base directory for *.trx files discovery. Defaults
to current directory.</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Recursively search for *.trx files</Description>
      </Option>
      <Option Short="v" Long="verbosity" Value="NULL" Required="false" 
Kind="scalar" ClrType="Devlooped.TrxCommand+Verbosity">
        <Description>Output display verbosity:
- quiet: only failed tests are displayed
- normal: failed and skipped tests are displayed
- verbose: failed, skipped and passed tests are displayed</Description>
      </Option>
      <Option Short="" Long="version" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Prints version information</Description>
      </Option>
    </Parameters>
  </Command>
</Model>