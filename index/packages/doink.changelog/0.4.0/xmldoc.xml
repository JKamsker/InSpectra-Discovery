<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="ChangeLog.Command.WelcomeCommand" 
Settings="ChangeLog.Command.WelcomeCommand+Settings">
    <Parameters>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
    </Parameters>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="ChangeLog.Command.GenerateCommand" 
Settings="ChangeLog.Command.GenerateCommand+Settings">
    <Parameters>
      <Argument Name="OutputFile" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of object to filter on</Description>
      </Option>
      <Option Short="s" Long="sourceConnectionString" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String" />
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Only compare specific types. 
        U = Table,
        V = View,
        P = Stored Procedure,
        FN = Function,
        IF = Inline Table Function,
        TF = Table Value Function</Description>
      </Option>
    </Parameters>
  </Command>
  <!--VALIDATE-->
  <Command Name="validate" IsBranch="false" 
ClrType="ChangeLog.Command.ValidateYamlCommand" 
Settings="ChangeLog.Command.ValidateYamlCommand+Settings">
    <Parameters>
      <Argument Name="File" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
  </Command>
  <!--DIFF-->
  <Command Name="diff" IsBranch="false" ClrType="ChangeLog.Command.DiffCommand" 
Settings="ChangeLog.Command.DiffCommand+Settings">
    <Parameters>
      <Option Short="c" Long="connectionString" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="d" Long="detail" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Show detailed comparison results</Description>
      </Option>
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of object to filter on</Description>
      </Option>
      <Option Short="s" Long="sourceConnectionString" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String" />
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Only compare specific types. 
        U = Table,
        V = View,
        P = Stored Procedure,
        FN = Function,
        IF = Inline Table Function,
        TF = Table Value Function,
        AF = Aggregate Function,
        FS = Scalar Function,
        CT = Custom Types</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SEED-->
  <Command Name="seed" IsBranch="false" ClrType="ChangeLog.Command.SeedCommand" 
Settings="ChangeLog.Command.SeedCommand+Settings">
    <Parameters>
      <Argument Name="OutputFile" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Table Name to get seed data from</Description>
      </Option>
      <Option Short="h" Long="schema" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Schema</Description>
      </Option>
      <Option Short="s" Long="sourceConnectionString" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="ChangeLog.Command.InitCommand" 
Settings="ChangeLog.Command.InitCommand+Settings" />
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="ChangeLog.Command.UpdateCommand" 
Settings="ChangeLog.Command.UpdateCommand+Settings">
    <Parameters>
      <Argument Name="Output" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="d" Long="dry-run" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="i" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
      <Option Short="s" Long="sourceConnectionString" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
</Model>