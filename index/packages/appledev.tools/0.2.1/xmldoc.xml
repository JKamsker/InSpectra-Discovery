<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--PROVISIONING-->
  <Command Name="provisioning" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.ListProvisioningProfilesCommand" 
Settings="AppleDev.Tool.Commands.ListProvisioningProfilesCommandSettings">
      <Parameters>
        <Option Short="a" Long="active" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Only list active</Description>
        </Option>
        <Option Short="b" Long="bundle-id" Value="BUNDLE-ID" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Filter Profiles by BundleID</Description>
        </Option>
        <Option Short="d" Long="download" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Download and install the profiles locally</Description>
        </Option>
        <Option Short="" Long="download-path" Value="DIRECTORY" Required="false"
Kind="scalar" ClrType="System.IO.DirectoryInfo">
          <Description>Override default directory to save downloaded profiles 
to</Description>
        </Option>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AppleDev.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="i" Long="issuer-id" Value="ISSUER_ID" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Issuer ID</Description>
        </Option>
        <Option Short="k" Long="key-id" Value="KEY_ID" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Key ID</Description>
        </Option>
        <Option Short="p" Long="private-key" Value="PRIVATE_KEY" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Private Key Filename or Base64 
string</Description>
        </Option>
        <Option Short="t" Long="type" Value="TYPE" Required="false" 
Kind="vector" ClrType="AppleAppStoreConnect.ProfileType[]">
          <Description>Filter to provisioning profile type</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Verbose</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CERTIFICATE-->
  <Command Name="certificate" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.CreateCertificateCommand" 
Settings="AppleDev.Tool.Commands.CreateCertificateCommandSettings">
      <Parameters>
        <Option Short="c" Long="common-name" Value="COMMON-NAME" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Optional common name for the CSR</Description>
        </Option>
        <Option Short="i" Long="issuer-id" Value="ISSUER_ID" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Issuer ID</Description>
        </Option>
        <Option Short="k" Long="key-id" Value="KEY_ID" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Key ID</Description>
        </Option>
        <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output path (file or directory) to save the certificate 
pfx/pkcs12</Description>
        </Option>
        <Option Short="" Long="passphrase" Value="PASSPHRASE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Optional passphrase for the output 
pfx/pkcs12</Description>
        </Option>
        <Option Short="p" Long="private-key" Value="PRIVATE_KEY" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Private Key Filename or Base64 
string</Description>
        </Option>
        <Option Short="t" Long="type" Value="TYPE" Required="false" 
Kind="scalar" ClrType="AppleAppStoreConnect.CertificateType">
          <Description>Type of Apple certificate</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>