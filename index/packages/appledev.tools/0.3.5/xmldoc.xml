<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--PROVISIONING-->
  <Command Name="provisioning" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.ListProvisioningProfilesCommand" 
Settings="AppleDev.Tool.Commands.ListProvisioningProfilesCommandSettings">
      <Parameters>
        <Option Short="a" Long="active" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Only list active</Description>
        </Option>
        <Option Short="b" Long="bundle-id" Value="BUNDLE-ID" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Filter Profiles by BundleID</Description>
        </Option>
        <Option Short="d" Long="download" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Download and install the profiles locally</Description>
        </Option>
        <Option Short="" Long="download-path" Value="DIRECTORY" Required="false"
Kind="scalar" ClrType="System.IO.DirectoryInfo">
          <Description>Override default directory to save downloaded profiles 
to</Description>
        </Option>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AppleDev.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="i" Long="issuer-id,app-store-connect-issuer-id" 
Value="ISSUER_ID" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Issuer ID value or environment variable 
name (Can also be supplied via the 'APP_STORE_CONNECT_ISSUER_ID' environment 
variable)</Description>
        </Option>
        <Option Short="k" Long="key-id,app-store-connect-key-id" Value="KEY_ID" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Key ID value or environment variable name
(Can also be supplied via the 'APP_STORE_CONNECT_KEY_ID' environment 
variable)</Description>
        </Option>
        <Option Short="p" Long="private-key,app-store-connect-private-key" 
Value="PRIVATE_KEY" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Private Key (.p8) filename or environment
variable name with (.p8) file contents (Can also be supplied via the 
'APP_STORE_CONNECT_PRIVATE_KEY' environment variable)</Description>
        </Option>
        <Option Short="t" Long="type" Value="TYPE" Required="false" 
Kind="vector" ClrType="AppleAppStoreConnect.ProfileType[]">
          <Description>Filter to provisioning profile type</Description>
        </Option>
        <Option Short="v" Long="verbose" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Verbose</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CERTIFICATE-->
  <Command Name="certificate" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.CreateCertificateCommand" 
Settings="AppleDev.Tool.Commands.CreateCertificateCommandSettings">
      <Parameters>
        <Option Short="c" Long="common-name" Value="COMMON-NAME" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Optional common name for the CSR</Description>
        </Option>
        <Option Short="i" Long="issuer-id" Value="ISSUER_ID" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Issuer ID</Description>
        </Option>
        <Option Short="k" Long="key-id" Value="KEY_ID" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Key ID</Description>
        </Option>
        <Option Short="o" Long="output" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output path (file or directory) to save the certificate 
pfx/pkcs12</Description>
        </Option>
        <Option Short="" Long="passphrase" Value="PASSPHRASE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Optional passphrase for the output 
pfx/pkcs12</Description>
        </Option>
        <Option Short="p" Long="private-key" Value="PRIVATE_KEY" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Private Key Filename or Base64 
string</Description>
        </Option>
        <Option Short="t" Long="type" Value="TYPE" Required="false" 
Kind="scalar" ClrType="AppleAppStoreConnect.CertificateType">
          <Description>Type of Apple certificate</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CI-->
  <Command Name="ci" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--PROVISION-->
    <Command Name="provision" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.ProvisionCiCommand" 
Settings="AppleDev.Tool.Commands.ProvisionCiCommandSettings">
      <Parameters>
        <Option Short="" Long="api-issuer-id,app-store-connect-issuer-id" 
Value="ISSUER_ID" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Issuer ID value or environment variable 
name (Can also be supplied via the 'APP_STORE_CONNECT_ISSUER_ID' environment 
variable)</Description>
        </Option>
        <Option Short="" Long="api-key-id,app-store-connect-key-id" 
Value="KEY_ID" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Key ID value or environment variable name
(Can also be supplied via the 'APP_STORE_CONNECT_KEY_ID' environment 
variable)</Description>
        </Option>
        <Option Short="" Long="api-private-key,app-store-connect-private-key" 
Value="PRIVATE_KEY" Required="false" Kind="scalar" ClrType="System.String">
          <Description>AppStoreConnect Private Key (.p8) filename or environment
variable name with (.p8) file contents (Can also be supplied via the 
'APP_STORE_CONNECT_PRIVATE_KEY' environment variable)</Description>
        </Option>
        <Option Short="" Long="bundle-identifier" Value="BUNDLE_IDENTIFIER" 
Required="false" Kind="vector" ClrType="System.String[]">
          <Description>App bundle identifier(s) to match provisioning profiles 
for</Description>
        </Option>
        <Option Short="" Long="certificate" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Base64 encoded certificate data, certificate filename, or
environment variable name with base 64 encoded certificate data</Description>
        </Option>
        <Option Short="" Long="certificate-passphrase" Value="PASSPHRASE" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Certificate's passphrase</Description>
        </Option>
        <Option Short="" Long="keychain" Value="KEYCHAIN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Keychain name to import into</Description>
        </Option>
        <Option Short="" Long="keychain-allow-any-app-read" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Allows any app read permission</Description>
        </Option>
        <Option Short="" Long="keychain-disallow-any-app-read" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Allows any app read permission</Description>
        </Option>
        <Option Short="" Long="keychain-password" Value="PASSWORD" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Keychain password</Description>
        </Option>
        <Option Short="" Long="profile-path" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="System.IO.DirectoryInfo">
          <Description>Override default directory to save downloaded profiles 
to</Description>
        </Option>
        <Option Short="" Long="profile-type" Value="PROFILE_TYPE" 
Required="false" Kind="vector" ClrType="AppleAppStoreConnect.ProfileType[]">
          <Description>Provisioning profile type(s) to match / 
download</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DEPROVISION-->
    <Command Name="deprovision" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.DeprovisionCiCommand" 
Settings="AppleDev.Tool.Commands.DeprovisionCiCommandSettings">
      <Parameters>
        <Option Short="" Long="keychain" Value="KEYCHAIN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Keychain name to import into</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SECRET-->
    <Command Name="secret" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.CreateSecretCommand" 
Settings="AppleDev.Tool.Commands.CreateSecretCommandSettings">
      <Parameters>
        <Option Short="" Long="from-binary-file" Value="BINARY_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Binary file</Description>
        </Option>
        <Option Short="" Long="from-certificate" Value="CERTIFICATE_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Certificate file (.p12 or .pfx)</Description>
        </Option>
        <Option Short="" Long="from-keystore" Value="KEYSTORE_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Keystore file (.keystore)</Description>
        </Option>
        <Option Short="" Long="from-pepk" Value="PEPK_KEY_FILE" Required="false"
Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Google PEPK Key file (.pepk)</Description>
        </Option>
        <Option Short="" Long="from-private-key" Value="PRIVATE_KEY_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Private Key file (.p8)</Description>
        </Option>
        <Option Short="" Long="from-text-file" Value="TEXT_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Text file</Description>
        </Option>
        <Option Short="" Long="output-file" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Output file</Description>
        </Option>
      </Parameters>
    </Command>
    <!--BASE64-TO-FILE-->
    <Command Name="base64-to-file" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.CreateSecretCommand" 
Settings="AppleDev.Tool.Commands.CreateSecretCommandSettings">
      <Parameters>
        <Option Short="" Long="from-binary-file" Value="BINARY_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Binary file</Description>
        </Option>
        <Option Short="" Long="from-certificate" Value="CERTIFICATE_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Certificate file (.p12 or .pfx)</Description>
        </Option>
        <Option Short="" Long="from-keystore" Value="KEYSTORE_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Keystore file (.keystore)</Description>
        </Option>
        <Option Short="" Long="from-pepk" Value="PEPK_KEY_FILE" Required="false"
Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Google PEPK Key file (.pepk)</Description>
        </Option>
        <Option Short="" Long="from-private-key" Value="PRIVATE_KEY_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Private Key file (.p8)</Description>
        </Option>
        <Option Short="" Long="from-text-file" Value="TEXT_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Text file</Description>
        </Option>
        <Option Short="" Long="output-file" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Output file</Description>
        </Option>
      </Parameters>
    </Command>
    <!--ENV-TO-FILE-->
    <Command Name="env-to-file" IsBranch="false" 
ClrType="AppleDev.Tool.Commands.CreateSecretCommand" 
Settings="AppleDev.Tool.Commands.CreateSecretCommandSettings">
      <Parameters>
        <Option Short="" Long="from-binary-file" Value="BINARY_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Binary file</Description>
        </Option>
        <Option Short="" Long="from-certificate" Value="CERTIFICATE_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Certificate file (.p12 or .pfx)</Description>
        </Option>
        <Option Short="" Long="from-keystore" Value="KEYSTORE_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Keystore file (.keystore)</Description>
        </Option>
        <Option Short="" Long="from-pepk" Value="PEPK_KEY_FILE" Required="false"
Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Google PEPK Key file (.pepk)</Description>
        </Option>
        <Option Short="" Long="from-private-key" Value="PRIVATE_KEY_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Private Key file (.p8)</Description>
        </Option>
        <Option Short="" Long="from-text-file" Value="TEXT_FILE" 
Required="false" Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Text file</Description>
        </Option>
        <Option Short="" Long="output-file" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.IO.FileInfo">
          <Description>Output file</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>