<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Jet.Commands.SmartCommand" Settings="Jet.Commands.GlobalSettings">
    <Parameters>
      <Option Short="n" Long="no-selection" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>List paths without fzf selection</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REPOS-->
  <Command Name="repos" IsBranch="false" ClrType="Jet.Commands.ReposCommand" 
Settings="Jet.Commands.GlobalSettings">
    <Description>Search for git repositories</Description>
    <Parameters>
      <Option Short="n" Long="no-selection" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>List paths without fzf selection</Description>
      </Option>
    </Parameters>
  </Command>
  <!--PROJECTS-->
  <Command Name="projects" IsBranch="false" 
ClrType="Jet.Commands.ProjectsCommand" Settings="Jet.Commands.GlobalSettings">
    <Description>Search for projects</Description>
    <Parameters>
      <Option Short="n" Long="no-selection" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>List paths without fzf selection</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UP-->
  <Command Name="up" IsBranch="false" ClrType="Jet.Commands.UpCommand" 
Settings="Jet.Commands.GlobalSettings">
