<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GEN-KEY-->
  <Command Name="gen-key" IsBranch="false" ClrType="PgpCli.GenKeyCommandCommand"
Settings="PgpCli.GenKeyCommandSettings">
    <Parameters>
      <Argument Name="EMAIL" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Email</Description>
      </Argument>
      <Argument Name="PASSPHRASE" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Passphrase for private key</Description>
      </Argument>
      <Option Short="o" Long="output-directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory path</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ENCRYPT-->
  <Command Name="encrypt" IsBranch="false" ClrType="PgpCli.EncryptCommand" 
Settings="PgpCli.EncryptCommandSettings">
    <Parameters>
      <Argument Name="FILE-TO-ENCRYPT" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>File to encrypt</Description>
      </Argument>
      <Option Short="k" Long="key" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Public key path (PGP)</Description>
      </Option>
      <Option Short="o" Long="output-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DECRYPT-->
  <Command Name="decrypt" IsBranch="false" ClrType="PgpCli.DecryptCommand" 
Settings="PgpCli.DecryptCommandSettings">
    <Parameters>
      <Argument Name="FILE-TO-DECRYPT" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>File to decrypt</Description>
      </Argument>
      <Argument Name="PASSPHRASE" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Passphrase for private key</Description>
      </Argument>
      <Option Short="k" Long="key" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Private key path (PGP)</Description>
      </Option>
      <Option Short="o" Long="output-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path</Description>
      </Option>
    </Parameters>
  </Command>
</Model>