<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--POST-->
  <Command Name="post" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="Hyde.Commands.Post.CreatePostCommand" 
Settings="Hyde.Commands.Post.CreatePostCommand+CreatePostSettings">
      <Parameters>
        <Option Short="" Long="date" Value="NULL" Required="false" Kind="scalar"
ClrType="System.DateOnly">
          <Description>The date the post is published</Description>
        </Option>
        <Option Short="" Long="draft" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Creates the post as draft</Description>
        </Option>
        <Option Short="" Long="excerpt" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The excerpt of the post</Description>
        </Option>
        <Option Short="f" Long="filename" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The alphanumeric portion of the file name. Default: 
generated from the title.</Description>
        </Option>
        <Option Short="" Long="layout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Sets the layout to be used when creating the 
post</Description>
        </Option>
        <Option Short="s" Long="site" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.DirectoryInfo">
          <Description>The path to the root of the site to work on. Default: 
working directory</Description>
        </Option>
        <Option Short="" Long="time" Value="NULL" Required="false" Kind="scalar"
ClrType="System.TimeOnly">
          <Description>The time the post is published</Description>
        </Option>
        <Option Short="t" Long="title" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The title of the post</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="Hyde.Commands.Post.ListPostCommand" 
Settings="Hyde.Commands.Post.ListPostCommand+ListPostSettings">
      <Parameters>
        <Option Short="" Long="include-drafts" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Includes posts from the draft folder</Description>
        </Option>
        <Option Short="s" Long="site" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.DirectoryInfo">
          <Description>The path to the root of the site to work on. Default: 
working directory</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DELETE-->
    <Command Name="delete" IsBranch="false" 
ClrType="Hyde.Commands.Post.DeletePostCommand" 
Settings="Hyde.Commands.Post.DeletePostCommand+DeletePostSettings">
      <Parameters>
        <Argument Name="FILENAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The name of the post file to delete.</Description>
        </Argument>
        <Option Short="" Long="draft" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Deletes the post from the draft folder</Description>
        </Option>
        <Option Short="s" Long="site" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.DirectoryInfo">
          <Description>The path to the root of the site to work on. Default: 
working directory</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>