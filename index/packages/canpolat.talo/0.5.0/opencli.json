  "opencli": "0.1-draft",
  "info": {
    "title": "talo",
    "version": "0.5.0",
    "description": "talo is a CLI tool to manage your ADRs, RFCs, software design documents and more.\n\n      With talo, you can create, update, list, and export your documents. It supports\n      ADRs (Architecture Decision Records) and RFCs (Request for Comments) out of the box.\n      But you can define your own document types."
  },
