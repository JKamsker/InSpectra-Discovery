<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Vibe.UI.CLI.Commands.InitCommand" 
Settings="Vibe.UI.CLI.Commands.InitCommand+Settings">
    <Description>Initialize Vibe.UI in your project</Description>
    <Parameters>
      <Option Short="" Long="minimal" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Minimal infrastructure only</Description>
      </Option>
      <Option Short="" Long="no-theme" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Skip theme system</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project directory path</Description>
      </Option>
      <Option Short="" Long="with-charts" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include Chart.js support</Description>
      </Option>
      <Option Short="" Long="with-css" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Add Vibe.UI.CSS package reference for build-time CSS 
generation</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip confirmation prompts</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="init" />
    </Examples>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" ClrType="Vibe.UI.CLI.Commands.AddCommand"
Settings="Vibe.UI.CLI.Commands.AddCommand+Settings">
    <Description>Add a component to your project</Description>
    <Parameters>
      <Argument Name="component" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Component name to add</Description>
      </Argument>
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Custom name for the component</Description>
      </Option>
      <Option Short="" Long="output" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Custom output directory for the component</Description>
      </Option>
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Overwrite existing files</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project directory path</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip confirmation prompts</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="add" />
      <Example commandLine="button" />
      <Example commandLine="add" />
      <Example commandLine="dialog" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="Vibe.UI.CLI.Commands.ListCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>List all available components</Description>
    <Examples>
      <Example commandLine="list" />
    </Examples>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="Vibe.UI.CLI.Commands.UpdateCommand" 
Settings="Vibe.UI.CLI.Commands.UpdateCommand+Settings">
    <Description>Update Vibe.UI components</Description>
    <Parameters>
      <Argument Name="component" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Update specific component</Description>
      </Argument>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project directory path</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip confirmation prompts</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="update" />
    </Examples>
  </Command>
  <!--CSS-->
  <Command Name="css" IsBranch="false" ClrType="Vibe.UI.CLI.Commands.CssCommand"
Settings="Vibe.UI.CLI.Commands.CssCommand+Settings">
    <Description>Generate CSS using Vibe.UI.CSS JIT engine</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Project directory path to scan</Description>
      </Argument>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output CSS file path</Description>
      </Option>
      <Option Short="" Long="patterns" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>File patterns to scan (comma-separated)</Description>
      </Option>
      <Option Short="" Long="prefix" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>CSS class prefix</Description>
      </Option>
      <Option Short="" Long="scan-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Only scan, don't generate CSS</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show verbose output</Description>
      </Option>
      <Option Short="w" Long="watch" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Watch for changes and regenerate</Description>
      </Option>
      <Option Short="" Long="with-base" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include vibe-base.css content</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="css" />
      <Example commandLine="css" />
      <Example commandLine="." />
      <Example commandLine="-o" />
      <Example commandLine="wwwroot/css/Vibe.UI.CSS" />
      <Example commandLine="css" />
      <Example commandLine="--watch" />
      <Example commandLine="css" />
      <Example commandLine="--scan-only" />
    </Examples>
  </Command>
</Model>