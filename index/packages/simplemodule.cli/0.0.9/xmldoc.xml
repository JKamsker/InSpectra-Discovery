<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--NEW-->
  <Command Name="new" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Create new projects, modules, or features</Description>
    <!--PROJECT-->
    <Command Name="project" IsBranch="false" 
ClrType="SimpleModule.Cli.Commands.New.NewProjectCommand" 
Settings="SimpleModule.Cli.Commands.New.NewProjectSettings">
      <Description>Scaffold a new SimpleModule solution</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Project name in PascalCase (e.g. MyApp)</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be created without writing any 
files</Description>
        </Option>
        <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output directory (defaults to current 
directory)</Description>
        </Option>
      </Parameters>
    </Command>
    <!--MODULE-->
    <Command Name="module" IsBranch="false" 
ClrType="SimpleModule.Cli.Commands.New.NewModuleCommand" 
Settings="SimpleModule.Cli.Commands.New.NewModuleSettings">
      <Description>Scaffold a new module</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Module name in PascalCase (e.g. Invoices)</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be created without writing any 
files</Description>
        </Option>
      </Parameters>
    </Command>
    <!--FEATURE-->
    <Command Name="feature" IsBranch="false" 
ClrType="SimpleModule.Cli.Commands.New.NewFeatureCommand" 
Settings="SimpleModule.Cli.Commands.New.NewFeatureSettings">
      <Description>Add a feature to an existing module</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Feature name in PascalCase (e.g. 
UpdateInvoice)</Description>
        </Argument>
        <Option Short="" Long="dry-run" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show what would be created without writing any 
files</Description>
        </Option>
        <Option Short="" Long="method" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>HTTP method (GET, POST, PUT, DELETE)</Description>
        </Option>
        <Option Short="m" Long="module" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Target module name</Description>
        </Option>
        <Option Short="" Long="no-view" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip creating the React view component and Pages/index.ts
entry</Description>
        </Option>
        <Option Short="r" Long="route" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Route pattern (e.g. /{id})</Description>
        </Option>
        <Option Short="" Long="validator" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Include a validator class</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--DOCTOR-->
  <Command Name="doctor" IsBranch="false" 
ClrType="SimpleModule.Cli.Commands.Doctor.DoctorCommand" 
Settings="SimpleModule.Cli.Commands.Doctor.DoctorSettings">
    <Description>Validate project structure and conventions</Description>
    <Parameters>
      <Option Short="" Long="fix" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Auto-fix missing slnx entries and project 
references</Description>
      </Option>
    </Parameters>
  </Command>
</Model>