<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="MartinCostello.WaitForNuGetPackage.WaitCommand" 
Settings="MartinCostello.WaitForNuGetPackage.WaitCommandSettings">
    <Parameters>
      <Argument Name="package-id" Position="0" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>The package ID(s), including an optional version, to wait 
for new versions to be published.</Description>
      </Argument>
      <Option Short="q" Long="no-logo" Value="NULL" Required="false" Kind="flag"
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Suppresses the logo.</Description>
      </Option>
      <Option Short="i" Long="service-index" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The NuGet service index URL to use.</Description>
      </Option>
      <Option Short="s" Long="since" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Nullable`1[[System.TimeSpan, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>The period of time before now to include when searching for
the published package(s).</Description>
      </Option>
      <Option Short="t" Long="timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.TimeSpan, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>The period of time to wait for the package(s) to be 
published.</Description>
      </Option>
      <Option Short="" Long="verbose" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Enables verbose logging.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="MyCompany.MyProduct" />
      <Example commandLine="MyCompany.MyProduct@1.2.3" />
      <Example commandLine="MyCompany.MyProduct" />
      <Example commandLine="MyCompany.MyOtherProduct@1.2.3" />
      <Example commandLine="--timeout" />
      <Example commandLine="00:15:00" />
    </Examples>
  </Command>
</Model>