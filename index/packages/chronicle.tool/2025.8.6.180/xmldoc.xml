<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ARCHIVE-->
  <Command Name="archive" IsBranch="false" 
ClrType="Chronicle.Commands.ArchiveCommand" 
Settings="Chronicle.Commands.Settings.ArchiveSettings">
    <Parameters>
      <Argument Name="source directory" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>Source directory path</Description>
      </Argument>
      <Argument Name="target directory" Position="1" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>Target directory path</Description>
      </Argument>
      <Argument Name="pattern" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Source file pattern</Description>
      </Argument>
      <Argument Name="archive prefix" Position="3" Required="true" Kind="scalar"
ClrType="System.String">
        <Description>Target zip file arcive prefix</Description>
      </Argument>
      <Option Short="" Long="age-unit" Value="NULL" Required="false" 
Kind="scalar" ClrType="Chronicle.Models.AgeUnit">
        <Description>Age unit day (default), hour, minute</Description>
      </Option>
      <Option Short="" Long="compression-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.IO.Compression.CompressionLevel">
        <Description>Zip file compression level NoCompression, Fastest, Optimal 
(default)</Description>
      </Option>
      <Option Short="" Long="display-progress-after" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.Int64">
        <Description>Display progress after specified number of files processed,
default 5000</Description>
      </Option>
      <Option Short="" Long="min-age" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.UInt32">
        <Description>Minimum age of file 1 day</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="archive" />
      <Example commandLine="&quot;C:\temp\Chronicle\source&quot;" />
      <Example commandLine="&quot;C:\temp\Chronicle\target&quot; 
&quot;*.log&quot;" />
      <Example commandLine="&quot;LogFiles&quot;" />
    </Examples>
  </Command>
