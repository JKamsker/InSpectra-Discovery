<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--RUN-->
  <Command Name="run" IsBranch="false" 
ClrType="Wcom.ClaudeAutomater.Commands.RunCommand" 
Settings="Wcom.ClaudeAutomater.Commands.RunCommandSettings">
    <Description>Run a single prompt through Claude Code with budget tracking 
and rate limit handling</Description>
    <Parameters>
      <Argument Name="prompt" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The prompt to send to Claude</Description>
      </Argument>
      <Option Short="" Long="allowed-tools" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Allowed (or disallowed) tools, actions, and commands. Can 
be specified multiple times (e.g. --allowed-tools "Bash(git:*)" --allowed-tools 
"Edit")</Description>
      </Option>
      <Option Short="" Long="budget" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Double">
        <Description>Maximum budget in USD (0 = no limit)</Description>
      </Option>
      <Option Short="" Long="max-retries" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum retry attempts on rate limit</Description>
      </Option>
      <Option Short="" Long="max-turns" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of agentic turns</Description>
      </Option>
      <Option Short="" Long="model" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Claude model to use (e.g. sonnet, opus)</Description>
      </Option>
      <Option Short="" Long="ongoing" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Keep running in a heartbeat loop after 
completion</Description>
      </Option>
      <Option Short="" Long="ongoing-wait" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Minutes to wait between heartbeat runs (default 
5)</Description>
      </Option>
      <Option Short="" Long="output-json" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Write a JSON session report to this file path</Description>
      </Option>
      <Option Short="" Long="working-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Working directory for Claude</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="run" />
      <Example commandLine="&quot;fix the auth bug&quot;" />
      <Example commandLine="--budget" />
      <Example commandLine="5.00" />
    </Examples>
  </Command>
  <!--BATCH-->
  <Command Name="batch" IsBranch="false" 
ClrType="Wcom.ClaudeAutomater.Commands.BatchCommand" 
Settings="Wcom.ClaudeAutomater.Commands.BatchCommandSettings">
    <Description>Run multiple tasks from a JSON file with shared budget 
tracking</Description>
    <Parameters>
      <Argument Name="tasks-file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the batch tasks JSON file</Description>
      </Argument>
      <Option Short="" Long="allowed-tools" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Default allowed (or disallowed) tools for tasks that don't 
specify them. Can be specified multiple times</Description>
      </Option>
      <Option Short="" Long="budget" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Double">
        <Description>Maximum total budget in USD across all tasks (0 = no 
limit)</Description>
      </Option>
      <Option Short="" Long="max-retries" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Default maximum retry attempts on rate limit (per 
task)</Description>
      </Option>
      <Option Short="" Long="no-dashboard" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Disable the live dashboard and show raw output 
instead</Description>
      </Option>
      <Option Short="" Long="ongoing" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Keep running in a heartbeat loop after 
completion</Description>
      </Option>
      <Option Short="" Long="ongoing-wait" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Minutes to wait between heartbeat runs (default 
5)</Description>
      </Option>
      <Option Short="" Long="output-json" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Write a JSON session report to this file path</Description>
      </Option>
      <Option Short="" Long="working-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Default working directory for tasks that don't specify 
one</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="batch" />
      <Example commandLine="tasks.json" />
      <Example commandLine="--budget" />
      <Example commandLine="50.00" />
    </Examples>
  </Command>
  <!--BOARDS-->
  <Command Name="boards" IsBranch="false" 
ClrType="Wcom.ClaudeAutomater.Commands.BoardsCommand" 
Settings="Wcom.ClaudeAutomater.Commands.BoardsCommandSettings">
    <Description>Find Agentic-tagged epics in an Azure DevOps project, clone 
repos as needed, and run Claude on approved work items</Description>
    <Parameters>
      <Argument Name="project-url" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Azure DevOps project URL (e.g. 
https://dev.azure.com/org/project). Finds all Epics tagged 
'Agentic'.</Description>
      </Argument>
      <Option Short="" Long="allowed-tools" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Allowed tools (repeatable)</Description>
      </Option>
      <Option Short="" Long="budget" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Double">
        <Description>Maximum budget in USD for all work items combined (0 = no 
limit)</Description>
      </Option>
      <Option Short="" Long="max-retries" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum retry attempts per work item on rate 
limit</Description>
      </Option>
      <Option Short="" Long="max-turns" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum agentic turns per work item</Description>
      </Option>
      <Option Short="" Long="model" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Claude model to use</Description>
      </Option>
      <Option Short="" Long="no-dashboard" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Disable the live dashboard and use classic 
output</Description>
      </Option>
      <Option Short="" Long="ongoing" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Keep running in a heartbeat loop after 
completion</Description>
      </Option>
      <Option Short="" Long="ongoing-wait" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Minutes to wait between heartbeat runs (default 
5)</Description>
      </Option>
      <Option Short="" Long="working-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Working directory (target repo root)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="boards" />
      <Example commandLine="&quot;https://dev.azure.com/org/project&quot;" />
      <Example commandLine="--budget" />
      <Example commandLine="20.00" />
      <Example commandLine="--working-dir" />
      <Example commandLine="./repos" />
    </Examples>
  </Command>
</Model>