<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--NEW-->
  <Command Name="new" IsBranch="false" ClrType="Moryx.Cli.CommandLine.New" 
Settings="Moryx.Cli.CommandLine.New+Settings">
    <Parameters>
      <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the project. Recommended to be 
PascalCase.</Description>
      </Argument>
      <Option Short="b" Long="branch" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Branch to use with the template repository.</Description>
      </Option>
      <Option Short="" Long="no-git-init" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Prevents the command from initializing a Git 
repository</Description>
      </Option>
      <Option Short="p" Long="products" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>A comma separated list of products to be created with the 
application project.</Description>
      </Option>
      <Option Short="" Long="pull" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Update the template repository.</Description>
      </Option>
      <Option Short="s" Long="steps" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>A comma separated list of steps to be created with the 
application project.</Description>
      </Option>
      <Option Short="t" Long="template-url" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>A Git repository url that will be used for the project 
template.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="true" 
Settings="Moryx.Cli.CommandLine.AddSettings">
    <Parameters>
      <Option Short="b" Long="branch" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Branch to use with the template repository.</Description>
      </Option>
      <Option Short="" Long="pull" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Update the template repository.</Description>
      </Option>
      <Option Short="t" Long="template-url" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>A Git repository url that will be used for the project 
template.</Description>
      </Option>
    </Parameters>
    <!--PRODUCT-->
    <Command Name="product" IsBranch="false" 
ClrType="Moryx.Cli.CommandLine.AddProduct" 
Settings="Moryx.Cli.CommandLine.AddProduct+AddProductSettings">
      <Parameters>
        <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Name of the product to be added</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--STEP-->
    <Command Name="step" IsBranch="false" 
ClrType="Moryx.Cli.CommandLine.AddStep" 
Settings="Moryx.Cli.CommandLine.AddStep+AddStepSettings">
      <Parameters>
        <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Name of the step to be added</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--MODULE-->
    <Command Name="module" IsBranch="false" 
ClrType="Moryx.Cli.CommandLine.AddModule" 
Settings="Moryx.Cli.CommandLine.AddModule+AddModuleSettings">
      <Parameters>
        <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Name of the module to be added</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--ADAPTER-->
    <Command Name="adapter" IsBranch="false" 
ClrType="Moryx.Cli.CommandLine.AddModule" 
Settings="Moryx.Cli.CommandLine.AddModule+AddModuleSettings">
      <Parameters>
        <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Name of the module to be added</Description>
        </Argument>
      </Parameters>
    </Command>
  </Command>
</Model>