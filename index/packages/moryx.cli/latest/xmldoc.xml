  <!--REMOTES-->
  <Command Name="remotes" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manages remote profiles</Description>
    <!--__DEFAULT_COMMAND-->
    <Command Name="__default_command" IsBranch="false" 
ClrType="Moryx.Cli.CommandLine.RemotesList" 
Settings="Moryx.Cli.CommandLine.RemotesList+Settings">
      <Description>Lists all configured remotes.</Description>
    </Command>
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="Moryx.Cli.CommandLine.RemotesAdd" 
Settings="Moryx.Cli.CommandLine.RemotesAdd+Settings">
      <Description>Adds a Git remote to the local config.</Description>
      <Parameters>
        <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Name of the remote.</Description>
        </Argument>
        <Argument Name="URL" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>URL of the remote repository.</Description>
        </Argument>
        <Argument Name="BRANCH" Position="2" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The branch to be used with for this remote.</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="remotes" />
        <Example commandLine="add" />
        <Example commandLine="custom" />
        <Example commandLine="https://example.com/repo.git" />
        <Example commandLine="main" />
      </Examples>
    </Command>
