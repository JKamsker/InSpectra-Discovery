        </Option>
        <Option Short="" Long="states" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Comma separated list of states to be added. Defaults to 
&lt;TO BE DEFINED&gt;</Description>
        </Option>
        <Option Short="t" Long="template-url" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>A Git repository url that will be used for the project 
template.</Description>
        </Option>
        <Option Short="" Long="transitions" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Comma separated list of state transitions.</Description>
        </Option>
      </Parameters>
      <Examples>
