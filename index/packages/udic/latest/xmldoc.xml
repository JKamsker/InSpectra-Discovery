<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--MOVE-->
  <Command Name="move" IsBranch="false" ClrType="MoveCommand" 
Settings="MoveSettings">
    <Description>Moves dictionary items matching the specified name to a new 
name. * matches all child paths.</Description>
    <Parameters>
      <Argument Name="currentName" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Argument Name="newName" Position="1" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
    <Examples>
      <Example commandLine="move Test.Old.Name*" />
      <Example commandLine="New.Name" />
    </Examples>
  </Command>
  <!--COPY-->
  <Command Name="copy" IsBranch="false" ClrType="CopyCommand" 
Settings="CopySettings">
    <Description>Copies dictionary items matching the specified name to a new 
name. * matches all child paths.</Description>
    <Parameters>
      <Argument Name="currentName" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Argument Name="newName" Position="1" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="" Long="empty" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean" />
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
    <Examples>
      <Example commandLine="copy Test.Old.Name*" />
      <Example commandLine="New.Name" />
    </Examples>
  </Command>
  <!--TREE-->
  <Command Name="tree" IsBranch="false" ClrType="TreeCommand" 
Settings="BaseSettings">
    <Description>Ensures parent dictionary items exist for every dot-separated 
segment in aliases.</Description>
    <Parameters>
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--ITEM-->
    <Command Name="item" IsBranch="false" ClrType="AddItemCommand" 
Settings="AddItemSettings">
      <Description>Adds a new dictionary item with the specified 
name.</Description>
      <Parameters>
        <Argument Name="alias" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Argument Name="value" Position="1" Required="false" Kind="scalar" 
ClrType="System.String" />
        <Option Short="c" Long="culture" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
      </Parameters>
      <Examples>
        <Example commandLine="add item New.Alias &quot;Value goes here&quot; -c 
en-GB" />
      </Examples>
    </Command>
    <!--SCAN-->
    <Command Name="scan" IsBranch="false" ClrType="AddScanCommand" 
Settings="AddScanSettings">
      <Description>Scans razor (cshtml) files for dictionary items and adds them
as dictionary items.</Description>
      <Parameters>
        <Option Short="c" Long="culture" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="f" Long="path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
        <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
      </Parameters>
      <Examples>
        <Example commandLine="add scan -p C:\Path\To\Project -c en-GB" />
        <Example commandLine="add scan -path C:\Path\To\Views\To\Scan.cshtml -c 
en-GB" />
      </Examples>
    </Command>
  </Command>
  <!--SEED-->
  <Command Name="seed" IsBranch="false" ClrType="SeedCommand" 
Settings="SeedSettings">
    <Description>Sets the value of the specified culture for specified name(s) 
to the given format.</Description>
    <Parameters>
      <Argument Name="format" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="c" Long="culture" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String" />
    </Parameters>
    <Examples>
      <Example commandLine="seed &quot;[{culture}] {value:en-GB} ({alias})&quot;
-n * -c da" />
    </Examples>
  </Command>
</Model>