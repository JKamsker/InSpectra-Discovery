Settings="dgt.power.profile.Base.ProfileSettings" />
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="dgt.power.profile.Commands.CreateProfileCommand" 
Settings="dgt.power.profile.Commands.CreateProfileSettings">
      <Parameters>
        <Argument Name="Name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Name</Description>
        </Argument>
        <Argument Name="ConnectionString" Position="1" Required="true" 
Kind="scalar" ClrType="System.String">
          <Description>ConnectionString</Description>
        </Argument>
        <Option Short="i" Long="insecure" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Ignore certificate issues; [[true|false]]</Description>
        </Option>
        <Option Short="" Long="msal" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Tokenbased Authentication (with MSAL)</Description>
        </Option>
        <Option Short="s" Long="security-protocol" Value="NULL" Required="false"
Kind="scalar" ClrType="System.String">
          <Description>Set specific protocol; 
[[ssl3|tls|tls11|tls12]]</Description>
        </Option>
        <Option Short="" Long="skipcheck" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip testing of the connection</Description>
        </Option>
      </Parameters>
    </Command>
