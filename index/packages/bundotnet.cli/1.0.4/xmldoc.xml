<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--WRAPPER-->
  <Command Name="wrapper" IsBranch="false" 
ClrType="BunDotNet.Cli.WrapperCommand" 
Settings="BunDotNet.Cli.WrapperCommand+Settings">
    <Description>Sets up Bun and ececutes the specified command.</Description>
    <Parameters>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The Bun installation directory.</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Bun version to use.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UPGRADE-->
  <Command Name="upgrade" IsBranch="false" 
ClrType="BunDotNet.Cli.UpgradeCommand" 
Settings="BunDotNet.Cli.UpgradeCommand+Settings">
    <Description>Upgrades Bun to the latest version.</Description>
    <Parameters>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The Bun installation directory.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--VERSIONS-->
  <Command Name="versions" IsBranch="false" 
ClrType="BunDotNet.Cli.VersionsCommand" 
Settings="BunDotNet.Cli.VersionsCommand+Settings">
    <Description>Lists installed Bun versions.</Description>
    <Parameters>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The Bun installation directory.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CLEANUP-->
  <Command Name="cleanup" IsBranch="false" 
ClrType="BunDotNet.Cli.CleanupCommand" 
Settings="BunDotNet.Cli.CleanupCommand+Settings">
    <Description>Removes all Bun versions except the latest one.</Description>
    <Parameters>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The Bun installation directory.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>