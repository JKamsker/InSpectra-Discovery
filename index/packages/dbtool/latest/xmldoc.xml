<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="dbTool.Commands.InitCommand" 
Settings="dbTool.Commands.InitCommand+Settings">
    <Description>Initialize a new schema file.
</Description>
    <Parameters>
      <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force re-initialization of the schema, overwriting existing
data.</Description>
      </Option>
      <Option Short="" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the database to initialize. If not provided, will 
prompt for input.</Description>
      </Option>
      <Option Short="" Long="tables" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Comma-separated list of tables to add during 
initialization. If not provided, no tables will be added. ie 'init --tables 
users,products,orders'</Description>
      </Option>
    </Parameters>
  </Command>
  <!--MIGRATE-->
  <Command Name="migrate" IsBranch="false" 
ClrType="dbTool.Commands.MigrationBeginCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Begin the migration process.</Description>
  </Command>
  <!--DRY-->
  <Command Name="dry" IsBranch="false" 
ClrType="dbTool.Commands.MigrateDryRunCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Runs a Dry Run of the migration</Description>
  </Command>
  <!--FINALIZE-->
  <Command Name="finalize" IsBranch="false" 
ClrType="dbTool.Commands.MigrationFinalizeCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Finish the migration.
</Description>
  </Command>
  <!--CREATE-->
  <Command Name="create" IsBranch="false" 
ClrType="dbTool.Commands.AddTableCommand" 
Settings="dbTool.Commands.AddTableCommand+Settings">
    <Description>Add a table.</Description>
    <Parameters>
      <Argument Name="table names" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Comma-separated list of table names to add. If not 
provided, will prompt for input.</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="dbTool.Commands.AddColumnCommand" 
Settings="dbTool.Commands.AddColumnCommand+Settings">
    <Description>Add a column to a table.</Description>
    <Parameters>
      <Option Short="" Long="column" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>The name of the column to add.</Description>
      </Option>
      <Option Short="" Long="default" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The default value for the column.</Description>
      </Option>
      <Option Short="" Long="nullable" Value="NULL" Required="false" Kind="flag"
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Whether the column is nullable (default: 
true).</Description>
      </Option>
      <Option Short="" Long="primary" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Whether the column is a primary key (default: 
false).</Description>
      </Option>
      <Option Short="" Long="table" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The name of the table to add the column to.</Description>
      </Option>
      <Option Short="" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The type of the column (e.g. string, int, 
uuid).</Description>
      </Option>
      <Option Short="" Long="unique" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Whether the column is unique (default: 
false).</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DROP-->
  <Command Name="drop" IsBranch="false" 
ClrType="dbTool.Commands.RemoveTableCommand" 
Settings="dbTool.Commands.RemoveTableCommand+Settings">
    <Description>Remove a table.</Description>
  </Command>
  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" 
ClrType="dbTool.Commands.RemoveColumnCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Remove a column from a table.
</Description>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="dbTool.Commands.GenerateSqlCommand" 
Settings="dbTool.Commands.GenerateSqlCommand+Settings">
    <Description>Generate SQL and Boiler Plate CRUD.</Description>
    <Parameters>
      <Option Short="b" Long="boilerplate" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Also generates basic CRUD controlers and 
models.</Description>
      </Option>
      <Option Short="j" Long="joins" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Generate SQL with joins for related tables. Auto-joins if 
column name matches a table name and is followed by 'Id'. Eg table = users, 
column name = userId (singular) will be make a join.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--VISUALIZE-->
  <Command Name="visualize" IsBranch="false" 
ClrType="dbTool.Commands.VisualizeSchemaCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>Visualize the database schema.
</Description>
  </Command>
</Model>