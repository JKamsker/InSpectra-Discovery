    <Command Name="scan" IsBranch="false" 
ClrType="Dependify.Cli.Commands.ScanCommand" 
Settings="Dependify.Cli.Commands.ScanCommandSettings">
      <Description>Scans for projects and solutions and retrives their 
dependencies</Description>
      <Parameters>
        <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="exclude-sln" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]" />
        <Option Short="" Long="format" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="System.Nullable`1[[Dependify.Cli.Commands.Settings.OutputFormat, 
Dependify.Cli, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null]]">
          <Description>The output format to use</Description>
        </Option>
        <Option Short="f" Long="framework" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Framework RTF version</Description>
        </Option>
        <Option Short="" Long="full-scan" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]" />
        <Option Short="" Long="include-packages" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]" />
        <Option Short="" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]" />
        <Option Short="l" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[Microsoft.Extensions.Logging.LogLevel,
Microsoft.Extensions.Logging.Abstractions, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=adb9793829ddae60]]">
          <Description>Log level</Description>
        </Option>
        <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The output path</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="graph" />
        <Example commandLine="scan" />
        <Example commandLine="./path/to/folder" />
        <Example commandLine="--framework" />
        <Example commandLine="net8" />
