<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="SA.OpenSearchTool.Commands.DefaultCommand" 
Settings="SA.OpenSearchTool.Commands.DefaultCommand+Settings">
    <Parameters>
      <Option Short="" Long="no-gui" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Run in non-interactive mode without the TUI</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Display version information</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="--help" />
      <Example commandLine="connection" />
      <Example commandLine="list" />
      <Example commandLine="snapshot" />
      <Example commandLine="list" />
      <Example commandLine="--repo" />
      <Example commandLine="my-repo" />
    </Examples>
  </Command>
  <!--CONNECTION-->
  <Command Name="connection" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage OpenSearch connections</Description>
    <!--__DEFAULT_COMMAND-->
    <Command Name="__default_command" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ConnectionCommand" 
Settings="SA.OpenSearchTool.Commands.ConnectionCommand+Settings" />
    <!--ADD-->
    <Command Name="add" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ConnectionAddCommand" 
Settings="SA.OpenSearchTool.Commands.ConnectionAddCommand+Settings">
      <Description>Add a new OpenSearch connection</Description>
      <Parameters>
        <Option Short="" Long="default" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Set as the default connection</Description>
        </Option>
        <Option Short="h" Long="host" Value="HOST" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>OpenSearch host address</Description>
        </Option>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Display name for the connection</Description>
        </Option>
        <Option Short="" Long="nodes" Value="NODES" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Comma-separated list of cluster node hostnames (e.g., 
node1,node2,node3)</Description>
        </Option>
        <Option Short="p" Long="port" Value="PORT" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>OpenSearch port (default: 9200)</Description>
        </Option>
        <Option Short="u" Long="user" Value="USERNAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Username for authentication</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ConnectionListCommand" 
Settings="SA.OpenSearchTool.Commands.ConnectionListCommand+Settings">
      <Description>List all saved connections</Description>
      <Parameters>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
      </Parameters>
    </Command>
    <!--TEST-->
    <Command Name="test" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ConnectionTestCommand" 
Settings="SA.OpenSearchTool.Commands.ConnectionTestCommand+Settings">
      <Description>Test a connection</Description>
      <Parameters>
        <Argument Name="NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Connection name or ID to test (uses default if not 
specified)</Description>
        </Argument>
      </Parameters>
    </Command>
    <!--DELETE-->
    <Command Name="delete" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ConnectionDeleteCommand" 
Settings="SA.OpenSearchTool.Commands.ConnectionDeleteCommand+Settings">
      <Description>Delete a connection</Description>
      <Parameters>
        <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Connection name or ID to delete</Description>
        </Argument>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Skip confirmation</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SET-DEFAULT-->
    <Command Name="set-default" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ConnectionSetDefaultCommand" 
Settings="SA.OpenSearchTool.Commands.ConnectionSetDefaultCommand+Settings">
      <Description>Set the default connection</Description>
      <Parameters>
        <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Connection name or ID to set as default</Description>
        </Argument>
      </Parameters>
    </Command>
  </Command>
  <!--SNAPSHOT-->
  <Command Name="snapshot" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage OpenSearch snapshots</Description>
    <!--__DEFAULT_COMMAND-->
    <Command Name="__default_command" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.SnapshotCommand" 
Settings="SA.OpenSearchTool.Commands.SnapshotCommand+Settings" />
    <!--REPOS-->
    <Command Name="repos" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.SnapshotReposCommand" 
Settings="SA.OpenSearchTool.Commands.SnapshotReposCommand+Settings">
      <Description>List snapshot repositories</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CREATE-REPO-->
    <Command Name="create-repo" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.SnapshotCreateRepoCommand" 
Settings="SA.OpenSearchTool.Commands.SnapshotCreateRepoCommand+Settings">
      <Description>Create a snapshot repository</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Repository name</Description>
        </Option>
        <Option Short="" Long="no-compress" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disable compression</Description>
        </Option>
        <Option Short="p" Long="path" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Repository path on the OpenSearch server</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.SnapshotListCommand" 
Settings="SA.OpenSearchTool.Commands.SnapshotListCommand+Settings">
      <Description>List snapshots in a repository</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="r" Long="repo" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Repository name</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.SnapshotCreateCommand" 
Settings="SA.OpenSearchTool.Commands.SnapshotCreateCommand+Settings">
      <Description>Create a new snapshot</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="include-global-state" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Include global cluster state</Description>
        </Option>
        <Option Short="i" Long="indices" Value="PATTERN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Index pattern to include (default: *ps-*)</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="n" Long="name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Snapshot name</Description>
        </Option>
        <Option Short="" Long="no-wait" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Don't wait for snapshot to complete</Description>
        </Option>
        <Option Short="r" Long="repo" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Repository name</Description>
        </Option>
      </Parameters>
    </Command>
    <!--STATUS-->
    <Command Name="status" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.SnapshotStatusCommand" 
Settings="SA.OpenSearchTool.Commands.SnapshotStatusCommand+Settings">
      <Description>Get snapshot status</Description>
      <Parameters>
        <Argument Name="SNAPSHOT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Snapshot name</Description>
        </Argument>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="r" Long="repo" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Repository name</Description>
        </Option>
      </Parameters>
    </Command>
    <!--COPY-->
    <Command Name="copy" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.SnapshotCopyCommand" 
Settings="SA.OpenSearchTool.Commands.SnapshotCopyCommand+Settings">
      <Description>Copy snapshot files to local path</Description>
      <Parameters>
        <Option Short="d" Long="dest" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Destination directory path</Description>
        </Option>
        <Option Short="s" Long="source" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Source directory path</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESTORE-->
    <Command Name="restore" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.SnapshotRestoreCommand" 
Settings="SA.OpenSearchTool.Commands.SnapshotRestoreCommand+Settings">
      <Description>Restore a snapshot</Description>
      <Parameters>
        <Argument Name="SNAPSHOT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>Snapshot name to restore</Description>
        </Argument>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="include-global-state" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Include global cluster state</Description>
        </Option>
        <Option Short="i" Long="indices" Value="PATTERN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Index pattern to restore (default: all)</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="" Long="no-wait" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Don't wait for restore to complete</Description>
        </Option>
        <Option Short="" Long="rename-pattern" Value="PATTERN" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Regex pattern for renaming indices</Description>
        </Option>
        <Option Short="" Long="rename-replacement" Value="REPLACEMENT" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Replacement string for renaming indices</Description>
        </Option>
        <Option Short="r" Long="repo" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Repository name</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--CLUSTER-->
  <Command Name="cluster" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Configure cluster nodes for snapshot operations</Description>
    <!--__DEFAULT_COMMAND-->
    <Command Name="__default_command" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ClusterCommand" 
Settings="SA.OpenSearchTool.Commands.ClusterCommand+Settings" />
    <!--CONFIGURE-REPO-->
    <Command Name="configure-repo" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ClusterConfigureRepoCommand" 
Settings="SA.OpenSearchTool.Commands.ClusterConfigureRepoCommand+Settings">
      <Description>Configure repository path on all cluster nodes (restarts 
services by default)</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="continue-on-failure" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Continue restarting remaining nodes if one 
fails</Description>
        </Option>
        <Option Short="" Long="no-restart" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Do not restart OpenSearch services after 
configuration</Description>
        </Option>
        <Option Short="" Long="nodes" Value="NODES" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override cluster nodes (comma-separated 
hostnames)</Description>
        </Option>
        <Option Short="p" Long="path" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Repository path to configure on all nodes (e.g., 
/mnt/snapshots)</Description>
        </Option>
        <Option Short="" Long="start-timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Timeout in seconds for starting services</Description>
        </Option>
        <Option Short="" Long="stop-timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Timeout in seconds for stopping services</Description>
        </Option>
      </Parameters>
    </Command>
    <!--VERIFY-NODES-->
    <Command Name="verify-nodes" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ClusterVerifyNodesCommand" 
Settings="SA.OpenSearchTool.Commands.ClusterVerifyNodesCommand+Settings">
      <Description>Verify access to cluster node configuration 
files</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="nodes" Value="NODES" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override cluster nodes (comma-separated 
hostnames)</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LIST-NODES-->
    <Command Name="list-nodes" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ClusterListNodesCommand" 
Settings="SA.OpenSearchTool.Commands.ClusterListNodesCommand+Settings">
      <Description>List cluster nodes and their configuration 
paths</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
      </Parameters>
    </Command>
    <!--RESTART-SERVICES-->
    <Command Name="restart-services" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ClusterRestartServicesCommand" 
Settings="SA.OpenSearchTool.Commands.ClusterRestartServicesCommand+Settings">
      <Description>Restart OpenSearch services on cluster nodes</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="continue-on-failure" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Continue restarting remaining nodes if one 
fails</Description>
        </Option>
        <Option Short="" Long="delay" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Delay in seconds between node restarts (rolling 
restart)</Description>
        </Option>
        <Option Short="" Long="nodes" Value="NODES" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override cluster nodes (comma-separated 
hostnames)</Description>
        </Option>
        <Option Short="" Long="start-timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Timeout in seconds for starting services</Description>
        </Option>
        <Option Short="" Long="stop-timeout" Value="SECONDS" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Timeout in seconds for stopping services</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SERVICE-STATUS-->
    <Command Name="service-status" IsBranch="false" 
ClrType="SA.OpenSearchTool.Commands.ClusterServiceStatusCommand" 
Settings="SA.OpenSearchTool.Commands.ClusterServiceStatusCommand+Settings">
      <Description>Check OpenSearch service status on cluster 
nodes</Description>
      <Parameters>
        <Option Short="c" Long="connection" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Connection name or ID (uses default if not 
specified)</Description>
        </Option>
        <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Output as JSON</Description>
        </Option>
        <Option Short="" Long="nodes" Value="NODES" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Override cluster nodes (comma-separated 
hostnames)</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>