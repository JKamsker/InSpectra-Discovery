<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="AWS.Deploy.CLI.Commands.RootCommand" 
Settings="AWS.Deploy.CLI.Commands.Settings.RootCommandSettings">
    <Parameters>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show help and usage information</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DEPLOY-->
  <Command Name="deploy" IsBranch="false" 
ClrType="AWS.Deploy.CLI.Commands.DeployCommand" 
Settings="AWS.Deploy.CLI.Commands.Settings.DeployCommandSettings">
    <Description>Inspect, build, and deploy the .NET project to AWS using the 
recommended AWS service.</Description>
    <Parameters>
      <Option Short="" Long="application-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the cloud application. If you choose to deploy via 
CloudFormation, this name will be used to identify the CloudFormation 
stack.</Description>
      </Option>
      <Option Short="" Long="apply" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the deployment settings file to be 
applied.</Description>
      </Option>
      <Option Short="" Long="deployment-project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The absolute or relative path of the CDK project that will 
be used for deployment.</Description>
      </Option>
      <Option Short="d" Long="diagnostics" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Enable diagnostic output.</Description>
      </Option>
      <Option Short="" Long="profile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>AWS credential profile used to make calls to 
AWS.</Description>
      </Option>
      <Option Short="" Long="project-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the project to deploy.</Description>
      </Option>
      <Option Short="" Long="region" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>AWS region to deploy the application to. For example, 
us-west-2.</Description>
      </Option>
      <Option Short="" Long="save-all-settings" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The absolute or the relative JSON file path where the 
deployment settings will be saved. All deployment settings will be 
persisted.</Description>
      </Option>
      <Option Short="" Long="save-settings" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The absolute or the relative JSON file path where the 
deployment settings will be saved. Only the settings modified by the user will 
be persisted.</Description>
      </Option>
      <Option Short="s" Long="silent" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Disable interactivity to execute commands without any 
prompts for user input.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LIST-DEPLOYMENTS-->
  <Command Name="list-deployments" IsBranch="false" 
ClrType="AWS.Deploy.CLI.Commands.ListDeploymentsCommand" 
Settings="AWS.Deploy.CLI.Commands.Settings.ListDeploymentsCommandSettings">
    <Description>List existing deployments.</Description>
    <Parameters>
      <Option Short="d" Long="diagnostics" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Enable diagnostic output.</Description>
      </Option>
      <Option Short="" Long="profile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>AWS credential profile used to make calls to 
AWS.</Description>
      </Option>
      <Option Short="" Long="region" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>AWS region to deploy the application to. For example, 
us-west-2.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DELETE-DEPLOYMENT-->
  <Command Name="delete-deployment" IsBranch="false" 
ClrType="AWS.Deploy.CLI.Commands.DeleteDeploymentCommand" 
Settings="AWS.Deploy.CLI.Commands.Settings.DeleteDeploymentCommandSettings">
    <Description>Delete an existing deployment.</Description>
    <Parameters>
      <Argument Name="deployment-name" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>The name of the deployment to be deleted.</Description>
      </Argument>
      <Option Short="d" Long="diagnostics" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Enable diagnostic output.</Description>
      </Option>
      <Option Short="" Long="profile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>AWS credential profile used to make calls to 
AWS.</Description>
      </Option>
      <Option Short="" Long="project-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to the project to deploy.</Description>
      </Option>
      <Option Short="" Long="region" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>AWS region to deploy the application to. For example, 
us-west-2.</Description>
      </Option>
      <Option Short="s" Long="silent" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Disable interactivity to execute commands without any 
prompts for user input.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DEPLOYMENT-PROJECT-->
  <Command Name="deployment-project" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Save the deployment project inside a user provided directory 
path.</Description>
    <!--GENERATE-->
    <Command Name="generate" IsBranch="false" 
ClrType="AWS.Deploy.CLI.Commands.GenerateDeploymentProjectCommand" 
Settings="AWS.Deploy.CLI.Commands.Settings.GenerateDeploymentProjectCommandSetti
ngs">
      <Description>Save the deployment project inside a user provided directory 
path without proceeding with a deployment</Description>
      <Parameters>
        <Option Short="d" Long="diagnostics" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enable diagnostic output.</Description>
        </Option>
        <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Directory path in which the CDK deployment project will 
be saved.</Description>
        </Option>
        <Option Short="" Long="project-display-name" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>The name of the deployment project that will be displayed
in the list of available deployment options.</Description>
        </Option>
        <Option Short="" Long="project-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to the project to deploy.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--SERVER-MODE-->
  <Command Name="server-mode" IsBranch="false" 
ClrType="AWS.Deploy.CLI.Commands.ServerModeCommand" 
Settings="AWS.Deploy.CLI.Commands.Settings.ServerModeCommandSettings">
    <Description>Launches the tool in a server mode for IDEs like Visual Studio 
to integrate with.</Description>
    <Parameters>
      <Option Short="d" Long="diagnostics" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Enable diagnostic output.</Description>
      </Option>
      <Option Short="" Long="parent-pid" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>The ID of the process that is launching server mode. Server
mode will exit when the parent pid terminates.</Description>
      </Option>
      <Option Short="" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Port the server mode will listen to.</Description>
      </Option>
      <Option Short="" Long="unsecure-mode" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>If set the cli uses an unsecure mode without 
encryption.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>