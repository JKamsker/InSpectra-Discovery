<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="PGrokClient.Commands.ClientStartCommand" 
Settings="PGrokClient.Commands.ClientSettings">
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Increase logging verbosity to show all debug 
logs.</Description>
      </Option>
      <Option Short="l" Long="localAddress" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The local address to use for calls redirections. Specify 
http(s)://my_local_url</Description>
      </Option>
      <Option Short="s" Long="serverAddress" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The server address. Specify http(s)://my_server_url, it 
will switch automatically to ws(s) protocol</Description>
      </Option>
      <Option Short="t" Long="tunnelId" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The tunnelId to use. will represents serviceName on server 
side.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--START-->
  <Command Name="start" IsBranch="false" 
ClrType="PGrokClient.Commands.ClientStartCommand" 
Settings="PGrokClient.Commands.ClientSettings">
    <Description>Start the client</Description>
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Increase logging verbosity to show all debug 
logs.</Description>
      </Option>
      <Option Short="l" Long="localAddress" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The local address to use for calls redirections. Specify 
http(s)://my_local_url</Description>
      </Option>
      <Option Short="s" Long="serverAddress" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The server address. Specify http(s)://my_server_url, it 
will switch automatically to ws(s) protocol</Description>
      </Option>
      <Option Short="t" Long="tunnelId" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The tunnelId to use. will represents serviceName on server 
side.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="start --tunnelId=1234 
--serverAddress=https://pgrok.azurecontainerapps.io 
--localAddress=http://localhost:5000" />
    </Examples>
  </Command>
