      </Option>
      <Option Short="s" Long="serverAddress" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The server address. Specify http(s)://my_server_url, it 
will switch automatically to ws(s) protocol</Description>
      </Option>
      <Option Short="t" Long="tunnelId" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The tunnelId to use. will represents serviceName on server 
