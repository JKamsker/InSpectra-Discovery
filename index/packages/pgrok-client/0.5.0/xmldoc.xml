<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="PGrokClient.Commands.ClientStartCommand" 
Settings="PGrokClient.Commands.ClientSettings">
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Increase logging verbosity to show all debug 
logs.</Description>
      </Option>
      <Option Short="l" Long="localAddress" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The local address to use for calls redirections. Specify 
http(s)://my_local_url</Description>
      </Option>
      <Option Short="r" Long="proxyPort" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Listen on this port to proxy calls to 
serverAddress.</Description>
      </Option>
      <Option Short="s" Long="serverAddress" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The server address. Specify http(s)://my_server_url, it 
will switch automatically to ws(s) protocol</Description>
      </Option>
      <Option Short="t" Long="tunnelId" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The tunnelId to use. will represents serviceName on server 
side.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--START-SERVER-->
  <Command Name="start-server" IsBranch="false" 
ClrType="PGrok.Server.Commands.ServerStartCommand" 
Settings="PGrok.Server.Commands.ServerSettings">
    <Description>Start the server in http mode</Description>
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Increase logging verbosity to show all debug 
logs.</Description>
      </Option>
      <Option Short="l" Long="localhost" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Use localhost instead of</Description>
      </Option>
      <Option Short="p" Long="port" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>The port to listen. 8080 is use if not 
provided.</Description>
      </Option>
      <Option Short="r" Long="proxyPort" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>The port use to call local services. all services should 
listen on this port</Description>
      </Option>
      <Option Short="s" Long="singleTunnel" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Use single tunnel. Useful for service 
replacement</Description>
      </Option>
      <Option Short="t" Long="tcpPort" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>The port to listen. Switch to tcp mode when 
specified</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="start-server --port=8080 --localhost" />
      <Example commandLine="start-server --port=8080 --tcpPort=3306 --localhost"
/>
    </Examples>
  </Command>
