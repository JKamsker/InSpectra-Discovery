<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INFO-->
  <Command Name="info" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.InfoCommand" 
Settings="Ivy.Inspector.Excel.Commands.InfoSettings">
    <Description>Workbook overview: sheets, tables, named ranges, 
images.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--SHEETS-->
  <Command Name="sheets" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.SheetsCommand" 
Settings="Ivy.Inspector.Excel.Commands.SheetsSettings">
    <Description>List sheets with dimensions and visibility.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--TABLES-->
  <Command Name="tables" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.TablesCommand" 
Settings="Ivy.Inspector.Excel.Commands.TablesSettings">
    <Description>List structured tables with columns and types.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--NAMES-->
  <Command Name="names" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.NamesCommand" 
Settings="Ivy.Inspector.Excel.Commands.NamesSettings">
    <Description>List named ranges with addresses and values.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--RANGE-->
  <Command Name="range" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.RangeCommand" 
Settings="Ivy.Inspector.Excel.Commands.RangeSettings">
    <Description>Read cell values from a range as a grid.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="range" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Range reference (e.g. Sheet1!A1:D10 or 
A1:D10)</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--CELL-->
  <Command Name="cell" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.CellCommand" 
Settings="Ivy.Inspector.Excel.Commands.CellSettings">
    <Description>Detailed cell info: value, formula, type, format, 
styling.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="ref" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Cell reference (e.g. Sheet1!B15 or B15)</Description>
      </Argument>
      <Option Short="" Long="include-styling" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include styling info (borders, foreground, background, 
typography)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--TABLE-->
  <Command Name="table" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.TableCommand" 
Settings="Ivy.Inspector.Excel.Commands.TableSettings">
    <Description>Read a structured table by name with pagination.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="name" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Table name</Description>
      </Argument>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of rows to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of rows to skip</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SEARCH-->
  <Command Name="search" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.SearchCommand" 
Settings="Ivy.Inspector.Excel.Commands.SearchSettings">
    <Description>Find cells containing a value.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="query" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Value to search for</Description>
      </Argument>
      <Option Short="" Long="include-styling" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include styling info (borders, foreground, background, 
typography)</Description>
      </Option>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of matches to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of matches to skip</Description>
      </Option>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--FORMULAS-->
  <Command Name="formulas" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.FormulasCommand" 
Settings="Ivy.Inspector.Excel.Commands.FormulasSettings">
    <Description>List all formula cells with cached values.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of formulas to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of formulas to skip</Description>
      </Option>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--IMAGES-->
  <Command Name="images" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.ImagesCommand" 
Settings="Ivy.Inspector.Excel.Commands.ImagesSettings">
    <Description>Extract embedded images as base64.</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of images to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of images to skip</Description>
      </Option>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
</Model>