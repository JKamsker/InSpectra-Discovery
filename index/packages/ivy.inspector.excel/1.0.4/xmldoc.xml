  <Command Name="pivots" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.PivotsCommand" 
Settings="Ivy.Inspector.Excel.Commands.PivotsSettings">
    <Description>List pivot tables with fields and source ranges</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--RANGE-->
  <Command Name="range" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.RangeCommand" 
Settings="Ivy.Inspector.Excel.Commands.RangeSettings">
    <Description>Read cell values from a range as a grid</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="range" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Range reference (e.g. Sheet1!A1:D10 or 
A1:D10)</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--SEARCH-->
  <Command Name="search" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.SearchCommand" 
Settings="Ivy.Inspector.Excel.Commands.SearchSettings">
    <Description>Find cells containing a value</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="query" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Value to search for</Description>
      </Argument>
      <Option Short="" Long="include-styling" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include styling info (borders, foreground, background, 
typography)</Description>
      </Option>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of matches to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of matches to skip</Description>
      </Option>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--SHEETS-->
  <Command Name="sheets" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.SheetsCommand" 
Settings="Ivy.Inspector.Excel.Commands.SheetsSettings">
    <Description>List sheets with dimensions and visibility</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="layout" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Include column widths and row heights for the used 
range</Description>
      </Option>
      <Option Short="" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--STATS-->
  <Command Name="stats" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.StatsCommand" 
Settings="Ivy.Inspector.Excel.Commands.StatsSettings">
    <Description>Descriptive statistics (min, max, sum, mean) for a numeric 
