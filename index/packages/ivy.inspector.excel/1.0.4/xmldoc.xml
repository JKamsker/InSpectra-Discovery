<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CELL-->
  <Command Name="cell" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.CellCommand" 
Settings="Ivy.Inspector.Excel.Commands.CellSettings">
    <Description>Detailed cell info: value, formula, type, format (use 
--include-styling for borders, colors, typography)</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="ref" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Cell reference (e.g. Sheet1!B15 or B15)</Description>
      </Argument>
      <Option Short="" Long="include-styling" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include styling info (borders, foreground, background, 
typography)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CHARTS-->
  <Command Name="charts" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.ChartsCommand" 
Settings="Ivy.Inspector.Excel.Commands.ChartsSettings">
    <Description>List chart objects with type, title, and series 
info</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DISTINCT-->
  <Command Name="distinct" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.DistinctCommand" 
Settings="Ivy.Inspector.Excel.Commands.DistinctSettings">
    <Description>Unique values with counts from a range</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="range" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Range reference (e.g. Sheet1!B1:B100 or B:B)</Description>
      </Argument>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum values to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of values to skip</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DOCS-->
  <Command Name="docs" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.DocsCommand" 
Settings="Ivy.Inspector.Excel.Commands.DocsSettings">
    <Description>Output full tool specification in YAML</Description>
  </Command>
  <!--FORMULAS-->
  <Command Name="formulas" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.FormulasCommand" 
Settings="Ivy.Inspector.Excel.Commands.FormulasSettings">
    <Description>List all formula cells with cached values</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of formulas to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of formulas to skip</Description>
      </Option>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--HISTOGRAM-->
  <Command Name="histogram" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.HistogramCommand" 
Settings="Ivy.Inspector.Excel.Commands.HistogramSettings">
    <Description>Value distribution histogram for numeric, datetime, or boolean 
ranges</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Argument Name="range" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Range reference (e.g. Sheet1!D2:D100)</Description>
      </Argument>
      <Option Short="" Long="bins" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of bins (default 10)</Description>
      </Option>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum bins to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of bins to skip</Description>
      </Option>
      <Option Short="" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Data type: numeric, datetime, boolean</Description>
      </Option>
    </Parameters>
  </Command>
  <!--IMAGES-->
  <Command Name="images" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.ImagesCommand" 
Settings="Ivy.Inspector.Excel.Commands.ImagesSettings">
    <Description>Extract embedded images as base64</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the .xlsx file</Description>
      </Argument>
      <Option Short="" Long="limit" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Maximum number of images to return</Description>
      </Option>
      <Option Short="" Long="offset" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of images to skip</Description>
      </Option>
      <Option Short="" Long="sheet" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Filter by sheet name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" 
ClrType="Ivy.Inspector.Excel.Commands.InfoCommand" 
Settings="Ivy.Inspector.Excel.Commands.InfoSettings">
    <Description>Workbook overview: sheets, tables, named ranges, 
