<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LOOK-->
  <Command Name="look" IsBranch="false" 
ClrType="PokedexCLI.Controllers.Commands.LookCommand" 
Settings="PokedexCLI.Models.Commands.LookCommandSettings">
    <Description>Consulta informações sobre o pokemon</Description>
    <Parameters>
      <Argument Name="pokemon" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>O nome do pokemon que será consultado</Description>
      </Argument>
      <Option Short="j" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Especifica se as informações serão exibidas no formato 
JSON</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="look" />
      <Example commandLine="pikachu" />
      <Example commandLine="--json" />
      <Example commandLine="info" />
      <Example commandLine="pikachu" />
    </Examples>
  </Command>
</Model>