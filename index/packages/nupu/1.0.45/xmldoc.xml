<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="NuPU.UpdateCommand" 
Settings="NuPU.UpdateCommand+UpdateCommandSettings">
    <Parameters>
      <Option Short="d" Long="directory" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>A root directory to search (default: current 
directory)</Description>
      </Option>
      <Option Short="i" Long="includeprerelease" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include prerelease versions in suggested updates (default: 
true)</Description>
      </Option>
      <Option Short="" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Run the tool in NuGet interactive mode which will prompt 
you to log in and more (default: false)</Description>
      </Option>
      <Option Short="p" Long="package" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>A NuGet package to update (default: all)</Description>
      </Option>
      <Option Short="r" Long="recursive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include subdirectories when looking for csproj files 
(default: true)</Description>
      </Option>
      <Option Short="v" Long="version" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Show version information</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="--directory c:\myproject" />
      <Example commandLine="--recursive false" />
      <Example commandLine="--package System.Text.Json" />
      <Example commandLine="--includeprerelease false" />
      <Example commandLine="--interactive true" />
      <Example commandLine="-d c:\myproject" />
      <Example commandLine="-r false" />
      <Example commandLine="-p System.Text.Json" />
      <Example commandLine="-i false" />
      <Example commandLine="--interactive true" />
    </Examples>
  </Command>
</Model>