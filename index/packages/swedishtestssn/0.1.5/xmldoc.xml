  <!--SWETESTSSN-->
  <Command Name="swetestssn" IsBranch="false" 
ClrType="SwedishTestSsn.TestSsnCommand" 
Settings="SwedishTestSsn.TestSsnCommand+Settings">
    <Description>Get swedish test social security numbers from The Swedish Tax 
Agency (Skatteverket). Using their publi API</Description>
    <Parameters>
      <Argument Name="Pattern" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Test social security number. Regular expressions may be 
used</Description>
      </Argument>
      <Option Short="" Long="json" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>output as json</Description>
      </Option>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32" />
      <Option Short="o" Long="offset" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32" />
    </Parameters>
    <Examples>
      <Example commandLine="swetestssn" />
      <Example commandLine="^1988.*" />
      <Example commandLine="--limit" />
      <Example commandLine="10" />
      <Example commandLine="swetestssn" />
      <Example commandLine="^198807.*" />
      <Example commandLine="--limit" />
      <Example commandLine="10" />
      <Example commandLine="--json" />
      <Example commandLine="swetestssn" />
      <Example commandLine="^1988.*" />
      <Example commandLine="--limit" />
      <Example commandLine="10" />
      <Example commandLine="--offset" />
      <Example commandLine="10" />
    </Examples>
  </Command>
