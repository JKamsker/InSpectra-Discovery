    <!--LOGIN-->
    <Command Name="login" IsBranch="false" 
ClrType="Devlooped.OpenAI.Auth.LoginCommand" 
Settings="Devlooped.OpenAI.Auth.LoginCommand+LoginSettings">
      <Description>Authenticate to OpenAI. 
Supports API key autentication using the Git Credential Manager for storage.
Switch easily between keys by just specifying the project name after initial 
login with `--with-token`.
Alternatively, openai will use the authentication token found in environment 
variables with the name `OPENAI_API_KEY`.
This method is most suitable for "headless" use such as in automation.
For example, to use openai in GitHub Actions, add `OPENAI_API_KEY: ${{ 
secrets.OPENAI_API_KEY }}` to "env".</Description>
      <Parameters>
        <Argument Name="project" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>OpenAI project the API key belongs to</Description>
        </Argument>
        <Option Short="" Long="with-token" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Read token from standard input</Description>
        </Option>
      </Parameters>
    </Command>
    <!--LOGOUT-->
    <Command Name="logout" IsBranch="false" 
ClrType="Devlooped.OpenAI.Auth.LogoutCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
      <Description>Log out of api.openai.com</Description>
    </Command>
