<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="Devrock.Cli.Commands.Init" 
Settings="Devrock.Cli.Commands.Init+InitSettings">
    <Description>Initialize or reconfigure the current project.</Description>
  </Command>
  <!--CONVERT-->
  <Command Name="convert" IsBranch="false" 
ClrType="Devrock.Cli.Commands.Convert" 
Settings="Devrock.Cli.Commands.Convert+ConvertSettings">
    <Description>Convert a model coordinate.</Description>
    <Examples>
      <Example commandLine="convert &lt;x y z&gt;" />
    </Examples>
  </Command>
  <!--IMAGE-->
  <Command Name="image" IsBranch="false" 
ClrType="Devrock.Cli.Commands.ImageTools" 
Settings="Devrock.Cli.Commands.ImageTools+ImageToolsSettings">
    <Description>Select an image related tool.</Description>
  </Command>
  <!--INSTALL-->
  <Command Name="install" IsBranch="false" 
ClrType="Devrock.Cli.Commands.Install" 
Settings="Devrock.Cli.Commands.Install+InstallSettings">
    <Description>Install a .mcaddon (resource/behavior pack) or .mcworld into 
the com.mojang directory.</Description>
    <Parameters>
      <Argument Name="path" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="o" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean" />
    </Parameters>
    <Examples>
      <Example commandLine="install &lt;path-to-.mcaddon|.mcworld&gt;" />
    </Examples>
  </Command>
  <!--PAINTIMAGERED-->
  <Command Name="paintImageRed" IsBranch="false" 
ClrType="Devrock.Cli.Commands.PaintImageRed" 
Settings="Devrock.Cli.Commands.PaintImageRed+PaintImageRedSettings">
    <Description>Paint an image red.</Description>
  </Command>
</Model>