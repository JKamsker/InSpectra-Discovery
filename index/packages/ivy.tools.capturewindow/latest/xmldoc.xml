<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CAPTURE-->
  <Command Name="capture" IsBranch="false" 
ClrType="Ivy.Tools.CaptureWindow.Commands.CaptureCommand" 
Settings="Ivy.Tools.CaptureWindow.Commands.CaptureCommand+Settings">
    <Description>Capture a window screenshot</Description>
    <Parameters>
      <Option Short="b" Long="background" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Background color (transparent, black, white, or hex color 
like #FF0000). Default: transparent</Description>
      </Option>
      <Option Short="c" Long="class" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Window class identifier</Description>
      </Option>
      <Option Short="i" Long="interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Interactive window selection</Description>
      </Option>
      <Option Short="m" Long="margins" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Capture margins in pixels for transparent shadows (format: 
left,top,right,bottom or single value for all sides)</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output filename</Description>
      </Option>
      <Option Short="r" Long="resize" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Resize window before capture (format: widthxheight, e.g., 
1920x1080)</Description>
      </Option>
      <Option Short="t" Long="title" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Window title</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="capture" />
      <Example commandLine="--interactive" />
      <Example commandLine="capture" />
      <Example commandLine="--title" />
      <Example commandLine="Notepad" />
      <Example commandLine="--output" />
      <Example commandLine="notepad.png" />
      <Example commandLine="capture" />
      <Example commandLine="--class" />
      <Example commandLine="Notepad" />
      <Example commandLine="capture" />
      <Example commandLine="--resize" />
      <Example commandLine="1920x1080" />
      <Example commandLine="capture" />
      <Example commandLine="--shadows" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="Ivy.Tools.CaptureWindow.Commands.ListCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>List all visible windows</Description>
    <Examples>
      <Example commandLine="list" />
    </Examples>
  </Command>
