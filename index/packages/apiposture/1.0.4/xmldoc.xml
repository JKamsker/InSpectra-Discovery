<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="ApiPosture.Commands.ScanCommand" 
Settings="ApiPosture.Commands.ScanCommand+Settings">
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the project or directory to scan</Description>
      </Argument>
      <Option Short="" Long="api-style" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Filter by API style (controller, minimal)</Description>
      </Option>
      <Option Short="" Long="classification" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Filter by security classification (public, authenticated, 
role-restricted, policy-restricted)</Description>
      </Option>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to configuration file (.apiposture.json)</Description>
      </Option>
      <Option Short="" Long="controller" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Filter by controller name</Description>
      </Option>
      <Option Short="" Long="fail-on" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Fail with exit code 1 if findings at or above this 
severity</Description>
      </Option>
      <Option Short="" Long="group-by" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Group endpoints by field (controller, classification, 
severity, method)</Description>
      </Option>
      <Option Short="" Long="group-findings-by" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Group findings by field (severity, controller, 
classification)</Description>
      </Option>
      <Option Short="" Long="method" Value="NULL" Required="false" Kind="vector"
ClrType="System.String[]">
        <Description>Filter by HTTP method (GET, POST, PUT, DELETE, 
PATCH)</Description>
      </Option>
      <Option Short="" Long="no-color" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Disable colored output</Description>
      </Option>
      <Option Short="" Long="no-icons" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Disable icons/emojis in output</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format (terminal, json, markdown)</Description>
      </Option>
      <Option Short="f" Long="output-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path</Description>
      </Option>
      <Option Short="" Long="route-contains" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter routes containing substring 
(case-insensitive)</Description>
      </Option>
      <Option Short="" Long="rule" Value="NULL" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Filter by rule ID (AP001, AP002, etc.)</Description>
      </Option>
      <Option Short="" Long="severity" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Minimum severity to report (info, low, medium, high, 
critical)</Description>
      </Option>
      <Option Short="" Long="sort-by" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sort by field (severity, route, method, classification, 
controller, location)</Description>
      </Option>
      <Option Short="" Long="sort-dir" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sort direction (asc, desc)</Description>
      </Option>
    </Parameters>
  </Command>
