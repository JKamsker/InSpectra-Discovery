  <!--LICENSE-->
  <Command Name="license" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage ApiPosture Pro license</Description>
    <!--ACTIVATE-->
    <Command Name="activate" IsBranch="false" 
ClrType="ApiPosture.Commands.LicenseActivateCommand" 
Settings="ApiPosture.Commands.LicenseActivateCommand+Settings">
      <Description>Activate a license key</Description>
      <Parameters>
        <Argument Name="key" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
          <Description>The license key to activate</Description>
        </Argument>
      </Parameters>
      <Examples>
        <Example commandLine="license" />
        <Example commandLine="activate" />
        <Example commandLine="XXXX-XXXX-XXXX-XXXX" />
      </Examples>
    </Command>
    <!--DEACTIVATE-->
    <Command Name="deactivate" IsBranch="false" 
ClrType="ApiPosture.Commands.LicenseDeactivateCommand" 
Settings="ApiPosture.Commands.LicenseDeactivateCommand+Settings">
      <Description>Deactivate the current license</Description>
    </Command>
    <!--STATUS-->
    <Command Name="status" IsBranch="false" 
ClrType="ApiPosture.Commands.LicenseStatusCommand" 
Settings="ApiPosture.Commands.LicenseStatusCommand+Settings">
      <Description>Show current license status</Description>
    </Command>
