<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--RUN-->
  <Command Name="run" IsBranch="false" ClrType="dothttp.Commands.RunCommand" 
Settings="dothttp.Commands.RunCommand+Settings">
    <Parameters>
      <Argument Name="Path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="n" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Sets name of the test plan</Description>
      </Option>
      <Option Short="q" Long="no-progress" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Runs without writing progress to stdout</Description>
      </Option>
      <Option Short="r" Long="report" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specify path to the report file (default junit xml 
format)</Description>
      </Option>
    </Parameters>
  </Command>
</Model>