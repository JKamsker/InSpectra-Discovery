  "opencli": "0.1-draft",
  "info": {
    "title": "peek-at-changelog",
    "version": "1.0.0-preview.0.9",
    "description": "Allows one to extract the release notes from a changelog, think CHANGELOG.md according to the https://keepachangelog.com format, for a particular version or fallback to the Unreleased notes if none specified. How you compose the changelog is out of scope. What you do with the output of the tool is out of scope."
