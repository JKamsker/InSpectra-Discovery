<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="SonicGD.PackagesToProjectsTool.PackagesToProjectsCommand" 
Settings="SonicGD.PackagesToProjectsTool.PackagesToProjectsCommandSettings">
    <Parameters>
      <Argument Name="path" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to solution</Description>
      </Argument>
      <Option Short="f" Long="" Value="NULL" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Folders to search projects in</Description>
      </Option>
      <Option Short="r" Long="" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Recursively replace packages in all dependent 
projects</Description>
      </Option>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Dry run. Don't change relad files</Description>
      </Option>
      <Option Short="" Long="no-cache" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Don't use cache. Reread all projects metadata</Description>
      </Option>
    </Parameters>
  </Command>
</Model>