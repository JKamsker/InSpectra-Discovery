<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SYNC-->
  <Command Name="sync" IsBranch="false" 
ClrType="Faborite.Cli.Commands.SyncCommand" 
Settings="Faborite.Cli.Commands.SyncSettings">
    <Description>Sync lakehouse tables to local storage</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to config file (faborite.json)</Description>
      </Option>
      <Option Short="" Long="date-column" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Date column for 'recent' strategy</Description>
      </Option>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format (parquet, delta, csv, json, 
duckdb)</Description>
      </Option>
      <Option Short="l" Long="lakehouse" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Lakehouse ID (GUID)</Description>
      </Option>
      <Option Short="" Long="no-schema" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Don't export table schemas</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory</Description>
      </Option>
      <Option Short="p" Long="parallel" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of tables to sync in parallel</Description>
      </Option>
      <Option Short="n" Long="rows" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>Number of rows to sample per table</Description>
      </Option>
      <Option Short="" Long="skip" Value="NULL" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Tables to skip (can be repeated)</Description>
      </Option>
      <Option Short="s" Long="strategy" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sampling strategy (random, recent, head, tail, stratified, 
query, full)</Description>
      </Option>
      <Option Short="t" Long="table" Value="NULL" Required="false" Kind="vector"
ClrType="System.String[]">
        <Description>Specific tables to sync (can be repeated)</Description>
      </Option>
      <Option Short="w" Long="workspace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Workspace ID (GUID)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="sync" />
      <Example commandLine="-w" />
      <Example commandLine="&lt;workspace-id&gt;" />
      <Example commandLine="-l" />
      <Example commandLine="&lt;lakehouse-id&gt;" />
      <Example commandLine="sync" />
      <Example commandLine="--config" />
      <Example commandLine="faborite.json" />
      <Example commandLine="sync" />
      <Example commandLine="-w" />
      <Example commandLine="&lt;id&gt;" />
      <Example commandLine="-l" />
      <Example commandLine="&lt;id&gt;" />
      <Example commandLine="--format" />
      <Example commandLine="duckdb" />
    </Examples>
  </Command>
  <!--LIST-TABLES-->
  <Command Name="list-tables" IsBranch="false" 
ClrType="Faborite.Cli.Commands.ListTablesCommand" 
Settings="Faborite.Cli.Commands.ListTablesSettings">
    <Description>List all tables in a lakehouse</Description>
    <Parameters>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to config file</Description>
      </Option>
      <Option Short="l" Long="lakehouse" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Lakehouse ID (GUID)</Description>
      </Option>
      <Option Short="w" Long="workspace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Workspace ID (GUID)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list-tables" />
      <Example commandLine="-w" />
      <Example commandLine="&lt;workspace-id&gt;" />
      <Example commandLine="-l" />
      <Example commandLine="&lt;lakehouse-id&gt;" />
    </Examples>
  </Command>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Faborite.Cli.Commands.InitCommand" 
Settings="Faborite.Cli.Commands.InitSettings">
    <Description>Generate a sample configuration file</Description>
    <Parameters>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Overwrite existing config file</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output path for config file</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="init" />
      <Example commandLine="init" />
      <Example commandLine="-o" />
      <Example commandLine="my-config.json" />
    </Examples>
  </Command>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" 
ClrType="Faborite.Cli.Commands.StatusCommand" 
Settings="Faborite.Cli.Commands.StatusSettings">
    <Description>Show status of locally synced data</Description>
    <Parameters>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Local output directory to check</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="status" />
      <Example commandLine="status" />
      <Example commandLine="-p" />
      <Example commandLine="./my_lakehouse" />
    </Examples>
  </Command>
</Model>