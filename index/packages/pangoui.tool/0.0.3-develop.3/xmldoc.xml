<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="Pango.Commands.DownloadComponent" 
Settings="Pango.Commands.DownloadComponentSettings">
    <Description>Downloads a component from the specified 
registry.</Description>
    <Parameters>
      <Argument Name="ARGUMENT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the component to download.</Description>
      </Argument>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target namespace.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output folder for the component download.</Description>
      </Option>
      <Option Short="" Long="registry-uri" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>URI of the registry to fetch the component.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="add" />
      <Example commandLine="button" />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" ClrType="Pango.Commands.ListComponents" 
Settings="Pango.Commands.ListComponentsSettings">
    <Description>List components from the specified registry</Description>
    <Parameters>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target namespace.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output folder for the component download.</Description>
      </Option>
      <Option Short="" Long="registry-uri" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>URI of the registry to fetch the component.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INIT-->
  <Command Name="init" IsBranch="false" 
ClrType="Pango.Commands.ConfigurationInit" 
Settings="Pango.Commands.ConfigurationInitSettings">
    <Description>Creates a Pango configuration file.</Description>
    <Parameters>
      <Option Short="c" Long="components" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Components to download.</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target namespace.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target output path.</Description>
      </Option>
      <Option Short="" Long="registry-uri" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>URI of the registry to fetch the component.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="init" />
      <Example commandLine="-n MyProject.Components" />
      <Example commandLine="-o src/MyProject.Components" />
      <Example commandLine="--registry-uri https://raw.github.com/repo" />
    </Examples>
  </Command>
  <!--REGISTRY-->
  <Command Name="registry" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Tools for managing registry</Description>
    <!--CREATE-METADATA-->
    <Command Name="create-metadata" IsBranch="false" 
ClrType="Pango.Commands.ComponentRegisterCreation" 
Settings="Pango.Commands.ComponentRegisterCreation+Settings">
      <Description>Creates registry metadata for the given 
components.</Description>
      <Parameters>
        <Argument Name="ARGUMENT" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
          <Description>Folder with multiple components or single 
component.</Description>
        </Argument>
        <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output folder for the components 
registration.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="registry" />
        <Example commandLine="create-metadata" />
        <Example commandLine="Components/*" />
        <Example commandLine="-o" />
        <Example commandLine="dist/components" />
        <Example commandLine="--registry-uri" />
        <Example commandLine="https://raw.github.com/repo" />
      </Examples>
    </Command>
  </Command>
</Model>