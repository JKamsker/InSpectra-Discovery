<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="Pango.Commands.DownloadComponent" 
Settings="Pango.Commands.DownloadComponentSettings">
    <Parameters>
      <Argument Name="ARGUMENT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Name of the component to download.</Description>
      </Argument>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target namespace.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output folder for the component download.</Description>
      </Option>
      <Option Short="" Long="registry-uri" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>URI of the registry to fetch the component.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REGISTRY-->
  <Command Name="registry" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--CREATE-METADATA-->
    <Command Name="create-metadata" IsBranch="false" 
ClrType="Pango.Commands.ComponentRegisterCreation" 
Settings="Pango.Commands.ComponentRegisterCreation+Settings">
      <Parameters>
        <Argument Name="ARGUMENT" Position="0" Required="true" Kind="vector" 
ClrType="System.String[]">
          <Description>Folder with multiple components or single 
component.</Description>
        </Argument>
        <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Output folder for the components 
registration.</Description>
        </Option>
        <Option Short="" Long="registry-uri" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>URI to upload with your components.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>