<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="Gitor.ConsoleApp.Commands.InteractiveCommand" 
Settings="Gitor.ConsoleApp.Commands.InteractiveCommand+Settings">
    <Parameters>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter repositories by group name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--PULL-->
  <Command Name="pull" IsBranch="false" 
ClrType="Gitor.ConsoleApp.Commands.PullCommand" 
Settings="Gitor.ConsoleApp.Commands.PullCommand+Settings">
    <Description>Pull all repositories</Description>
    <Parameters>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter repositories by group name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CHECKOUT-->
  <Command Name="checkout" IsBranch="false" 
ClrType="Gitor.ConsoleApp.Commands.CheckoutCommand" 
Settings="Gitor.ConsoleApp.Commands.CheckoutCommand+Settings">
    <Description>Checkout a specific branch in all repositories</Description>
    <Parameters>
      <Argument Name="branch" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The branch to checkout</Description>
      </Argument>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter repositories by group name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--PRUNE-->
  <Command Name="prune" IsBranch="false" 
ClrType="Gitor.ConsoleApp.Commands.PruneCommand" 
Settings="Gitor.ConsoleApp.Commands.PruneCommand+Settings">
    <Description>Delete gone branches</Description>
    <Parameters>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter repositories by group name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" 
ClrType="Gitor.ConsoleApp.Commands.StatusCommand" 
Settings="Gitor.ConsoleApp.Commands.StatusCommand+Settings">
    <Description>Show repository status table</Description>
    <Parameters>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter repositories by group name</Description>
      </Option>
    </Parameters>
  </Command>
  <!--COMPARE-->
  <Command Name="compare" IsBranch="false" 
ClrType="Gitor.ConsoleApp.Commands.CompareCommand" 
Settings="Gitor.ConsoleApp.Commands.CompareCommand+Settings">
    <Description>Compare two branches</Description>
    <Parameters>
      <Argument Name="a" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The first branch to compare</Description>
      </Argument>
      <Argument Name="b" Position="1" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The second branch to compare</Description>
      </Argument>
      <Option Short="g" Long="group" Value="GROUP" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Filter repositories by group name</Description>
      </Option>
    </Parameters>
  </Command>
</Model>