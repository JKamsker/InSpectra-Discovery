<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SIMULATE-->
  <Command Name="simulate" IsBranch="false" 
ClrType="devdeer.tools.tocpm.Commands.SimulateCommand" 
Settings="devdeer.tools.tocpm.Models.DefaultSettings">
    <Description>Simulates the operation at the provided location and writes the
results to the console.</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="b" Long="backup" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>If set, the command will generate a backup of every project
file before editing it.</Description>
      </Option>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>If set, the command executes without any security check 
from the user</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="simulate" />
      <Example commandLine="." />
    </Examples>
  </Command>
  <!--EXECUTE-->
  <Command Name="execute" IsBranch="false" 
ClrType="devdeer.tools.tocpm.Commands.ExecuteCommand" 
Settings="devdeer.tools.tocpm.Models.DefaultSettings">
    <Description>Executes a real run at the specified location.</Description>
    <Parameters>
      <Argument Name="PATH" Position="0" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="b" Long="backup" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>If set, the command will generate a backup of every project
file before editing it.</Description>
      </Option>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>If set, the command executes without any security check 
from the user</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="execute" />
      <Example commandLine="C:\temp\project" />
      <Example commandLine="execute" />
      <Example commandLine="C:\temp\project" />
      <Example commandLine="-f" />
    </Examples>
  </Command>
</Model>