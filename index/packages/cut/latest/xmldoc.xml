<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" ClrType="Cut.Commands.VersionCommand"
Settings="Cut.Commands.VersionCommand+Settings">
    <Description>Displays the current cut cli version.</Description>
  </Command>
  <!--AUTH-->
  <Command Name="auth" IsBranch="false" ClrType="Cut.Commands.AuthCommand" 
Settings="Cut.Commands.AuthCommand+Settings">
    <Description>Authenticates to a Contentful account.</Description>
  </Command>
  <!--INFO-->
  <Command Name="info" IsBranch="false" ClrType="Cut.Commands.InfoCommand" 
Settings="Cut.Commands.InfoCommand+Settings">
    <Description>Display information about the default or specified 
space.</Description>
  </Command>
  <!--DOWNLOAD-->
  <Command Name="download" IsBranch="false" 
ClrType="Cut.Commands.DownloadCommand" 
Settings="Cut.Commands.DownloadCommand+Settings">
    <Description>Downloads content from the default or specified 
space.</Description>
    <Parameters>
      <Option Short="c" Long="content-type" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specifies the content type to download data 
for</Description>
      </Option>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="System.Nullable`1[[Cut.Lib.OutputAdapters.OutputFileFormat, Cut.Lib, 
Version=1.0.25.0, Culture=neutral, PublicKeyToken=null]]">
        <Description>The output format for the download operation 
(Excel/Csv/Tsv/Json/Yaml)</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The output path and filename for the download 
operation</Description>
      </Option>
    </Parameters>
  </Command>
  <!--UPLOAD-->
  <Command Name="upload" IsBranch="false" ClrType="Cut.Commands.UploadCommand" 
Settings="Cut.Commands.UploadCommand+Settings">
    <Description>Uploads local content to the default or specified 
space.</Description>
    <Parameters>
      <Option Short="a" Long="apply" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Apply and publish all the calculated changes. The default 
behaviour is to only list the detected changes.</Description>
      </Option>
      <Option Short="c" Long="content-type" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specifies the content type to download data 
for</Description>
      </Option>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[Cut.Lib.Enums.InputFileFormat, 
Cut.Lib, Version=1.0.25.0, Culture=neutral, PublicKeyToken=null]]">
        <Description>The format of the file specified in '--path' 
(Excel/Csv/Tsv/Json/Yaml)</Description>
      </Option>
      <Option Short="p" Long="path" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The local path to the file containg the data to 
sync</Description>
      </Option>
    </Parameters>
  </Command>
  <!--GENERATE-->
  <Command Name="generate" IsBranch="false" 
ClrType="Cut.Commands.GenerateCommand" 
Settings="Cut.Commands.GenerateCommand+Settings">
    <Description>Use generative AI to help build drafts of your 
content.</Description>
    <Parameters>
      <Option Short="l" Long="limit" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>The total number of entries to generate content for before 
stopping. Default is five.</Description>
      </Option>
      <Option Short="t" Long="prompt-title" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The title of the Contentful prompt entry to generate 
content from.</Description>
      </Option>
      <Option Short="s" Long="skip" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Int32">
        <Description>The total number of entries to skip before starting. 
Default is zero.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>