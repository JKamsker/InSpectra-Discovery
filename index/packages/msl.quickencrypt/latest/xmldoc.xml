<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="QuickEncrypt.EncryptDecryptCommand" 
Settings="QuickEncrypt.EncryptDecryptCommand+Settings">
    <Parameters>
      <Argument Name="Value" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Value to encrypt/decrypt [green][[Not required for 
config]][/]</Description>
      </Argument>
      <Option Short="d" Long="decrypt" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Decrypts the value 	[blue]Must be Base64 
encoded[/]</Description>
      </Option>
      <Option Short="k" Long="key" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Choose an encryption key.</Description>
      </Option>
      <Option Short="m" Long="mode" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Choose the encryption mode 
[blue][[DES]]|AES[/]</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CONFIG-->
  <Command Name="config" IsBranch="false" ClrType="QuickEncrypt.ConfigCommand" 
Settings="QuickEncrypt.ConfigCommand+Settings">
    <Parameters>
      <Option Short="k" Long="key" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String" />
      <Option Short="m" Long="mode" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Save a default encryption mode 
[blue][[DES]]|AES[/]</Description>
      </Option>
    </Parameters>
  </Command>
</Model>