<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--TRANSPORT-->
  <Command Name="transport" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Manage transport configurations.</Description>
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="BuslyCLI.Commands.Transport.ListTransportsCommand" 
Settings="BuslyCLI.Commands.Transport.ListTransportsSettings">
      <Description>List all configured transports.</Description>
      <Parameters>
        <Option Short="" Long="config" Value="FILE" Required="false" 
Kind="scalar" ClrType="BuslyCLI.TypeConverters.ExpandedPath">
          <Description>Path to the config.yaml file to use for the 
CLI.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CURRENT-->
    <Command Name="current" IsBranch="false" 
ClrType="BuslyCLI.Commands.Transport.CurrentTransportCommand" 
Settings="BuslyCLI.Commands.Transport.CurrentTransportSettings">
      <Description>Display current transport.</Description>
      <Parameters>
        <Option Short="" Long="config" Value="FILE" Required="false" 
Kind="scalar" ClrType="BuslyCLI.TypeConverters.ExpandedPath">
          <Description>Path to the config.yaml file to use for the 
CLI.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DELETE-->
    <Command Name="delete" IsBranch="false" 
ClrType="BuslyCLI.Commands.Transport.DeleteTransportCommand" 
Settings="BuslyCLI.Commands.Transport.DeleteTransportSettings">
      <Description>Delete a configured transport.</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="config" Value="FILE" Required="false" 
Kind="scalar" ClrType="BuslyCLI.TypeConverters.ExpandedPath">
          <Description>Path to the config.yaml file to use for the 
CLI.</Description>
        </Option>
      </Parameters>
    </Command>
    <!--SET-->
    <Command Name="set" IsBranch="false" 
ClrType="BuslyCLI.Commands.Transport.SetTransportCommand" 
Settings="BuslyCLI.Commands.Transport.SetTransportSettings">
      <Description>Set the current transport.</Description>
      <Parameters>
        <Argument Name="name" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
        <Option Short="" Long="config" Value="FILE" Required="false" 
Kind="scalar" ClrType="BuslyCLI.TypeConverters.ExpandedPath">
          <Description>Path to the config.yaml file to use for the 
CLI.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--COMMAND-->
  <Command Name="command" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Operations related to NServiceBus commands.</Description>
    <!--SEND-->
    <Command Name="send" IsBranch="false" 
ClrType="BuslyCLI.Commands.Command.SendCommand" 
Settings="BuslyCLI.Commands.Command.SendCommandSettings">
      <Description>Send a one-way command to an endpoint.</Description>
      <Parameters>
        <Option Short="" Long="config" Value="FILE" Required="false" 
Kind="scalar" ClrType="BuslyCLI.TypeConverters.ExpandedPath">
          <Description>Path to the config.yaml file to use for the 
CLI.</Description>
        </Option>
        <Option Short="c" Long="content-type" Value="CONTENT-TYPE" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>The type of serialization used for the 
message</Description>
        </Option>
        <Option Short="d" Long="destination-endpoint" 
Value="DESTINATION-ENDPOINT" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The destination endpoint to send a message 
to</Description>
        </Option>
        <Option Short="e" Long="enclosed-message-type" 
Value="ENCLOSED-MESSAGE-TYPE" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The fully qualified .NET type name of the enclosed 
message</Description>
        </Option>
        <Option Short="m" Long="message-body" Value="MESSAGE-BODY" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>The content of the message body</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--EVENT-->
  <Command Name="event" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Operations related to NServiceBus events.</Description>
    <!--PUBLISH-->
    <Command Name="publish" IsBranch="false" 
ClrType="BuslyCLI.Commands.Event.PublishCommand" 
Settings="BuslyCLI.Commands.Event.PublishCommandSettings">
      <Description>Publish an event to subscribing endpoints.</Description>
      <Parameters>
        <Option Short="" Long="config" Value="FILE" Required="false" 
Kind="scalar" ClrType="BuslyCLI.TypeConverters.ExpandedPath">
          <Description>Path to the config.yaml file to use for the 
CLI.</Description>
        </Option>
        <Option Short="c" Long="content-type" Value="CONTENT-TYPE" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>The type of serialization used for the 
message</Description>
        </Option>
        <Option Short="e" Long="enclosed-message-type" 
Value="ENCLOSED-MESSAGE-TYPE" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>The fully qualified .NET type name of the enclosed 
message</Description>
        </Option>
        <Option Short="m" Long="message-body" Value="MESSAGE-BODY" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>The content of the message body</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
  <!--DEMO-->
  <Command Name="demo" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Demo mode for the busly quick start guide.</Description>
    <!--START-->
    <Command Name="start" IsBranch="false" 
ClrType="BuslyCLI.Commands.Demo.StartDemoCommand" 
Settings="BuslyCLI.Commands.Transport.CurrentTransportSettings">
      <Description>Start a demo endpoint that can receive any command and a 
single 'Messages.Events.OrderPlaced' event.</Description>
      <Parameters>
        <Option Short="" Long="config" Value="FILE" Required="false" 
Kind="scalar" ClrType="BuslyCLI.TypeConverters.ExpandedPath">
          <Description>Path to the config.yaml file to use for the 
CLI.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>