<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="JInspect.Commands.InspectCommand" 
Settings="JInspect.Commands.InspectSettings">
    <Parameters>
      <Argument Name="FILE" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the JSON file to inspect</Description>
      </Argument>
      <Option Short="f" Long="fuzzy" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Fuzzy-match the filename by searching the current directory
recursively</Description>
      </Option>
      <Option Short="" Long="inner-sample" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of elements to sample in nested arrays</Description>
      </Option>
      <Option Short="d" Long="max-depth" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum nesting depth to traverse</Description>
      </Option>
      <Option Short="s" Long="sample" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of top-level array elements to sample</Description>
      </Option>
    </Parameters>
  </Command>
</Model>