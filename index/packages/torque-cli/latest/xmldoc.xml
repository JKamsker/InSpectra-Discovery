ClrType="Quali.Torque.Cli.Commands.Environments.EnvironmentStartCommand" 
Settings="Quali.Torque.Cli.Models.Settings.Environments.EnvironmentStartUserCont
extSettings">
      <Parameters>
        <Argument Name="BLUEPRINT-NAME" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
          <Description>The bluerpint name to run an envrironment 
from</Description>
        </Argument>
        <Option Short="b" Long="branch" Value="BRANCH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Run the Blueprint version from a remote Git 
branch</Description>
        </Option>
        <Option Short="c" Long="commit" Value="COMMIT" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Specify a specific Commit ID. This is used in order to 
run a environment from a specific Blueprint historic version. If this parameter 
is used, the Branch parameter must also be specified.</Description>
        </Option>
        <Option Short="" Long="detail" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Show detailed output in a json format</Description>
        </Option>
        <Option Short="d" Long="duration" Value="MINUTES" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>The Environment will automatically de-provision at the 
end of the provided duration (minutes).</Description>
        </Option>
        <Option Short="i" Long="input" Value="KEY=VALUE" Required="false" 
Kind="pair" ClrType="System.Collections.Generic.IDictionary`2[[System.String, 
System.Private.CoreLib, Version=9.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e],[System.String, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>The Blueprints inputs can be provided as a key=value 
pair. For example: -i key1=value1 -i key2=value2.</Description>
        </Option>
        <Option Short="n" Long="name" Value="ENV-NAME" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Provide a name for the Environment. If not set, the name 
will be generated automatically using the source branch (or local changes) and 
current time.</Description>
        </Option>
        <Option Short="p" Long="profile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The user profile name</Description>
        </Option>
        <Option Short="r" Long="repo" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The repository name to use with command</Description>
        </Option>
        <Option Short="s" Long="space" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The space name</Description>
        </Option>
        <Option Short="" Long="timeout" Value="MINUTES" Required="false" 
Kind="scalar" ClrType="System.Int32">
          <Description>Set how long (default timeout is 30 minutes) to block and
wait before releasingcontrol back to shell prompt. If timeout is reached before 
the desired statusthe wait loop will be interrupted.</Description>
        </Option>
        <Option Short="t" Long="token" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>The user long token</Description>
        </Option>
        <Option Short="w" Long="wait" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Block shell prompt and wait for the Environment to be 
Active while the timeout is not reached.Default timeout is 30 minutes.The 
default timeout can be changed using the 'timeout' flag.</Description>
        </Option>
      </Parameters>
    </Command>
