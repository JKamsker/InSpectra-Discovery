<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.AddCliCommand" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.SolutionCommandSettings">
    <Description>Add Git2SemVer solution versioning to solution in working 
directory.</Description>
    <Parameters>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution name. Optional, only required when there are 
multiple solutions in the working directory.</Description>
      </Option>
      <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Unattened execution. Accepts all defaults.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.RemoveCliCommand" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.SolutionCommandSettings">
    <Description>Remove Git2SemVer solution versioning from solution in working 
directory.</Description>
    <Parameters>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution name. Optional, only required when there are 
multiple solutions in the working directory.</Description>
      </Option>
      <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Unattened execution. Accepts all defaults.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--RUN-->
  <Command Name="run" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.RunCliCommand" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.RunCommandSettings">
    <Description>Run version generator.</Description>
    <Parameters>
      <Option Short="" Long="enable-json-write" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Enables writing of generated version JSON 
file.</Description>
      </Option>
      <Option Short="" Long="host-type" Value="TYPE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Force the host type. Use for testing expected behaviour on 
other hosts. Valid values are 'Custom', 'Uncontrolled', 'TeamCity', or 
'GitHub'.</Description>
      </Option>
      <Option Short="o" Long="output" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Directory in which to place the generated version JSON file
and the build log.</Description>
      </Option>
      <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Unattened execution. Accepts all defaults.</Description>
      </Option>
      <Option Short="v" Long="verbosity" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Sets output verbosity. Valid values are 'trace', 'debug', 
'info', 'warning', or 'error'.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>