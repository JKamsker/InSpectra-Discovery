<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CHANGELOG-->
  <Command Name="changelog" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Changelog commands</Description>
    <!--RUN-->
    <Command Name="run" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.Changelog.ChangelogCliCommand" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.Changelog.ChangelogCommandSett
ings">
      <Description>Generate/update changelog command</Description>
      <Parameters>
        <Option Short="a" Long="artifact-url" Value="URL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Optional url to a version's artifacts. May contain 
version placeholder '%VERSION%'.</Description>
        </Option>
        <Option Short="d" Long="data-directory" Value="DIRECTORY" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Path to generator's data and configuration files 
directory. May be a relative or absolute path.</Description>
        </Option>
        <Option Short="" Long="host-type" Value="TYPE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Optional the host type. Use for testing expected 
behaviour on other hosts. Valid values are 'Custom', 'Uncontrolled', 'TeamCity',
or 'GitHub'.</Description>
        </Option>
        <Option Short="" Long="no-writes" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Nullable`1[[System.Boolean, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Optional. Disable file writes. Useful for testing to 
avoid changing existing Changelog files.</Description>
        </Option>
        <Option Short="o" Long="output" Value="FILEPATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Generated changelog file path. May be a relative or 
absolute path.</Description>
        </Option>
        <Option Short="r" Long="release-as" Value="TITLE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>If not an empty string, sets the changes version 
(normally version or 'Unreleased'). Any text permitted.</Description>
        </Option>
        <Option Short="s" Long="show" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Show changelog in console.</Description>
        </Option>
        <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Run unattended. If used, does not ask user before 
operation is performed and choices defaults are used.</Description>
        </Option>
        <Option Short="v" Long="verbosity" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Sets output verbosity. Valid values are 'trace', 'debug',
'info', 'warning', or 'error'.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="changelog" />
        <Example commandLine="run" />
      </Examples>
    </Command>
  </Command>
  <!--VERSIONING-->
  <Command Name="versioning" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <Description>Solution versioning commands (alias 'ver')</Description>
    <!--RUN-->
    <Command Name="run" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.Versioning.Run.RunCliCommand" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.Versioning.Run.RunCommandSetti
ngs">
      <Description>Run version generator command</Description>
      <Parameters>
        <Option Short="b" Long="branch-maturity-pattern" Value="PATTERN" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Optional regular expression value to map branch name to 
release and prerelease labels.</Description>
        </Option>
        <Option Short="" Long="conv-commits-json-write" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Enables writing found conventional commits to file 
'conventionalcommits.g.json'. Used for changelog generation.</Description>
        </Option>
        <Option Short="" Long="enable-json-write" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Enables writing generated versions to file 
'Git2SemVer.VersionInfo.g.json'.</Description>
        </Option>
        <Option Short="" Long="host-type" Value="TYPE" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Force the host type. Use for testing expected behaviour 
on other hosts. Valid values are 'Custom', 'Uncontrolled', 'TeamCity', or 
'GitHub'.</Description>
        </Option>
        <Option Short="o" Long="output" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Directory in which to place the generated version JSON 
file and the build log.</Description>
        </Option>
        <Option Short="r" Long="release-tag-format" Value="FORMAT" 
Required="false" Kind="scalar" ClrType="System.String">
          <Description>Optional regular expression format to identify a release,
and get the version, from a Git tag's friendly name. Must include `%VERSION%` 
placeholder text.</Description>
        </Option>
        <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Run unattended. If used, does not ask user before 
operation is performed and choices defaults are used.</Description>
        </Option>
        <Option Short="v" Long="verbosity" Value="LEVEL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Sets output verbosity. Valid values are 'trace', 'debug',
'info', 'warning', or 'error'.</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="versioning" />
        <Example commandLine="run" />
      </Examples>
    </Command>
    <!--SETUP-->
    <Command Name="setup" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
      <Description>Solution versioning setup command (Alias 
'setup')</Description>
      <!--ADD-->
      <Command Name="add" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.Versioning.Add.AddCliCommand" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.Versioning.SolutionCommandSett
ings">
        <Description>Add Git2SemVer solution versioning to solution in working 
directory</Description>
        <Parameters>
          <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Solution name. Optional, only required when there are 
multiple solutions in the working directory.</Description>
          </Option>
          <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Run unattended. If used, does not ask user before 
operation is performed and choices defaults are used.</Description>
          </Option>
        </Parameters>
        <Examples>
          <Example commandLine="versioning" />
          <Example commandLine="setup" />
          <Example commandLine="add" />
          <Example commandLine="versioning" />
          <Example commandLine="setup" />
          <Example commandLine="add" />
          <Example commandLine="-confirm" />
          <Example commandLine="false" />
          <Example commandLine="--solution" />
          <Example commandLine="'MyOtherSolution.sln'" />
        </Examples>
      </Command>
      <!--REMOVE-->
      <Command Name="remove" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.Versioning.Remove.RemoveCliComm
and" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.Versioning.SolutionCommandSett
ings">
        <Description>Remove Git2SemVer solution versioning from solution in 
working directory</Description>
        <Parameters>
          <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
            <Description>Solution name. Optional, only required when there are 
multiple solutions in the working directory.</Description>
          </Option>
          <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
            <Description>Run unattended. If used, does not ask user before 
operation is performed and choices defaults are used.</Description>
          </Option>
        </Parameters>
        <Examples>
          <Example commandLine="versioning" />
          <Example commandLine="setup" />
          <Example commandLine="remove" />
          <Example commandLine="--solution" />
          <Example commandLine="'MyOtherSolution.sln'" />
        </Examples>
      </Command>
    </Command>
  </Command>
</Model>