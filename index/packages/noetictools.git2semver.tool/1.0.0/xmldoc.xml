<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.AddCliCommand" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.CommonCommandSettings">
    <Description>Add Git2SemVer solution versioning to solution in working 
directory.</Description>
    <Parameters>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution name. Optional, only required when there are 
multiple solutions in the working directory.</Description>
      </Option>
      <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Unattened execution. Accepts all defaults.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REMOVE-->
  <Command Name="remove" IsBranch="false" 
ClrType="NoeticTools.Git2SemVer.Tool.CommandLine.RemoveCliCommand" 
Settings="NoeticTools.Git2SemVer.Tool.CommandLine.CommonCommandSettings">
    <Description>Add Git2SemVer solution versioning to solution in working 
directory.</Description>
    <Parameters>
      <Option Short="s" Long="solution" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Solution name. Optional, only required when there are 
multiple solutions in the working directory.</Description>
      </Option>
      <Option Short="u" Long="unattended" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Unattened execution. Accepts all defaults.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>