<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LIST-MIGRATIONS-->
  <Command Name="list-migrations" IsBranch="false" 
ClrType="Nabs.Tools.MigrationsCli.Commands.ListMigrationsCommand" 
Settings="Nabs.Tools.MigrationsCli.Commands.NabsMigrationsSettings">
    <Description>Scans a solution for EF Core migrations and lists them in a 
tree view.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to scan. Defaults to current directory.</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="list-migrations" />
      <Example commandLine="list-migrations" />
      <Example commandLine="./MySolution" />
    </Examples>
  </Command>
  <!--LIST-PENDING-MODEL-CHANGES-->
  <Command Name="list-pending-model-changes" IsBranch="false" 
ClrType="Nabs.Tools.MigrationsCli.Commands.ListPendingModelChangesCommand" 
Settings="Nabs.Tools.MigrationsCli.Commands.NabsMigrationsSettings">
    <Description>Scans a solution for EF Core pending model changes and list 
them in a tree view.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to scan. Defaults to current directory.</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="list-pending-model-changes" />
      <Example commandLine="list-pending-model-changes" />
      <Example commandLine="./MySolution" />
    </Examples>
  </Command>
  <!--APPLY-MIGRATIONS-->
  <Command Name="apply-migrations" IsBranch="false" 
ClrType="Nabs.Tools.MigrationsCli.Commands.ApplyMigrationsCommand" 
Settings="Nabs.Tools.MigrationsCli.Commands.ApplyMigrationsSettings">
    <Description>Applies pending migrations to the local database.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to scan. Defaults to current directory.</Description>
      </Argument>
      <Option Short="" Long="context" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the DbContext to migrate. Required when using the 
command line.</Description>
      </Option>
      <Option Short="" Long="migrationName" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the specific migration to apply. If not provided, 
all pending migrations will be applied.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="apply-migrations" />
      <Example commandLine="apply-migrations" />
      <Example commandLine="./MySolution" />
      <Example commandLine="apply-migrations" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="apply-migrations" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="--migrationName" />
      <Example commandLine="InitialCreate" />
      <Example commandLine="apply-migrations" />
      <Example commandLine="./MySolution" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
    </Examples>
  </Command>
  <!--DROP-DB-->
  <Command Name="drop-db" IsBranch="false" 
ClrType="Nabs.Tools.MigrationsCli.Commands.DropDbCommand" 
Settings="Nabs.Tools.MigrationsCli.Commands.DropDbSettings">
    <Description>Drop the database. This is a destructive 
operation.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to scan. Defaults to current directory.</Description>
      </Argument>
      <Option Short="" Long="context" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the DbContext whose database should be dropped. 
Required when using the command line.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="drop-db" />
      <Example commandLine="drop-db" />
      <Example commandLine="./MySolution" />
      <Example commandLine="drop-db" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="drop-db" />
      <Example commandLine="./MySolution" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
    </Examples>
  </Command>
  <!--ADD-MIGRATIONS-->
  <Command Name="add-migrations" IsBranch="false" 
ClrType="Nabs.Tools.MigrationsCli.Commands.AddMigrationsCommand" 
Settings="Nabs.Tools.MigrationsCli.Commands.AddMigrationsSettings">
    <Description>Adds new migrations.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to scan. Defaults to current directory.</Description>
      </Argument>
      <Option Short="" Long="context" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the DbContext to use for the migration. Required 
when using the command line.</Description>
      </Option>
      <Option Short="" Long="migrationName" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the migration to create. Required when using the 
command line.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="add-migrations" />
      <Example commandLine="add-migrations" />
      <Example commandLine="./MySolution" />
      <Example commandLine="add-migrations" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="--migrationName" />
      <Example commandLine="AddCustomerTable" />
      <Example commandLine="add-migrations" />
      <Example commandLine="./MySolution" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="--migrationName" />
      <Example commandLine="AddCustomerTable" />
    </Examples>
  </Command>
  <!--REMOVE-MIGRATIONS-->
  <Command Name="remove-migrations" IsBranch="false" 
ClrType="Nabs.Tools.MigrationsCli.Commands.RemoveMigrationsCommand" 
Settings="Nabs.Tools.MigrationsCli.Commands.RemoveMigrationsSettings">
    <Description>Remove the last migration from a DbContext.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to scan. Defaults to current directory.</Description>
      </Argument>
      <Option Short="" Long="context" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the DbContext to remove the migration from. 
Required when using the command line.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="remove-migrations" />
      <Example commandLine="remove-migrations" />
      <Example commandLine="./MySolution" />
      <Example commandLine="remove-migrations" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="remove-migrations" />
      <Example commandLine="./MySolution" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
    </Examples>
  </Command>
  <!--RESET-ALL-MIGRATIONS-->
  <Command Name="reset-all-migrations" IsBranch="false" 
ClrType="Nabs.Tools.MigrationsCli.Commands.ResetAllMigrationsCommand" 
Settings="Nabs.Tools.MigrationsCli.Commands.ResetAllMigrationsSettings">
    <Description>Delete all migrations and start over.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to scan. Defaults to current directory.</Description>
      </Argument>
      <Option Short="" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the project to reset migrations for. Required when 
using the command line.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="reset-all-migrations" />
      <Example commandLine="reset-all-migrations" />
      <Example commandLine="./MySolution" />
      <Example commandLine="reset-all-migrations" />
      <Example commandLine="--project" />
      <Example commandLine="MyProject.DataMigrations" />
      <Example commandLine="reset-all-migrations" />
      <Example commandLine="./MySolution" />
      <Example commandLine="--project" />
      <Example commandLine="MyProject.DataMigrations" />
    </Examples>
  </Command>
  <!--BUILD-->
  <Command Name="build" IsBranch="false" 
ClrType="Nabs.Tools.MigrationsCli.Commands.BuildCommand" 
Settings="Nabs.Tools.MigrationsCli.Commands.NabsMigrationsSettings">
    <Description>Builds the solution.</Description>
    <Parameters>
      <Argument Name="searchPath" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to scan. Defaults to current directory.</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="build" />
      <Example commandLine="build" />
      <Example commandLine="./MySolution" />
    </Examples>
  </Command>
</Model>