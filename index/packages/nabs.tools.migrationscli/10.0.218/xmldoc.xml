<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--LIST-MIGRATIONS-->
  <Command Name="list-migrations" IsBranch="false" 
ClrType="Nabs.Launchpad.Core.MigrationsCli.Commands.ListMigrations.ListMigration
sCommand" Settings="Nabs.Launchpad.Core.MigrationsCli.NabsMigrationsSettings">
    <Description>Lists all the DbContext together with their outstanding model 
changes, migrations, and seed data processors.</Description>
    <Examples>
      <Example commandLine="list-migrations" />
    </Examples>
  </Command>
  <!--ADD-MIGRATIONS-->
  <Command Name="add-migrations" IsBranch="false" 
ClrType="Nabs.Launchpad.Core.MigrationsCli.Commands.AddMigrations.AddMigrationsC
ommand" 
Settings="Nabs.Launchpad.Core.MigrationsCli.Commands.AddMigrations.AddMigrations
Settings">
    <Description>Adds new migrations to the DbContexts.</Description>
    <Parameters>
      <Option Short="" Long="context" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the DbContext to use for the migration. Required 
when using the command line.</Description>
      </Option>
      <Option Short="" Long="migrationName" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the migration to create. Required when using the 
command line.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="add-migrations" />
      <Example commandLine="add-migrations" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="--migrationName" />
      <Example commandLine="AddCustomerTable" />
    </Examples>
  </Command>
  <!--APPLY-MIGRATIONS-->
  <Command Name="apply-migrations" IsBranch="false" 
ClrType="Nabs.Launchpad.Core.MigrationsCli.Commands.ApplyMigrations.ApplyMigrati
onsCommand" 
Settings="Nabs.Launchpad.Core.MigrationsCli.Commands.AddMigrations.AddMigrations
Settings">
    <Description>Applies pending migrations to the local database.</Description>
    <Parameters>
      <Option Short="" Long="context" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the DbContext to use for the migration. Required 
when using the command line.</Description>
      </Option>
      <Option Short="" Long="migrationName" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the migration to create. Required when using the 
command line.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="apply-migrations" />
      <Example commandLine="apply-migrations" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="apply-migrations" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
      <Example commandLine="--migrationName" />
      <Example commandLine="InitialCreate" />
    </Examples>
  </Command>
  <!--REMOVE-MIGRATIONS-->
  <Command Name="remove-migrations" IsBranch="false" 
ClrType="Nabs.Launchpad.Core.MigrationsCli.Commands.RemoveMigrations.RemoveMigra
tionsCommand" 
Settings="Nabs.Launchpad.Core.MigrationsCli.Commands.RemoveMigrations.RemoveMigr
ationsSettings">
    <Description>Lists the last migration for each DbContext in order to remove 
it.</Description>
    <Parameters>
      <Option Short="" Long="context" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the DbContext to remove the migration from. 
Required when using the command line.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="remove-migrations" />
      <Example commandLine="remove-migrations" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
    </Examples>
  </Command>
  <!--RESET-MIGRATIONS-->
  <Command Name="reset-migrations" IsBranch="false" 
ClrType="Nabs.Launchpad.Core.MigrationsCli.Commands.RemoveMigrations.ResetMigrat
ionsCommand" 
Settings="Nabs.Launchpad.Core.MigrationsCli.NabsMigrationsSettings">
    <Description>Delete all migrations and start over.</Description>
    <Examples>
      <Example commandLine="reset-migrations" />
      <Example commandLine="reset-migrations" />
      <Example commandLine="--project" />
      <Example commandLine="MyProject.DataMigrations" />
    </Examples>
  </Command>
  <!--DROP-DB-->
  <Command Name="drop-db" IsBranch="false" 
ClrType="Nabs.Launchpad.Core.MigrationsCli.Commands.DropDb.DropDbCommand" 
Settings="Nabs.Launchpad.Core.MigrationsCli.NabsMigrationsSettings">
    <Description>Drop the design-time database.</Description>
    <Examples>
      <Example commandLine="drop-db" />
      <Example commandLine="drop-db" />
      <Example commandLine="--context" />
      <Example commandLine="PrimaryDbContext" />
    </Examples>
  </Command>
</Model>