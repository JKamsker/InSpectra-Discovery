<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--APPROVE-->
  <Command Name="approve" IsBranch="false" 
ClrType="ApprovalTests.Terminal.Commands.ApproveCommand" 
Settings="ApprovalTests.Terminal.Commands.ModifyCommand+Settings">
    <Parameters>
      <Option Short="w" Long="work" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="Spectre.IO.DirectoryPath">
        <Description>The working directory to use</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Confirm all prompts. Chooses affirmative answer instead of 
prompting.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REJECT-->
  <Command Name="reject" IsBranch="false" 
ClrType="ApprovalTests.Terminal.Commands.RejectCommand" 
Settings="ApprovalTests.Terminal.Commands.ModifyCommand+Settings">
    <Parameters>
      <Option Short="w" Long="work" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="Spectre.IO.DirectoryPath">
        <Description>The working directory to use</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Confirm all prompts. Chooses affirmative answer instead of 
prompting.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--REVIEW-->
  <Command Name="review" IsBranch="false" 
ClrType="ApprovalTests.Terminal.Commands.ReviewCommand" 
Settings="ApprovalTests.Terminal.Commands.ReviewCommand+Settings">
    <Parameters>
      <Option Short="c" Long="context" Value="LINE-COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>The number of context lines to show. Defaults to 
2.</Description>
      </Option>
      <Option Short="w" Long="work" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="Spectre.IO.DirectoryPath">
        <Description>The working directory to use</Description>
      </Option>
    </Parameters>
  </Command>
</Model>