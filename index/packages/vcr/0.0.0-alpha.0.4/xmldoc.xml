<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="VcrSharp.Cli.Commands.RecordCommand" 
Settings="VcrSharp.Cli.Commands.RecordCommand+Settings">
    <Parameters>
      <Argument Name="tape-file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean" />
    </Parameters>
  </Command>
  <!--VALIDATE-->
  <Command Name="validate" IsBranch="false" 
ClrType="VcrSharp.Cli.Commands.ValidateCommand" 
Settings="VcrSharp.Cli.Commands.ValidateCommand+Settings">
    <Description>Validate a tape file without recording</Description>
    <Parameters>
      <Argument Name="tape-file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String" />
    </Parameters>
    <Examples>
      <Example commandLine="validate" />
      <Example commandLine="demo.tape" />
    </Examples>
  </Command>
  <!--THEMES-->
  <Command Name="themes" IsBranch="false" 
ClrType="VcrSharp.Cli.Commands.ThemesCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>List available themes</Description>
  </Command>
</Model>