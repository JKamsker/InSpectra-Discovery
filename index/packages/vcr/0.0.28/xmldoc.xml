  <!--SNAP-->
  <Command Name="snap" IsBranch="false" 
ClrType="VcrSharp.Cli.Commands.SnapCommand" 
Settings="VcrSharp.Cli.Commands.SnapCommand+Settings">
    <Description>Capture a static SVG screenshot of a command's final 
output</Description>
    <Parameters>
      <Argument Name="command" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Shell command to execute</Description>
      </Argument>
      <Option Short="" Long="cols" Value="COLS" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Terminal width in columns</Description>
      </Option>
      <Option Short="" Long="disable-cursor" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Hide cursor in output</Description>
      </Option>
      <Option Short="" Long="end-buffer" Value="DURATION" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Buffer after last activity (e.g., '500ms', 
'2s')</Description>
      </Option>
      <Option Short="" Long="font-size" Value="SIZE" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Font size in pixels</Description>
      </Option>
      <Option Short="o" Long="output" Value="FILE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file path (default: output.svg)</Description>
      </Option>
      <Option Short="" Long="rows" Value="ROWS" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Terminal height in rows</Description>
      </Option>
      <Option Short="" Long="theme" Value="THEME" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Terminal theme (e.g., 'Dracula', 'One Dark')</Description>
      </Option>
      <Option Short="" Long="transparent-background" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Use transparent background</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose logging</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="snap" />
      <Example commandLine="&quot;echo Hello&quot;" />
      <Example commandLine="-o" />
      <Example commandLine="hello.svg" />
      <Example commandLine="snap" />
      <Example commandLine="&quot;ls -la&quot;" />
      <Example commandLine="--theme" />
      <Example commandLine="Dracula" />
      <Example commandLine="--cols" />
      <Example commandLine="100" />
    </Examples>
  </Command>
