<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--DEFAULT COMMAND-->
  <Command Name="__default_command" IsBranch="false" IsDefault="true" 
ClrType="D20Tek.Tools.DevLog.Commands.InteractiveCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings" />
  <!--ADD-->
  <Command Name="add" IsBranch="false" 
ClrType="D20Tek.Tools.DevLog.Commands.AddEntryCommand" 
Settings="D20Tek.Tools.DevLog.Commands.AddEntryCommand+Settings">
    <Description>Add a project entry to this week's dev-log.</Description>
    <Parameters>
      <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The name of the project to add the dev-log entry 
for.</Description>
      </Argument>
      <Option Short="d" Long="date" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The date for the dev-log entry (defaults to today). Format:
MM-dd-yyyy.</Description>
      </Option>
      <Option Short="f" Long="folder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The folder path where dev-log files are 
stored.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="add" />
      <Example commandLine="MyProject" />
      <Example commandLine="-f" />
      <Example commandLine="." />
    </Examples>
  </Command>
  <!--EDIT-->
  <Command Name="edit" IsBranch="false" 
ClrType="D20Tek.Tools.DevLog.Commands.EditEntryCommand" 
Settings="D20Tek.Tools.DevLog.Commands.EditEntryCommand+Settings">
    <Description>Edit an existing project entry in this week's 
dev-log.</Description>
    <Parameters>
      <Argument Name="PROJECT" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The name of the project entry to edit.</Description>
      </Argument>
      <Option Short="d" Long="date" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The date for the dev-log entry (defaults to today). Format:
MM-dd-yyyy.</Description>
      </Option>
      <Option Short="f" Long="folder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The folder path where dev-log files are 
stored.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="edit" />
      <Example commandLine="MyProject" />
      <Example commandLine="-f" />
      <Example commandLine="." />
    </Examples>
  </Command>
  <!--VIEW-->
  <Command Name="view" IsBranch="false" 
ClrType="D20Tek.Tools.DevLog.Commands.ViewLogCommand" 
Settings="D20Tek.Tools.DevLog.Commands.ViewLogCommand+Settings">
    <Description>Views this week's full dev-log.</Description>
    <Parameters>
      <Option Short="d" Long="date" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The date for the dev-log entry (defaults to today). Format:
MM-dd-yyyy.</Description>
      </Option>
      <Option Short="f" Long="folder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The folder path where dev-log files are 
stored.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="view" />
      <Example commandLine="-f" />
      <Example commandLine="." />
    </Examples>
  </Command>
  <!--LIST-->
  <Command Name="list" IsBranch="false" 
ClrType="D20Tek.Tools.DevLog.Commands.ListLogsCommand" 
Settings="D20Tek.Tools.DevLog.Commands.ListLogsCommand+Settings">
    <Description>List all available dev-log files.</Description>
    <Parameters>
      <Option Short="f" Long="folder" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The folder path where dev-log files are 
stored.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="list" />
      <Example commandLine="-f" />
      <Example commandLine="." />
    </Examples>
  </Command>
</Model>