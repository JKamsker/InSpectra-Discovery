ClrType="Advocu.NuGet.Commands.DefaultCommand" 
Settings="Advocu.NuGet.Settings.AdvocuSettings">
    <Parameters>
      <Option Short="a" Long="api-token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Advocu API Token. Defaults to ADVOCU_API_TOKEN 
environment variable.</Description>
      </Option>
      <Option Short="u" Long="api-url" Value="URL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Advocu API URL. Defaults to ADVOCU_URL environment 
variable.</Description>
      </Option>
      <Option Short="p" Long="private" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Mark the activity as private.</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CONTENT-->
  <Command Name="content" IsBranch="false" 
ClrType="Advocu.NuGet.Commands.ContentCreationCommand" 
Settings="Advocu.NuGet.Settings.ContentCreationSettings">
    <Description>Creates a new Content Creation Activity draft.</Description>
    <Parameters>
      <Option Short="a" Long="api-token" Value="TOKEN" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Advocu API Token. Defaults to ADVOCU_API_TOKEN 
environment variable.</Description>
      </Option>
      <Option Short="u" Long="api-url" Value="URL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The Advocu API URL. Defaults to ADVOCU_URL environment 
variable.</Description>
      </Option>
      <Option Short="" Long="content-type" Value="TYPE" Required="false" 
Kind="scalar" ClrType="Advocu.AdvocuActivityContentType">
        <Description>Type of content (e.g., Articles, Videos, 
etc.).</Description>
      </Option>
      <Option Short="" Long="date" Value="DATE" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Date of activity (YYYY-MM-DD). Defaults to 
today.</Description>
      </Option>
      <Option Short="d" Long="description" Value="DESCRIPTION" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Description of the activity.</Description>
      </Option>
      <Option Short="" Long="info" Value="INFO" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Additional info.</Description>
      </Option>
      <Option Short="p" Long="private" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Mark the activity as private.</Description>
      </Option>
      <Option Short="" Long="readers" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of readers/views.</Description>
      </Option>
      <Option Short="" Long="tags" Value="TAGS" Required="false" Kind="vector" 
ClrType="System.String[]">
        <Description>Comma-separated list of tags.</Description>
      </Option>
      <Option Short="t" Long="title" Value="TITLE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Title of the activity.</Description>
      </Option>
      <Option Short="" Long="url" Value="URL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>URL of the activity.</Description>
      </Option>
    </Parameters>
  </Command>
