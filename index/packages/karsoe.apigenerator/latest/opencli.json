  "info": {
    "title": "Karsoe API Generator - OpenAPI/Swagger C# Client Generator",
    "version": "1.0.2",
    "description": "A powerful .NET command-line tool that generates strongly-typed C# API clients from\n      OpenAPI/Swagger specifications. Prime focus on not to get tangled in circular references -\n      avoids dublicate model genereation. Features include automatic DTO model generation with\n      validation attributes, built-in Polly retry policies, comprehensive logging support, XML\n      documentation for IntelliSense, and automatic README generation. Supports OpenAPI 3.0+\n      specifications in JSON or YAML format. Simple to use: karsoe-api-gen -i swagger.json -o\n      ./Generated -n MyApp.ApiClient"
  },
