<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SDK-->
  <Command Name="sdk" IsBranch="false" 
ClrType="DotBump.Commands.BumpSdk.BumpSdkCommand" 
Settings="DotBump.Commands.BumpSdk.BumpSdkSettings">
    <Description>Bump the global.json SDK version. Use the 'minor' type option 
to bump the SDK to the latest minor or patch version for the current major 
version. Use the 'patch' type option to bump the SDK to the latest patch version
for the current minor version. </Description>
    <Parameters>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable debug logging for troubleshooting. Includes response
data.</Description>
      </Option>
      <Option Short="f" Long="file" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The global.json file to update. Defaults to 
`./global.json`.</Description>
      </Option>
      <Option Short="" Long="logfile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The file to send the log output to.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file name. The name of the file to write the result 
to. The output format is json.</Description>
      </Option>
      <Option Short="s" Long="security-only" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Only bump the version if the new release is a security 
release. Defaults to false.</Description>
      </Option>
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[DotBump.Commands.BumpType, DotBump, Version=0.2.0.0,
Culture=neutral, PublicKeyToken=null]]">
        <Description>The bump type. Defaults to `minor`. Available options are 
`minor` and `patch`.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="sdk" />
      <Example commandLine="sdk" />
      <Example commandLine="--type" />
      <Example commandLine="patch" />
      <Example commandLine="sdk" />
      <Example commandLine="--file" />
      <Example commandLine="./other/global.json" />
      <Example commandLine="--output" />
      <Example commandLine="bump-sdk-report.json" />
      <Example commandLine="sdk" />
      <Example commandLine="--security-only" />
      <Example commandLine="true" />
      <Example commandLine="--debug" />
      <Example commandLine="true" />
      <Example commandLine="--logfile" />
      <Example commandLine="bump-sdk-log.txt" />
    </Examples>
  </Command>
  <!--TOOLS-->
  <Command Name="tools" IsBranch="false" 
ClrType="DotBump.Commands.BumpTools.BumpToolsCommand" 
Settings="DotBump.Commands.BumpTools.BumpToolsSettings">
    <Description>Bump the local .NET tools versions. Use the 'minor' type option
to bump the tools to the latest minor or patch versions for the current major 
version. Use the 'patch' type option to bump the tools to the latest patch 
version for the current minor version. </Description>
    <Parameters>
      <Option Short="c" Long="config" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The nuget config file to use. Defaults to 
`./nuget.config`.</Description>
      </Option>
      <Option Short="" Long="debug" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable debug logging for troubleshooting. Includes response
data.</Description>
      </Option>
      <Option Short="" Long="logfile" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The file to send the log output to.</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output file name. The name of the file to write the result 
to. The output format is json.</Description>
      </Option>
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[DotBump.Commands.BumpType, DotBump, Version=0.2.0.0,
Culture=neutral, PublicKeyToken=null]]">
        <Description>The bump type. Defaults to `minor`. Available options are 
`minor` and `patch`.</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="tools" />
      <Example commandLine="tools" />
      <Example commandLine="--type" />
      <Example commandLine="patch" />
      <Example commandLine="tools" />
      <Example commandLine="--config" />
      <Example commandLine="./custom-nuget.config" />
      <Example commandLine="--output" />
      <Example commandLine="bump-tools-report.json" />
      <Example commandLine="tools" />
      <Example commandLine="--debug" />
      <Example commandLine="true" />
      <Example commandLine="--logfile" />
      <Example commandLine="bump-tools-log.txt" />
    </Examples>
  </Command>
</Model>