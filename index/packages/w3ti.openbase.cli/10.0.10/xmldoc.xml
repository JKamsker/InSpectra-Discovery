<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INSTALL-->
  <Command Name="install" IsBranch="false" 
ClrType="OpenBase.Commands.InstallCommand" 
Settings="OpenBase.Commands.InstallSettings">
    <Description>Instala o ecossistema de templates OpenBase.</Description>
    <Examples>
      <Example commandLine="install" />
    </Examples>
  </Command>
  <!--UPDATE-->
  <Command Name="update" IsBranch="false" 
ClrType="OpenBase.Commands.UpdateCommand" 
Settings="OpenBase.Commands.UpdateSettings">
    <Description>Sincroniza e atualiza todos os templates 
OpenBase.</Description>
  </Command>
  <!--NEW-->
  <Command Name="new" IsBranch="false" ClrType="OpenBase.Commands.NewCommand" 
Settings="OpenBase.Commands.NewSettings">
    <Description>Cria um novo projeto baseado em um template.</Description>
    <Parameters>
      <Option Short="n" Long="name" Value="NOME" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>O nome do projeto a ser criado</Description>
      </Option>
      <Option Short="s" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>O nome do template (ex: sqlserver)</Description>
      </Option>
      <Option Short="t" Long="type" Value="TIPO" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>O tipo do template (ex: api)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="new" />
      <Example commandLine="--type" />
      <Example commandLine="api" />
      <Example commandLine="--template" />
      <Example commandLine="sqlserver" />
      <Example commandLine="--name" />
      <Example commandLine="MeuProjeto" />
    </Examples>
  </Command>
  <!--HELP-->
  <Command Name="help" IsBranch="false" ClrType="OpenBase.Commands.HelpCommand" 
Settings="OpenBase.Commands.HelpSettings">
    <Description>Exibe a ajuda para os comandos do OpenBase</Description>
  </Command>
  <!--VERSION-->
  <Command Name="version" IsBranch="false" 
ClrType="OpenBase.Commands.VersionCommand" 
Settings="OpenBase.Commands.VersionSettings">
    <Description>Exibe as versões da CLI e do template do OpenBase</Description>
  </Command>
</Model>