<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="InitCommand" 
Settings="InitCommand+Settings">
    <Parameters>
      <Argument Name="PROJECT_NAME" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>The name of the project to initialize</Description>
      </Argument>
      <Option Short="a" Long="agentic" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable agentic features and AI automation</Description>
      </Option>
      <Option Short="d" Long="description" Value="DESCRIPTION" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Optional project description</Description>
      </Option>
      <Option Short="" Long="devcontainer" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Enable devcontainer configuration for isolated 
development</Description>
      </Option>
      <Option Short="" Long="devcontainer-features" Value="FEATURES" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of devcontainer features (e.g., 
dotnet,docker-in-docker,python)</Description>
      </Option>
      <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Force overwrite existing files</Description>
      </Option>
      <Option Short="m" Long="mcp" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Enable Model Context Protocol (MCP) 
integration</Description>
      </Option>
      <Option Short="t" Long="template" Value="TEMPLATE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Project template to use (api, web, console, 
agent)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DEPLOY-->
  <Command Name="deploy" IsBranch="false" ClrType="DeployCommand" 
Settings="DeployCommand+Settings">
    <Parameters>
      <Option Short="" Long="ai-optimize" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Use AI to optimize deployment strategy</Description>
      </Option>
      <Option Short="e" Long="environment" Value="ENV" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Target environment (dev, staging, prod)</Description>
      </Option>
      <Option Short="r" Long="replicas" Value="COUNT" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of replicas to deploy</Description>
      </Option>
      <Option Short="w" Long="watch" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Watch deployment progress in real-time</Description>
      </Option>
    </Parameters>
  </Command>
