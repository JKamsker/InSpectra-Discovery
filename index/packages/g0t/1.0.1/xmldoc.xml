<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="G0tLib.Commands.InitCommand" 
Settings="G0tLib.Commands.InitCommand+Settings">
    <Description>Initialize a new G0t repository</Description>
  </Command>
  <!--COMMIT-->
  <Command Name="commit" IsBranch="false" 
ClrType="G0tLib.Commands.CommitCommand" 
Settings="G0tLib.Commands.CommitCommand+Settings">
    <Description>Commit current state</Description>
    <Parameters>
      <Option Short="m" Long="message" Value="MESSAGE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Commit message</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="commit" />
      <Example commandLine="-m" />
      <Example commandLine="my message" />
    </Examples>
  </Command>
  <!--LOG-->
  <Command Name="log" IsBranch="false" ClrType="G0tLib.Commands.LogCommand" 
Settings="G0tLib.Commands.LogCommand+Settings">
    <Description>Show commit log</Description>
  </Command>
  <!--ADD-->
  <Command Name="add" IsBranch="false" ClrType="G0tLib.Commands.AddCommand" 
Settings="G0tLib.Commands.AddCommand+Settings">
    <Description>Stage a file for the next commit</Description>
    <Parameters>
      <Argument Name="file" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>File to stage</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--STATUS-->
  <Command Name="status" IsBranch="false" 
ClrType="G0tLib.Commands.StatusCommand" 
Settings="G0tLib.Commands.StatusCommand+Settings">
    <Description>Show the current status of the repository</Description>
  </Command>
  <!--CHECKOUT-->
  <Command Name="checkout" IsBranch="false" 
ClrType="G0tLib.Commands.CheckoutCommand" 
Settings="G0tLib.Commands.CheckoutCommand+Settings">
    <Description>Checkout a previous commit state</Description>
    <Parameters>
      <Argument Name="COMMIT_HASH" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Commit hash to checkout</Description>
      </Argument>
    </Parameters>
    <Examples>
      <Example commandLine="checkout" />
      <Example commandLine="commit_hash" />
    </Examples>
  </Command>
  <!--BRANCH-->
  <Command Name="branch" IsBranch="false" 
ClrType="G0tLib.Commands.BranchCommand" 
Settings="G0tLib.Commands.BranchCommand+Settings">
    <Description>Manage branches: create or switch branches</Description>
    <Parameters>
      <Option Short="c" Long="create" Value="BRANCH_NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Create a new branch</Description>
      </Option>
      <Option Short="s" Long="switch" Value="BRANCH_NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Switch to an existing branch</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="branch" />
      <Example commandLine="--create" />
      <Example commandLine="newBranch" />
      <Example commandLine="branch" />
      <Example commandLine="--switch" />
      <Example commandLine="featureBranch" />
    </Examples>
  </Command>
</Model>