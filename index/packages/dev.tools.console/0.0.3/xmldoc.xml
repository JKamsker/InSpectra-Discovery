<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--BASE64-DECODER-->
  <Command Name="base64-decoder" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.Base64DecoderCommand" 
Settings="Dev.Tools.Console.Commands.Base64DecoderCommand+Settings">
    <Description>Decodes Base64-encoded text back to its original string 
representation using UTF-8 encoding</Description>
    <Parameters>
      <Argument Name="text" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Base64-encoded text to decode</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--BASE64-ENCODER-->
  <Command Name="base64-encoder" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.Base64EncoderCommand" 
Settings="Dev.Tools.Console.Commands.Base64EncoderCommand+Settings">
    <Description>Encodes text to Base64 format with optional URL-safe encoding 
and line breaks for compatibility with various systems</Description>
    <Parameters>
      <Argument Name="text" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Text to encode to Base64 format</Description>
      </Argument>
      <Option Short="i" Long="insertLineBreaks" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Insert line breaks every 76 characters for better 
readability</Description>
      </Option>
      <Option Short="u" Long="urlSafe" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Use URL-safe encoding (replaces + with -, / with _, and 
removes padding)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CASE-CONVERTER-->
  <Command Name="case-converter" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.CaseConverterCommand" 
Settings="Dev.Tools.Console.Commands.CaseConverterCommand+Settings">
    <Description>Converts text between various casing formats including 
camelCase, PascalCase, snake_case, kebab-case, and many others</Description>
    <Parameters>
      <Argument Name="text" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Text to convert to a different case format</Description>
      </Argument>
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="Dev.Tools.Tools.CaseConverterTool+CaseType">
        <Description>Target case format for the conversion</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CHAR-VIEWER-->
  <Command Name="char-viewer" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.CharacterViewerCommand" 
Settings="Dev.Tools.Console.Commands.CharacterViewerCommand+Settings">
    <Description>Analyzes and visualizes non-standard, control, and special 
characters in text, revealing hidden Unicode characters with detailed 
information</Description>
    <Parameters>
      <Argument Name="text" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Text to analyze for special characters</Description>
      </Argument>
      <Option Short="i" Long="includeCharInfo" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include detailed information about each character (Unicode 
category, hex codes, etc.)</Description>
      </Option>
      <Option Short="t" Long="treatAsStandardHexCodes" Value="NULL" 
Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.IList`1[[System.String, 
System.Private.CoreLib, Version=10.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>List of Unicode characters (e.g., U+00A0) to treat as 
standard characters</Description>
      </Option>
      <Option Short="v" Long="viewType" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.CharacterViewerTool+ViewType">
        <Description>How to display special and control characters</Description>
      </Option>
    </Parameters>
  </Command>
  <!--DATE-CONVERT-->
  <Command Name="date-convert" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.DateTimeConverterCommand" 
Settings="Dev.Tools.Console.Commands.DateTimeConverterCommand+Settings">
    <Description>Converts dates and times between various formats including Unix
timestamps, ISO 8601, RFC standards, Excel dates, and MongoDB 
ObjectIds</Description>
    <Parameters>
      <Argument Name="date" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Date/time value to convert (leave empty for current 
date/time)</Description>
      </Argument>
      <Option Short="f" Long="from" Value="NULL" Required="false" Kind="scalar" 
ClrType="Dev.Tools.Tools.DateTimeConverterTool+DateFormatType">
        <Description>Source format of the input date/time</Description>
      </Option>
      <Option Short="t" Long="to" Value="NULL" Required="false" Kind="scalar" 
ClrType="Dev.Tools.Tools.DateTimeConverterTool+DateFormatType">
        <Description>Target format for the output date/time</Description>
      </Option>
    </Parameters>
  </Command>
  <!--HASH-->
  <Command Name="hash" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.HashTextCommand" 
Settings="Dev.Tools.Console.Commands.HashTextCommand+Settings">
    <Description>Generates cryptographic hash values from text using various 
algorithms including MD5, SHA-1, SHA-256, SHA-384, and SHA-512</Description>
    <Parameters>
      <Argument Name="text" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Text to generate a hash from</Description>
      </Argument>
      <Option Short="a" Long="algorithm" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.HashTextTool+HashAlgorithm">
        <Description>Hashing algorithm to use</Description>
      </Option>
    </Parameters>
  </Command>
  <!--INT-BASE-CONVERTER-->
  <Command Name="int-base-converter" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.IntegerBaseConverterCommand" 
Settings="Dev.Tools.Console.Commands.IntegerBaseConverterCommand+Settings">
    <Description>Converts integers between different number bases including 
binary, octal, decimal, hexadecimal, Base64, and custom bases 
(2-64)</Description>
    <Parameters>
      <Argument Name="inputValue" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Number to convert</Description>
      </Argument>
      <Option Short="i" Long="inputBase" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.IntegerBaseConverterTool+BaseType">
        <Description>Number base of the input value</Description>
      </Option>
      <Option Short="t" Long="targetBase" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.IntegerBaseConverterTool+BaseType">
        <Description>Number base for the output value</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ROMAN-CONVERTER-->
  <Command Name="roman-converter" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.IntegerToRomanConverterCommand" 
Settings="Dev.Tools.Console.Commands.IntegerToRomanConverterCommand+Settings">
    <Description>Converts between decimal integers (1-3999) and Roman numerals 
(I, V, X, L, C, D, M)</Description>
    <Parameters>
      <Argument Name="number" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Decimal number or Roman numeral to convert</Description>
      </Argument>
      <Option Short="t" Long="transcoding" Value="NULL" Required="false" 
Kind="scalar" 
ClrType="Dev.Tools.Tools.IntegerToRomanConverterTool+TranscodingType">
        <Description>Convert to Roman numerals or from Roman 
numerals</Description>
      </Option>
    </Parameters>
  </Command>
  <!--IP-DETAILS-->
  <Command Name="ip-details" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.IpDetailsCommand" 
Settings="Dev.Tools.Console.Commands.IpDetailsCommand+Settings">
    <Description>Retrieves your current public IPv4 and IPv6 addresses by 
querying external services</Description>
  </Command>
  <!--JSON-FORMATTER-->
  <Command Name="json-formatter" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.JsonFormatterCommand" 
Settings="Dev.Tools.Console.Commands.JsonFormatterCommand+Settings">
    <Description>Formats and beautifies JSON with options for indentation, key 
sorting, case conversion, and removal of empty values</Description>
    <Parameters>
      <Argument Name="json" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>JSON text to format</Description>
      </Argument>
      <Option Short="c" Long="compact" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Minify JSON by removing all whitespace</Description>
      </Option>
      <Option Short="e" Long="excludeEmpty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Remove null and empty values from output</Description>
      </Option>
      <Option Short="i" Long="indentSize" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of spaces for indentation</Description>
      </Option>
      <Option Short="k" Long="keyFormat" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.JsonFormatterTool+TextCase">
        <Description>Case format to apply to all keys</Description>
      </Option>
      <Option Short="s" Long="sortKeys" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.JsonFormatterTool+SortDirection">
        <Description>Sort object keys alphabetically</Description>
      </Option>
    </Parameters>
  </Command>
  <!--JWT-PARSER-->
  <Command Name="jwt-parser" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.JwtParserCommand" 
Settings="Dev.Tools.Console.Commands.JwtParserCommand+Settings">
    <Description>Parses and decodes JWT tokens, extracting the header, payload 
claims, signature, and all standard registered fields</Description>
    <Parameters>
      <Argument Name="token" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>JWT token to parse (three Base64url-encoded parts separated
by dots)</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--LOREM-IPSUM-->
  <Command Name="lorem-ipsum" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.LoremIpsumGeneratorCommand" 
Settings="Dev.Tools.Console.Commands.LoremIpsumGeneratorCommand+Settings">
    <Description>Generates Lorem Ipsum placeholder text with configurable number
of paragraphs, sentences, and words</Description>
    <Parameters>
      <Option Short="p" Long="paragraphs" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of paragraphs to generate</Description>
      </Option>
      <Option Short="s" Long="sentencesPerParagraph" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.Int32">
        <Description>Number of sentences in each paragraph</Description>
      </Option>
      <Option Short="S" Long="startWithLoremIpsum" Value="NULL" Required="false"
Kind="flag" ClrType="System.Boolean">
        <Description>Begin the first sentence with the classic "Lorem ipsum 
dolor sit amet..." opening</Description>
      </Option>
      <Option Short="w" Long="wordsPerSentence" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of words in each sentence</Description>
      </Option>
    </Parameters>
  </Command>
  <!--PASSPHRASE-GENERATOR-->
  <Command Name="passphrase-generator" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.PassphraseGeneratorCommand" 
Settings="Dev.Tools.Console.Commands.PassphraseGeneratorCommand+Settings">
    <Description>Generates memorable and secure passphrases by combining random 
words with optional separators, capitalization, and salt</Description>
    <Parameters>
      <Option Short="c" Long="capitalize" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Capitalize the first letter of the passphrase</Description>
      </Option>
      <Option Short="p" Long="phraseCount" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of passphrases to generate</Description>
      </Option>
      <Option Short="S" Long="salt" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Custom text to append at the end of each 
passphrase</Description>
      </Option>
      <Option Short="s" Long="separator" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Char, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Character to separate words (e.g., -, _, 
space)</Description>
      </Option>
      <Option Short="w" Long="wordCount" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of words per passphrase</Description>
      </Option>
    </Parameters>
  </Command>
  <!--URL-TRANSCODER-->
  <Command Name="url-transcoder" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.SafeUrlTranscoderCommand" 
Settings="Dev.Tools.Console.Commands.SafeUrlTranscoderCommand+Settings">
    <Description>Encodes or decodes URLs by converting special characters to 
percent-encoded format for safe transmission</Description>
    <Parameters>
      <Argument Name="url" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>URL or text to encode/decode</Description>
      </Argument>
      <Option Short="t" Long="transcoding" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.SafeUrlTranscoderTool+TranscodingType">
        <Description>Encode or decode the URL</Description>
      </Option>
    </Parameters>
  </Command>
  <!--NATO-->
  <Command Name="nato" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.StringToNatoAlphabetCommand" 
Settings="Dev.Tools.Console.Commands.StringToNatoAlphabetCommand+Settings">
    <Description>Converts text to NATO phonetic alphabet words (Alfa, Bravo, 
Charlie, etc.) for clear voice communication</Description>
    <Parameters>
      <Argument Name="text" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Text to convert to NATO phonetic alphabet</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--TEXT-DECRYPTOR-->
  <Command Name="text-decryptor" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.TextDecryptorCommand" 
Settings="Dev.Tools.Console.Commands.TextDecryptorCommand+Settings">
    <Description>Decrypts encrypted text. Supports AES, TripleDES, and RC4 
algorithms.</Description>
    <Parameters>
      <Argument Name="encryptedText" Position="0" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Base64 or Hex encoded encrypted text to 
decrypt</Description>
      </Argument>
      <Option Short="a" Long="algorithm" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.TextDecryptorTool+EncryptionAlgorithm">
        <Description>Encryption algorithm that was used to encrypt the 
text</Description>
      </Option>
      <Option Short="i" Long="inputFormat" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.TextDecryptorTool+InputFormat">
        <Description>Encoding format of the encrypted input (must match the 
output format used during encryption)</Description>
      </Option>
      <Option Short="k" Long="key" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Secret key used for decryption (must match the key used for
encryption)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--TEXT-ENCRYPTOR-->
  <Command Name="text-encryptor" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.TextEncryptorCommand" 
Settings="Dev.Tools.Console.Commands.TextEncryptorCommand+Settings">
    <Description>Encrypts text using symmetric encryption algorithms (AES, 
TripleDES, RC4). Output is Base64-encoded and includes the IV for block 
ciphers.</Description>
    <Parameters>
      <Argument Name="text" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Plain text to encrypt</Description>
      </Argument>
      <Option Short="a" Long="algorithm" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.TextEncryptorTool+EncryptionAlgorithm">
        <Description>Encryption algorithm to use</Description>
      </Option>
      <Option Short="k" Long="key" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Secret key used for encryption. Derived internally via 
SHA-256.</Description>
      </Option>
      <Option Short="o" Long="outputFormat" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.TextEncryptorTool+OutputFormat">
        <Description>Encoding format for the encrypted output</Description>
      </Option>
    </Parameters>
  </Command>
  <!--TOKEN-GENERATOR-->
  <Command Name="token-generator" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.TokenGeneratorCommand" 
Settings="Dev.Tools.Console.Commands.TokenGeneratorCommand+Settings">
    <Description>Generates random secure tokens with customizable length, 
character sets (uppercase, lowercase, numbers, symbols), and custom 
alphabets</Description>
    <Parameters>
      <Option Short="a" Long="alphabet" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Custom character set to use (overrides other options if 
provided)</Description>
      </Option>
      <Option Short="e" Long="excludeSymbols" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Specific characters to exclude from 
generation</Description>
      </Option>
      <Option Short="l" Long="lowercase" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include lowercase letters (a-z)</Description>
      </Option>
      <Option Short="n" Long="numbers" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Include digits (0-9)</Description>
      </Option>
      <Option Short="s" Long="symbols" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Include special characters (!@#$%^&amp;*...)</Description>
      </Option>
      <Option Short="T" Long="tokenCount" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of tokens to generate</Description>
      </Option>
      <Option Short="t" Long="tokenLength" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Length of each generated token</Description>
      </Option>
      <Option Short="u" Long="uppercase" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Include uppercase letters (A-Z)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--ULID-GENERATOR-->
  <Command Name="ulid-generator" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.UlidGeneratorCommand" 
Settings="Dev.Tools.Console.Commands.UlidGeneratorCommand+Settings">
    <Description>Generates Universally Unique Lexicographically Sortable 
Identifiers (ULIDs) which are sortable, URL-safe, and 
timestamp-based</Description>
    <Parameters>
      <Option Short="c" Long="count" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of ULIDs to generate</Description>
      </Option>
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="Dev.Tools.Tools.UlidGeneratorTool+UlidType">
        <Description>Type of ULID to generate</Description>
      </Option>
    </Parameters>
  </Command>
  <!--URL-PARSER-->
  <Command Name="url-parser" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.UrlParserCommand" 
Settings="Dev.Tools.Console.Commands.UrlParserCommand+Settings">
    <Description>Parses and extracts all components from a URL including scheme,
hostname, port, path, query parameters, and credentials</Description>
    <Parameters>
      <Argument Name="url" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>URL to parse and analyze</Description>
      </Argument>
    </Parameters>
  </Command>
  <!--UUID-GENERATOR-->
  <Command Name="uuid-generator" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.UuidGeneratorCommand" 
Settings="Dev.Tools.Console.Commands.UuidGeneratorCommand+Settings">
    <Description>Generates Universally Unique Identifiers (UUIDs/GUIDs) in 
various versions including V3 (MD5), V4 (random), V5 (SHA-1), and V7 
(timestamp-based)</Description>
    <Parameters>
      <Option Short="c" Long="count" Value="NULL" Required="false" Kind="scalar"
ClrType="System.Int32">
        <Description>Number of UUIDs to generate</Description>
      </Option>
      <Option Short="N" Long="name" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Name to hash with namespace (for V3 and V5)</Description>
      </Option>
      <Option Short="n" Long="namespace" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Guid, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Namespace UUID (required for V3 and V5)</Description>
      </Option>
      <Option Short="T" Long="time" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.DateTime, System.Private.CoreLib, 
Version=10.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Custom timestamp (for V7, defaults to current 
time)</Description>
      </Option>
      <Option Short="t" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="Dev.Tools.Tools.UuidGeneratorTool+UuidType">
        <Description>UUID version to generate</Description>
      </Option>
    </Parameters>
  </Command>
  <!--XML-FORMATTER-->
  <Command Name="xml-formatter" IsBranch="false" 
ClrType="Dev.Tools.Console.Commands.XmlFormatterCommand" 
Settings="Dev.Tools.Console.Commands.XmlFormatterCommand+Settings">
    <Description>Formats and beautifies XML with options for indentation, 
element sorting, case conversion, and removal of empty elements</Description>
    <Parameters>
      <Argument Name="xml" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>XML text to format</Description>
      </Argument>
      <Option Short="c" Long="compact" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Minify XML by removing all whitespace</Description>
      </Option>
      <Option Short="e" Long="excludeEmpty" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Remove empty elements from output</Description>
      </Option>
      <Option Short="i" Long="indentSize" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Number of spaces for indentation</Description>
      </Option>
      <Option Short="k" Long="keyFormat" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.XmlFormatterTool+TextCase">
        <Description>Case format to apply to all element names</Description>
      </Option>
      <Option Short="s" Long="sortKeys" Value="NULL" Required="false" 
Kind="scalar" ClrType="Dev.Tools.Tools.XmlFormatterTool+SortDirection">
        <Description>Sort XML elements alphabetically</Description>
      </Option>
    </Parameters>
  </Command>
</Model>