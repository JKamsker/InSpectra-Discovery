<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--GENERATE-KEYS-->
  <Command Name="generate-keys" IsBranch="false" 
ClrType="XrmEmulator.LicenseGenerator.Commands.GenerateKeysCommand" 
Settings="XrmEmulator.LicenseGenerator.Commands.GenerateKeysSettings">
    <Description>Generate an Ed25519 key pair for license signing</Description>
    <Parameters>
      <Option Short="" Long="output" Value="DIRECTORY" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory for key files (default: current 
directory)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--CREATE-->
  <Command Name="create" IsBranch="false" 
ClrType="XrmEmulator.LicenseGenerator.Commands.CreateLicenseCommand" 
Settings="XrmEmulator.LicenseGenerator.Commands.CreateLicenseSettings">
    <Description>Create a signed license key</Description>
    <Parameters>
      <Option Short="" Long="expires" Value="DATE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Expiry date (e.g. 2026-06-01). Omit for perpetual 
license</Description>
      </Option>
      <Option Short="" Long="features" Value="FEATURES" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of feature keys 
(required)</Description>
      </Option>
      <Option Short="" Long="licensee" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Name of the licensee (required)</Description>
      </Option>
      <Option Short="" Long="output" Value="FILE" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Output .lic file path (optional, also prints to 
stdout)</Description>
      </Option>
      <Option Short="" Long="private-key" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to private key file (default: 
./private.key)</Description>
      </Option>
      <Option Short="" Long="private-key-base64" Value="KEY" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Base64-encoded private key (alternative to --private-key 
file)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--VALIDATE-->
  <Command Name="validate" IsBranch="false" 
ClrType="XrmEmulator.LicenseGenerator.Commands.ValidateLicenseCommand" 
Settings="XrmEmulator.LicenseGenerator.Commands.ValidateLicenseSettings">
    <Description>Validate an existing license key</Description>
    <Parameters>
      <Argument Name="LICENSE_KEY" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The license key string to validate</Description>
      </Argument>
      <Option Short="" Long="public-key" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to public key file (default: 
./public.key)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--LIST-FEATURES-->
  <Command Name="list-features" IsBranch="false" 
ClrType="XrmEmulator.LicenseGenerator.Commands.ListFeaturesCommand" 
Settings="Spectre.Console.Cli.EmptyCommandSettings">
    <Description>List available feature keys</Description>
  </Command>
</Model>