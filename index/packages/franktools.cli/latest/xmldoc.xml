<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--OPENAPI-GEN-->
  <Command Name="openapi-gen" IsBranch="false" 
ClrType="FrankTools.Cli.Commands.OpenApiGenerateCommand" 
Settings="FrankTools.Cli.Commands.OpenApiGenerateCommand+Settings">
    <Description>Generate client/server C# from OpenAPI file</Description>
    <Parameters>
      <Option Short="" Long="class-name" Value="NAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Class name of client/server</Description>
      </Option>
      <Option Short="" Long="filename" Value="FILENAME" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Nome del file di output (senza estensione)</Description>
      </Option>
      <Option Short="" Long="generate-interfaces" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Generate interface for clients</Description>
      </Option>
      <Option Short="i" Long="input" Value="URL_OR_PATH" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Swagger/OpenAPI path (to .json file) or URL</Description>
      </Option>
      <Option Short="" Long="namespace" Value="NAMESPACE" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Namespace da usare per il codice generato</Description>
      </Option>
      <Option Short="o" Long="output" Value="DIR" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>Destination folder of generated code</Description>
      </Option>
      <Option Short="" Long="type" Value="CLIENT|SERVER" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Generation type: client o server</Description>
      </Option>
      <Option Short="" Long="use-async" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Generate async methods (default: true)</Description>
      </Option>
      <Option Short="" Long="use-httpclient-factory" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
        <Description>Use IHttpClientFactory (only for client)</Description>
      </Option>
    </Parameters>
  </Command>
  <!--MICROGEN NEW-->
  <Command Name="microgen new" IsBranch="false" 
ClrType="FrankTools.Cli.Commands.MicroserviceNewCommand" 
Settings="FrankTools.Cli.Commands.MicroserviceNewCommand+Settings">
    <Description>Generate microservice C# structure from scratch</Description>
    <Parameters>
      <Argument Name="NAME" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Microservice name to create</Description>
      </Argument>
      <Option Short="" Long="mongo" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Add MongoDB template</Description>
      </Option>
      <Option Short="" Long="sql" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Add SQL Server template</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="microservice" />
      <Example commandLine="new" />
      <Example commandLine="PaymentService" />
      <Example commandLine="--mongo" />
    </Examples>
  </Command>
</Model>