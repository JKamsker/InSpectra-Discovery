<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SDK-->
  <Command Name="sdk" IsBranch="true" 
Settings="Spectre.Console.Cli.CommandSettings">
    <!--LIST-->
    <Command Name="list" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkListCommand" 
Settings="AndroidSdk.Tool.SdkListCommandSettings">
      <Description>Lists Android SDK packages</Description>
      <Parameters>
        <Option Short="" Long="all" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Show all packages</Description>
        </Option>
        <Option Short="" Long="available" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show available packages to install</Description>
        </Option>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AndroidSdk.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="" Long="installed" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show available packages to install</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="sdk" />
        <Example commandLine="list" />
        <Example commandLine="sdk" />
        <Example commandLine="list" />
        <Example commandLine="--available" />
        <Example commandLine="sdk" />
        <Example commandLine="list" />
        <Example commandLine="--installed" />
      </Examples>
    </Command>
    <!--INSTALL-->
    <Command Name="install" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkInstallCommand" 
Settings="AndroidSdk.Tool.SdkInstallCommandSettings">
      <Description>Installs and/or Updates the specified Android SDK 
package(s)</Description>
      <Parameters>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AndroidSdk.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="p" Long="package" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Package to install</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="sdk" />
        <Example commandLine="install" />
        <Example commandLine="--package emulator" />
      </Examples>
    </Command>
    <!--UNINSTALL-->
    <Command Name="uninstall" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkUninstallCommand" 
Settings="AndroidSdk.Tool.SdkUninstallCommandSettings">
      <Description>Uninstalls the specified Android SDK package(s)</Description>
      <Parameters>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AndroidSdk.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="p" Long="package" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Package to uninstall</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="sdk" />
        <Example commandLine="uninstall" />
        <Example commandLine="--package emulator" />
      </Examples>
    </Command>
    <!--DOWNLOAD-->
    <Command Name="download" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkDownloadCommand" 
Settings="AndroidSdk.Tool.SdkDownloadCommandSettings">
      <Description>Downloads a new copy of the Android SDK 
cmdline-tools</Description>
      <Parameters>
        <Option Short="" Long="arch" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>Optional specific architecture (current host arch is 
default)</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Forces re-download of cmdline-tools even if already 
installed</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="" Long="os" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
          <Description>Optional specific OS (current host OS is 
default)</Description>
        </Option>
        <Option Short="" Long="preview" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Allow preview versions to be downloaded</Description>
        </Option>
        <Option Short="" Long="version" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Optional version to download</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="sdk" />
        <Example commandLine="download" />
        <Example commandLine="--home /path/to/sdk" />
        <Example commandLine="sdk" />
        <Example commandLine="download" />
        <Example commandLine="--home /path/to/sdk" />
        <Example commandLine="--force" />
      </Examples>
    </Command>
    <!--INFO-->
    <Command Name="info" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkInfoCommand" 
Settings="AndroidSdk.Tool.SdkInfoCommandSettings">
      <Description>Android SDK Info</Description>
      <Parameters>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AndroidSdk.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="sdk" />
        <Example commandLine="info" />
      </Examples>
    </Command>
    <!--DOTNET-PREFER-->
    <Command Name="dotnet-prefer" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkDotNetPreferCommand" 
Settings="AndroidSdk.Tool.SdkDotNetPreferCommandSettings">
      <Description>Sets the DotNet (.NET) preferred SDK location</Description>
      <Parameters>
        <Option Short="h" Long="home" Value="PATH" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home Path</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="sdk" />
        <Example commandLine="dotnet-prefer" />
        <Example commandLine="--home /path/to/androidsdk" />
      </Examples>
    </Command>
    <!--FIND-->
    <Command Name="find" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkFindCommand" 
Settings="AndroidSdk.Tool.SdkFindCommandSettings">
      <Description>Searches for and returns the ANDROID_HOME path to best 
matching Android SDK</Description>
      <Examples>
        <Example commandLine="sdk" />
        <Example commandLine="find" />
      </Examples>
    </Command>
    <!--LICENSES-->
    <Command Name="licenses" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkLicenseCommand" 
Settings="AndroidSdk.Tool.SdkLicenseCommandSettings">
      <Description>Lists Android SDK licenses</Description>
      <Parameters>
        <Option Short="a" Long="accepted" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Only accepted licenses</Description>
        </Option>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AndroidSdk.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="u" Long="unaccepted" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Only unaccepted licenses</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="sdk" />
        <Example commandLine="licenses" />
        <Example commandLine="sdk" />
        <Example commandLine="licenses" />
        <Example commandLine="--unaccepted" />
        <Example commandLine="sdk" />
        <Example commandLine="licenses" />
        <Example commandLine="--accepted" />
      </Examples>
    </Command>
    <!--ACCEPT-LICENSES-->
    <Command Name="accept-licenses" IsBranch="false" 
ClrType="AndroidSdk.Tool.SdkAcceptLicenseCommand" 
Settings="AndroidSdk.Tool.SdkAcceptLicenseCommandSettings">
      <Description>Accepts Android SDK licenses</Description>
      <Parameters>
        <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Force license accept without display license text or 
