        <Example commandLine="--package com.example.App" />
        <Example commandLine="device" />
        <Example commandLine="uninstall" />
        <Example commandLine="--package com.example.App --keep-data" />
      </Examples>
    </Command>
    <!--LAUNCH-->
    <Command Name="launch" IsBranch="false" 
ClrType="AndroidSdk.Tool.DeviceLaunchCommand" 
Settings="AndroidSdk.Tool.DeviceLaunchCommandSettings">
      <Description>Launches an app on a device</Description>
      <Parameters>
        <Option Short="a" Long="activity" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Activity name to launch (optional - uses default launcher
activity if not specified)</Description>
        </Option>
        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AndroidSdk.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="d" Long="id,device,serial" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
          <Description>Serial or Device to filter for</Description>
        </Option>
        <Option Short="p" Long="pkg,package" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Package name to launch (e.g., 
com.companyname.myapp)</Description>
        </Option>
        <Option Short="w" Long="wait" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Wait for the activity to finish launching</Description>
        </Option>
      </Parameters>
      <Examples>
        <Example commandLine="device" />
        <Example commandLine="launch" />
        <Example commandLine="--package com.example.App" />
        <Example commandLine="device" />
        <Example commandLine="launch" />
        <Example commandLine="--package com.example.App --activity 
.MainActivity" />
      </Examples>
    </Command>
