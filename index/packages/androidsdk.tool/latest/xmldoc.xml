    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="AndroidSdk.Tool.AvdCreateCommand" 
Settings="AndroidSdk.Tool.AvdCreateCommandSettings">
      <Description>Creates a new AVD</Description>
      <Parameters>
        <Option Short="a" Long="abi" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
          <Description>The ABI to use for the AVD (Auto-selects if there is only
one ABI)</Description>
        </Option>
        <Option Short="d" Long="device" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Device Id or NumericId (Possible options from: `avd 
devices`)</Description>
        </Option>
        <Option Short="f" Long="force" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
          <Description>Force the creation of the AVD</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="n" Long="name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Name of the AVD/Emulator</Description>
        </Option>
        <Option Short="p" Long="path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
