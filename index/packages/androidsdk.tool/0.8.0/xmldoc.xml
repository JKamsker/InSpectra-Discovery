        <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="AndroidSdk.Tool.OutputFormat">
          <Description>Output Format</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
      </Parameters>
    </Command>
    <!--CREATE-->
    <Command Name="create" IsBranch="false" 
ClrType="AndroidSdk.Tool.AvdCreateCommand" 
Settings="AndroidSdk.Tool.AvdCreateCommandSettings">
      <Parameters>
        <Option Short="d" Long="device" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Device Id or NumericId (Possible options from: `avd 
devices`)</Description>
        </Option>
        <Option Short="" Long="force" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
          <Description>Force the creation of the AVD</Description>
        </Option>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="n" Long="name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Name of the AVD/Emulator</Description>
        </Option>
        <Option Short="p" Long="path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to create the AVD</Description>
        </Option>
        <Option Short="" Long="sdcard-path" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Path to create the SDCard</Description>
        </Option>
        <Option Short="" Long="sdcard-size" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Size of SDCard to create in megabytes</Description>
        </Option>
        <Option Short="s" Long="sdk,sdkid" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>SDK Id (Possible values from: `sdk list`)</Description>
        </Option>
        <Option Short="t" Long="target" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Target Id or NumericId (Possible options from: `avd 
targets`)</Description>
        </Option>
      </Parameters>
    </Command>
    <!--DELETE-->
    <Command Name="delete" IsBranch="false" 
ClrType="AndroidSdk.Tool.AvdDeleteCommand" 
Settings="AndroidSdk.Tool.AvdDeleteCommandSettings">
      <Parameters>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK Home/Root Path</Description>
        </Option>
        <Option Short="n" Long="name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Name of the AVD/Emulator</Description>
        </Option>
      </Parameters>
    </Command>
