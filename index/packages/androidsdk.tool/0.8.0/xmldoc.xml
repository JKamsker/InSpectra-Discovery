    <Command Name="start" IsBranch="false" 
ClrType="AndroidSdk.Tool.AvdStartCommand" 
Settings="AndroidSdk.Tool.AvdStartCommandSettings">
      <Parameters>
        <Option Short="h" Long="home" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Android SDK home/root path</Description>
        </Option>
        <Option Short="n" Long="name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Name of the AVD/Emulator</Description>
        </Option>
        <Option Short="" Long="no-snapshot" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disable Snapshot load/save</Description>
        </Option>
        <Option Short="t" Long="timeout" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
          <Description>Timeout in seconds if waiting for emulator to 
boot</Description>
        </Option>
        <Option Short="" Long="wait-exit" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Wait for emulator process to exit</Description>
        </Option>
        <Option Short="w" Long="wait,wait-boot" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Wait for emulator to boot</Description>
        </Option>
        <Option Short="" Long="wipe,wipe-data" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Wipe data</Description>
        </Option>
      </Parameters>
    </Command>
