<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--CONVERT-->
  <Command Name="convert" IsBranch="false" 
ClrType="GraphQLToKarate.CommandLine.Commands.ConvertCommand" 
Settings="GraphQLToKarate.CommandLine.Settings.ConvertCommandSettings">
    <Parameters>
      <Argument Name="GraphQL Schema File" Position="0" Required="true" 
Kind="scalar" ClrType="System.String">
        <Description>The path of the GraphQL schema file to 
convert</Description>
      </Argument>
      <Option Short="" Long="base-url" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The base URL to be used in the Karate feature</Description>
      </Option>
      <Option Short="" Long="configuration-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The path of the configuration file</Description>
      </Option>
      <Option Short="" Long="custom-scalar-mapping" Value="NULL" 
Required="false" Kind="scalar" ClrType="System.String">
        <Description>The path or raw value custom scalar mapping</Description>
      </Option>
      <Option Short="" Long="exclude-queries" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Whether to exclude queries from the Karate feature or 
not</Description>
      </Option>
      <Option Short="" Long="include-mutations" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Whether to include mutations in the Karate feature or 
not</Description>
      </Option>
      <Option Short="" Long="log-level" Value="NULL" Required="false" 
Kind="scalar" ClrType="Serilog.Events.LogEventLevel">
        <Description>Minimum level for logging</Description>
      </Option>
      <Option Short="" Long="mutation-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name of the GraphQL mutation type</Description>
      </Option>
      <Option Short="" Long="mutation-operation-filter" Value="NULL" 
Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.ISet`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>A comma-separated list of GraphQL mutation operations to 
include in the Karate feature. If empty, all mutation operations will be 
included.</Description>
      </Option>
      <Option Short="" Long="non-interactive" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Whether to run conversion in a non-interactive way or 
not</Description>
      </Option>
      <Option Short="" Long="output-file" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The output file to write the Karate feature 
to</Description>
      </Option>
      <Option Short="" Long="query-name" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>The name of the GraphQL query type</Description>
      </Option>
      <Option Short="" Long="query-operation-filter" Value="NULL" 
Required="false" Kind="scalar" 
ClrType="System.Collections.Generic.ISet`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>A comma-separated list of GraphQL query operations to 
include in the Karate feature. If empty, all query operations will be 
included.</Description>
      </Option>
      <Option Short="" Long="type-filter" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Collections.Generic.ISet`1[[System.String, 
System.Private.CoreLib, Version=8.0.0.0, Culture=neutral, 
PublicKeyToken=7cec85d7bea7798e]]">
        <Description>A comma-separated list of GraphQL types to include in the 
Karate feature. If empty, all types will be included.</Description>
      </Option>
    </Parameters>
  </Command>
</Model>