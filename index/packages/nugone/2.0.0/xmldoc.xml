<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--ANALYZE-->
  <Command Name="analyze" IsBranch="false" 
ClrType="NuGone.Cli.Features.AnalyzeCommand.Commands.AnalyzeCommand" 
Settings="NuGone.Cli.Features.AnalyzeCommand.Commands.AnalyzeCommand+Settings">
    <Description>Analyze project(s) for unused NuGet packages</Description>
    <Parameters>
      <Option Short="" Long="dry-run" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Only analyze packages, don't perform any 
modifications</Description>
      </Option>
      <Option Short="" Long="exclude" Value="NULL" Required="false" 
Kind="vector" ClrType="System.String[]">
        <Description>Exclude packages from analysis</Description>
      </Option>
      <Option Short="f" Long="format" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output format: json or text</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Write report to file</Description>
      </Option>
      <Option Short="p" Long="project" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Path to project or solution</Description>
      </Option>
      <Option Short="v" Long="verbose" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Enable verbose output</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="analyze" />
      <Example commandLine="--project" />
      <Example commandLine="MySolution.sln" />
      <Example commandLine="analyze" />
      <Example commandLine="--dry-run" />
      <Example commandLine="--format" />
      <Example commandLine="json" />
    </Examples>
  </Command>
</Model>