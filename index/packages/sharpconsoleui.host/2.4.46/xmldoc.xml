<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--INIT-->
  <Command Name="init" IsBranch="false" ClrType="ScHost.Commands.InitCommand" 
Settings="ScHost.Commands.InitCommandSettings">
    <Description>Initialize schost.json for a project</Description>
    <Parameters>
      <Argument Name="project" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to .csproj file or directory</Description>
      </Argument>
      <Option Short="" Long="color-scheme" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Color scheme (WT name)</Description>
      </Option>
      <Option Short="" Long="columns" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Terminal columns</Description>
      </Option>
      <Option Short="" Long="font" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Font face</Description>
      </Option>
      <Option Short="" Long="font-size" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Font size</Description>
      </Option>
      <Option Short="" Long="rows" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=9.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Terminal rows</Description>
      </Option>
      <Option Short="" Long="title" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Window title</Description>
      </Option>
      <Option Short="y" Long="yes" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Skip interactive prompts, use defaults</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="init" />
      <Example commandLine="init" />
      <Example commandLine="MyApp/MyApp.csproj" />
    </Examples>
  </Command>
  <!--RUN-->
  <Command Name="run" IsBranch="false" ClrType="ScHost.Commands.RunCommand" 
Settings="ScHost.Commands.RunCommandSettings">
    <Description>Build and launch the app in a configured terminal</Description>
    <Parameters>
      <Argument Name="project" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to .csproj file or directory</Description>
      </Argument>
      <Option Short="" Long="inline" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Run in current terminal (for debugging/CI)</Description>
      </Option>
      <Option Short="" Long="no-build" Value="NULL" Required="false" Kind="flag"
ClrType="System.Boolean">
        <Description>Skip building before launch</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="run" />
      <Example commandLine="run" />
      <Example commandLine="--no-build" />
      <Example commandLine="run" />
      <Example commandLine="--inline" />
    </Examples>
  </Command>
  <!--PACK-->
  <Command Name="pack" IsBranch="false" ClrType="ScHost.Commands.PackCommand" 
Settings="ScHost.Commands.PackCommandSettings">
    <Description>Package the app for distribution</Description>
    <Parameters>
      <Argument Name="project" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to .csproj file or directory</Description>
      </Argument>
      <Option Short="" Long="installer" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Build Inno Setup installer (Windows only)</Description>
      </Option>
      <Option Short="" Long="no-self-contained" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Do not bundle the .NET runtime</Description>
      </Option>
      <Option Short="" Long="no-trim" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Disable IL trimming</Description>
      </Option>
      <Option Short="o" Long="output" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Output directory</Description>
      </Option>
      <Option Short="r" Long="runtime" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Runtime identifier (e.g., win-x64, linux-x64)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="pack" />
      <Example commandLine="pack" />
      <Example commandLine="--installer" />
      <Example commandLine="pack" />
      <Example commandLine="-r" />
      <Example commandLine="win-x64" />
    </Examples>
  </Command>
  <!--INSTALL-->
  <Command Name="install" IsBranch="false" 
ClrType="ScHost.Commands.InstallCommand" 
Settings="ScHost.Commands.InstallCommandSettings">
    <Description>Register/unregister terminal profile</Description>
    <Parameters>
      <Argument Name="project" Position="0" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to .csproj file or directory</Description>
      </Argument>
      <Option Short="" Long="exe" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.String">
        <Description>Path to the built executable</Description>
      </Option>
      <Option Short="" Long="uninstall" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Uninstall instead of install</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="install" />
      <Example commandLine="--exe" />
      <Example commandLine="path/to/app.exe" />
      <Example commandLine="install" />
      <Example commandLine="--uninstall" />
    </Examples>
  </Command>
</Model>