<?xml version="1.0" encoding="utf-8"?>
<Model>
  <!--SEARCH-->
  <Command Name="search" IsBranch="false" 
ClrType="Ivy.Exa.Cli.Commands.SearchCommand" 
Settings="Ivy.Exa.Cli.Commands.SearchCommand+Settings">
    <Description>Search for content using the Exa API</Description>
    <Parameters>
      <Argument Name="query" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The search query</Description>
      </Argument>
      <Option Short="" Long="category" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Data category: company, research paper, news, pdf, github, 
tweet, personal site, linkedin profile, financial report</Description>
      </Option>
      <Option Short="" Long="exclude-domains" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of domains to exclude (exclusive with 
include-domains)</Description>
      </Option>
      <Option Short="" Long="exclude-text" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of strings that must not appear in the
page text</Description>
      </Option>
      <Option Short="" Long="include-domains" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of domains to include (exclusive with 
exclude-domains)</Description>
      </Option>
      <Option Short="" Long="include-text" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of strings that must appear in the 
page text</Description>
      </Option>
      <Option Short="n" Long="num-results" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Number of search results to return (default: 10, max: 
10)</Description>
      </Option>
      <Option Short="" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[Ivy.Exa.Models.SearchType, Ivy.Exa, Version=1.0.0.0,
Culture=neutral, PublicKeyToken=null]]">
        <Description>Search type: auto, keyword, neural, hybrid, fast (default: 
auto)</Description>
      </Option>
      <Option Short="" Long="use-autoprompt" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Convert query to Exa format</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="search" />
      <Example commandLine="artificial intelligence" />
      <Example commandLine="search" />
      <Example commandLine="machine learning" />
      <Example commandLine="--num-results" />
      <Example commandLine="5" />
      <Example commandLine="search" />
      <Example commandLine="quantum computing" />
      <Example commandLine="--include-domains" />
      <Example commandLine="arxiv.org,wikipedia.org" />
    </Examples>
  </Command>
  <!--ANSWER-->
  <Command Name="answer" IsBranch="false" 
ClrType="Ivy.Exa.Cli.Commands.AnswerCommand" 
Settings="Ivy.Exa.Cli.Commands.AnswerCommand+Settings">
    <Description>Get a direct answer to a question using the Exa 
API</Description>
    <Parameters>
      <Argument Name="question" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The question to get an answer for</Description>
      </Argument>
      <Option Short="" Long="category" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Data category: company, research paper, news, pdf, github, 
tweet, personal site, linkedin profile, financial report</Description>
      </Option>
      <Option Short="" Long="exclude-domains" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of domains to exclude</Description>
      </Option>
      <Option Short="" Long="exclude-text" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of strings that must not appear in the
page text</Description>
      </Option>
      <Option Short="" Long="include-domains" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of domains to include</Description>
      </Option>
      <Option Short="" Long="include-text" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of strings that must appear in the 
page text</Description>
      </Option>
      <Option Short="n" Long="num-results" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Number of search results to consider for the answer 
(default: 10)</Description>
      </Option>
      <Option Short="" Long="show-citations" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Show detailed citations (default: true)</Description>
      </Option>
      <Option Short="" Long="type" Value="NULL" Required="false" Kind="scalar" 
ClrType="System.Nullable`1[[Ivy.Exa.Models.SearchType, Ivy.Exa, Version=1.0.0.0,
Culture=neutral, PublicKeyToken=null]]">
        <Description>Search type: auto, keyword, neural, hybrid, fast (default: 
auto)</Description>
      </Option>
      <Option Short="" Long="use-autoprompt" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
        <Description>Convert query to Exa format</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="answer" />
      <Example commandLine="What is the latest valuation of SpaceX?" />
      <Example commandLine="answer" />
      <Example commandLine="How does machine learning work?" />
      <Example commandLine="--num-results" />
      <Example commandLine="5" />
      <Example commandLine="answer" />
      <Example commandLine="Latest developments in quantum computing" />
      <Example commandLine="--category" />
      <Example commandLine="research paper" />
    </Examples>
  </Command>
  <!--RESEARCH-->
  <Command Name="research" IsBranch="false" 
ClrType="Ivy.Exa.Cli.Commands.ResearchCommand" 
Settings="Ivy.Exa.Cli.Commands.ResearchCommand+Settings">
    <Description>Create a research task using the Exa API</Description>
    <Parameters>
      <Argument Name="instructions" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Instructions for the research task</Description>
      </Argument>
      <Option Short="" Long="max-wait" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum time to wait for completion in minutes (default: 
15)</Description>
      </Option>
      <Option Short="m" Long="model" Value="NULL" Required="false" Kind="scalar"
ClrType="System.String">
        <Description>The model to use for research (default: 
exa-research)</Description>
      </Option>
      <Option Short="" Long="poll-interval" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Polling interval in seconds (default: 5)</Description>
      </Option>
      <Option Short="w" Long="wait" Value="NULL" Required="false" Kind="flag" 
ClrType="System.Boolean">
        <Description>Wait for the research task to complete</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="research" />
      <Example commandLine="Latest developments in renewable energy" />
      <Example commandLine="research" />
      <Example commandLine="Impact of AI on healthcare" />
      <Example commandLine="--wait" />
    </Examples>
  </Command>
  <!--SIMILAR-->
  <Command Name="similar" IsBranch="false" 
ClrType="Ivy.Exa.Cli.Commands.SimilarCommand" 
Settings="Ivy.Exa.Cli.Commands.SimilarCommand+Settings">
    <Description>Find content similar to a given URL</Description>
    <Parameters>
      <Argument Name="url" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>The URL to find similar content for</Description>
      </Argument>
      <Option Short="" Long="category" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Data category to focus on</Description>
      </Option>
      <Option Short="" Long="exclude-domains" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of domains to exclude</Description>
      </Option>
      <Option Short="" Long="include-domains" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.String">
        <Description>Comma-separated list of domains to include</Description>
      </Option>
      <Option Short="n" Long="num-results" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Nullable`1[[System.Int32, System.Private.CoreLib, 
Version=8.0.0.0, Culture=neutral, PublicKeyToken=7cec85d7bea7798e]]">
        <Description>Number of search results to return (default: 10, max: 
10)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="similar" />
      <Example commandLine="https://en.wikipedia.org/wiki/Machine_learning" />
      <Example commandLine="similar" />
      <Example commandLine="https://arxiv.org/abs/2103.00020" />
      <Example commandLine="--num-results" />
      <Example commandLine="3" />
    </Examples>
  </Command>
  <!--CONTENTS-->
  <Command Name="contents" IsBranch="false" 
ClrType="Ivy.Exa.Cli.Commands.ContentsCommand" 
Settings="Ivy.Exa.Cli.Commands.ContentsCommand+Settings">
    <Description>Retrieve content from specific URLs</Description>
    <Parameters>
      <Argument Name="urls" Position="0" Required="true" Kind="scalar" 
ClrType="System.String">
        <Description>Comma-separated list of URLs to retrieve content 
for</Description>
      </Argument>
      <Option Short="" Long="max-chars" Value="NULL" Required="false" 
Kind="scalar" ClrType="System.Int32">
        <Description>Maximum number of characters to display per content 
(default: 1000)</Description>
      </Option>
    </Parameters>
    <Examples>
      <Example commandLine="contents" />
      <Example commandLine="https://example.com" />
      <Example commandLine="contents" />
      <Example commandLine="https://example.com,https://another.com" />
    </Examples>
  </Command>
</Model>