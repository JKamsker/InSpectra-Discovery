    <!--SELF-->
    <Command Name="self" IsBranch="false" 
ClrType="InSpectra.Gen.Commands.Render.SelfDocCommand" 
Settings="InSpectra.Gen.Commands.Render.SelfDocSettings">
      <Description>Render documentation for InSpectra itself. Exports 
opencli.json, xmldoc.xml, Markdown tree, and HTML bundle.</Description>
      <Parameters>
        <Option Short="" Long="enable-nuget-browser" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Enable the NuGet package browser on the 
self-documentation viewer home screen.</Description>
        </Option>
        <Option Short="" Long="enable-package-upload" Value="NULL" 
Required="false" Kind="flag" ClrType="System.Boolean">
          <Description>Enable local package upload on the self-documentation 
viewer home screen.</Description>
        </Option>
        <Option Short="" Long="enable-url" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Allow the viewer to load alternate OpenCLI inputs from 
URL query parameters.</Description>
        </Option>
        <Option Short="" Long="include-hidden" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Include hidden commands and options from InSpectra's own 
CLI surface.</Description>
        </Option>
        <Option Short="" Long="include-metadata" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Include metadata sections in the generated Markdown tree 
and HTML bundle.</Description>
        </Option>
        <Option Short="" Long="label" Value="TEXT" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Custom label shown in the viewer header (e.g. a version 
string).</Description>
        </Option>
        <Option Short="" Long="no-composer" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Hide the interactive command composer from the generated 
self-documentation app.</Description>
        </Option>
        <Option Short="" Long="no-dark" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disable dark mode in the generated self-documentation 
app.</Description>
        </Option>
        <Option Short="" Long="no-light" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Disable light mode in the generated self-documentation 
app.</Description>
        </Option>
        <Option Short="" Long="out-dir" Value="DIR" Required="false" 
Kind="scalar" ClrType="System.String">
          <Description>Directory where the self-documentation bundle should be 
written.</Description>
        </Option>
        <Option Short="" Long="overwrite" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Allow existing self-documentation output to be 
replaced.</Description>
        </Option>
        <Option Short="" Long="show-home" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Show the viewer home screen button in the generated 
self-documentation app.</Description>
        </Option>
        <Option Short="" Long="skip-html" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip generating the HTML app bundle under 
html/.</Description>
        </Option>
        <Option Short="" Long="skip-markdown" Value="NULL" Required="false" 
Kind="flag" ClrType="System.Boolean">
          <Description>Skip generating the Markdown tree output under 
tree/.</Description>
        </Option>
      </Parameters>
    </Command>
  </Command>
</Model>