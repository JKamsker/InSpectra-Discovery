        "projectUrl": "https://github.com/bbajt/csharp-code-map",
        "packageUrl": "https://www.nuget.org/packages/codemap-mcp/1.4.0",
        "packageContentUrl": "https://api.nuget.org/v3-flatcontainer/codemap-mcp/1.4.0/codemap-mcp.1.4.0.nupkg",
